      },
      {
        "@type": "Review",
        "author": {"@type": "Person", "name": "ELENA CIBRIAN"},
        "reviewRating": {"@type": "Rating", "ratingValue": "5"},
        "reviewBody": "Katy me ha ayudado a recuperarme de una lesión en la muñeca y hombro. Es muy buena profesional, se nota mucho su experiencia y toda su formación. El nuevo espacio es súper acogedor."
      },
      {
        "@type": "Review",
        "author": {"@type": "Person", "name": "Elias Garcia Martinez"},
        "reviewRating": {"@type": "Rating", "ratingValue": "5"},
        "reviewBody": "Katy me ha ayudado en la recuperación de una lesión de rodilla y a desinflamar y tratar el dolor. Tiene un trato muy agradable y respetuoso, es una gran profesional."
      }
    ],
    "sameAs": [
      "https://www.instagram.com/katycaballero.osteopata",
      "https://es.nextdoor.com/pages/sala-osteopatia-katy-caballero-alpedrete-comunidad-de-madrid/",
      "https://www.bing.com/forbusiness/singleEntity?bizid=24de5fa7-ed7a-48d4-af66-dd995283aec4"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Servicios de osteopatía y masajes",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Osteopatía estructural, visceral y sacrocraneal"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Masaje deportivo"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Masaje tradicional tailandés"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Masaje corporal con aceite"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Masaje para embarazadas"}}
      ]
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Katy Caballero - Osteópata y Masajista",
    "url": "https://katycaballeroosteopata.com",
    "description": "Centro de osteopatía y masajes en Alpedrete, Sierra Noroeste de Madrid",
    "inLanguage": "es",
    "publisher": {
      "@type": "HealthAndBeautyBusiness",
      "name": "Katy Caballero - Osteópata y Masajista",
      "url": "https://katycaballeroosteopata.com"
    }
  }
  </script>
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  <ViewTransitions />
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido</a>
  <Header />

  <main id="main-content" transition:animate="fade">
    {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
    <slot />
  </main>
  
  <Footer />
  <WhatsAppButton />
  <CookieBanner />
  <SearchModal />

  <!-- Exit Intent Popup -->
  <div id="exit-intent-overlay" class="exit-overlay" role="dialog" aria-modal="true" aria-label="Reservar cita" hidden>
    <div class="exit-modal">
      <button class="exit-close" aria-label="Cerrar">&times;</button>
      <div class="exit-content">
        <div class="exit-icon">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
            <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"></path>
          </svg>
        </div>
        <h2 class="exit-title">¿Te vas sin reservar?</h2>
        <p class="exit-text">Primera consulta con valoración incluida, sin coste extra</p>
        <div class="exit-buttons">
          <a href="/reservar" class="exit-btn-primary">Reservar Cita</a>
          <button class="exit-btn-secondary" id="exit-dismiss">No, gracias</button>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    .exit-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      z-index: 10000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
      padding: 20px;
    }

    .exit-overlay[hidden] {
      display: none;
    }

    .exit-overlay.exit-visible {
      opacity: 1;
    }

    .exit-modal {
      background: var(--color-warm-white, #fffefb);
      border-radius: 16px;
      padding: 40px 36px;
      max-width: 420px;
      width: 100%;
      position: relative;
      transform: translateY(20px) scale(0.95);
      transition: transform 0.3s ease;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .exit-visible .exit-modal {
      transform: translateY(0) scale(1);
    }

    .exit-close {
      position: absolute;
      top: 12px;
      right: 16px;
      background: none;
      border: none;
      font-size: 1.8rem;
      color: var(--color-text-muted, #767676);
      cursor: pointer;
      line-height: 1;
      padding: 4px 8px;
      transition: color 0.2s ease;
    }

    .exit-close:hover {
      color: var(--color-text, #3d3d3d);
    }

    .exit-content {
      text-align: center;
    }

    .exit-icon {
      color: var(--color-primary, #5a7c59);
      margin-bottom: 16px;
    }

    .exit-title {
      font-family: var(--font-display, 'Cormorant Garamond', serif);
      font-size: 1.8rem;
      color: var(--color-primary-dark, #4a6548);
      margin-bottom: 12px;
      font-weight: 600;
    }

    .exit-text {
      font-family: var(--font-body, 'Montserrat', sans-serif);
      font-size: 1rem;
      color: var(--color-text-light, #6b6b6b);
      margin-bottom: 28px;
      line-height: 1.6;
    }

    .exit-buttons {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .exit-btn-primary {
      display: inline-block;
      background: var(--color-primary-dark, #4a6548);
      color: white;
      padding: 14px 28px;
      border-radius: 50px;
      font-family: var(--font-body, 'Montserrat', sans-serif);
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      text-align: center;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(74, 101, 72, 0.4);
    }

    .exit-btn-primary:hover {
      background: #3a5338;
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(74, 101, 72, 0.5);
      color: white;
    }

    .exit-btn-secondary {
      background: none;
      border: none;
      color: var(--color-text-muted, #767676);
      font-family: var(--font-body, 'Montserrat', sans-serif);
      font-size: 0.9rem;
      cursor: pointer;
      padding: 8px;
      transition: color 0.2s ease;
    }

    .exit-btn-secondary:hover {
      color: var(--color-text, #3d3d3d);
    }

    /* Dark mode */
    [data-theme="dark"] .exit-modal {
      background: #2a2a3e;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    [data-theme="dark"] .exit-close:hover {
      color: var(--color-text);
    }

    [data-theme="dark"] .exit-btn-secondary:hover {
      color: var(--color-text);
    }

    @media (max-width: 480px) {
      .exit-modal {
        padding: 32px 24px;
      }

      .exit-title {
        font-size: 1.5rem;
      }
    }
  </style>

  <script>
    (function() {
      // Don't show on admin pages
      if (window.location.pathname.startsWith('/admin')) return;

      // Don't show if already shown this session
      if (sessionStorage.getItem('exitIntentShown')) return;

      // Don't show if user came from /reservar or is on /reservar
      if (window.location.pathname === '/reservar' || document.referrer.includes('/reservar')) {
        sessionStorage.setItem('exitIntentShown', '1');
        return;
      }

      const overlay = document.getElementById('exit-intent-overlay');
      if (!overlay) return;

      let pageLoadTime = Date.now();
      let shown = false;
      const MIN_TIME_ON_PAGE = 10000; // 10 seconds minimum

      function showPopup() {
        if (shown) return;
        if (Date.now() - pageLoadTime < MIN_TIME_ON_PAGE) return;

        shown = true;
        sessionStorage.setItem('exitIntentShown', '1');
        overlay.removeAttribute('hidden');
        // Trigger reflow then add visible class for animation
        overlay.offsetHeight;
        overlay.classList.add('exit-visible');

        // Track in GA4 if available
        if (typeof gtag === 'function') {
          gtag('event', 'exit_intent_shown', {
            event_category: 'engagement',
            page_path: window.location.pathname
          });
        }
      }

      function closePopup() {
        overlay.classList.remove('exit-visible');
        setTimeout(function() {
          overlay.setAttribute('hidden', '');
        }, 300);
      }

      // Desktop: exit intent (mouse leaves viewport at top)
      var isMobile = /Android|iPhone|iPad|iPod|webOS|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)
        || window.matchMedia('(max-width: 768px)').matches;

      if (!isMobile) {
        document.addEventListener('mouseout', function(e) {
          if (e.clientY <= 0 && !shown) {
            showPopup();
          }
        });
      } else {
        // Mobile: show after 30 seconds
        setTimeout(function() {
          if (!shown) showPopup();
        }, 30000);
      }

      // Close handlers
      overlay.querySelector('.exit-close')?.addEventListener('click', closePopup);
      document.getElementById('exit-dismiss')?.addEventListener('click', closePopup);

      // Close on overlay click (not modal)
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closePopup();
      });

      // Close on Escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && shown && !overlay.hasAttribute('hidden')) {
          closePopup();
        }
      });
    })();
  </script>

  <!-- Scroll animation styles -->
  <style is:global>
    .animate-on-scroll {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

    .animate-on-scroll.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .animate-on-scroll {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <!-- Scroll to top button -->
  <button id="scroll-top" class="scroll-top-btn" aria-label="Volver arriba">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>
  
  <script>
    document.addEventListener('astro:page-load', () => {
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });

      // WhatsApp click tracking (GA4)
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href*="wa.me"]');
        if (link && typeof gtag === 'function') {
          const url = new URL(link.href);
          const text = url.searchParams.get('text') || '';
          gtag('event', 'whatsapp_click', {
            event_category: 'conversion',
            event_label: text,
            link_url: link.href,
            page_path: window.location.pathname
          });
        }
      });

      // Scroll to top button
      const scrollBtn = document.getElementById('scroll-top');
      if (scrollBtn) {
        window.addEventListener('scroll', () => {
          scrollBtn.classList.toggle('visible', window.scrollY > 400);
        });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // Scroll animations with IntersectionObserver
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const animatedElements = document.querySelectorAll('.animate-on-scroll');
        if (animatedElements.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          animatedElements.forEach((el) => observer.observe(el));
        }
      }
    });
  </script>
</body>
</html>
