---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SearchModal from '../components/SearchModal.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { reviews, averageRating, reviewCount } from '../data/reviews';
import '../styles/fonts.css';
import '../styles/global.css';

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  /** @deprecated Google ignores meta keywords since 2009. Prop kept for backwards compatibility but no longer rendered. */
  keywords?: string;
  breadcrumbs?: BreadcrumbItem[];
  publishedDate?: string;
  noindex?: boolean;
  /** Render the full MedicalBusiness schema (with reviews, areaServed, services, etc.). Default false: emit a lighter schema. Use true on home and /opiniones to keep rich snippets. */
  fullSchema?: boolean;
}

// Google Search Console verification. Para añadir el código:
//   1. En Search Console, Settings → Ownership verification → HTML tag
//   2. Copia el valor del atributo `content=` y pégalo abajo (o define la
//      variable de entorno PUBLIC_GSC_VERIFICATION en .env / Cloudflare)
const GSC_VERIFICATION = import.meta.env.PUBLIC_GSC_VERIFICATION || '';

const {
  title,
  description = "Osteópata y masajista en Alpedrete (Madrid). Osteopatía estructural, visceral, craneal y masajes terapéuticos. 12+ años de experiencia. Reserva online.",
  image = "/images/og-default.jpg",
  type = "website",
  breadcrumbs = [],
  publishedDate,
  noindex = false,
  fullSchema = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);

const breadcrumbSchema = breadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    ...(item.url ? { "item": `https://katycaballeroosteopata.com${item.url}` } : {})
  }))
} : null;

const businessAddress = {
  "@type": "PostalAddress",
  "streetAddress": "Calle Río Guadarrama 2",
  "addressLocality": "Alpedrete",
  "addressRegion": "Madrid",
  "postalCode": "28430",
  "addressCountry": "ES"
};

const businessGeo = {
  "@type": "GeoCoordinates",
  "latitude": "40.6631",
  "longitude": "-4.0270"
};

const openingHours = [
  { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "20:00" },
  { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "14:00" }
];

const aggregateRatingObj = {
  "@type": "AggregateRating",
  "ratingValue": averageRating,
  "bestRating": "5",
  "worstRating": "1",
  "ratingCount": String(reviewCount),
  "reviewCount": String(reviewCount)
};

const lightSchema = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "HealthAndBeautyBusiness"],
  "@id": "https://katycaballeroosteopata.com/#business",
  "name": "Katy Caballero - Osteópata y Masajista",
  "url": "https://katycaballeroosteopata.com",
  "image": "https://katycaballeroosteopata.com/images/logo.png",
  "telephone": "+34643961065",
  "priceRange": "€€",
  "address": businessAddress,
  "geo": businessGeo,
  "openingHoursSpecification": openingHours,
  "aggregateRating": aggregateRatingObj,
  "sameAs": [
    "https://www.instagram.com/katycaballero.osteopata",
    "https://es.nextdoor.com/pages/sala-osteopatia-katy-caballero-alpedrete-comunidad-de-madrid/",
    "https://pueblus.com/empresas/katy-caballero-osteopatia-y-masajes-alpedrete"
  ]
};

const fullBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "HealthAndBeautyBusiness"],
  "@id": "https://katycaballeroosteopata.com/#business",
  "name": "Katy Caballero - Osteópata y Masajista",
  "description": "Centro de osteopatía y masajes en Alpedrete, Sierra Noroeste de Madrid. Tratamientos de osteopatía estructural, visceral y craneal, masaje deportivo, tailandés y terapéutico.",
  "image": "https://katycaballeroosteopata.com/images/logo.png",
  "medicalSpecialty": "Osteopathic",
  "isAcceptingNewPatients": true,
  "availableService": [
    { "@type": "MedicalTherapy", "name": "Osteopatía estructural, visceral y sacrocraneal", "description": "Tratamiento osteopático integral que aborda problemas estructurales, viscerales y craneales mediante técnicas manuales suaves.", "url": "https://katycaballeroosteopata.com/servicios/osteopatia-alpedrete" },
    { "@type": "MedicalTherapy", "name": "Masaje deportivo", "description": "Masaje terapéutico enfocado en la recuperación muscular y prevención de lesiones deportivas.", "url": "https://katycaballeroosteopata.com/servicios/masaje-deportivo-alpedrete" },
    { "@type": "MedicalTherapy", "name": "Masaje tradicional tailandés", "description": "Técnica milenaria de masaje que combina presiones, estiramientos y movilizaciones articulares.", "url": "https://katycaballeroosteopata.com/servicios/masaje-tailandes-alpedrete" },
    { "@type": "MedicalTherapy", "name": "Masaje corporal relajante con aceite", "description": "Masaje corporal con aceites esenciales para aliviar tensiones y promover la relajación profunda.", "url": "https://katycaballeroosteopata.com/servicios/masaje-corporal-alpedrete" },
    { "@type": "MedicalTherapy", "name": "Masaje con pindas herbales", "description": "Terapia que utiliza saquitos de hierbas medicinales calientes para aliviar dolores musculares y articulares.", "url": "https://katycaballeroosteopata.com/servicios/masaje-pindas-herbales-alpedrete" },
    { "@type": "MedicalTherapy", "name": "Masaje para embarazadas", "description": "Masaje prenatal adaptado para aliviar las molestias del embarazo de forma segura y relajante.", "url": "https://katycaballeroosteopata.com/servicios/masaje-embarazadas-alpedrete" }
  ],
  "telephone": "+34643961065",
  "email": "katycaballero.osteopata@gmail.com",
  "address": businessAddress,
  "geo": businessGeo,
  "areaServed": [
    { "@type": "City", "name": "Alpedrete" },
    { "@type": "City", "name": "Collado Villalba" },
    { "@type": "City", "name": "Moralzarzal" },
    { "@type": "City", "name": "Galapagar" },
    { "@type": "City", "name": "Guadarrama" },
    { "@type": "City", "name": "Torrelodones" },
    { "@type": "City", "name": "El Escorial" },
    { "@type": "City", "name": "Cercedilla" },
    { "@type": "City", "name": "Navacerrada" },
    { "@type": "City", "name": "Collado Mediano" },
    { "@type": "City", "name": "Becerril de la Sierra" },
    { "@type": "City", "name": "Los Molinos" },
    { "@type": "AdministrativeArea", "name": "Sierra de Guadarrama" },
    { "@type": "AdministrativeArea", "name": "Sierra de Madrid" },
    { "@type": "AdministrativeArea", "name": "Sierra Noroeste de Madrid" },
    { "@type": "AdministrativeArea", "name": "Zona Noroeste de Madrid" }
  ],
  "url": "https://katycaballeroosteopata.com",
  "priceRange": "€€",
  "paymentAccepted": "Cash, Bizum, PayPal, Revolut",
  "currenciesAccepted": "EUR",
  "openingHoursSpecification": openingHours,
  "aggregateRating": aggregateRatingObj,
  "founder": {
    "@type": "Person",
    "name": "Katy Caballero",
    "jobTitle": "Osteópata y Masajista",
    "description": "Osteópata profesional con más de 12 años de experiencia en osteopatía estructural, visceral y sacrocraneal, masaje deportivo y terapéutico.",
    "knowsAbout": ["Osteopatía estructural", "Osteopatía visceral", "Osteopatía craneal", "Masaje deportivo", "Masaje tailandés", "Masaje para embarazadas"]
  },
  "review": reviews.map(r => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.name },
    "reviewRating": { "@type": "Rating", "ratingValue": String(r.rating), "bestRating": "5" },
    "reviewBody": r.text
  })),
  "sameAs": [
    "https://www.instagram.com/katycaballero.osteopata",
    "https://es.nextdoor.com/pages/sala-osteopatia-katy-caballero-alpedrete-comunidad-de-madrid/",
    "https://www.bing.com/forbusiness/singleEntity?bizid=24de5fa7-ed7a-48d4-af66-dd995283aec4",
    "https://pueblus.com/empresas/katy-caballero-osteopatia-y-masajes-alpedrete"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de osteopatía y masajes",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Osteopatía estructural, visceral y sacrocraneal" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masaje deportivo" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masaje tradicional tailandés" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masaje corporal con aceite" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masaje para embarazadas" } }
    ]
  }
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('theme');
      if (!theme) {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Katy Caballero">
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"}>

  <!-- Geo Tags para SEO Local -->
  <meta name="geo.region" content="ES-MD">
  <meta name="geo.placename" content="Alpedrete, Madrid">
  <meta name="geo.position" content="40.6631;-4.0270">
  <meta name="ICBM" content="40.6631, -4.0270">

  {GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL}>
  <link rel="alternate" hreflang="es" href={canonicalURL}>
  <link rel="alternate" type="application/rss+xml" title="Blog de Katy Caballero" href="/rss.xml">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={socialImageURL}>
  <meta property="og:image:alt" content={title}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content={image.endsWith('.webp') ? 'image/webp' : image.endsWith('.png') ? 'image/png' : 'image/jpeg'}>
  <meta property="og:locale" content="es_ES">
  <meta property="og:site_name" content="Katy Caballero - Osteópata y Masajista">
  {publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
    <meta property="article:author" content="Katy Caballero" />
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={canonicalURL}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={socialImageURL}>
  <meta name="twitter:image:alt" content={title}>
  
  <!-- Preload hero image for LCP -->
  <link rel="preload" as="image" type="image/webp" href="/images/logo.webp">

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#4a6548" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#1a2e1a" media="(prefers-color-scheme: dark)">
  <meta name="mobile-web-app-capable" content="yes">

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

  <!-- Preconnect third-party origins -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link rel="dns-prefetch" href="https://www.google-analytics.com">
  <link rel="preconnect" href="https://w.behold.so" crossorigin>
  <link rel="dns-prefetch" href="https://feeds.behold.so">

  <!-- Fonts (self-hosted) -->
  <link rel="preload" href="/fonts/cormorant-garamond-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/cormorant-garamond-italic-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/montserrat-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
  
  <!-- Schema.org markup -->
  <script type="application/ld+json" set:html={JSON.stringify(fullSchema ? fullBusinessSchema : lightSchema)} />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Katy Caballero - Osteópata y Masajista",
    "url": "https://katycaballeroosteopata.com",
    "description": "Centro de osteopatía y masajes en Alpedrete, Sierra Noroeste de Madrid",
    "inLanguage": "es",
    "publisher": {
      "@type": ["MedicalBusiness", "HealthAndBeautyBusiness"],
      "name": "Katy Caballero - Osteópata y Masajista",
      "url": "https://katycaballeroosteopata.com"
    }
  }
  </script>
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  <ViewTransitions />
</head>
<body>
  <Header />

  <main id="main-content" transition:animate="fade">
    {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
    <slot />
  </main>
  
  <Footer />
  <WhatsAppButton />
  <CookieBanner />
  <SearchModal />



  <!-- Scroll animation styles -->
  <style is:global>
    .animate-on-scroll {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

    .animate-on-scroll.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .animate-on-scroll {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <!-- Scroll to top button -->
  <button id="scroll-top" class="scroll-top-btn" aria-label="Volver arriba">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>
  
  <script>
    document.addEventListener('astro:page-load', () => {
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });

      // --- GA4 Conversion Tracking ---
      const pagePath = window.location.pathname;

      // 1. Click-based tracking via event delegation on body
      document.body.addEventListener('click', (e) => {
        if (typeof gtag !== 'function') return;
        const anchor = (e.target as Element).closest('a');
        if (!anchor) return;
        const href = anchor.getAttribute('href') || '';
        const linkText = (anchor.textContent || '').trim();

        // WhatsApp clicks
        if (href.includes('wa.me') || href.includes('whatsapp')) {
          gtag('event', 'whatsapp_click', {
            page_path: pagePath,
            link_text: linkText
          });
        }

        // Phone clicks
        if (href.startsWith('tel:')) {
          gtag('event', 'phone_click', {
            page_path: pagePath
          });
        }

        // Booking / Reservar clicks
        if (href.includes('/reservar')) {
          gtag('event', 'booking_click', {
            page_path: pagePath,
            link_text: linkText
          });
        }
      });

      // 2. Page-view based events
      if (typeof gtag === 'function') {
        // Pricing page view
        if (pagePath === '/tarifas' || pagePath === '/tarifas/') {
          gtag('event', 'view_pricing');
        }

        // Service page view
        const serviceMatch = pagePath.match(/^\/servicios\/([^/]+)/);
        if (serviceMatch) {
          gtag('event', 'view_service', {
            service_name: serviceMatch[1]
          });
        }
      }

      // 3. Form submit tracking
      if (typeof gtag === 'function') {
        // Contact form on /contacto
        if (pagePath === '/contacto' || pagePath === '/contacto/') {
          const contactForms = document.querySelectorAll('form');
          contactForms.forEach((form) => {
            form.addEventListener('submit', () => {
              gtag('event', 'contact_submit');
            });
          });
        }

        // Review form on /opiniones
        if (pagePath === '/opiniones' || pagePath === '/opiniones/') {
          const reviewForms = document.querySelectorAll('form');
          reviewForms.forEach((form) => {
            form.addEventListener('submit', () => {
              gtag('event', 'review_submit');
            });
          });
        }
      }

      // 4. Scroll depth tracking (25%, 50%, 75%, 100%)
      if (typeof gtag === 'function') {
        const scrollThresholds = [25, 50, 75, 100];
        const firedThresholds = new Set<number>();

        const onScroll = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          const percent = Math.round((scrollTop / docHeight) * 100);

          for (const threshold of scrollThresholds) {
            if (percent >= threshold && !firedThresholds.has(threshold)) {
              firedThresholds.add(threshold);
              gtag('event', 'scroll_depth', {
                percent: threshold,
                page_path: pagePath
              });
            }
          }

          // Clean up once all thresholds fired
          if (firedThresholds.size === scrollThresholds.length) {
            window.removeEventListener('scroll', onScroll);
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // Scroll to top button
      const scrollBtn = document.getElementById('scroll-top');
      if (scrollBtn) {
        window.addEventListener('scroll', () => {
          scrollBtn.classList.toggle('visible', window.scrollY > 400);
        });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // Scroll animations with IntersectionObserver
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const animatedElements = document.querySelectorAll('.animate-on-scroll');
        if (animatedElements.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          animatedElements.forEach((el) => observer.observe(el));
        }
      }
    });
  </script>

  <!-- Register public service worker -->
  <script is:inline>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js', { scope: '/' })
        .catch(() => {});
    }
  </script>
</body>
</html>
