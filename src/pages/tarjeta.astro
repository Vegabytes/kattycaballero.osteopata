    <div class="card-container">
      <div class="card-header">
        <img src="/images/logo.webp" alt="Katy Caballero - Osteópata" class="card-logo" width="100" height="100" />
        <h1 class="card-name">Katy Caballero</h1>
        <p class="card-title">Osteópata y Masajista · Colegiada CO-2785</p>
      </div>

      <div class="card-divider"></div>

      <div class="card-info">
