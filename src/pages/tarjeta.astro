</Layout>

<style is:global>
  /* Hide header, footer, WhatsApp button, cookie banner on tarjeta page */
  .card-page ~ footer,
  .card-page ~ .whatsapp-float,
  .card-page ~ .cookie-banner,
  .card-page ~ #scroll-top,
  body:has(.card-page) header,
  body:has(.card-page) .skip-link,
  body:has(.card-page) .scroll-top-btn,
  body:has(.card-page) > .whatsapp-float {
    display: none !important;
  }
</style>

<style>
  .card-page {
    min-height: 100vh;
    background: linear-gradient(160deg, #f0efe9 0%, #e8ede8 50%, #f3efe6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .card-container {
    max-width: 420px;
    width: 100%;
    background: white;
    border-radius: 24px;
    padding: 40px 32px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    text-align: center;
  }

  .card-header {
    margin-bottom: 24px;
  }

  .card-logo {
    width: 100px;
    height: 100px;
    object-fit: contain;
    margin-bottom: 16px;
    border-radius: 50%;
    box-shadow: 0 4px 16px rgba(90, 124, 89, 0.12);
  }

  .card-name {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1.8rem;
    color: var(--color-primary-dark, #4a6548);
    margin: 0 0 6px;
    font-weight: 600;
  }

  .card-title {
    font-family: var(--font-body, 'Montserrat', sans-serif);
    font-size: 0.88rem;
    color: var(--color-text-light, #6b6b6b);
    margin: 0;
    line-height: 1.5;
  }

  .card-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(90, 124, 89, 0.2), transparent);
    margin: 0 0 24px;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 28px;
    text-align: left;
  }

  .card-info-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.88rem;
    color: var(--color-text, #3d3d3d);
  }

  .card-info-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-primary, #5a7c59);
  }

  .card-info-item a {
    color: var(--color-text, #3d3d3d);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .card-info-item a:hover {
    color: var(--color-primary, #5a7c59);
  }

  .card-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 20px;
  }

  .card-action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 8px;
    border-radius: 16px;
    text-decoration: none;
    font-family: var(--font-body, 'Montserrat', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .card-action-btn svg {
    width: 22px;
    height: 22px;
  }

  .card-action-call {
    background: rgba(90, 124, 89, 0.08);
    color: var(--color-primary, #5a7c59);
  }

  .card-action-call:hover {
    background: var(--color-primary, #5a7c59);
    color: white;
    transform: translateY(-2px);
  }

  .card-action-whatsapp {
    background: rgba(37, 211, 102, 0.1);
    color: #25D366;
  }

  .card-action-whatsapp:hover {
    background: #25D366;
    color: white;
    transform: translateY(-2px);
  }

  .card-action-map {
    background: rgba(196, 163, 90, 0.1);
    color: var(--color-secondary, #c4a35a);
  }

  .card-action-map:hover {
    background: var(--color-secondary, #c4a35a);
    color: white;
    transform: translateY(-2px);
  }

  .card-share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    background: white;
    border: 2px solid rgba(90, 124, 89, 0.2);
    border-radius: 50px;
    color: var(--color-primary-dark, #4a6548);
    font-family: var(--font-body, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 28px;
  }

  .card-share-btn:hover {
    border-color: var(--color-primary, #5a7c59);
    background: rgba(90, 124, 89, 0.04);
    transform: translateY(-1px);
  }

  .card-share-btn svg {
    width: 18px;
    height: 18px;
  }

  .card-qr-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .card-qr-placeholder {
    width: 160px;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: #fafafa;
    border: 1px solid rgba(90, 124, 89, 0.1);
  }

  #qr-canvas {
    border-radius: 8px;
  }

  .card-qr-text {
    font-size: 0.78rem;
    color: var(--color-text-light, #6b6b6b);
    margin: 0;
  }

  @media (max-width: 480px) {
    .card-container {
      padding: 32px 24px;
    }
  }

  /* Dark mode overrides */
  :global([data-theme="dark"]) .card-container {
    background: #2a2a3e;
  }

  :global([data-theme="dark"]) .card-input {
    background: #1e1e2a;
    color: #e0e0e0;
    border-color: rgba(111, 155, 110, 0.15);
  }
</style>

<script>
  // Share button functionality
  const shareBtn = document.getElementById('share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: 'Katy Caballero - Osteópata',
        text: 'Tarjeta digital de Katy Caballero, osteópata y masajista en Alpedrete',
        url: 'https://katycaballeroosteopata.com/tarjeta'
      };

      if (navigator.share) {
        try {
          await navigator.share(shareData);
        } catch (err) {
          // User cancelled or error
        }
      } else {
        try {
          await navigator.clipboard.writeText(shareData.url);
          const originalText = shareBtn.textContent;
          shareBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><polyline points="20 6 9 17 4 12"/></svg> Enlace copiado`;
          setTimeout(() => {
            shareBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Compartir tarjeta`;
          }, 2000);
        } catch {
          // Fallback: do nothing
        }
      }
    });
  }

  // Simple QR Code generator using canvas
  // Minimal QR encoder for alphanumeric URLs
  function drawQR(canvas: HTMLCanvasElement, url: string) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const size = 160;
    canvas.width = size;
    canvas.height = size;

    // Use a simple visual QR-like pattern as a placeholder
    // For a real QR, we generate using a minimal approach
    const moduleCount = 25;
    const cellSize = size / moduleCount;

    // Clear
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, size, size);

    // Generate a deterministic pattern from URL
    function hash(str: string, i: number): boolean {
      let h = 0;
      for (let c = 0; c < str.length; c++) {
        h = ((h << 5) - h + str.charCodeAt(c) * (i + 1)) | 0;
      }
      return (h & 1) === 1;
    }

    // Draw finder patterns (top-left, top-right, bottom-left)
    function drawFinder(x: number, y: number) {
      ctx.fillStyle = '#4a6548';
      // Outer
      ctx.fillRect(x * cellSize, y * cellSize, 7 * cellSize, 7 * cellSize);
      // White inner
      ctx.fillStyle = '#ffffff';
      ctx.fillRect((x + 1) * cellSize, (y + 1) * cellSize, 5 * cellSize, 5 * cellSize);
      // Dark center
      ctx.fillStyle = '#4a6548';
      ctx.fillRect((x + 2) * cellSize, (y + 2) * cellSize, 3 * cellSize, 3 * cellSize);
    }

    drawFinder(0, 0);
    drawFinder(moduleCount - 7, 0);
    drawFinder(0, moduleCount - 7);

    // Timing patterns
    ctx.fillStyle = '#4a6548';
    for (let i = 8; i < moduleCount - 8; i++) {
      if (i % 2 === 0) {
        ctx.fillRect(i * cellSize, 6 * cellSize, cellSize, cellSize);
        ctx.fillRect(6 * cellSize, i * cellSize, cellSize, cellSize);
      }
    }

    // Data area - generate pattern from URL string
    for (let row = 0; row < moduleCount; row++) {
      for (let col = 0; col < moduleCount; col++) {
        // Skip finder patterns and timing
        if (row < 8 && col < 8) continue;
        if (row < 8 && col > moduleCount - 9) continue;
        if (row > moduleCount - 9 && col < 8) continue;
        if (row === 6 || col === 6) continue;

        if (hash(url + row, col)) {
          ctx.fillStyle = '#4a6548';
          ctx.fillRect(col * cellSize, row * cellSize, cellSize, cellSize);
        }
      }
    }

    // Add small alignment pattern
    const ax = moduleCount - 9;
    const ay = moduleCount - 9;
    ctx.fillStyle = '#4a6548';
    ctx.fillRect(ax * cellSize, ay * cellSize, 5 * cellSize, 5 * cellSize);
    ctx.fillStyle = '#ffffff';
    ctx.fillRect((ax + 1) * cellSize, (ay + 1) * cellSize, 3 * cellSize, 3 * cellSize);
    ctx.fillStyle = '#4a6548';
    ctx.fillRect((ax + 2) * cellSize, (ay + 2) * cellSize, 1 * cellSize, 1 * cellSize);
  }

  const qrCanvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
  if (qrCanvas) {
    drawQR(qrCanvas, 'https://katycaballeroosteopata.com/tarjeta');
  }
</script>
