---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Tarjeta Digital | Katy Caballero Osteópata";
const pageDescription = "Tarjeta digital de contacto de Katy Caballero, osteópata y masajista en Alpedrete.";
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
