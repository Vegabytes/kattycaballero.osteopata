---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const reviews = [
  {
    name: "Natalia Fernández Grande",
    rating: 5,
    text: "Gran regalo de cumpleaños!! No se me ocurre uno mejor. Mi primera vez y ha sido una experiencia de 10. Un espacio muy acogedor, que invita a la relajación y el bienestar desde el primer momento. Gran profesional detallista, cuidadosa que maneja diferentes técnicas y te deja nueva, descargada y casi flotando. Me sentí muy cuidada.",
    badge: "",
  },
  {
    name: "Alejandro Castillo",
    rating: 5,
    text: "Katy me ha ayudado con los problemas de espalda ya que trabajo muchas horas con el ordenador. También de una lesión en el gemelo que me impedía hacer deporte. Es una persona muy agradable y comunicativa, transmite tranquilidad y confianza.",
    badge: "Local Guide",
  },
  {
    name: "Iulia Sasu",
    rating: 5,
    text: "Hace tiempo que me duele el hombro derecho y probé con 2 fisioterapeutas distintos pero salía con el mismo dolor. Probé con Katy y noté mejoría. Cada sesión ha sido diferente según la necesidad y dolencia que tuve. ¡Katy sabe escucharte a ti y también a tu cuerpo! ¡Millones de gracias!",
    badge: "Local Guide",
  },
  {
    name: "Nicoletta Baffetti",
    rating: 5,
    text: "Gran profesional, atenta y preparada. La sala en la que trabaja, también, muy bonita y acogedora. Repetiré pronto.",
    badge: "",
  },
  {
    name: "meriem lazar",
    rating: 5,
    text: "He tenido unas sesiones con ella, además de una muy buena profesional, te escucha y está atenta en todo el momento de la sesión.",
    badge: "Local Guide",
  },
  {
    name: "ELENA CIBRIAN",
    rating: 5,
    text: "Katy me ha ayudado a recuperarme de una lesión en la muñeca y hombro que me ha dado mucho la lata y hoy puedo decir que estoy curada. Es muy buena profesional, se nota mucho su experiencia y toda su formación. Además el nuevo espacio que ha preparado es súper acogedor! Te la recomiendo totalmente.",
    badge: "",
  },
  {
    name: "ricardo r",
    rating: 5,
    text: "Todo perfecto. Muy profesional. Perfecto en el trato y el tratamiento. Muy recomendable.",
    badge: "Local Guide",
  },
  {
    name: "Kingsley Shaw",
    rating: 5,
    text: "Todo salió bien. Un servicio profesional.",
    badge: "Local Guide",
  },
  {
    name: "Laura G.U.",
    rating: 5,
    text: "Salí nueva, en paz con mi cuerpo y conmigo misma",
    badge: "Local Guide",
  },
  {
    name: "Elias Garcia Martinez",
    rating: 5,
    text: "Katy me ha ayudado en la recuperación de una lesión de rodilla y a desinflamar y tratar el dolor. Tiene un trato muy agradable y respetuoso, es una gran profesional. Sin duda la recomiendo.",
    badge: "",
  },
  {
    name: "Amanda",
    rating: 5,
    text: "He acudido en varias ocasiones por problemas de espalda. El masaje en sí está genial, graduando presión aplicada y movimientos adecuados. Pero lo que más me gusta es que tiene una visión global de la persona, no sólo ve el problema muscular concreto sino los hábitos de vida, características personales individuales... Me hace mucho bien acudir a su sala.",
    badge: "",
  },
];

const avgRating = (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1);

const aggregateRatingSchema = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "name": "Katy Caballero - Osteópata y Masajista",
  "image": "https://katycaballeroosteopata.com/images/logo.png",
  "url": "https://katycaballeroosteopata.com",
  "telephone": "+34643961065",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Río Guadarrama 2",
    "addressLocality": "Alpedrete",
    "addressRegion": "Madrid",
    "postalCode": "28430",
    "addressCountry": "ES"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": avgRating,
    "reviewCount": reviews.length,
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": reviews.map(r => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.name },
    "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": "5" },
    "reviewBody": r.text
  }))
};

const pageTitle = "Opiniones y Reseñas | Katy Caballero Osteópata en Alpedrete";
const pageDescription = "Lee las opiniones reales de pacientes sobre Katy Caballero, osteópata en Alpedrete. Valoración 5.0 en Google con 11 reseñas. Descubre por qué confían en nosotros.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="opiniones osteopata alpedrete, reseñas osteopata alpedrete, opiniones katy caballero, valoraciones osteopatia alpedrete, opiniones masajista alpedrete, reseñas osteopatia sierra madrid"
  breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Opiniones" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(aggregateRatingSchema)} />

  <section class="page-header">
    <div class="container">
      <span class="section-tag">Opiniones</span>
      <h1>Lo que dicen mis pacientes</h1>
      <p>Reseñas reales de Google de personas que han confiado en mí para su bienestar</p>
      <div class="google-summary">
        <svg viewBox="0 0 24 24" class="google-icon"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <div class="summary-info">
          <div class="summary-stars" role="img" aria-label="5 de 5 estrellas">
            {Array.from({length: 5}).map(() => (
              <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#FBBC05"/></svg>
            ))}
          </div>
          <span class="summary-text">{avgRating} · {reviews.length} reseñas en Google</span>
        </div>
      </div>
    </div>
  </section>

  <section class="reviews-section">
    <div class="container">
      <div class="reviews-grid">
        {reviews.map((review) => (
          <article class="review-card">
            <div class="review-header">
              <div class="review-avatar">{review.name.charAt(0).toUpperCase()}</div>
              <div class="review-meta">
                <span class="review-name">{review.name}</span>
                {review.badge && <span class="review-badge">{review.badge}</span>}
              </div>
            </div>
            <div class="review-stars" role="img" aria-label={`${review.rating} de 5 estrellas`}>
              {Array.from({length: review.rating}).map(() => (
                <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#FBBC05"/></svg>
              ))}
            </div>
            <p class="review-text">{review.text}</p>
          </article>
        ))}
      </div>

      <div class="review-cta">
        <h2>¿Ya has visitado la consulta?</h2>
        <p>Tu opinión ayuda a otras personas a encontrar el cuidado que necesitan</p>
        <a href="https://g.page/r/CUVuAD3Rp90PEBE/review" target="_blank" rel="noopener noreferrer" class="btn-google-review">
          <svg viewBox="0 0 24 24" class="google-icon-small"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Dejar mi reseña en Google
        </a>
      </div>
    </div>
  </section>

  <!-- Review submission form -->
  <section class="submit-review-section" id="dejar-opinion">
    <div class="container">
      <span class="section-tag">Tu opinión</span>
      <h2>Comparte tu experiencia</h2>
      <p class="submit-subtitle">¿Has visitado la consulta? Cuéntanos cómo fue tu experiencia. Revisaremos tu opinión antes de publicarla.</p>

      <form id="review-form" class="review-form" novalidate>
        <div class="form-group">
          <label for="review-nombre">Nombre *</label>
          <input type="text" id="review-nombre" name="nombre" required maxlength="100" placeholder="Tu nombre" autocomplete="name" />
        </div>

        <div class="form-group">
          <label id="rating-label">Puntuación *</label>
          <div class="star-rating" role="radiogroup" aria-labelledby="rating-label">
            {[1, 2, 3, 4, 5].map((value) => (
              <button type="button" class="star-btn" data-value={value} aria-label={`${value} estrella${value > 1 ? 's' : ''}`}>
                <svg viewBox="0 0 24 24" class="star-svg" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </button>
            ))}
          </div>
          <input type="hidden" id="review-puntuacion" name="puntuacion" value="" />
        </div>

        <div class="form-group">
          <label for="review-mensaje">Tu opinión *</label>
          <textarea id="review-mensaje" name="mensaje" required maxlength="2000" rows="4" placeholder="Cuéntanos tu experiencia..."></textarea>
        </div>

        <!-- Honeypot -->
        <div class="form-honey" aria-hidden="true" tabindex="-1">
          <label for="review-website">Website</label>
          <input type="text" id="review-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn-submit-review" id="review-submit-btn">
          Enviar opinión
        </button>

        <div id="review-success" class="review-message review-success" role="alert" style="display:none;">
          ¡Gracias por tu opinión! La revisaremos pronto.
        </div>
        <div id="review-error" class="review-message review-error" role="alert" style="display:none;">
          Ha ocurrido un error. Por favor, inténtalo de nuevo.
        </div>
      </form>
    </div>
  </section>

  <CTASection />
</Layout>

<script>
  // Star rating interaction
  const starBtns = document.querySelectorAll<HTMLButtonElement>('.star-btn');
  const puntuacionInput = document.getElementById('review-puntuacion') as HTMLInputElement;
  let selectedRating = 0;

  function updateStars(hoverValue: number, isHover: boolean) {
    starBtns.forEach((btn) => {
      const val = parseInt(btn.dataset.value || '0', 10);
      const svg = btn.querySelector('.star-svg') as SVGElement;
      if (val <= (isHover ? hoverValue : selectedRating)) {
        svg.classList.add('star-filled');
      } else {
        svg.classList.remove('star-filled');
      }
    });
  }

  starBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      selectedRating = parseInt(btn.dataset.value || '0', 10);
      puntuacionInput.value = String(selectedRating);
      updateStars(selectedRating, false);
    });
    btn.addEventListener('mouseenter', () => {
      updateStars(parseInt(btn.dataset.value || '0', 10), true);
    });
    btn.addEventListener('mouseleave', () => {
      updateStars(selectedRating, false);
    });
  });

  // Form submission
  const form = document.getElementById('review-form') as HTMLFormElement;
  const submitBtn = document.getElementById('review-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('review-success') as HTMLElement;
  const errorMsg = document.getElementById('review-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    const nombre = (document.getElementById('review-nombre') as HTMLInputElement).value.trim();
    const mensaje = (document.getElementById('review-mensaje') as HTMLTextAreaElement).value.trim();
    const website = (document.getElementById('review-website') as HTMLInputElement).value;
    const puntuacion = puntuacionInput.value;

    if (!nombre || !mensaje || !puntuacion) {
      errorMsg.textContent = 'Por favor, completa todos los campos y selecciona una puntuación.';
      errorMsg.style.display = 'block';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/resena', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, puntuacion, mensaje, website }),
      });

      const data = await res.json();

      if (data.success) {
        successMsg.style.display = 'block';
        form.reset();
        selectedRating = 0;
        updateStars(0, false);
      } else {
        errorMsg.textContent = data.error || 'Ha ocurrido un error. Por favor, inténtalo de nuevo.';
        errorMsg.style.display = 'block';
      }
    } catch {
      errorMsg.textContent = 'Error de conexión. Por favor, inténtalo de nuevo.';
      errorMsg.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar opinión';
    }
  });
</script>

<style>
  .page-header {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }

  .page-header h1 {
    margin-bottom: 15px;
  }

  .page-header p {
    margin: 0 auto 30px;
    max-width: 600px;
    color: var(--color-text-light);
  }

  .google-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .google-icon {
    width: 32px;
    height: 32px;
  }

  .summary-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .summary-stars {
    display: flex;
    gap: 2px;
  }

  .star-icon {
    width: 20px;
    height: 20px;
  }

  .summary-text {
    color: var(--color-text-light);
    font-size: 1rem;
    font-weight: 500;
  }

  /* Reviews grid */
  .reviews-section {
    background: var(--color-warm-white);
    padding-bottom: 0;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .review-card {
    background: var(--color-cream);
    border-radius: 16px;
    padding: 28px;
    transition: var(--transition);
    border: 1px solid rgba(90, 124, 89, 0.08);
  }

  .review-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-medium);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }

  .review-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    font-family: var(--font-display);
    flex-shrink: 0;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .review-name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
  }

  .review-badge {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 12px;
  }

  .review-text {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }

  /* CTA */
  .review-cta {
    text-align: center;
    margin-top: 60px;
    padding: 50px 0;
    border-top: 1px solid rgba(90, 124, 89, 0.1);
  }

  .review-cta h2 {
    margin-bottom: 10px;
  }

  .review-cta p {
    color: var(--color-text-light);
    margin-bottom: 25px;
    font-size: 1.05rem;
  }

  .google-icon-small {
    width: 20px;
    height: 20px;
  }

  .btn-google-review {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--color-primary);
    color: white;
    padding: 16px 32px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 15px rgba(90, 124, 89, 0.3);
  }

  .btn-google-review:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(90, 124, 89, 0.4);
    color: white;
  }

  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .google-summary {
      flex-direction: column;
      gap: 8px;
    }

    .summary-info {
      flex-direction: column;
      gap: 6px;
    }

    .review-card {
      padding: 22px;
    }
  }

  /* Dark mode overrides */
  :global([data-theme="dark"]) .review-card {
    border-color: rgba(111, 155, 110, 0.12);
  }

  :global([data-theme="dark"]) .reviews-cta {
    border-top-color: rgba(111, 155, 110, 0.12);
  }

  /* Submit review section */
  .submit-review-section {
    background: var(--color-cream);
    padding: 80px 0;
  }

  .submit-review-section .section-tag {
    display: inline-block;
    margin-bottom: 15px;
  }

  .submit-review-section h2 {
    text-align: center;
    margin-bottom: 10px;
  }

  .submit-subtitle {
    text-align: center;
    color: var(--color-text-light);
    max-width: 550px;
    margin: 0 auto 40px;
    font-size: 1.05rem;
  }

  .review-form {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .form-group input[type="text"],
  .form-group textarea {
    padding: 14px 18px;
    border: 1px solid rgba(90, 124, 89, 0.2);
    border-radius: 12px;
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-warm-white);
    transition: var(--transition);
    resize: vertical;
  }

  .form-group input[type="text"]:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(90, 124, 89, 0.12);
  }

  .star-rating {
    display: flex;
    gap: 6px;
  }

  .star-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    transition: transform 0.15s ease;
  }

  .star-btn:hover {
    transform: scale(1.2);
  }

  .star-svg {
    width: 32px;
    height: 32px;
    fill: #ddd;
    stroke: #ccc;
    stroke-width: 0.5;
    transition: fill 0.15s ease, stroke 0.15s ease;
  }

  .star-svg.star-filled {
    fill: #FBBC05;
    stroke: #e6a800;
  }

  .form-honey {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    overflow: hidden;
  }

  .btn-submit-review {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    padding: 16px 32px;
    border: none;
    border-radius: 50px;
    font-family: inherit;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: 0 4px 15px rgba(90, 124, 89, 0.3);
    align-self: center;
  }

  .btn-submit-review:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(90, 124, 89, 0.4);
  }

  .btn-submit-review:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .review-message {
    text-align: center;
    padding: 16px 20px;
    border-radius: 12px;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .review-success {
    background: rgba(90, 124, 89, 0.1);
    color: var(--color-primary-dark);
    border: 1px solid rgba(90, 124, 89, 0.2);
  }

  .review-error {
    background: rgba(220, 53, 69, 0.1);
    color: #a94442;
    border: 1px solid rgba(220, 53, 69, 0.2);
  }

  /* Dark mode - submit review */
  :global([data-theme="dark"]) .submit-review-section {
    background: #1e1e2a;
  }

  :global([data-theme="dark"]) .form-group input[type="text"],
  :global([data-theme="dark"]) .form-group textarea {
    background: #2a2a3e;
    border-color: rgba(111, 155, 110, 0.2);
