        <a href="https://wa.me/34643961065?text=Hola%20Katy,%20soy%20de%20Moralzarzal%20y%20me%20gustaría%20reservar%20una%20cita" class="btn btn-primary" target="_blank" rel="noopener noreferrer">WhatsApp: 643 961 065</a>
        <a href="/reservar" class="btn btn-outline">Reservar online</a>
        <a href="tel:+34643961065" class="btn btn-outline">Llamar</a>
