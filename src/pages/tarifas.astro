---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/services';

const pageTitle = "Tarifas y Precios | Osteopat\u00eda y Masajes en Alpedrete - Sierra Noroeste de Madrid";
const pageDescription = "Consulta las tarifas de osteopat\u00eda y masajes en Alpedrete, Sierra Noroeste de Madrid. Osteopat\u00eda 40\u20ac (55 min), masaje deportivo 20\u20ac (30 min), masaje tailand\u00e9s desde 45\u20ac. Sin sorpresas.";
const pageKeywords = "precios osteopatia alpedrete, tarifas masaje sierra noroeste madrid, tarifas masaje sierra madrid, tarifas masaje sierra de guadarrama, cuanto cuesta osteopata, precio masaje deportivo alpedrete";

const shortDescriptions: Record<string, string> = {
  "osteopatia-alpedrete": "Tratamiento global: estructural, visceral y sacrocraneal.",
  "masaje-deportivo-alpedrete": "Recuperaci\u00f3n muscular, prevenci\u00f3n de lesiones y rendimiento.",
  "masaje-tailandes-alpedrete": "Estiramientos asistidos, presiones r\u00edtmicas y trabajo energ\u00e9tico.",
  "masaje-corporal-alpedrete": "Relajaci\u00f3n profunda con aceites esenciales de alta calidad.",
  "masaje-pindas-herbales-alpedrete": "Saquitos de hierbas medicinales calientes con efecto terap\u00e9utico.",
  "masaje-embarazadas-alpedrete": "Masaje suave y adaptado a partir del cuarto mes de embarazo.",
};

// Offer schema for pricing (SEO: rich results for service prices)
const offerSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Tarifas de Osteopatía y Masajes en Alpedrete",
  "itemListElement": services.map((service, index) => {
    const priceText = service.price.split(' / ')[0].replace('€', '');
    return {
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Service",
        "name": service.title,
        "description": shortDescriptions[service.slug],
        "url": `https://katycaballeroosteopata.com/servicios/${service.slug}`,
        "provider": {
          "@type": "HealthAndBeautyBusiness",
          "name": "Katy Caballero - Osteópata y Masajista",
          "url": "https://katycaballeroosteopata.com"
        },
        "offers": {
          "@type": "Offer",
          "price": priceText,
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "url": `https://katycaballeroosteopata.com/servicios/${service.slug}`
        }
      }
    };
  })
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "\u00bfLa primera consulta tiene alg\u00fan coste extra?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, la valoración inicial est\u00e1 incluida en el precio de la sesi\u00f3n. En tu primera visita dedico tiempo a evaluar tu postura, movilidad e historial para dise\u00f1ar un tratamiento personalizado, todo dentro del mismo precio."
      }
    },
    {
      "@type": "Question",
      "name": "\u00bfQu\u00e9 m\u00e9todos de pago acept\u00e1is?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aceptamos efectivo, Bizum y transferencia bancaria. Puedes elegir el m\u00e9todo que te resulte más cómodo."
      }
    },
    {
      "@type": "Question",
      "name": "\u00bfOfrec\u00e9is bonos o descuentos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "S\u00ed, ofrezco bonos de osteopat\u00eda: Bono 3 sesiones por 114\u20ac (38\u20ac/sesi\u00f3n) y Bono 5 sesiones por 180\u20ac (36\u20ac/sesi\u00f3n). Adem\u00e1s, 10% de descuento para socios del AMPA El Peralejo y la AFA Santa Quiteria."
      }
    },
    {
      "@type": "Question",
      "name": "\u00bfPuedo cancelar o cambiar mi cita?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "S\u00ed, puedes cancelar o cambiar tu cita con al menos 24 horas de antelación sin ning\u00fan coste. Esto nos permite ofrecer ese hueco a otro paciente."
      }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Tarifas" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="page-header">
    <div class="container">
      <span class="section-tag">Tarifas</span>
      <h1>Precios de los tratamientos</h1>
      <p>Precios claros y transparentes. Sin sorpresas ni costes ocultos. La primera valoración siempre está incluida.</p>
    </div>
  </section>

  <section class="pricing-section">
    <div class="container">
      <div class="pricing-grid">
        {services.map((service) => (
          <div class="pricing-card">
            <div class="pricing-card-header">
              <h2 class="pricing-card-title">
                <a href={`/servicios/${service.slug}`}>{service.title}</a>
              </h2>
              <span class="pricing-card-duration">{service.duration}</span>
            </div>
            <div class="pricing-card-price">
              {service.price}
            </div>
            <p class="pricing-card-description">
              {shortDescriptions[service.slug]}
            </p>
            <a href={`/servicios/${service.slug}`} class="pricing-card-link">
              Ver más
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bonos-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Ahorra con los bonos</span>
        <h2>Bonos de osteopatía</h2>
        <p>Si necesitas varias sesiones, los bonos te permiten ahorrar en cada visita.</p>
      </div>
      <div class="bonos-grid">
        <div class="bono-card">
          <span class="bono-label">Sesión individual</span>
          <div class="bono-price">40<span class="bono-currency">€</span></div>
          <span class="bono-detail">Osteopatía · 55 min</span>
        </div>
        <div class="bono-card featured">
          <span class="bono-badge">Más popular</span>
          <span class="bono-label">Bono 3 sesiones</span>
          <div class="bono-price">114<span class="bono-currency">€</span></div>
          <span class="bono-per-session">38€ por sesión</span>
          <span class="bono-saving">Ahorras 6€</span>
        </div>
        <div class="bono-card best">
          <span class="bono-badge">Mejor precio</span>
          <span class="bono-label">Bono 5 sesiones</span>
          <div class="bono-price">180<span class="bono-currency">€</span></div>
          <span class="bono-per-session">36€ por sesión</span>
          <span class="bono-saving">Ahorras 20€</span>
        </div>
      </div>
      <p class="bonos-note">Los bonos son para sesiones de osteopatía (55 min). Consúltame al reservar tu cita.</p>
    </div>
  </section>

  <section class="info-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Información útil</span>
        <h2>Lo que debes saber</h2>
      </div>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </div>
          <h3>Métodos de pago</h3>
          <p>Acepto <strong>efectivo</strong>, <strong>Bizum</strong> y <strong>transferencia bancaria</strong>. Elige el que te resulte más cómodo.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3>Primera sesión</h3>
          <p>La <strong>valoración inicial</strong> está incluida en el precio. En tu primera visita evalúo tu postura, movilidad e historial sin coste extra.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Cancelaciones</h3>
          <p>Puedes cancelar o cambiar tu cita con al menos <strong>24 horas de antelación</strong>. Así puedo ofrecer ese hueco a otro paciente.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Preguntas Frecuentes</span>
        <h2>Dudas sobre precios y reservas</h2>
      </div>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>&iquest;La primera consulta tiene alg&uacute;n coste extra?</summary>
          <p>No, la valoraci&oacute;n inicial est&aacute; incluida en el precio de la sesi&oacute;n. En tu primera visita dedico tiempo a evaluar tu postura, movilidad e historial para dise&ntilde;ar un tratamiento personalizado, todo dentro del mismo precio.</p>
        </details>
        <details class="faq-item">
          <summary>&iquest;Qu&eacute; m&eacute;todos de pago acept&aacute;is?</summary>
          <p>Acepto efectivo, Bizum y transferencia bancaria. Puedes elegir el m&eacute;todo de pago que te resulte m&aacute;s c&oacute;modo.</p>
        </details>
        <details class="faq-item">
          <summary>&iquest;Ofrec&eacute;is bonos o descuentos?</summary>
          <p>S&iacute;, ofrezco <strong>bonos de osteopat&iacute;a</strong>: Bono 3 sesiones por 114&euro; (38&euro;/sesi&oacute;n) y Bono 5 sesiones por 180&euro; (36&euro;/sesi&oacute;n). Adem&aacute;s, 10% de descuento para socios del <strong>AMPA El Peralejo</strong> y la <strong>AFA Santa Quiteria</strong>.</p>
        </details>
        <details class="faq-item">
          <summary>&iquest;Puedo cancelar o cambiar mi cita?</summary>
          <p>S&iacute;, puedes cancelar o cambiar tu cita con al menos 24 horas de antelaci&oacute;n sin ning&uacute;n coste. Esto me permite ofrecer ese hueco a otro paciente que lo necesite.</p>
        </details>
      </div>
    </div>
  </section>

  <CTASection
    title="&iquest;Quieres reservar?"
    description="Contacta conmigo y te ayudo a elegir el tratamiento adecuado."
    buttonText="Reservar Cita por WhatsApp"
    buttonLink="https://wa.me/34643961065?text=Hola%20Katy,%20me%20gustar%C3%ADa%20reservar%20una%20cita"
  />
</Layout>

<style>
  .page-header {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }

  .page-header h1 {
    margin-bottom: 20px;
  }

  .page-header p {
    margin: 0 auto;
    max-width: 600px;
  }

  /* Pricing Section */
  .pricing-section {
    background: var(--color-warm-white);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .pricing-card {
    background: white;
    border-radius: 20px;
    padding: 35px 30px;
    border: 1px solid rgba(90, 124, 89, 0.1);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(90, 124, 89, 0.12);
    border-color: var(--color-primary);
  }

  .pricing-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
  }

  .pricing-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    text-align: left;
  }

  .pricing-card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .pricing-card-title a:hover {
    color: var(--color-primary);
  }

  .pricing-card-duration {
    font-size: 0.85rem;
    color: var(--color-text-light);
    background: var(--color-cream);
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pricing-card-price {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 15px;
    line-height: 1;
  }

  .pricing-card-description {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 20px;
    flex-grow: 1;
    max-width: none;
  }

  .pricing-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .pricing-card-link:hover {
    gap: 10px;
    color: var(--color-primary-dark);
  }

  .pricing-card-link svg {
    transition: transform 0.3s ease;
  }

  .pricing-card-link:hover svg {
    transform: translateX(3px);
  }

  /* Info Section */
  .info-section {
    background: var(--color-cream);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .info-card {
    background: var(--color-warm-white);
    border-radius: 20px;
    padding: 35px 30px;
    text-align: center;
    border: 1px solid rgba(90, 124, 89, 0.1);
  }

  .info-icon {
    width: 60px;
    height: 60px;
    background: var(--color-secondary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: var(--color-primary);
  }

  .info-card h3 {
    font-size: 1.1rem;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .info-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: none;
  }

  /* FAQ Section */
  .faq-section {
    background: var(--color-warm-white);
  }

  .faq-grid {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .faq-item {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgba(90, 124, 89, 0.1);
    transition: all 0.3s ease;
  }

  .faq-item[open] {
    box-shadow: 0 4px 15px rgba(90, 124, 89, 0.1);
  }

  .faq-item summary {
    padding: 20px 25px;
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    font-size: 1.05rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--color-primary);
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-item[open] summary::after {
    content: '\2212';
  }

  .faq-item summary:hover {
    color: var(--color-primary);
  }

  .faq-item p {
    padding: 0 25px 20px;
    color: var(--color-text-light);
    line-height: 1.8;
    font-size: 0.95rem;
    max-width: none;
  }

  /* Bonos Section */
  .bonos-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
  }

  .bonos-section .section-tag {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .bonos-section h2 {
    color: white;
  }

  .bonos-section .section-header p {
    color: rgba(255, 255, 255, 0.85);
  }

  .bonos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    max-width: 900px;
    margin: 0 auto;
  }

  .bono-card {
    background: rgba(255, 255, 255, 0.12);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 35px 25px;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
  }

  .bono-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.18);
  }

  .bono-card.featured,
  .bono-card.best {
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-text);
    border-color: transparent;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  }

  .bono-card.featured:hover,
  .bono-card.best:hover {
    background: white;
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
  }

  .bono-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-secondary);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .bono-label {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 12px;
    opacity: 0.9;
  }

  .bono-card.featured .bono-label,
  .bono-card.best .bono-label {
    color: var(--color-text);
    opacity: 1;
  }

  .bono-price {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 8px;
  }

  .bono-card.featured .bono-price,
  .bono-card.best .bono-price {
    color: var(--color-primary);
  }

  .bono-currency {
    font-size: 1.5rem;
    vertical-align: super;
  }

  .bono-per-session {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--color-text-light);
  }

  .bono-detail {
    display: block;
    font-size: 0.85rem;
    opacity: 0.75;
    margin-top: 4px;
  }

  .bono-saving {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 3px 12px;
    border-radius: 20px;
    margin-top: 4px;
  }

  .bonos-note {
    text-align: center;
    margin-top: 30px;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card-price {
      font-size: 2rem;
    }

    .bonos-grid {
      grid-template-columns: 1fr;
      max-width: 350px;
    }

    .bono-card.featured,
    .bono-card.best {
      order: -1;
    }
  }
</style>
