<script>
  const slider = document.getElementById('session-slider') as HTMLInputElement;
  const countEl = document.getElementById('session-count')!;
  const priceIndividual = document.getElementById('price-individual')!;
  const priceBono3 = document.getElementById('price-bono3')!;
  const priceBono5 = document.getElementById('price-bono5')!;
  const savingBono3 = document.getElementById('saving-bono3')!;
  const savingBono5 = document.getElementById('saving-bono5')!;
  const optIndividual = document.getElementById('opt-individual')!;
  const optBono3 = document.getElementById('opt-bono3')!;
  const optBono5 = document.getElementById('opt-bono5')!;
  const recommendation = document.getElementById('calc-recommendation')!;
  const bestName = document.getElementById('best-option-name')!;
  const bestSaving = document.getElementById('best-option-saving')!;

  function calcPrice(sessions: number) {
    const individual = sessions * 40;

    // Bono 3: groups of 3 at 38€, remainder at 40€
    let bono3 = individual;
    if (sessions >= 3) {
      const groups3 = Math.floor(sessions / 3);
      const rest3 = sessions % 3;
      bono3 = groups3 * 3 * 38 + rest3 * 40;
    }

    // Bono 5: groups of 5 at 36€, remainder at 40€
    let bono5 = individual;
    if (sessions >= 5) {
      const groups5 = Math.floor(sessions / 5);
      const rest5 = sessions % 5;
      bono5 = groups5 * 5 * 36 + rest5 * 40;
    }

    return { individual, bono3, bono5 };
  }

  function animatePrice(el: HTMLElement) {
    el.classList.add('animate');
    setTimeout(() => el.classList.remove('animate'), 300);
  }

  function update() {
    const sessions = parseInt(slider.value);
    const pct = ((sessions - 1) / 9) * 100;
    slider.style.setProperty('--range-pct', pct + '%');

    countEl.textContent = String(sessions);
    countEl.classList.add('pulse');
    setTimeout(() => countEl.classList.remove('pulse'), 200);

    const { individual, bono3, bono5 } = calcPrice(sessions);

    priceIndividual.textContent = individual + '€';
    priceBono3.textContent = bono3 + '€';
    priceBono5.textContent = bono5 + '€';

    animatePrice(priceIndividual);
    animatePrice(priceBono3);
    animatePrice(priceBono5);

    const saving3 = individual - bono3;
    const saving5 = individual - bono5;

    savingBono3.textContent = saving3 > 0 ? `Ahorras ${saving3}€` : '';
    savingBono5.textContent = saving5 > 0 ? `Ahorras ${saving5}€` : '';

    // Determine availability
    optBono3.classList.toggle('unavailable', sessions < 3);
    optBono5.classList.toggle('unavailable', sessions < 5);

    // Find best option
    optIndividual.classList.remove('best-choice');
    optBono3.classList.remove('best-choice');
    optBono5.classList.remove('best-choice');

    const prices = [
      { cost: individual, name: 'Sesión individual', saving: 0, el: optIndividual },
      ...(sessions >= 3 ? [{ cost: bono3, name: 'Bono 3 sesiones', saving: saving3, el: optBono3 }] : []),
      ...(sessions >= 5 ? [{ cost: bono5, name: 'Bono 5 sesiones', saving: saving5, el: optBono5 }] : []),
    ];

    const best = prices.reduce((a, b) => (b.cost < a.cost ? b : a));
    best.el.classList.add('best-choice');

    if (best.saving > 0) {
      recommendation.classList.remove('hidden');
      bestName.textContent = best.name;
      bestSaving.textContent = `ahorras ${best.saving}€`;
    } else {
      recommendation.classList.add('hidden');
    }
  }

  slider.addEventListener('input', update);
  update();
</script>
