---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getCitasSemana } from '../../../lib/db';

let dbError = '';

const fechaParam = Astro.url.searchParams.get('fecha') || '';
const hoy = new Date().toISOString().split('T')[0];

// Get current week
const fecha = fechaParam || hoy;
const fechaObj = new Date(fecha + 'T00:00:00');
const dia = fechaObj.getDay();
const lunes = new Date(fechaObj);
lunes.setDate(fechaObj.getDate() - (dia === 0 ? 6 : dia - 1));
const domingo = new Date(lunes);
domingo.setDate(lunes.getDate() + 6);

const lunesStr = lunes.toISOString().split('T')[0];
const domingoStr = domingo.toISOString().split('T')[0];

let citasSemana: any[] = [];
try {
  citasSemana = await getCitasSemana(Astro, lunesStr, domingoStr);
} catch (e: any) {
  dbError = e.message;
  console.error('DB error in citas:', e);
}

// Group by date
const citasPorDia: Record<string, typeof citasSemana> = {};
const diasSemana = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
for (let i = 0; i < 7; i++) {
  const d = new Date(lunes);
  d.setDate(lunes.getDate() + i);
  const key = d.toISOString().split('T')[0];
  citasPorDia[key] = citasSemana.filter(c => c.fecha === key);
}

// Navigation
const semanaAnterior = new Date(lunes);
semanaAnterior.setDate(lunes.getDate() - 7);
const semanaSiguiente = new Date(lunes);
semanaSiguiente.setDate(lunes.getDate() + 7);

function formatFechaCorta(fecha: string) {
  const d = new Date(fecha + 'T00:00:00');
  return d.getDate() + '/' + (d.getMonth() + 1);
}
---

<AdminLayout title="Citas" activeSection="citas">
  {dbError && (
    <div class="alert alert-error">
      <strong>Error de base de datos:</strong> {dbError}
      <br><small>Verifica que D1 esté vinculado en Cloudflare Pages → Settings → Functions → D1 database bindings.</small>
    </div>
  )}
  <div class="page-header">
    <h2>Citas — Semana del {formatFechaCorta(lunesStr)} al {formatFechaCorta(domingoStr)}</h2>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href={`/admin/citas?fecha=${semanaAnterior.toISOString().split('T')[0]}`} class="btn btn-secondary btn-sm">← Anterior</a>
      <a href="/admin/citas" class="btn btn-secondary btn-sm">Hoy</a>
      <a href={`/admin/citas?fecha=${semanaSiguiente.toISOString().split('T')[0]}`} class="btn btn-secondary btn-sm">Siguiente →</a>
      <a href={`/admin/citas/dia?fecha=${hoy}`} class="btn btn-secondary btn-sm">Vista día</a>
      <a href={`/admin/citas/mensual?fecha=${fecha}`} class="btn btn-secondary btn-sm">Vista mensual</a>
      <a href="/admin/citas/nueva" class="btn btn-primary btn-sm">+ Nueva cita</a>
      <a href="/api/export/citas" class="btn btn-secondary btn-sm" style="background:#5a7c59;color:#fff;border-color:#5a7c59;" title="Exportar citas a CSV">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="vertical-align:middle;margin-right:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        Exportar CSV
      </a>
    </div>
  </div>

  <!-- Week summary -->
  {(() => {
    const totalSemana = citasSemana.length;
    const completadas = citasSemana.filter(c => c.estado === 'completada').length;
    const pendientes = citasSemana.filter(c => c.estado === 'pendiente').length;
    const canceladas = citasSemana.filter(c => c.estado === 'cancelada').length;
    const noShows = citasSemana.filter(c => c.estado === 'no_show').length;
    const ingresos = citasSemana.filter(c => c.estado === 'completada' && c.precio).reduce((s, c) => s + (c.precio || 0), 0);
    return totalSemana > 0 ? (
      <div class="week-summary">
        <span class="ws-item"><strong>{totalSemana}</strong> citas</span>
        <span class="ws-sep">|</span>
        <span class="ws-item ws-ok">{completadas} completadas</span>
        {pendientes > 0 && <><span class="ws-sep">|</span><span class="ws-item ws-pending">{pendientes} pendientes</span></>}
        {canceladas > 0 && <><span class="ws-sep">|</span><span class="ws-item ws-cancel">{canceladas} canceladas</span></>}
        {noShows > 0 && <><span class="ws-sep">|</span><span class="ws-item ws-noshow">{noShows} no-show</span></>}
        {ingresos > 0 && <><span class="ws-sep">|</span><span class="ws-item ws-money">{ingresos.toFixed(0)}&euro;</span></>}
      </div>
    ) : null;
  })()}

  <!-- Weekly calendar -->
  <div class="week-grid">
    {Object.entries(citasPorDia).map(([fechaDia, citas], i) => {
      const esHoy = fechaDia === hoy;
      return (
        <div class="card" style={`padding:16px;${esHoy ? 'border-color:#5a7c59;border-width:2px;' : ''}`}>
          <a href={`/admin/citas/dia?fecha=${fechaDia}`} style="text-align:center;margin-bottom:12px;display:block;text-decoration:none;">
            <div style={`font-size:0.75rem;font-weight:600;text-transform:uppercase;color:${esHoy ? '#5a7c59' : '#666'};`}>
              {diasSemana[i]}
            </div>
            <div style={`font-size:1.25rem;font-weight:700;color:${esHoy ? '#5a7c59' : '#333'};`}>
              {new Date(fechaDia + 'T00:00:00').getDate()}
            </div>
          </a>

          {(() => {
            const ingDia = citas.filter((c: any) => c.estado === 'completada' && c.precio).reduce((s: number, c: any) => s + (c.precio || 0), 0);
            return ingDia > 0 ? <div style="text-align:center;font-size:0.7rem;font-weight:600;color:#4caf50;margin-bottom:4px;">{ingDia.toFixed(0)}&euro;</div> : null;
          })()}
          {citas.length === 0 ? (
            <p style="text-align:center;color:#ccc;font-size:0.75rem;">Sin citas</p>
          ) : (
            <div style="display:flex;flex-direction:column;gap:8px;">
              {citas.map((c) => (
                <div style={`padding:8px;border-radius:6px;font-size:0.8rem;background:${
                  c.estado === 'completada' ? '#e8f5e9' :
                  c.estado === 'cancelada' ? '#fce4ec' :
                  c.estado === 'no_show' ? '#fff3e0' :
                  c.estado === 'confirmada' ? '#e3f2fd' : '#fff3e0'
                };`}>
                  <a href={`/admin/citas/${c.id}`} style="text-decoration:none;">
                    <strong style="color:#333;">{c.hora}</strong>
                    <div style="color:#666;font-size:0.7rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                      {c.paciente_nombre} {c.paciente_apellidos}
                    </div>
                    {c.servicio && <div style="color:#999;font-size:0.65rem;">{c.servicio}</div>}
                    {c.recordatorio_enviado ? (
                      <div style="color:#4caf50;font-size:0.6rem;margin-top:2px;" title="Recordatorio enviado">✓ Recordatorio</div>
                    ) : (c.estado === 'pendiente' || c.estado === 'confirmada') && c.fecha >= hoy ? (
                      <div style="color:#e65100;font-size:0.6rem;margin-top:2px;font-weight:600;" title="Recordatorio pendiente de enviar">⚠ Sin recordatorio</div>
                    ) : null}
                  </a>
                  {c.estado !== 'completada' && c.estado !== 'cancelada' && c.estado !== 'no_show' && (
                    <div class="btn-cal-row">
                      <button class="btn-cal-complete" data-id={c.id} data-estado="completada" title="Completada">&#10003;</button>
                      <button class="btn-cal-cancel" data-id={c.id} data-estado="cancelada" title="Cancelar">&#10007;</button>
                      <button class="btn-cal-noshow" data-id={c.id} data-estado="no_show" title="No-show">?</button>
                    </div>
                  )}
                  {c.paciente_telefono && (
                    <a
                      href={`https://wa.me/34${c.paciente_telefono.replace(/\D/g, '').replace(/^34/, '')}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-cal-wa"
                      title={`WhatsApp a ${c.paciente_nombre}`}
                    >&#128242;</a>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>

  <style>
    .week-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 12px;
    }
    .week-summary {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      padding: 10px 16px;
      background: #f8f9fa;
      border-radius: 8px;
      border: 1px solid #e9ecef;
      margin-bottom: 12px;
      font-size: 0.82rem;
    }
    .ws-sep { color: #ddd; }
    .ws-ok { color: #2e7d32; }
    .ws-pending { color: #e65100; }
    .ws-cancel { color: #c62828; }
    .ws-noshow { color: #ff9800; }
    .ws-money { color: #7b1fa2; font-weight: 700; }
    .btn-cal-row {
      display: flex;
      gap: 2px;
      margin-top: 4px;
    }
    .btn-cal-complete, .btn-cal-cancel, .btn-cal-noshow {
      flex: 1;
      padding: 2px;
      color: #fff;
      border: none;
      border-radius: 4px;
      font-size: 0.7rem;
      cursor: pointer;
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    .btn-cal-complete { background: #4caf50; }
    .btn-cal-cancel { background: #ef5350; }
    .btn-cal-noshow { background: #ff9800; }
    .btn-cal-complete:hover, .btn-cal-cancel:hover, .btn-cal-noshow:hover { opacity: 1; }
    .btn-cal-wa {
      display: inline-block;
      margin-top: 4px;
      width: 22px;
      height: 22px;
      line-height: 22px;
      text-align: center;
      background: #25d366;
      color: #fff;
      border-radius: 50%;
      font-size: 0.7rem;
      text-decoration: none;
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    .btn-cal-wa:hover { opacity: 1; }
    @media (max-width: 900px) {
      .week-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (max-width: 600px) {
      .week-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>

  <script>
    document.querySelectorAll('.btn-cal-complete, .btn-cal-cancel, .btn-cal-noshow').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const button = e.currentTarget as HTMLButtonElement;
        const id = button.dataset.id;
        const estado = button.dataset.estado;
        if (estado === 'cancelada' && !confirm('¿Cancelar esta cita?')) return;
        if (estado === 'no_show' && !confirm('¿Marcar como no-show?')) return;
        button.disabled = true;
        try {
          const res = await fetch('/api/cita-estado', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: Number(id), estado }),
          });
          if (res.ok) window.location.reload();
        } catch { /* ignore */ }
        button.disabled = false;
      });
    });
  </script>
</AdminLayout>
