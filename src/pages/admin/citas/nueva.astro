---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { crearCita, getPacientes } from '../../../lib/db';

const pacientes = await getPacientes(Astro);
const pacienteId = Astro.url.searchParams.get('paciente') || '';
const fechaParam = Astro.url.searchParams.get('fecha') || new Date().toISOString().split('T')[0];
const horaParam = Astro.url.searchParams.get('hora') || '';
const servicioParam = Astro.url.searchParams.get('servicio') || '';
const duracionParam = Astro.url.searchParams.get('duracion') || '';
const precioParam = Astro.url.searchParams.get('precio') || '';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const paciente_id = Number(form.get('paciente_id'));
  const fecha = form.get('fecha') as string;
  const hora = form.get('hora') as string;

  if (!paciente_id || !fecha || !hora) {
    error = 'Paciente, fecha y hora son obligatorios';
  } else {
    const id = await crearCita(Astro, {
      paciente_id,
      fecha,
      hora,
      duracion: Number(form.get('duracion')) || 60,
      servicio: form.get('servicio') as string,
      estado: form.get('estado') as string || 'pendiente',
      notas: form.get('notas') as string,
      precio: form.get('precio') ? Number(form.get('precio')) : null,
    });
    return Astro.redirect(`/admin/citas/${id}`);
  }
}

const servicios = [
  { nombre: 'Osteopatía Estructural, Visceral y Sacrocraneal', duracion: 55, precio: 40 },
  { nombre: 'Masaje Deportivo', duracion: 30, precio: 20 },
  { nombre: 'Masaje Corporal con Aceite (60 min)', duracion: 60, precio: 40 },
  { nombre: 'Masaje Corporal con Aceite (90 min)', duracion: 90, precio: 55 },
  { nombre: 'Masaje Tradicional Tailandés (60 min)', duracion: 60, precio: 45 },
  { nombre: 'Masaje Tradicional Tailandés (90 min)', duracion: 90, precio: 60 },
  { nombre: 'Masaje con Pindas Herbales Calientes', duracion: 90, precio: 70 },
  { nombre: 'Masaje para Embarazadas', duracion: 60, precio: 40 },
];
---

<AdminLayout title="Nueva cita" activeSection="citas">
  <a href="/admin/citas" class="back-link">← Volver a citas</a>

  {error && <div class="alert alert-error">{error}</div>}

  <div class="card">
    <form method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="paciente_id">Paciente *</label>
          <div style="display:flex;gap:8px;">
            <select id="paciente_id" name="paciente_id" required style="flex:1;">
              <option value="">Seleccionar paciente...</option>
              {pacientes.map((p) => (
                <option value={p.id} selected={String(p.id) === pacienteId}>
                  {p.apellidos}, {p.nombre}
                </option>
              ))}
            </select>
            <button type="button" id="btn-nuevo-paciente" class="btn btn-secondary btn-sm" style="white-space:nowrap;" title="Crear paciente nuevo">+ Nuevo</button>
          </div>
        </div>
        <div class="form-group">
          <label for="servicio">Servicio</label>
          <select id="servicio" name="servicio">
            <option value="">Seleccionar...</option>
            {servicios.map((s) => (
              <option value={s.nombre} selected={s.nombre === servicioParam} data-duracion={s.duracion} data-precio={s.precio}>
                {s.nombre} — {s.precio}€
              </option>
            ))}
            {servicioParam && !servicios.find(s => s.nombre === servicioParam) && (
              <option value={servicioParam} selected>{servicioParam}</option>
            )}
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="fecha">Fecha *</label>
          <input type="date" id="fecha" name="fecha" value={fechaParam} required>
        </div>
        <div class="form-group">
          <label for="hora">Hora *</label>
          <input type="time" id="hora" name="hora" value={horaParam} required>
        </div>
      </div>

      <div id="citas-dia-preview" style="display:none;margin-bottom:16px;padding:12px 16px;background:#e3f2fd;border-radius:8px;font-size:0.85rem;">
        <strong>Citas ese día:</strong>
        <div id="citas-dia-list" style="margin-top:6px;"></div>
      </div>
      <div id="conflicto-aviso" style="display:none;" class="alert alert-error">
        <strong>⚠ Posible solapamiento:</strong> <span id="conflicto-texto"></span>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="duracion">Duración (min)</label>
          <select id="duracion" name="duracion">
            <option value="30" selected={duracionParam === '30'}>30 min</option>
            <option value="45" selected={duracionParam === '45'}>45 min</option>
            <option value="55" selected={duracionParam === '55'}>55 min</option>
            <option value="60" selected={!duracionParam || duracionParam === '60'}>60 min</option>
            <option value="90" selected={duracionParam === '90'}>90 min</option>
            <option value="120" selected={duracionParam === '120'}>120 min</option>
          </select>
        </div>
        <div class="form-group">
          <label for="precio">Precio (€)</label>
          <input type="number" id="precio" name="precio" step="0.01" min="0" value={precioParam}>
        </div>
      </div>

      <div class="form-group">
        <label for="estado">Estado</label>
        <select id="estado" name="estado">
          <option value="pendiente">Pendiente</option>
          <option value="confirmada">Confirmada</option>
          <option value="completada">Completada</option>
          <option value="cancelada">Cancelada</option>
        </select>
      </div>

      <div class="form-group">
        <label for="notas">Notas</label>
        <textarea id="notas" name="notas" placeholder="Observaciones sobre la cita..."></textarea>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-primary">Crear cita</button>
        <a href="/admin/citas" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
<!-- Modal nuevo paciente rápido -->
<div id="modal-paciente" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:24px;width:90%;max-width:400px;box-shadow:0 8px 32px rgba(0,0,0,0.2);">
    <h3 style="margin-bottom:16px;font-size:1rem;">Nuevo paciente rápido</h3>
    <div class="form-group">
      <label for="np_nombre">Nombre *</label>
      <input type="text" id="np_nombre" required>
    </div>
    <div class="form-group">
      <label for="np_apellidos">Apellidos *</label>
      <input type="text" id="np_apellidos" required>
    </div>
    <div class="form-group">
      <label for="np_telefono">Telefono</label>
      <input type="tel" id="np_telefono" placeholder="612345678">
    </div>
    <div style="display:flex;gap:8px;margin-top:16px;">
      <button type="button" id="btn-guardar-paciente" class="btn btn-primary btn-sm">Guardar</button>
      <button type="button" id="btn-cerrar-modal" class="btn btn-secondary btn-sm">Cancelar</button>
    </div>
    <div id="modal-error" style="color:#c62828;font-size:0.85rem;margin-top:8px;display:none;"></div>
  </div>
</div>

<script>
  // Auto-fill servicio → duración + precio
  document.getElementById('servicio')?.addEventListener('change', (e) => {
    const select = e.target as HTMLSelectElement;
    const option = select.selectedOptions[0];
    if (option && option.dataset.duracion) {
      const durSelect = document.getElementById('duracion') as HTMLSelectElement;
      const precioInput = document.getElementById('precio') as HTMLInputElement;
      const dur = option.dataset.duracion;
      for (const opt of durSelect.options) {
        if (opt.value === dur) { durSelect.value = dur; break; }
      }
      precioInput.value = option.dataset.precio || '';
    }
  });

  // Double-booking check
  let citasDia: any[] = [];
  async function checkCitasDia() {
    const fecha = (document.getElementById('fecha') as HTMLInputElement).value;
    const preview = document.getElementById('citas-dia-preview')!;
    const list = document.getElementById('citas-dia-list')!;
    if (!fecha) { preview.style.display = 'none'; return; }
    try {
      const res = await fetch(`/api/citas-dia?fecha=${fecha}`);
      citasDia = await res.json();
      if (Array.isArray(citasDia) && citasDia.length > 0) {
        list.innerHTML = citasDia.map((c: any) =>
          `<div style="padding:2px 0;"><strong>${c.hora}</strong> (${c.duracion}min) — ${c.paciente_nombre} ${c.paciente_apellidos} · ${c.servicio || 'Sin servicio'}</div>`
        ).join('');
        preview.style.display = 'block';
      } else {
        preview.style.display = 'none';
        citasDia = [];
      }
    } catch { preview.style.display = 'none'; }
    checkConflicto();
  }

  function checkConflicto() {
    const hora = (document.getElementById('hora') as HTMLInputElement).value;
    const duracion = Number((document.getElementById('duracion') as HTMLSelectElement).value) || 60;
    const aviso = document.getElementById('conflicto-aviso')!;
    const texto = document.getElementById('conflicto-texto')!;
    if (!hora || !Array.isArray(citasDia) || citasDia.length === 0) { aviso.style.display = 'none'; return; }

    const [h, m] = hora.split(':').map(Number);
    const newStart = h * 60 + m;
    const newEnd = newStart + duracion;

    const conflictos = citasDia.filter((c: any) => {
      const [ch, cm] = c.hora.split(':').map(Number);
      const cStart = ch * 60 + cm;
      const cEnd = cStart + (c.duracion || 60);
      return newStart < cEnd && newEnd > cStart;
    });

    if (conflictos.length > 0) {
      texto.textContent = `Se solapa con: ${conflictos.map((c: any) => `${c.hora} (${c.paciente_nombre})`).join(', ')}`;
      aviso.style.display = 'block';
    } else {
      aviso.style.display = 'none';
    }
  }

  document.getElementById('fecha')?.addEventListener('change', checkCitasDia);
  document.getElementById('hora')?.addEventListener('change', checkConflicto);
  document.getElementById('duracion')?.addEventListener('change', checkConflicto);
  // Initial check if fecha is pre-filled
  if ((document.getElementById('fecha') as HTMLInputElement).value) checkCitasDia();

  // Modal nuevo paciente
  const modal = document.getElementById('modal-paciente')!;
  document.getElementById('btn-nuevo-paciente')?.addEventListener('click', () => {
    modal.style.display = 'flex';
    (document.getElementById('np_nombre') as HTMLInputElement).focus();
  });
  document.getElementById('btn-cerrar-modal')?.addEventListener('click', () => {
    modal.style.display = 'none';
  });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });

  document.getElementById('btn-guardar-paciente')?.addEventListener('click', async () => {
    const nombre = (document.getElementById('np_nombre') as HTMLInputElement).value.trim();
    const apellidos = (document.getElementById('np_apellidos') as HTMLInputElement).value.trim();
    const telefono = (document.getElementById('np_telefono') as HTMLInputElement).value.trim();
    const errorDiv = document.getElementById('modal-error')!;

    if (!nombre || !apellidos) {
      errorDiv.textContent = 'Nombre y apellidos son obligatorios';
      errorDiv.style.display = 'block';
      return;
    }

    errorDiv.style.display = 'none';
    const btn = document.getElementById('btn-guardar-paciente') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    try {
      const res = await fetch('/api/paciente-rapido', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, apellidos, telefono }),
      });
      const data = await res.json();
      if (data.ok) {
        const select = document.getElementById('paciente_id') as HTMLSelectElement;
        const opt = document.createElement('option');
        opt.value = String(data.id);
        opt.textContent = `${data.apellidos}, ${data.nombre}`;
        opt.selected = true;
        select.appendChild(opt);
        modal.style.display = 'none';
        // Reset form
        (document.getElementById('np_nombre') as HTMLInputElement).value = '';
        (document.getElementById('np_apellidos') as HTMLInputElement).value = '';
        (document.getElementById('np_telefono') as HTMLInputElement).value = '';
      } else {
        errorDiv.textContent = data.error || 'Error al crear paciente';
        errorDiv.style.display = 'block';
      }
    } catch (e) {
      errorDiv.textContent = 'Error de conexión';
      errorDiv.style.display = 'block';
    }
    btn.disabled = false;
    btn.textContent = 'Guardar';
  });
</script>
</AdminLayout>
