---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getCita, actualizarCita, eliminarCita, getPacientes } from '../../../lib/db';

const id = Number(Astro.params.id);
let mensaje = '';
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'eliminar') {
    await eliminarCita(Astro, id);
    return Astro.redirect('/admin/citas');
  }

  const paciente_id = Number(form.get('paciente_id'));
  const fecha = form.get('fecha') as string;
  const hora = form.get('hora') as string;

  if (!paciente_id || !fecha || !hora) {
    error = 'Paciente, fecha y hora son obligatorios';
  } else {
    await actualizarCita(Astro, id, {
      paciente_id,
      fecha,
      hora,
      duracion: Number(form.get('duracion')) || 60,
      servicio: form.get('servicio') as string,
      estado: form.get('estado') as string || 'pendiente',
      notas: form.get('notas') as string,
      precio: form.get('precio') ? Number(form.get('precio')) : null,
    });
    mensaje = 'Cita actualizada correctamente';
  }
}

const cita = await getCita(Astro, id);
if (!cita) {
  return Astro.redirect('/admin/citas');
}

const pacientes = await getPacientes(Astro);

const servicios = [
  { nombre: 'Osteopatía Estructural, Visceral y Sacrocraneal', duracion: 55, precio: 40 },
  { nombre: 'Masaje Deportivo', duracion: 30, precio: 20 },
  { nombre: 'Masaje Corporal con Aceite (60 min)', duracion: 60, precio: 40 },
  { nombre: 'Masaje Corporal con Aceite (90 min)', duracion: 90, precio: 55 },
  { nombre: 'Masaje Tradicional Tailandés (60 min)', duracion: 60, precio: 45 },
  { nombre: 'Masaje Tradicional Tailandés (90 min)', duracion: 90, precio: 60 },
  { nombre: 'Masaje con Pindas Herbales Calientes', duracion: 90, precio: 70 },
  { nombre: 'Masaje para Embarazadas', duracion: 60, precio: 40 },
];

// WhatsApp reminder
const telefonoLimpio = cita.paciente_telefono ? cita.paciente_telefono.replace(/\D/g, '') : '';
const fechaFormateada = cita.fecha ? new Date(cita.fecha + 'T00:00:00').toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' }) : '';
const mensajeWhatsApp = `Hola ${cita.paciente_nombre}, te recordamos tu cita de ${cita.servicio || 'osteopatía'} el ${fechaFormateada} a las ${cita.hora} en Katy Caballero Osteopatía. ¡Te esperamos! 😊`;
const whatsappUrl = telefonoLimpio ? `https://wa.me/34${telefonoLimpio}?text=${encodeURIComponent(mensajeWhatsApp)}` : '';
---

<AdminLayout title={`Cita #${id}`} activeSection="citas">
  <a href="/admin/citas" class="back-link">← Volver a citas</a>

  {mensaje && <div class="alert alert-success">{mensaje}</div>}
  {error && <div class="alert alert-error">{error}</div>}

  {(cita as any).paciente_alergias && (
    <div class="alert alert-error" style="display:flex;align-items:center;gap:8px;">
      <strong>⚠ Alergias / Contraindicaciones:</strong> {(cita as any).paciente_alergias}
    </div>
  )}
  {(cita as any).paciente_antecedentes && (
    <div class="alert" style="background:#fff3e0;border-color:#ff9800;display:flex;align-items:center;gap:8px;">
      <strong>Antecedentes:</strong> {(cita as any).paciente_antecedentes}
    </div>
  )}

  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
    <a href={`/admin/pacientes/${cita.paciente_id}`} class="btn btn-secondary btn-sm">Ver paciente: {cita.paciente_nombre} {cita.paciente_apellidos}</a>
    <a href={`/admin/tratamientos/nuevo?paciente=${cita.paciente_id}&cita=${id}`} class="btn btn-primary btn-sm">+ Registrar tratamiento</a>
    <a href={`/admin/factura/${id}`} target="_blank" class="btn btn-secondary btn-sm">Factura</a>
    <a href={`/admin/citas/nueva?paciente=${cita.paciente_id}&servicio=${encodeURIComponent(cita.servicio || '')}&duracion=${cita.duracion || 60}&precio=${cita.precio || ''}`} class="btn btn-secondary btn-sm">Duplicar cita</a>
    {whatsappUrl && (
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-whatsapp">📱 Recordatorio WhatsApp</a>
    )}
    <a href={`/api/admin/cita-ics?id=${id}`} class="btn btn-secondary btn-sm btn-calendar" download>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="vertical-align:middle;margin-right:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      Anadir a calendario
    </a>
  </div>

  <div class="card" style="margin-bottom:24px;">
    <form method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="paciente_id">Paciente *</label>
          <select id="paciente_id" name="paciente_id" required>
            {pacientes.map((p) => (
              <option value={p.id} selected={p.id === cita.paciente_id}>
                {p.apellidos}, {p.nombre}
              </option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="servicio">Servicio</label>
          <select id="servicio" name="servicio">
            <option value="">Seleccionar...</option>
            {servicios.map((s) => (
              <option value={s.nombre} selected={s.nombre === cita.servicio} data-duracion={s.duracion} data-precio={s.precio}>
                {s.nombre} — {s.precio}€
              </option>
            ))}
            {cita.servicio && !servicios.find(s => s.nombre === cita.servicio) && (
              <option value={cita.servicio} selected>{cita.servicio}</option>
            )}
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="fecha">Fecha *</label>
          <input type="date" id="fecha" name="fecha" value={cita.fecha} required>
        </div>
        <div class="form-group">
          <label for="hora">Hora *</label>
          <input type="time" id="hora" name="hora" value={cita.hora} required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="duracion">Duración (min)</label>
          <select id="duracion" name="duracion">
            <option value="30" selected={cita.duracion === 30}>30 min</option>
            <option value="45" selected={cita.duracion === 45}>45 min</option>
            <option value="55" selected={cita.duracion === 55}>55 min</option>
            <option value="60" selected={cita.duracion === 60}>60 min</option>
            <option value="90" selected={cita.duracion === 90}>90 min</option>
            <option value="120" selected={cita.duracion === 120}>120 min</option>
          </select>
        </div>
        <div class="form-group">
          <label for="precio">Precio (€)</label>
          <input type="number" id="precio" name="precio" step="0.01" min="0" value={cita.precio || ''}>
        </div>
      </div>

      <div class="form-group">
        <label for="estado">Estado</label>
        <select id="estado" name="estado">
          <option value="pendiente" selected={cita.estado === 'pendiente'}>Pendiente</option>
          <option value="confirmada" selected={cita.estado === 'confirmada'}>Confirmada</option>
          <option value="completada" selected={cita.estado === 'completada'}>Completada</option>
          <option value="cancelada" selected={cita.estado === 'cancelada'}>Cancelada</option>
          <option value="no_show" selected={cita.estado === 'no_show'}>No acudio</option>
        </select>
      </div>

      <div class="form-group">
        <label for="notas">Notas</label>
        <textarea id="notas" name="notas">{cita.notas || ''}</textarea>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        {cita.estado !== 'completada' && cita.estado !== 'cancelada' && cita.estado !== 'no_show' && (
          <button type="button" class="btn btn-no-show btn-sm" id="btn-no-show">No acudio</button>
        )}
      </div>
    </form>

    <form method="POST" style="margin-top:24px;padding-top:16px;border-top:1px solid #eee;" onsubmit="return confirm('¿Eliminar esta cita?')">
      <input type="hidden" name="_action" value="eliminar">
      <button type="submit" class="btn btn-danger btn-sm">Eliminar cita</button>
    </form>
  </div>

  {/* No-show notice */}
  {cita.estado === 'no_show' && (
    <div class="card" style="background:#fff3e0;border-color:#ff9800;">
      <h3 style="font-size:0.95rem;font-weight:600;margin-bottom:12px;color:#e65100;">El paciente no acudio a esta cita</h3>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href={`/admin/citas/nueva?paciente=${cita.paciente_id}&servicio=${encodeURIComponent(cita.servicio || '')}&duracion=${cita.duracion || 60}&precio=${cita.precio || ''}`} class="btn btn-primary btn-sm">Reprogramar cita</a>
        {whatsappUrl && (
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-whatsapp">Contactar por WhatsApp</a>
        )}
      </div>
    </div>
  )}

  {/* Suggest next appointment when completed */}
  {cita.estado === 'completada' && (
    <div class="card" style="background:#e8f5e9;border-color:#4caf50;">
      <h3 style="font-size:0.95rem;font-weight:600;margin-bottom:12px;color:#2e7d32;">Cita completada — ¿Programar siguiente?</h3>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        {[3, 7, 14, 21, 30].map(dias => {
          const nextDate = new Date(cita.fecha + 'T00:00:00');
          nextDate.setDate(nextDate.getDate() + dias);
          const nextStr = nextDate.toISOString().split('T')[0];
          const label = dias < 7 ? `${dias} días` : dias === 7 ? '1 semana' : dias === 14 ? '2 semanas' : dias === 21 ? '3 semanas' : '1 mes';
          return (
            <a href={`/admin/citas/nueva?paciente=${cita.paciente_id}&fecha=${nextStr}`} class="btn btn-primary btn-sm">
              + En {label} ({nextDate.getDate()}/{nextDate.getMonth() + 1})
            </a>
          );
        })}
      </div>
      <div style="margin-top:12px;">
        <a href={`/admin/tratamientos/nuevo?paciente=${cita.paciente_id}&cita=${id}`} class="btn btn-secondary btn-sm">Registrar tratamiento de esta cita</a>
      </div>
    </div>
  )}
</AdminLayout>

<script>
  document.getElementById('btn-no-show')?.addEventListener('click', async () => {
    if (!confirm('Marcar esta cita como "No acudio"?')) return;
    const btn = document.getElementById('btn-no-show') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      const res = await fetch('/api/cita-estado', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: Number(window.location.pathname.split('/').pop()), estado: 'no_show' }),
      });
      if (res.ok) window.location.reload();
    } catch { /* ignore */ }
    btn.disabled = false;
    btn.textContent = 'No acudio';
  });

  document.getElementById('servicio')?.addEventListener('change', (e) => {
    const select = e.target as HTMLSelectElement;
    const option = select.selectedOptions[0];
    if (option && option.dataset.duracion) {
      const durSelect = document.getElementById('duracion') as HTMLSelectElement;
      const precioInput = document.getElementById('precio') as HTMLInputElement;
      const dur = option.dataset.duracion;
      for (const opt of durSelect.options) {
        if (opt.value === dur) { durSelect.value = dur; break; }
      }
      precioInput.value = option.dataset.precio || '';
    }
  });
</script>

<style is:global>
  .btn-whatsapp {
    background: #25D366 !important;
    color: #fff !important;
    border: none;
    text-decoration: none;
  }
  .btn-whatsapp:hover {
    background: #1da851 !important;
    color: #fff !important;
  }
  .btn-calendar {
    display: inline-flex;
    align-items: center;
  }
  .btn-calendar svg {
    width: 16px !important;
    height: 16px !important;
    max-width: 16px;
    max-height: 16px;
  }
  .btn-no-show {
    background: #ff9800 !important;
    color: #fff !important;
    border: none;
  }
  .btn-no-show:hover {
    background: #e68900 !important;
    color: #fff !important;
  }
</style>
