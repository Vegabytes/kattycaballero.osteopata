---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const fechaParam = Astro.url.searchParams.get('fecha') || new Date().toISOString().split('T')[0];
const db = (Astro.locals as any).runtime.env.DB;

let citas: any[] = [];
try {
  citas = (await db
    .prepare(`SELECT c.*, p.nombre, p.apellidos, p.telefono
      FROM citas c LEFT JOIN pacientes p ON c.paciente_id = p.id
      WHERE c.fecha = ? ORDER BY c.hora ASC`)
    .bind(fechaParam)
    .all()).results;
} catch { /* ok */ }

const fechaObj = new Date(fechaParam + 'T00:00:00');
const diasSemana = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
const meses = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
const tituloFecha = `${diasSemana[fechaObj.getDay()]} ${fechaObj.getDate()} de ${meses[fechaObj.getMonth()]} de ${fechaObj.getFullYear()}`;

// Navigation
const ayer = new Date(fechaObj); ayer.setDate(ayer.getDate() - 1);
const manana = new Date(fechaObj); manana.setDate(manana.getDate() + 1);

// Summary
const totalCitas = citas.length;
const confirmadas = citas.filter(c => c.estado === 'confirmada').length;
const pendientes = citas.filter(c => c.estado === 'pendiente').length;
const completadas = citas.filter(c => c.estado === 'completada').length;
const canceladas = citas.filter(c => c.estado === 'cancelada').length;
---

<AdminLayout title={`Agenda — ${tituloFecha}`} activeSection="citas">
  <div class="page-header no-print">
    <h2>Agenda del dia</h2>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <a href={`/admin/agenda?fecha=${ayer.toISOString().split('T')[0]}`} class="btn btn-secondary btn-sm">&larr; Dia anterior</a>
      <a href="/admin/agenda" class="btn btn-secondary btn-sm">Hoy</a>
      <a href={`/admin/agenda?fecha=${manana.toISOString().split('T')[0]}`} class="btn btn-secondary btn-sm">Dia siguiente &rarr;</a>
      <button onclick="window.print()" class="btn btn-primary btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z" /></svg>
        Imprimir
      </button>
    </div>
  </div>

  <!-- Print header (only visible when printing) -->
  <div class="print-header">
    <h1>Katy Caballero - Osteopata</h1>
    <h2>Agenda del dia: {tituloFecha}</h2>
  </div>

  {citas.length === 0 ? (
    <div class="card">
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
        <p>No hay citas programadas para este dia.</p>
        <a href={`/admin/citas/nueva?fecha=${fechaParam}`} class="btn btn-primary no-print">+ Nueva cita</a>
      </div>
    </div>
  ) : (
    <div class="card agenda-card">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Hora</th>
              <th>Paciente</th>
              <th>Telefono</th>
              <th>Servicio</th>
              <th>Duracion</th>
              <th>Estado</th>
              <th>Notas</th>
            </tr>
          </thead>
          <tbody>
            {citas.map(cita => (
              <tr>
                <td class="col-hora">{(cita.hora || '').substring(0, 5)}</td>
                <td class="col-paciente">
                  <strong>{cita.nombre || ''} {cita.apellidos || ''}</strong>
                </td>
                <td class="col-telefono">{cita.telefono || '-'}</td>
                <td>{cita.servicio || '-'}</td>
                <td>{cita.duracion || 60} min</td>
                <td>
                  <span class={`badge badge-${cita.estado}`}>{cita.estado || 'pendiente'}</span>
                </td>
                <td class="col-notas">{cita.notas || ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- Summary -->
  <div class="agenda-summary">
    <div class="summary-item">
      <span class="summary-label">Total citas:</span>
      <span class="summary-value">{totalCitas}</span>
    </div>
    {confirmadas > 0 && (
      <div class="summary-item">
        <span class="summary-label">Confirmadas:</span>
        <span class="summary-value" style="color: var(--admin-info);">{confirmadas}</span>
      </div>
    )}
    {pendientes > 0 && (
      <div class="summary-item">
        <span class="summary-label">Pendientes:</span>
        <span class="summary-value" style="color: var(--admin-warning);">{pendientes}</span>
      </div>
    )}
    {completadas > 0 && (
      <div class="summary-item">
        <span class="summary-label">Completadas:</span>
        <span class="summary-value" style="color: var(--admin-success);">{completadas}</span>
      </div>
    )}
    {canceladas > 0 && (
      <div class="summary-item">
        <span class="summary-label">Canceladas:</span>
        <span class="summary-value" style="color: var(--admin-danger);">{canceladas}</span>
      </div>
    )}
  </div>

  <style>
    /* Screen styles */
    .print-header {
      display: none;
    }

    .agenda-card {
      margin-bottom: 24px;
    }

    .col-hora {
      font-weight: 600;
      font-size: 0.95rem;
      white-space: nowrap;
    }

    .col-paciente strong {
      color: var(--admin-text);
    }

    .col-telefono {
      white-space: nowrap;
      font-size: 0.85rem;
      color: var(--admin-text-light);
    }

    .col-notas {
      font-size: 0.8rem;
      color: var(--admin-text-light);
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .agenda-summary {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      padding: 16px 20px;
      background: var(--admin-card);
      border-radius: 12px;
      border: 1px solid var(--admin-border);
      margin-top: 16px;
    }

    .summary-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .summary-label {
      font-size: 0.85rem;
      color: var(--admin-text-light);
    }

    .summary-value {
      font-size: 1rem;
      font-weight: 700;
      color: var(--admin-text);
    }

    /* Print styles */
    @media print {
      /* Hide admin chrome */
      :global(.admin-sidebar),
      :global(.sidebar-overlay),
      :global(.admin-topbar),
      .no-print,
      .page-header {
        display: none !important;
      }

      :global(.admin-main) {
        margin-left: 0 !important;
      }

      :global(.admin-content) {
        padding: 0 !important;
      }

      :global(body) {
        background: white;
        font-family: 'Inter', Arial, sans-serif;
        color: #000;
      }

      .print-header {
        display: block;
        text-align: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 2px solid #000;
      }

      .print-header h1 {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .print-header h2 {
        font-size: 1rem;
        font-weight: 500;
        color: #333;
      }

      .agenda-card,
      .card {
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
      }

      th {
        background: #f0f0f0 !important;
        color: #000 !important;
        border-bottom: 2px solid #000;
        padding: 8px 10px;
        font-size: 0.75rem;
      }

      td {
        border-bottom: 1px solid #ccc;
        padding: 8px 10px;
        color: #000;
      }

      tr:hover td {
        background: transparent;
      }

      .badge {
        border: 1px solid #999;
        background: transparent !important;
        color: #000 !important;
        font-size: 0.7rem;
      }

      .col-notas {
        max-width: none;
        white-space: normal;
        color: #000;
      }

      .col-telefono {
        color: #000;
      }

      .agenda-summary {
        border: 1px solid #ccc;
        margin-top: 16px;
        padding: 12px 16px;
        border-radius: 0;
        page-break-inside: avoid;
      }

      .summary-label {
        color: #333;
      }

      .summary-value {
        color: #000 !important;
      }

      .empty-state .btn {
        display: none;
      }
    }
  </style>
</AdminLayout>
