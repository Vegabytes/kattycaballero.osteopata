---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getEstadisticas, getCitas } from '../../lib/db';

let stats = { totalPacientes: 0, citasHoy: 0, citasSemana: 0, citasPendientes: 0 };
let citasHoy: any[] = [];
let agendaHoy: any[] = [];
let dbError = '';

const hoy = new Date().toISOString().split('T')[0];
const hoyDisplay = new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
const mesActual = new Date().toISOString().slice(0, 7); // YYYY-MM

let pacientesNuevosMes = 0;
let ingresosMes = 0;
let bonosActivos = 0;
let ingresosHoy = 0;
let citasMes = 0;
let citasCompletadasMes = 0;
let pacientesNuevosMesAnterior = 0;
let ingresosMesAnterior = 0;
let citasMesAnterior = 0;

const mesAnterior = new Date();
mesAnterior.setMonth(mesAnterior.getMonth() - 1);
const mesAnteriorStr = mesAnterior.toISOString().slice(0, 7);

try {
  stats = await getEstadisticas(Astro);
  citasHoy = await getCitas(Astro, hoy);
  ingresosHoy = citasHoy
    .filter((c: any) => c.estado === 'completada' && c.precio)
    .reduce((sum: number, c: any) => sum + (c.precio || 0), 0);
} catch (e: any) {
  dbError = `Error conectando a la base de datos: ${e.message}`;
  console.error('DB error in admin/index:', e);
}

// Agenda del día - query with phone number for WhatsApp links
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const agendaResult = await db.prepare(
    `SELECT citas.*, pacientes.nombre, pacientes.apellidos, pacientes.telefono
     FROM citas
     LEFT JOIN pacientes ON citas.paciente_id = pacientes.id
     WHERE citas.fecha = ?
     ORDER BY citas.hora ASC`
  ).bind(hoy).all();
  agendaHoy = (agendaResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching agenda:', e);
}

// New stats queries - wrapped in own try-catch so they don't break the page
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const pnResult = await db.prepare("SELECT COUNT(*) as total FROM pacientes WHERE created_at LIKE ?").bind(mesActual + '%').first();
  pacientesNuevosMes = (pnResult as any)?.total || 0;

  const ingResult = await db.prepare("SELECT COALESCE(SUM(precio), 0) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?").bind(mesActual + '%').first();
  ingresosMes = (ingResult as any)?.total || 0;

  const cmResult = await db.prepare("SELECT COUNT(*) as total FROM citas WHERE fecha LIKE ?").bind(mesActual + '%').first();
  citasMes = (cmResult as any)?.total || 0;

  const ccResult = await db.prepare("SELECT COUNT(*) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?").bind(mesActual + '%').first();
  citasCompletadasMes = (ccResult as any)?.total || 0;

  // Mes anterior para comparativa
  const pnAntResult = await db.prepare("SELECT COUNT(*) as total FROM pacientes WHERE created_at LIKE ?").bind(mesAnteriorStr + '%').first();
  pacientesNuevosMesAnterior = (pnAntResult as any)?.total || 0;

  const ingAntResult = await db.prepare("SELECT COALESCE(SUM(precio), 0) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?").bind(mesAnteriorStr + '%').first();
  ingresosMesAnterior = (ingAntResult as any)?.total || 0;

  const cmAntResult = await db.prepare("SELECT COUNT(*) as total FROM citas WHERE fecha LIKE ?").bind(mesAnteriorStr + '%').first();
  citasMesAnterior = (cmAntResult as any)?.total || 0;
} catch (e: any) {
  console.error('DB error fetching new stats:', e);
}

try {
  const db = (Astro.locals as any).runtime.env.DB;
  const bonosResult = await db.prepare("SELECT COUNT(*) as total FROM bonos WHERE estado = 'activo'").bind().first();
  bonosActivos = (bonosResult as any)?.total || 0;
} catch (e: any) {
  console.error('DB error fetching bonos:', e);
}

// Alertas / acciones pendientes
let alertas: { tipo: string; texto: string; link: string }[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;

  // Citas pendientes sin confirmar (próximos 3 días)
  const en3dias = new Date(); en3dias.setDate(en3dias.getDate() + 3);
  const pendientes = await db.prepare(
    `SELECT COUNT(*) as total FROM citas WHERE estado = 'pendiente' AND fecha BETWEEN ? AND ?`
  ).bind(hoy, en3dias.toISOString().split('T')[0]).first();
  if ((pendientes as any)?.total > 0) {
    alertas.push({ tipo: 'warning', texto: `${(pendientes as any).total} cita(s) sin confirmar en los próximos 3 días`, link: '/admin/citas' });
  }

  // Pacientes inactivos (>90 días sin visita completada)
  const inactivos = await db.prepare(
    `SELECT COUNT(DISTINCT p.id) as total FROM pacientes p
     LEFT JOIN citas c ON c.paciente_id = p.id AND c.estado = 'completada'
     GROUP BY p.id
     HAVING MAX(c.fecha) < ? OR MAX(c.fecha) IS NULL`
  ).bind(new Date(Date.now() - 90 * 86400000).toISOString().split('T')[0]).all();
  const numInactivos = inactivos?.results?.length || 0;
  if (numInactivos > 0) {
    alertas.push({ tipo: 'info', texto: `${numInactivos} paciente(s) sin visita en +90 días`, link: '/admin/pacientes?orden=visita' });
  }

  // Bonos próximos a expirar (30 días)
  const en30dias = new Date(); en30dias.setDate(en30dias.getDate() + 30);
  const bonosExp = await db.prepare(
    `SELECT COUNT(*) as total FROM bonos WHERE estado = 'activo' AND fecha_expiracion IS NOT NULL AND fecha_expiracion <= ?`
  ).bind(en30dias.toISOString().split('T')[0]).first();
  if ((bonosExp as any)?.total > 0) {
    alertas.push({ tipo: 'warning', texto: `${(bonosExp as any).total} bono(s) expiran en los próximos 30 días`, link: '/admin/bonos' });
  }
} catch { /* alertas are non-critical */ }

// Reservas web recientes (pendientes, últimos 7 días)
let reservasWeb: any[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const hace7dias = new Date();
  hace7dias.setDate(hace7dias.getDate() - 7);
  const rwResult = await db.prepare(
    `SELECT citas.*, pacientes.nombre, pacientes.apellidos, pacientes.telefono,
            citas.created_at as fecha_reserva
     FROM citas
     LEFT JOIN pacientes ON citas.paciente_id = pacientes.id
     WHERE citas.estado = 'pendiente'
     ORDER BY citas.created_at DESC
     LIMIT 15`
  ).all();
  reservasWeb = (rwResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching reservas web:', e);
}

// Pacientes inactivos (+90 días sin cita)
let pacientesInactivos: any[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const inactivosResult = await db.prepare(
    `SELECT p.id, p.nombre, p.apellidos, p.telefono, MAX(c.fecha) as ultima_cita FROM pacientes p LEFT JOIN citas c ON p.id = c.paciente_id GROUP BY p.id HAVING ultima_cita < date('now', '-90 days') OR ultima_cita IS NULL ORDER BY ultima_cita ASC LIMIT 5`
  ).all();
  pacientesInactivos = (inactivosResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching pacientes inactivos:', e);
}

// Monthly revenue for bar chart
const year = new Date().getFullYear();
let ingresosAnuales: { mes: string; total: number }[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const revResult = await db.prepare(
    `SELECT strftime('%Y-%m', fecha) as mes, SUM(precio) as total FROM citas WHERE estado='completada' AND fecha LIKE ? GROUP BY mes ORDER BY mes`
  ).bind(year + '%').all();
  ingresosAnuales = (revResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching monthly revenue:', e);
}

// Build 12-month data array
const mesesLabels = ['E', 'F', 'M', 'A', 'M', 'J', 'J', 'A', 'S', 'O', 'N', 'D'];
const mesesCompletos = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const ingresosPorMes: number[] = Array(12).fill(0);
for (const row of ingresosAnuales) {
  const monthIndex = parseInt(row.mes.split('-')[1], 10) - 1;
  ingresosPorMes[monthIndex] = row.total || 0;
}
const maxIngreso = Math.max(...ingresosPorMes, 1);
const totalAnual = ingresosPorMes.reduce((a, b) => a + b, 0);

// All patients for quick note form
let todosLosPacientes: any[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const pacResult = await db.prepare("SELECT id, nombre, apellidos FROM pacientes ORDER BY nombre ASC, apellidos ASC").all();
  todosLosPacientes = (pacResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching pacientes for nota:', e);
}

// Handle quick note POST
let notaSuccess = '';
let notaError = '';
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const pacienteId = formData.get('paciente_id');
    const nota = formData.get('nota');

    if (!pacienteId || !nota) {
      notaError = 'Selecciona un paciente y escribe una nota.';
    } else {
      const db = (Astro.locals as any).runtime.env.DB;
      const fechaHoy = new Date().toISOString().split('T')[0];
      await db.prepare(
        "INSERT INTO notas_clinicas (paciente_id, fecha, motivo, diagnostico, tratamiento_realizado) VALUES (?, ?, ?, NULL, NULL)"
      ).bind(Number(pacienteId), fechaHoy, nota.toString()).run();
      notaSuccess = 'Nota guardada correctamente.';
    }
  } catch (e: any) {
    notaError = `Error al guardar la nota: ${e.message}`;
    console.error('DB error saving nota rapida:', e);
  }
}

// Occupancy rate this week (L-V: 8 slots/day, S: 4 = 44 total)
let citasSemanaOcupacion = 0;
const slotsSemanales = 44;
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const occResult = await db.prepare(
    `SELECT COUNT(*) as total FROM citas WHERE fecha >= date('now', 'weekday 1', '-7 days') AND fecha <= date('now', 'weekday 0') AND estado != 'cancelada'`
  ).first();
  citasSemanaOcupacion = (occResult as any)?.total || 0;
} catch (e: any) {
  console.error('DB error fetching occupancy:', e);
}
const ocupacionPct = slotsSemanales > 0 ? Math.min(Math.round((citasSemanaOcupacion / slotsSemanales) * 100), 100) : 0;

// Próximas citas (próximos 7 días, excluyendo hoy)
let proximasCitas: any[] = [];
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const manana = new Date();
  manana.setDate(manana.getDate() + 1);
  const en7dias = new Date();
  en7dias.setDate(en7dias.getDate() + 7);
  const mananaStr = manana.toISOString().split('T')[0];
  const en7diasStr = en7dias.toISOString().split('T')[0];
  const proxResult = await db.prepare(
    `SELECT citas.*, pacientes.nombre, pacientes.apellidos, pacientes.telefono
     FROM citas
     LEFT JOIN pacientes ON citas.paciente_id = pacientes.id
     WHERE citas.fecha BETWEEN ? AND ? AND citas.estado != 'cancelada'
     ORDER BY citas.fecha ASC, citas.hora ASC
     LIMIT 10`
  ).bind(mananaStr, en7diasStr).all();
  proximasCitas = (proxResult as any)?.results || [];
} catch (e: any) {
  console.error('DB error fetching proximas citas:', e);
}
---

<AdminLayout title="Dashboard" activeSection="dashboard">
  {dbError && (
    <div class="alert alert-error">
      <strong>Error de base de datos:</strong> {dbError}
      <br><small>Verifica que D1 esté correctamente vinculado en Cloudflare Pages → Settings → Functions → D1 database bindings.</small>
    </div>
  )}
  {alertas.length > 0 && (
    <div class="dashboard-alerts" style="margin-bottom:20px;display:flex;flex-direction:column;gap:8px;">
      {alertas.map(a => (
        <a href={a.link} style={`display:flex;align-items:center;gap:10px;padding:10px 16px;border-radius:8px;text-decoration:none;font-size:0.85rem;font-weight:500;${a.tipo === 'warning' ? 'background:#fff3e0;color:#e65100;border:1px solid #ffcc80;' : 'background:#e3f2fd;color:#1565c0;border:1px solid #90caf9;'}`}>
          <span>{a.tipo === 'warning' ? '⚠' : 'ℹ'}</span>
          <span>{a.texto}</span>
          <span style="margin-left:auto;opacity:0.6;">→</span>
        </a>
      ))}
    </div>
  )}

  {reservasWeb.length > 0 && (
    <div class="card reservas-web-card">
      <div class="page-header">
        <h2>
          <span class="reservas-web-badge">{reservasWeb.length}</span>
          Reservas pendientes
        </h2>
      </div>
      <div class="reservas-web-list">
        {reservasWeb.map((r: any) => {
          const fechaDisplay = new Date(r.fecha + 'T00:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' });
          const tiempoDesde = r.fecha_reserva ? (() => {
            const diff = Date.now() - new Date(r.fecha_reserva).getTime();
            const horas = Math.floor(diff / 3600000);
            if (horas < 1) return 'hace menos de 1h';
            if (horas < 24) return `hace ${horas}h`;
            return `hace ${Math.floor(horas / 24)}d`;
          })() : '';
          return (
            <div class="reserva-web-item">
              <div class="reserva-web-info">
                <div class="reserva-web-nombre">
                  <strong>{r.nombre} {r.apellidos}</strong>
                  {tiempoDesde && <span class="reserva-web-tiempo">{tiempoDesde}</span>}
                </div>
                <div class="reserva-web-detalle">
                  <span>{fechaDisplay} a las <strong>{r.hora}</strong></span>
                  {r.servicio && <span class="reserva-web-servicio">{r.servicio}</span>}
                </div>
              </div>
              <div class="reserva-web-acciones">
                <button class="btn btn-success btn-sm btn-quick-estado" data-id={r.id} data-estado="confirmada">Confirmar</button>
                <a href={`/admin/citas/${r.id}`} class="btn btn-secondary btn-sm">Ver</a>
                {r.telefono && (
                  <a
                    href={`https://wa.me/${r.telefono.replace(/\s+/g, '').replace(/^(\d)/, '34$1')}?text=${encodeURIComponent(`Hola ${r.nombre}, te confirmo tu cita el ${fechaDisplay} a las ${r.hora}. ¡Nos vemos! 😊`)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-whatsapp btn-sm"
                    title="Confirmar por WhatsApp"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.totalPacientes}</h3>
        <p>Pacientes totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasHoy}</h3>
        <p>Citas hoy</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasSemana}</h3>
        <p>Citas esta semana</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasPendientes}</h3>
        <p>Pendientes confirmar</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{pacientesNuevosMes}</h3>
        <p>Nuevos este mes</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{ingresosMes.toFixed(0)}&euro;</h3>
        <p>Ingresos del mes</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{bonosActivos}</h3>
        <p>Bonos activos</p>
      </div>
    </div>

    {ingresosHoy > 0 && (
      <div class="stat-card" style="border-left:3px solid #4caf50;">
        <div class="stat-icon green">
