  <!-- Ingresos mensuales bar chart -->
  <div class="card" style="margin-top:20px;">
    <div class="page-header">
      <h2>Ingresos mensuales {year}</h2>
      <span style="font-size:0.85rem;color:var(--admin-text-light);">Total: {totalAnual.toFixed(0)}&euro;</span>
    </div>
    <div class="chart-container">
      <svg viewBox="0 0 600 220" class="revenue-chart" xmlns="http://www.w3.org/2000/svg">
        {/* Grid lines */}
        <line x1="40" y1="10" x2="40" y2="180" stroke="#e0e0e0" stroke-width="1" />
        <line x1="40" y1="180" x2="580" y2="180" stroke="#e0e0e0" stroke-width="1" />
        <line x1="40" y1="137.5" x2="580" y2="137.5" stroke="#f0f0f0" stroke-width="0.5" stroke-dasharray="4,4" />
        <line x1="40" y1="95" x2="580" y2="95" stroke="#f0f0f0" stroke-width="0.5" stroke-dasharray="4,4" />
        <line x1="40" y1="52.5" x2="580" y2="52.5" stroke="#f0f0f0" stroke-width="0.5" stroke-dasharray="4,4" />
        <line x1="40" y1="10" x2="580" y2="10" stroke="#f0f0f0" stroke-width="0.5" stroke-dasharray="4,4" />
        {/* Y-axis labels */}
        <text x="36" y="184" text-anchor="end" fill="#999" font-size="10">0</text>
        <text x="36" y="141" text-anchor="end" fill="#999" font-size="10">{Math.round(maxIngreso * 0.25)}</text>
        <text x="36" y="99" text-anchor="end" fill="#999" font-size="10">{Math.round(maxIngreso * 0.5)}</text>
        <text x="36" y="56" text-anchor="end" fill="#999" font-size="10">{Math.round(maxIngreso * 0.75)}</text>
        <text x="36" y="14" text-anchor="end" fill="#999" font-size="10">{Math.round(maxIngreso)}</text>
        {/* Bars */}
        {ingresosPorMes.map((val, i) => {
          const barWidth = 32;
          const gap = 45;
          const x = 50 + i * gap;
          const barHeight = maxIngreso > 0 ? (val / maxIngreso) * 170 : 0;
          const y = 180 - barHeight;
          const currentMonth = new Date().getMonth();
          const fill = i === currentMonth ? '#4a6548' : '#5a7c59';
          const opacity = val === 0 ? 0.15 : (i === currentMonth ? 1 : 0.75);
          return (
            <g class="bar-group">
              <rect x={x} y={y} width={barWidth} height={barHeight} rx="3" fill={fill} opacity={opacity}>
                <title>{mesesCompletos[i]}: {val.toFixed(0)}&euro;</title>
              </rect>
              {val > 0 && (
                <text x={x + barWidth / 2} y={y - 4} text-anchor="middle" fill="#333" font-size="9" font-weight="600" class="bar-value">{val.toFixed(0)}&euro;</text>
              )}
              <text x={x + barWidth / 2} y="198" text-anchor="middle" fill="#666" font-size="11" font-weight={i === currentMonth ? '700' : '400'}>{mesesLabels[i]}</text>
            </g>
          );
        })}
      </svg>
    </div>
  </div>

  {stats.totalPacientes === 0 && !dbError && (
