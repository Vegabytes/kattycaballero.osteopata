---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getEstadisticas, getCitas } from '../../lib/db';

let stats = { totalPacientes: 0, citasHoy: 0, citasSemana: 0, citasPendientes: 0 };
let citasHoy: any[] = [];
let dbError = '';

const hoy = new Date().toISOString().split('T')[0];
const mesActual = new Date().toISOString().slice(0, 7); // YYYY-MM

let pacientesNuevosMes = 0;
let ingresosMes = 0;
let bonosActivos = 0;
let ingresosHoy = 0;

try {
  stats = await getEstadisticas(Astro);
  citasHoy = await getCitas(Astro, hoy);
  ingresosHoy = citasHoy
    .filter((c: any) => c.estado === 'completada' && c.precio)
    .reduce((sum: number, c: any) => sum + (c.precio || 0), 0);
} catch (e: any) {
  dbError = `Error conectando a la base de datos: ${e.message}`;
  console.error('DB error in admin/index:', e);
}

// New stats queries - wrapped in own try-catch so they don't break the page
try {
  const db = (Astro.locals as any).runtime.env.DB;
  const pnResult = await db.prepare("SELECT COUNT(*) as total FROM pacientes WHERE created_at LIKE ?").bind(mesActual + '%').first();
  pacientesNuevosMes = (pnResult as any)?.total || 0;

  const ingResult = await db.prepare("SELECT COALESCE(SUM(precio), 0) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?").bind(mesActual + '%').first();
  ingresosMes = (ingResult as any)?.total || 0;
} catch (e: any) {
  console.error('DB error fetching new stats:', e);
}

try {
  const db = (Astro.locals as any).runtime.env.DB;
  const bonosResult = await db.prepare("SELECT COUNT(*) as total FROM bonos WHERE estado = 'activo'").bind().first();
  bonosActivos = (bonosResult as any)?.total || 0;
} catch (e: any) {
  // bonos table might not exist yet
  console.error('DB error fetching bonos:', e);
}
---

<AdminLayout title="Dashboard" activeSection="dashboard">
  {dbError && (
    <div class="alert alert-error">
      <strong>Error de base de datos:</strong> {dbError}
      <br><small>Verifica que D1 esté correctamente vinculado en Cloudflare Pages → Settings → Functions → D1 database bindings.</small>
    </div>
  )}
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.totalPacientes}</h3>
        <p>Pacientes totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasHoy}</h3>
        <p>Citas hoy</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasSemana}</h3>
        <p>Citas esta semana</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{stats.citasPendientes}</h3>
        <p>Pendientes confirmar</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{pacientesNuevosMes}</h3>
        <p>Nuevos este mes</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{ingresosMes.toFixed(0)}&euro;</h3>
        <p>Ingresos del mes</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{bonosActivos}</h3>
        <p>Bonos activos</p>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="quick-actions">
    <a href="/admin/pacientes/nuevo" class="quick-action-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
      Nuevo paciente
    </a>
    <a href="/admin/citas/nueva" class="quick-action-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" /></svg>
      Nueva cita
    </a>
    <a href="/admin/bonos/nuevo" class="quick-action-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" /></svg>
      Nuevo bono
    </a>
    <a href="/admin/tratamientos/nuevo" class="quick-action-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
      Nota clinica
    </a>
  </div>

  <!-- Citas de hoy -->
  <div class="card">
    <div class="page-header">
      <h2>Citas de hoy ({hoy}){citasHoy.length > 0 && ingresosHoy > 0 ? ` — Ingresos: ${ingresosHoy.toFixed(0)}\u20AC` : ''}</h2>
      <a href="/admin/citas/nueva" class="btn btn-primary btn-sm">+ Nueva cita</a>
    </div>

    {citasHoy.length === 0 ? (
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
        <p>No hay citas para hoy</p>
      </div>
    ) : (
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Hora</th>
              <th>Paciente</th>
              <th>Servicio</th>
              <th>Precio</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {citasHoy.map((cita) => (
              <tr>
                <td><strong>{cita.hora}</strong></td>
                <td>
                  <a href={`/admin/pacientes/${cita.paciente_id}`}>{cita.paciente_nombre} {cita.paciente_apellidos}</a>
                </td>
                <td>{cita.servicio || '-'}</td>
                <td>{cita.precio ? `${cita.precio}\u20AC` : '-'}</td>
                <td>
                  <span class={`badge badge-${cita.estado}`}>{cita.estado}</span>
                </td>
                <td>
                  <a href={`/admin/citas/${cita.id}`} class="btn btn-secondary btn-sm">Ver</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>

<style is:global>
  .quick-actions {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .quick-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    color: var(--admin-text);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .quick-action-btn:hover {
    border-color: var(--admin-primary);
    color: var(--admin-primary);
    background: #f0f7f0;
  }

  .quick-action-btn svg {
    width: 20px !important;
    height: 20px !important;
    max-width: 20px;
    max-height: 20px;
  }
</style>
