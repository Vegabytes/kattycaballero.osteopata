        </div>
        <div class="stat-info">
          <h3>{ingresosHoy.toFixed(0)}&euro;</h3>
          <p>Ingresos hoy</p>
        </div>
      </div>
    )}
  </div>

  <!-- Monthly comparison -->
  <div class="card" style="margin-top:20px;">
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
      <h2>Resumen mensual</h2>
      <div style="display:flex;gap:8px;">
        <a href="/api/admin/exportar?tipo=citas" class="btn btn-secondary btn-sm" download>Exportar citas CSV</a>
        <a href="/api/admin/exportar?tipo=pacientes" class="btn btn-secondary btn-sm" download>Exportar pacientes CSV</a>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:16px;">
      <div style="background:#f8f6f0;padding:16px;border-radius:10px;">
        <div style="font-size:0.8rem;color:#888;margin-bottom:4px;">Citas este mes</div>
        <div style="font-size:1.5rem;font-weight:700;color:#333;">{citasMes}</div>
        {citasMesAnterior > 0 && (
          <div style={`font-size:0.75rem;margin-top:4px;${citasMes >= citasMesAnterior ? 'color:#4caf50;' : 'color:#e65100;'}`}>
            {citasMes >= citasMesAnterior ? '+' : ''}{citasMes - citasMesAnterior} vs mes anterior ({citasMesAnterior})
          </div>
        )}
      </div>
      <div style="background:#f8f6f0;padding:16px;border-radius:10px;">
        <div style="font-size:0.8rem;color:#888;margin-bottom:4px;">Completadas</div>
        <div style="font-size:1.5rem;font-weight:700;color:#333;">{citasCompletadasMes}</div>
        {citasMes > 0 && (
          <div style="font-size:0.75rem;margin-top:4px;color:#888;">
            {citasMes > 0 ? Math.round(citasCompletadasMes / citasMes * 100) : 0}% del total
          </div>
        )}
      </div>
      <div style="background:#f8f6f0;padding:16px;border-radius:10px;">
        <div style="font-size:0.8rem;color:#888;margin-bottom:4px;">Ingresos</div>
        <div style="font-size:1.5rem;font-weight:700;color:#333;">{ingresosMes.toFixed(0)}&euro;</div>
        {ingresosMesAnterior > 0 && (
          <div style={`font-size:0.75rem;margin-top:4px;${ingresosMes >= ingresosMesAnterior ? 'color:#4caf50;' : 'color:#e65100;'}`}>
            {ingresosMes >= ingresosMesAnterior ? '+' : ''}{(ingresosMes - ingresosMesAnterior).toFixed(0)}&euro; vs mes anterior ({ingresosMesAnterior.toFixed(0)}&euro;)
          </div>
        )}
      </div>
      <div style="background:#f8f6f0;padding:16px;border-radius:10px;">
        <div style="font-size:0.8rem;color:#888;margin-bottom:4px;">Pacientes nuevos</div>
        <div style="font-size:1.5rem;font-weight:700;color:#333;">{pacientesNuevosMes}</div>
        {pacientesNuevosMesAnterior > 0 && (
          <div style={`font-size:0.75rem;margin-top:4px;${pacientesNuevosMes >= pacientesNuevosMesAnterior ? 'color:#4caf50;' : 'color:#e65100;'}`}>
