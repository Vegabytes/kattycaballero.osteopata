---
export const prerender = false;

import { getCita, getPaciente } from '../../../lib/db';
import { getSettings } from '../../../lib/settings';

const id = Number(Astro.params.id);
const cita = await getCita(Astro, id);

if (!cita) {
  return Astro.redirect('/admin/citas');
}

const paciente = await getPaciente(Astro, cita.paciente_id);
const settings = await getSettings(Astro);

const hoy = new Date();
const fechaFactura = hoy.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
const anio = hoy.getFullYear();
const numFactura = `F-${anio}-${String(id).padStart(5, '0')}`;

const precio = cita.precio || 0;
const servicio = cita.servicio || 'Sesión de osteopatía';

const nombreClinica = settings.nombre_clinica || 'Katy Caballero - Osteópata';
const telefonoClinica = settings.telefono_clinica || '634063461';
const emailClinica = settings.email_clinica || '';
const nif = settings.facturacion_nif || '';
const direccionClinica = settings.facturacion_direccion || '';

const fechaCita = new Date(cita.fecha).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Factura {numFactura}</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #3d3d3d;
      background: #f5f5f5;
      line-height: 1.5;
    }

    .invoice-wrapper {
      max-width: 210mm;
      margin: 20px auto;
      background: #fff;
      padding: 40px 50px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
      min-height: 297mm;
      position: relative;
    }

    .print-actions {
      text-align: center;
      margin: 20px auto;
      max-width: 210mm;
    }

    .print-actions button {
      background: #5a7c59;
      color: #fff;
      border: none;
      padding: 12px 32px;
      font-size: 16px;
      border-radius: 6px;
      cursor: pointer;
      margin: 0 8px;
    }

    .print-actions button:hover {
      background: #4a6548;
    }

    .print-actions a {
      display: inline-block;
      padding: 12px 32px;
      font-size: 16px;
      border-radius: 6px;
      text-decoration: none;
      color: #5a7c59;
      border: 1px solid #5a7c59;
    }

    .print-actions a:hover {
      background: #f0f5f0;
    }

    /* Header */
    .invoice-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 3px solid #5a7c59;
    }

    .clinic-info h1 {
      font-size: 22px;
      color: #5a7c59;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .clinic-info p {
      font-size: 13px;
      color: #6b6b6b;
      line-height: 1.6;
    }

    .invoice-meta {
      text-align: right;
    }

    .invoice-meta .label-factura {
      font-size: 28px;
      font-weight: 700;
      color: #5a7c59;
      margin-bottom: 8px;
      letter-spacing: 1px;
    }

    .invoice-meta p {
      font-size: 13px;
      color: #6b6b6b;
    }

    .invoice-meta strong {
      color: #3d3d3d;
    }

    /* Patient section */
    .patient-section {
      background: #f8faf8;
      border: 1px solid #e0e8e0;
      border-radius: 6px;
      padding: 20px 24px;
      margin-bottom: 32px;
    }

    .patient-section h3 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #5a7c59;
      margin-bottom: 8px;
    }

    .patient-section p {
      font-size: 14px;
      color: #3d3d3d;
    }

    /* Table */
    .invoice-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }

    .invoice-table thead th {
      background: #5a7c59;
      color: #fff;
      padding: 12px 16px;
      text-align: left;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .invoice-table thead th:last-child {
      text-align: right;
    }

    .invoice-table tbody td {
      padding: 14px 16px;
      border-bottom: 1px solid #eee;
      font-size: 14px;
    }

    .invoice-table tbody td:last-child {
      text-align: right;
      font-weight: 500;
    }

    /* Totals */
    .totals {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 40px;
    }

    .totals-table {
      width: 280px;
    }

    .totals-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 14px;
      color: #6b6b6b;
    }

    .totals-row.iva-note {
      font-size: 12px;
      color: #999;
      font-style: italic;
    }

    .totals-row.total {
      border-top: 2px solid #5a7c59;
      margin-top: 8px;
      padding-top: 12px;
      font-size: 18px;
      font-weight: 700;
      color: #3d3d3d;
    }

    .totals-row.total span:last-child {
      color: #5a7c59;
    }

    /* Footer */
    .invoice-footer {
      position: absolute;
      bottom: 40px;
      left: 50px;
      right: 50px;
      text-align: center;
      padding-top: 16px;
      border-top: 1px solid #e0e0e0;
    }

    .invoice-footer p {
      font-size: 11px;
      color: #999;
      line-height: 1.6;
    }

    .invoice-footer p.legal {
      font-size: 10px;
      margin-top: 4px;
    }

    /* Print styles */
    @media print {
      body {
        background: #fff;
      }

      .print-actions {
        display: none !important;
      }

      .invoice-wrapper {
        box-shadow: none;
        margin: 0;
        padding: 30px 40px;
        min-height: auto;
      }

      @page {
        size: A4;
        margin: 10mm;
      }
    }
  </style>
</head>
<body>
  <div class="print-actions">
    <button onclick="window.print()">Imprimir / Guardar PDF</button>
    <a href={`/admin/citas/${id}`}>Volver a la cita</a>
  </div>

  <div class="invoice-wrapper">
    <div class="invoice-header">
      <div class="clinic-info">
        <h1>{nombreClinica}</h1>
        {nif && <p><strong>NIF:</strong> {nif}</p>}
        {direccionClinica && <p>{direccionClinica}</p>}
        {telefonoClinica && <p>Tel: {telefonoClinica}</p>}
        {emailClinica && <p>{emailClinica}</p>}
      </div>
      <div class="invoice-meta">
        <div class="label-factura">FACTURA</div>
        <p><strong>N.:</strong> {numFactura}</p>
        <p><strong>Fecha:</strong> {fechaFactura}</p>
      </div>
    </div>

    <div class="patient-section">
      <h3>Datos del paciente</h3>
      <p><strong>{paciente?.nombre} {paciente?.apellidos}</strong></p>
      {paciente?.direccion && <p>{paciente.direccion}</p>}
      {paciente?.telefono && <p>Tel: {paciente.telefono}</p>}
      {paciente?.email && <p>{paciente.email}</p>}
    </div>

    <table class="invoice-table">
      <thead>
        <tr>
          <th>Concepto</th>
          <th>Fecha</th>
          <th>Duraci&oacute;n</th>
          <th>Importe</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{servicio}</td>
          <td>{fechaCita}</td>
          <td>{cita.duracion} min</td>
          <td>{precio.toFixed(2)} &euro;</td>
        </tr>
      </tbody>
    </table>

    <div class="totals">
      <div class="totals-table">
        <div class="totals-row">
          <span>Subtotal</span>
          <span>{precio.toFixed(2)} &euro;</span>
        </div>
        <div class="totals-row iva-note">
          <span>IVA</span>
          <span>Exento</span>
        </div>
        <div class="totals-row total">
          <span>Total</span>
          <span>{precio.toFixed(2)} &euro;</span>
        </div>
      </div>
    </div>

    <div class="invoice-footer">
      <p>Actividad exenta de IVA seg&uacute;n Art. 20.1.3.&ordm; Ley 37/1992, de 28 de diciembre, del Impuesto sobre el Valor A&ntilde;adido.</p>
      <p class="legal">{nombreClinica}{nif ? ` - NIF: ${nif}` : ''}{direccionClinica ? ` - ${direccionClinica}` : ''}</p>
    </div>
  </div>
</body>
</html>
