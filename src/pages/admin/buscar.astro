---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const q = Astro.url.searchParams.get('q')?.trim() || '';
let pacientes: any[] = [];
let citas: any[] = [];
let notas: any[] = [];
let dbError = '';
let searched = false;

if (q) {
  searched = true;
  const db = (Astro.locals as any).runtime.env.DB;
  const like = `%${q}%`;

  try {
    const pResult = await db.prepare(
      `SELECT id, nombre, apellidos, telefono, email
       FROM pacientes
       WHERE nombre LIKE ? OR apellidos LIKE ? OR telefono LIKE ? OR email LIKE ?
       ORDER BY apellidos, nombre
       LIMIT 50`
    ).bind(like, like, like, like).all();
    pacientes = pResult.results || [];
  } catch (e: any) {
    dbError = `Error buscando pacientes: ${e.message}`;
  }

  try {
    const cResult = await db.prepare(
      `SELECT c.id, c.fecha, c.hora, c.servicio, c.estado, c.notas,
              p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, c.paciente_id
       FROM citas c
       LEFT JOIN pacientes p ON c.paciente_id = p.id
       WHERE c.notas LIKE ? OR c.servicio LIKE ?
       ORDER BY c.fecha DESC, c.hora DESC
       LIMIT 50`
    ).bind(like, like).all();
    citas = cResult.results || [];
  } catch (e: any) {
    dbError += ` Error buscando citas: ${e.message}`;
  }

  try {
    const nResult = await db.prepare(
      `SELECT nc.id, nc.motivo, nc.diagnostico, nc.tratamiento_realizado, nc.fecha,
              p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, nc.paciente_id
       FROM notas_clinicas nc
       LEFT JOIN pacientes p ON nc.paciente_id = p.id
       WHERE nc.motivo LIKE ? OR nc.diagnostico LIKE ? OR nc.tratamiento_realizado LIKE ?
       ORDER BY nc.fecha DESC
       LIMIT 50`
    ).bind(like, like, like).all();
    notas = nResult.results || [];
  } catch (e: any) {
    // Table may not exist - silently ignore
    console.error('Search notas_clinicas error (table may not exist):', e.message);
  }
}

const totalResults = pacientes.length + citas.length + notas.length;
---

<AdminLayout title="Buscar" activeSection="buscar">
  <div class="search-page">
    <form method="GET" action="/admin/buscar" class="search-form">
      <div class="search-input-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="search-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <input
          type="text"
          name="q"
          value={q}
          placeholder="Buscar pacientes, citas, notas..."
          autofocus
        />
        <button type="submit" class="btn btn-primary">Buscar</button>
      </div>
    </form>

    {dbError && (
      <div class="alert alert-error">{dbError}</div>
    )}

    {searched && totalResults === 0 && !dbError && (
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <p>No se encontraron resultados para <strong>"{q}"</strong></p>
        <p>Intenta con otro termino de busqueda</p>
      </div>
    )}

    {searched && totalResults > 0 && (
      <p class="results-summary">{totalResults} resultado{totalResults !== 1 ? 's' : ''} para "<strong>{q}</strong>"</p>
    )}

    {/* Pacientes */}
    {pacientes.length > 0 && (
      <div class="results-section">
        <h3 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
          Pacientes ({pacientes.length})
        </h3>
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Telefono</th>
                  <th>Email</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {pacientes.map((p) => (
                  <tr>
                    <td><strong>{p.nombre} {p.apellidos}</strong></td>
                    <td>{p.telefono || '-'}</td>
                    <td>{p.email || '-'}</td>
                    <td><a href={`/admin/pacientes/${p.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}

    {/* Citas */}
    {citas.length > 0 && (
      <div class="results-section">
        <h3 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
          Citas ({citas.length})
        </h3>
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Hora</th>
                  <th>Paciente</th>
                  <th>Servicio</th>
                  <th>Estado</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {citas.map((c) => (
                  <tr>
                    <td>{c.fecha}</td>
                    <td>{c.hora}</td>
                    <td>
                      {c.paciente_id ? (
                        <a href={`/admin/pacientes/${c.paciente_id}`}>{c.paciente_nombre} {c.paciente_apellidos}</a>
                      ) : '-'}
                    </td>
                    <td>{c.servicio || '-'}</td>
                    <td><span class={`badge badge-${c.estado}`}>{c.estado}</span></td>
                    <td><a href={`/admin/citas/${c.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}

    {/* Notas clinicas */}
    {notas.length > 0 && (
      <div class="results-section">
        <h3 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
          Notas clinicas ({notas.length})
        </h3>
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Paciente</th>
                  <th>Motivo</th>
                  <th>Diagnostico</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {notas.map((n) => (
                  <tr>
                    <td>{n.fecha}</td>
                    <td>
                      {n.paciente_id ? (
                        <a href={`/admin/pacientes/${n.paciente_id}`}>{n.paciente_nombre} {n.paciente_apellidos}</a>
                      ) : '-'}
                    </td>
                    <td>{n.motivo ? (n.motivo.length > 60 ? n.motivo.substring(0, 60) + '...' : n.motivo) : '-'}</td>
                    <td>{n.diagnostico ? (n.diagnostico.length > 60 ? n.diagnostico.substring(0, 60) + '...' : n.diagnostico) : '-'}</td>
                    <td><a href={`/admin/tratamientos/${n.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}
  </div>
</AdminLayout>

<style is:global>
  .search-page {
    max-width: 1000px;
  }

  .search-form {
    margin-bottom: 32px;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--admin-card);
    border: 2px solid var(--admin-border);
    border-radius: 12px;
    padding: 8px 16px;
    transition: border-color 0.2s;
  }

  .search-input-wrapper:focus-within {
    border-color: var(--admin-primary);
    box-shadow: 0 0 0 3px rgba(90, 124, 89, 0.1);
  }

  .search-input-wrapper .search-icon {
    width: 24px;
    height: 24px;
    color: var(--admin-text-light);
    flex-shrink: 0;
  }

  .search-input-wrapper input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    font-family: inherit;
    background: transparent;
    padding: 8px 0;
    color: var(--admin-text);
  }

  .search-input-wrapper input::placeholder {
    color: #aaa;
  }

  .results-summary {
    font-size: 0.9rem;
    color: var(--admin-text-light);
    margin-bottom: 24px;
  }

  .results-section {
    margin-bottom: 32px;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--admin-text);
    margin-bottom: 12px;
  }

  .section-title svg {
    width: 20px;
    height: 20px;
    color: var(--admin-primary);
  }
</style>
