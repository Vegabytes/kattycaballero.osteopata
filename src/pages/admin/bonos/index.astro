---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getBonos } from '../../../lib/db';

const buscar = Astro.url.searchParams.get('buscar') || '';
const filtroEstado = Astro.url.searchParams.get('estado') || '';
let bonos: any[] = [];
let dbError = '';

try {
  bonos = await getBonos(Astro, buscar || undefined);
} catch (e: any) {
  dbError = e.message;
  console.error('DB error in bonos:', e);
}

// Stats
const totalActivos = bonos.filter(b => b.estado === 'activo').length;
const totalCompletados = bonos.filter(b => b.estado === 'completado').length;
const totalCaducados = bonos.filter(b => b.estado === 'caducado').length;
const hoy = new Date(); hoy.setHours(0,0,0,0);
const porCaducar = bonos.filter(b => {
  if (b.estado !== 'activo' || !b.fecha_caducidad) return false;
  const caduca = new Date(b.fecha_caducidad + 'T00:00:00');
  return (caduca.getTime() - hoy.getTime()) / (1000*60*60*24) <= 30;
}).length;
const ultimaSesion = bonos.filter(b => b.estado === 'activo' && b.sesiones_total - b.sesiones_usadas === 1).length;

// Ingresos totales
const ingresosBonos = bonos.filter(b => b.precio).reduce((sum, b) => sum + b.precio, 0);

// Filtrar por estado
const bonosFiltrados = filtroEstado ? bonos.filter(b => b.estado === filtroEstado) : bonos;

// Helper: dias hasta caducidad
function diasHastaCaducidad(fecha: string): { dias: number; texto: string; clase: string } {
  const caduca = new Date(fecha + 'T00:00:00');
  const dias = Math.ceil((caduca.getTime() - hoy.getTime()) / (1000*60*60*24));
  if (dias < 0) return { dias, texto: `Hace ${Math.abs(dias)}d`, clase: 'cad-expired' };
  if (dias === 0) return { dias, texto: 'Hoy', clase: 'cad-urgent' };
  if (dias <= 15) return { dias, texto: `${dias}d`, clase: 'cad-warning' };
  if (dias <= 30) return { dias, texto: `${dias}d`, clase: 'cad-notice' };
  return { dias, texto: `${dias}d`, clase: 'cad-ok' };
}
---

<AdminLayout title="Bonos" activeSection="bonos">
  {dbError && (
    <div class="alert alert-error">
      <strong>Error de base de datos:</strong> {dbError}
      <br><small>Verifica que D1 este vinculado en Cloudflare Pages → Settings → Functions → D1 database bindings.</small>
    </div>
  )}
  <div class="page-header">
    <h2>Bonos ({bonos.length})</h2>
    <a href="/admin/bonos/nuevo" class="btn btn-primary">+ Nuevo bono</a>
  </div>

  <!-- Stats cards -->
  {bonos.length > 0 && (
    <div class="bonos-stats">
      <a href="/admin/bonos?estado=activo" class={`stat-card stat-activo ${filtroEstado === 'activo' ? 'stat-selected' : ''}`}>
        <span class="stat-number">{totalActivos}</span>
        <span class="stat-label">Activos</span>
      </a>
      <a href="/admin/bonos?estado=completado" class={`stat-card stat-completado ${filtroEstado === 'completado' ? 'stat-selected' : ''}`}>
        <span class="stat-number">{totalCompletados}</span>
        <span class="stat-label">Completados</span>
      </a>
      <a href="/admin/bonos?estado=caducado" class={`stat-card stat-caducado ${filtroEstado === 'caducado' ? 'stat-selected' : ''}`}>
        <span class="stat-number">{totalCaducados}</span>
        <span class="stat-label">Caducados</span>
      </a>
      {porCaducar > 0 && (
        <div class="stat-card stat-alert">
          <span class="stat-number">{porCaducar}</span>
          <span class="stat-label">Caducan pronto</span>
        </div>
      )}
      {ultimaSesion > 0 && (
        <div class="stat-card stat-alert-orange">
          <span class="stat-number">{ultimaSesion}</span>
          <span class="stat-label">Ultima sesion</span>
        </div>
      )}
      {ingresosBonos > 0 && (
        <div class="stat-card stat-ingresos">
          <span class="stat-number">{ingresosBonos.toFixed(0)}&euro;</span>
          <span class="stat-label">Ingresos bonos</span>
        </div>
      )}
    </div>
  )}

  <form class="search-bar" method="GET">
    <input type="text" name="buscar" placeholder="Buscar por paciente o nombre del bono..." value={buscar}>
    <button type="submit" class="btn btn-secondary">Buscar</button>
    {(buscar || filtroEstado) && <a href="/admin/bonos" class="btn btn-secondary">Limpiar</a>}
  </form>

  {bonosFiltrados.length === 0 ? (
    <div class="card empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" /></svg>
      <p>{buscar || filtroEstado ? 'No se encontraron bonos' : 'Aun no hay bonos registrados'}</p>
      <a href="/admin/bonos/nuevo" class="btn btn-primary">Anadir primer bono</a>
    </div>
  ) : (
    <div class="card">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Paciente</th>
              <th>Bono</th>
              <th>Sesiones</th>
              <th>Precio</th>
              <th>Estado</th>
              <th>Caducidad</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {bonosFiltrados.map((b) => {
              const porcentaje = b.sesiones_total > 0 ? Math.round((b.sesiones_usadas / b.sesiones_total) * 100) : 0;
              const barColor = porcentaje >= 100 ? '#1565c0' : porcentaje >= 80 ? '#ff9800' : 'var(--admin-primary)';
              const badgeClass = b.estado === 'activo' ? 'badge-activo' : b.estado === 'completado' ? 'badge-completado' : 'badge-caducado';
              const restantes = b.sesiones_total - b.sesiones_usadas;
              const cad = b.fecha_caducidad ? diasHastaCaducidad(b.fecha_caducidad) : null;
              return (
                <tr>
                  <td>
                    <a href={`/admin/pacientes/${b.paciente_id}`}>
                      <strong>{b.paciente_apellidos}, {b.paciente_nombre}</strong>
                    </a>
                  </td>
                  <td>
                    <a href={`/admin/bonos/${b.id}`}>{b.nombre}</a>
                  </td>
                  <td>
                    <div class="sesiones-cell">
                      <span>{b.sesiones_usadas} / {b.sesiones_total} <span class="restantes-inline">({restantes} rest.)</span></span>
                      <div class="progress-mini">
                        <div class="progress-mini-bar" style={`width: ${porcentaje}%; background: ${barColor};`}></div>
                      </div>
                    </div>
                  </td>
                  <td>{b.precio ? `${b.precio.toFixed(2)} €` : '-'}</td>
                  <td><span class={`badge ${badgeClass}`}>{b.estado}</span></td>
                  <td>
                    {cad ? (
                      <span class={`cad-badge ${cad.clase}`} title={b.fecha_caducidad}>{cad.texto}</span>
                    ) : '-'}
                  </td>
                  <td>
                    <a href={`/admin/bonos/${b.id}`} class="btn btn-secondary btn-sm">Ver</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>

<style is:global>
  .badge-activo { background: #e8f5e9; color: #2e7d32; }
  .badge-completado { background: #e3f2fd; color: #1565c0; }
  .badge-caducado { background: #fce4ec; color: #c62828; }

  /* Stats cards */
  .bonos-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 18px;
    border-radius: 10px;
    border: 1px solid #e0e0e0;
    background: #fff;
    min-width: 80px;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
  }
  .stat-card:hover { transform: translateY(-2px); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .stat-selected { border-width: 2px; font-weight: 700; }
  .stat-number { font-size: 1.3rem; font-weight: 700; line-height: 1; }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.3px; margin-top: 4px; font-weight: 600; }
  .stat-activo { border-color: #a5d6a7; background: #f0f9f0; }
  .stat-activo .stat-number { color: #2e7d32; }
  .stat-activo .stat-label { color: #4caf50; }
  .stat-completado { border-color: #90caf9; background: #e8f4fd; }
  .stat-completado .stat-number { color: #1565c0; }
  .stat-completado .stat-label { color: #1e88e5; }
  .stat-caducado { border-color: #ef9a9a; background: #fef0f0; }
  .stat-caducado .stat-number { color: #c62828; }
  .stat-caducado .stat-label { color: #e53935; }
  .stat-alert { border-color: #ef9a9a; background: #fff5f5; }
  .stat-alert .stat-number { color: #c62828; }
  .stat-alert .stat-label { color: #e53935; }
  .stat-alert-orange { border-color: #ffcc80; background: #fff8f0; }
  .stat-alert-orange .stat-number { color: #e65100; }
  .stat-alert-orange .stat-label { color: #ff9800; }
  .stat-ingresos { border-color: #ce93d8; background: #faf0fc; }
  .stat-ingresos .stat-number { color: #7b1fa2; }
  .stat-ingresos .stat-label { color: #9c27b0; }

  .sesiones-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 100px;
  }

  .restantes-inline {
    font-size: 0.75rem;
    color: var(--admin-text-light, #888);
    font-weight: 400;
  }

  .progress-mini {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-mini-bar {
    height: 100%;
    background: var(--admin-primary);
    border-radius: 3px;
    transition: width 0.3s;
  }

  /* Caducidad badges */
  .cad-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .cad-expired { background: #fce4ec; color: #c62828; }
  .cad-urgent { background: #fff3e0; color: #e65100; }
  .cad-warning { background: #fff8e1; color: #f57f17; }
  .cad-notice { background: #e8f5e9; color: #2e7d32; }
  .cad-ok { background: #f5f5f5; color: #757575; }

  @media (max-width: 600px) {
    .bonos-stats { gap: 6px; }
    .stat-card { padding: 8px 12px; min-width: 65px; }
    .stat-number { font-size: 1.1rem; }
  }
</style>
