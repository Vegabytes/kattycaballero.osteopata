---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { crearTratamiento, getPacientes } from '../../../lib/db';

const pacientes = await getPacientes(Astro);
const pacienteId = Astro.url.searchParams.get('paciente') || '';
const citaId = Astro.url.searchParams.get('cita') || '';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const paciente_id = Number(form.get('paciente_id'));
  const fecha = form.get('fecha') as string;
  const tipo = form.get('tipo') as string;

  if (!paciente_id || !fecha || !tipo) {
    error = 'Paciente, fecha y tipo son obligatorios';
  } else {
    let observaciones = (form.get('observaciones') as string) || '';
    const evolucion = form.get('evolucion') as string;
    const proximaSesion = form.get('proxima_sesion') as string;
    if (evolucion) observaciones += `\n[Evolución: ${evolucion}]`;
    if (proximaSesion) observaciones += `\n[Próxima sesión: ${proximaSesion} días]`;

    await crearTratamiento(Astro, {
      paciente_id,
      cita_id: form.get('cita_id') ? Number(form.get('cita_id')) : null,
      fecha,
      tipo,
      zona: form.get('zona') as string,
      observaciones: observaciones.trim(),
    });
    return Astro.redirect(`/admin/pacientes/${paciente_id}`);
  }
}

const tiposTratamiento = [
  'Osteopatía estructural',
  'Osteopatía visceral',
  'Osteopatía craneal',
  'Masaje deportivo',
  'Masaje corporal descontracturante',
  'Masaje tailandés',
  'Masaje embarazadas',
  'Masaje pindas herbales',
  'Valoración inicial',
  'Seguimiento',
  'Otro',
];

const zonasCorporales = [
  'Cervical',
  'Dorsal',
  'Lumbar',
  'Hombro',
  'Cadera',
  'Rodilla',
  'Tobillo/Pie',
  'Muñeca/Mano',
  'Cabeza',
  'Abdomen',
  'Cuerpo completo',
  'Otra',
];
---

<AdminLayout title="Nuevo tratamiento" activeSection="tratamientos">
  <a href="/admin/tratamientos" class="back-link">← Volver a tratamientos</a>

  {error && <div class="alert alert-error">{error}</div>}

  <div class="card">
    <form method="POST">
      {citaId && <input type="hidden" name="cita_id" value={citaId}>}

      <div class="form-group">
        <label for="plantilla">Plantilla</label>
        <select id="plantilla">
          <option value="">Seleccionar plantilla...</option>
          <option value="Osteopatía estructural|Osteopatía estructural|Columna vertebral">Osteopatía estructural</option>
          <option value="Osteopatía visceral|Osteopatía visceral|Abdomen">Osteopatía visceral</option>
          <option value="Osteopatía craneal|Osteopatía craneal|Cráneo">Osteopatía craneal</option>
          <option value="Masaje deportivo|Masaje deportivo|Piernas/Espalda">Masaje deportivo</option>
          <option value="Masaje relajante|Masaje corporal descontracturante|Cuerpo completo">Masaje relajante</option>
          <option value="Masaje tailandés|Masaje tailandés|Cuerpo completo">Masaje tailandés</option>
          <option value="Embarazo|Masaje embarazadas|Espalda/Piernas">Embarazo</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="paciente_id">Paciente *</label>
          <select id="paciente_id" name="paciente_id" required>
            <option value="">Seleccionar paciente...</option>
            {pacientes.map((p) => (
              <option value={p.id} selected={String(p.id) === pacienteId}>
                {p.apellidos}, {p.nombre}
              </option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="fecha">Fecha *</label>
          <input type="date" id="fecha" name="fecha" value={new Date().toISOString().split('T')[0]} required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="tipo">Tipo de tratamiento *</label>
          <select id="tipo" name="tipo" required>
            <option value="">Seleccionar...</option>
            {tiposTratamiento.map((t) => (
              <option value={t}>{t}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="zona">Zona corporal</label>
          <select id="zona" name="zona">
            <option value="">Seleccionar...</option>
            {zonasCorporales.map((z) => (
              <option value={z}>{z}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="observaciones">Observaciones</label>
        <div style="display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;">
          <button type="button" class="btn btn-secondary btn-sm obs-template" data-text="Exploración: \nHallazgos: \nTécnicas aplicadas: \nRecomendaciones: ">Plantilla general</button>
          <button type="button" class="btn btn-secondary btn-sm obs-template" data-text="Motivo: dolor en zona {zona}\nExploración: movilidad, palpación\nTécnica: \nRespuesta al tratamiento: \nPauta domiciliaria: ">Plantilla osteopatía</button>
          <button type="button" class="btn btn-secondary btn-sm obs-template" data-text="Zona tratada: \nTensión muscular: leve / moderada / severa\nTécnicas: amasamiento, presiones, fricciones\nObservaciones: \nRecomendaciones: ">Plantilla masaje</button>
        </div>
        <textarea id="observaciones" name="observaciones" placeholder="Hallazgos, técnicas aplicadas, recomendaciones..." style="min-height:150px;"></textarea>
      </div>

      <div class="form-group">
        <label for="evolucion">Evolución / Resultado</label>
        <select id="evolucion" name="evolucion">
          <option value="">Sin valorar</option>
          <option value="mejoria">Mejoría</option>
          <option value="sin_cambios">Sin cambios</option>
          <option value="empeoramiento">Empeoramiento</option>
          <option value="alta">Alta / Resuelto</option>
        </select>
      </div>

      <div class="form-group">
        <label for="proxima_sesion">Próxima sesión recomendada</label>
        <select id="proxima_sesion" name="proxima_sesion">
          <option value="">No especificar</option>
          <option value="3">En 3 días</option>
          <option value="7">En 1 semana</option>
          <option value="14">En 2 semanas</option>
          <option value="21">En 3 semanas</option>
          <option value="30">En 1 mes</option>
        </select>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-primary">Guardar tratamiento</button>
        <a href="/admin/tratamientos" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

<script>
  // Treatment template auto-fill
  document.getElementById('plantilla')?.addEventListener('change', (e) => {
    const value = (e.target as HTMLSelectElement).value;
    if (!value) return;

    const parts = value.split('|');
    const tipoValue = parts[1];
    const zonaValue = parts[2];

    const tipoSelect = document.getElementById('tipo') as HTMLSelectElement;
    const zonaSelect = document.getElementById('zona') as HTMLSelectElement;

    // Set tipo
    if (tipoSelect) {
      for (let i = 0; i < tipoSelect.options.length; i++) {
        if (tipoSelect.options[i].value === tipoValue) {
          tipoSelect.selectedIndex = i;
          break;
        }
      }
    }

    // Set zona - may be a custom value not in the select
    if (zonaSelect) {
      let found = false;
      for (let i = 0; i < zonaSelect.options.length; i++) {
        if (zonaSelect.options[i].value === zonaValue) {
          zonaSelect.selectedIndex = i;
          found = true;
          break;
        }
      }
      // If zona not found in existing options, add it temporarily
      if (!found && zonaValue) {
        const option = document.createElement('option');
        option.value = zonaValue;
        option.textContent = zonaValue;
        option.selected = true;
        zonaSelect.appendChild(option);
      }
    }
  });

  // Observation templates
  document.querySelectorAll('.obs-template').forEach(btn => {
    btn.addEventListener('click', () => {
      const textarea = document.getElementById('observaciones') as HTMLTextAreaElement;
      const template = (btn as HTMLElement).dataset.text || '';
      if (textarea.value && !confirm('¿Reemplazar el contenido actual?')) return;
      textarea.value = template;
      textarea.focus();
    });
  });

  // Auto-fill observation template based on treatment type
  const tipoTemplates: Record<string, string> = {
    'Osteopatía estructural': 'Motivo de consulta: \nExploración: movilidad articular, test ortopédicos\nHallazgos: \nTécnicas: thrust, articulatoria, músculo-energía\nZonas tratadas: \nRespuesta: \nPauta domiciliaria: \nPróxima revisión: ',
    'Osteopatía visceral': 'Motivo de consulta: \nExploración: test de movilidad visceral\nHallazgos: \nTécnicas: bombeo, fascial, recoil\nÓrganos/zonas tratados: \nRespuesta: \nRecomendaciones dietéticas: \nPróxima revisión: ',
    'Osteopatía craneal': 'Motivo de consulta: \nExploración: ritmo cráneo-sacro, test suturas\nHallazgos: \nTécnicas: descompresión, CV4, modelado\nZonas tratadas: \nRespuesta: \nPauta domiciliaria: \nPróxima revisión: ',
    'Masaje deportivo': 'Deporte/actividad: \nZona principal: \nTensión muscular: leve / moderada / severa\nTécnicas: fricción profunda, estiramientos, compresión isquémica\nPuntos gatillo: \nRespuesta: \nRecomendaciones: ',
    'Masaje corporal descontracturante': 'Zona principal: \nTensión: leve / moderada / severa\nTécnicas: amasamiento, fricciones, presiones\nPuntos de tensión: \nRespuesta al tratamiento: \nRecomendaciones: ',
    'Masaje tailandés': 'Estado general: \nFlexibilidad: buena / limitada\nTécnicas: presiones, estiramientos pasivos, líneas sen\nZonas trabajadas: \nRespuesta: \nRecomendaciones: ',
    'Masaje embarazadas': 'Semanas de gestación: \nMolestias principales: \nPosición: decúbito lateral\nZonas tratadas: \nTécnicas: suaves, drenaje, estiramientos\nRespuesta: \nRecomendaciones: ',
    'Masaje pindas herbales': 'Zona principal: \nTemperatura pindas: \nTécnicas: presión, rodamiento, deslizamiento\nHierbas utilizadas: \nRespuesta: \nRecomendaciones: ',
    'Valoración inicial': 'Motivo de consulta: \nAnamnesis: \nAntecedentes: \nExploración física: \nTest realizados: \nDiagnóstico osteopático: \nPlan de tratamiento: \nSesiones estimadas: ',
  };

  document.getElementById('tipo')?.addEventListener('change', (e) => {
    const tipo = (e.target as HTMLSelectElement).value;
    const textarea = document.getElementById('observaciones') as HTMLTextAreaElement;
    if (textarea && !textarea.value.trim() && tipoTemplates[tipo]) {
      textarea.value = tipoTemplates[tipo];
      textarea.focus();
    }
  });
</script>
</AdminLayout>
