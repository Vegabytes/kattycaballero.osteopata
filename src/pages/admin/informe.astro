---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const url = new URL(Astro.request.url);
const mesParam = url.searchParams.get('mes');
const now = new Date();
const mesActual = mesParam || now.toISOString().slice(0, 7); // YYYY-MM

// Parse month for display and navigation
const [anio, mes] = mesActual.split('-').map(Number);
const mesDate = new Date(anio, mes - 1, 1);
const mesDisplay = mesDate.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

// Previous/next month
const prevDate = new Date(anio, mes - 2, 1);
const nextDate = new Date(anio, mes, 1);
const prevMes = prevDate.toISOString().slice(0, 7);
const nextMes = nextDate.toISOString().slice(0, 7);
const isCurrentMonth = mesActual === now.toISOString().slice(0, 7);

// Stats
let totalCitas = 0;
let citasCompletadas = 0;
let citasCanceladas = 0;
let ingresosTotales = 0;
let pacientesNuevos = 0;
let servicioPopular = '-';
let servicioPopularCount = 0;
let mediaPorSesion = 0;
let dbError = '';

try {
  const db = (Astro.locals as any).runtime.env.DB;
  const likePattern = mesActual + '%';

  // Total appointments
  const totalResult = await db.prepare(
    "SELECT COUNT(*) as total FROM citas WHERE fecha LIKE ?"
  ).bind(likePattern).first();
  totalCitas = (totalResult as any)?.total || 0;

  // Completed
  const completadasResult = await db.prepare(
    "SELECT COUNT(*) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?"
  ).bind(likePattern).first();
  citasCompletadas = (completadasResult as any)?.total || 0;

  // Cancelled
  const canceladasResult = await db.prepare(
    "SELECT COUNT(*) as total FROM citas WHERE estado = 'cancelada' AND fecha LIKE ?"
  ).bind(likePattern).first();
  citasCanceladas = (canceladasResult as any)?.total || 0;

  // Revenue
  const ingresosResult = await db.prepare(
    "SELECT COALESCE(SUM(precio), 0) as total FROM citas WHERE estado = 'completada' AND fecha LIKE ?"
  ).bind(likePattern).first();
  ingresosTotales = (ingresosResult as any)?.total || 0;

  // New patients
  const pnResult = await db.prepare(
    "SELECT COUNT(*) as total FROM pacientes WHERE created_at LIKE ?"
  ).bind(likePattern).first();
  pacientesNuevos = (pnResult as any)?.total || 0;

  // Most popular service
  const servicioResult = await db.prepare(
    "SELECT servicio, COUNT(*) as cnt FROM citas WHERE fecha LIKE ? AND servicio IS NOT NULL AND servicio != '' GROUP BY servicio ORDER BY cnt DESC LIMIT 1"
  ).bind(likePattern).first();
  if (servicioResult && (servicioResult as any).servicio) {
    servicioPopular = (servicioResult as any).servicio;
    servicioPopularCount = (servicioResult as any).cnt;
  }

  // Average revenue per session
  if (citasCompletadas > 0) {
    mediaPorSesion = ingresosTotales / citasCompletadas;
  }
} catch (e: any) {
  dbError = `Error: ${e.message}`;
  console.error('DB error in informe:', e);
}
---

<AdminLayout title={`Informe - ${mesDisplay}`} activeSection="estadisticas">
  {dbError && (
    <div class="alert alert-error">{dbError}</div>
  )}

  <!-- Month navigation -->
  <div class="informe-nav">
    <a href={`/admin/informe?mes=${prevMes}`} class="btn btn-secondary btn-sm">&larr; Mes anterior</a>
    <h2 class="informe-title">{mesDisplay.charAt(0).toUpperCase() + mesDisplay.slice(1)}</h2>
    {!isCurrentMonth ? (
      <a href={`/admin/informe?mes=${nextMes}`} class="btn btn-secondary btn-sm">Mes siguiente &rarr;</a>
    ) : (
      <span></span>
    )}
  </div>

  <!-- Stat cards -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalCitas}</h3>
        <p>Citas totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{citasCompletadas}</h3>
        <p>Completadas</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{citasCanceladas}</h3>
        <p>Canceladas</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{ingresosTotales.toFixed(0)}&euro;</h3>
        <p>Ingresos totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{pacientesNuevos}</h3>
        <p>Pacientes nuevos</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{mediaPorSesion.toFixed(0)}&euro;</h3>
        <p>Media por sesi&oacute;n</p>
      </div>
    </div>
  </div>

  <!-- Detail cards -->
  <div class="informe-details">
    <div class="card">
      <h3>Servicio m&aacute;s popular</h3>
      <div class="informe-highlight">
        <span class="informe-highlight-value">{servicioPopular}</span>
        {servicioPopularCount > 0 && (
          <span class="informe-highlight-sub">{servicioPopularCount} citas</span>
        )}
      </div>
    </div>

    <div class="card">
      <h3>Tasa de completado</h3>
      <div class="informe-highlight">
        <span class="informe-highlight-value">{totalCitas > 0 ? Math.round(citasCompletadas / totalCitas * 100) : 0}%</span>
        <span class="informe-highlight-sub">{citasCompletadas} de {totalCitas} citas</span>
      </div>
    </div>

    <div class="card">
      <h3>Tasa de cancelaci&oacute;n</h3>
      <div class="informe-highlight">
        <span class="informe-highlight-value">{totalCitas > 0 ? Math.round(citasCanceladas / totalCitas * 100) : 0}%</span>
        <span class="informe-highlight-sub">{citasCanceladas} de {totalCitas} citas</span>
      </div>
    </div>
  </div>

  <!-- Print button -->
  <div class="informe-print-row">
    <button class="btn btn-primary" onclick="window.print()">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M9.75 8.25h4.5" /></svg>
      Imprimir informe
    </button>
    <a href="/admin/estadisticas" class="btn btn-secondary">Ver estad&iacute;sticas</a>
  </div>
</AdminLayout>

<style is:global>
  .informe-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
  }

  .informe-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--admin-text);
    text-align: center;
  }

  .informe-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .informe-details .card h3 {
    font-size: 0.85rem;
    color: var(--admin-text-light);
    font-weight: 500;
    margin-bottom: 12px;
  }

  .informe-highlight {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .informe-highlight-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--admin-text);
  }

  .informe-highlight-sub {
    font-size: 0.8rem;
    color: var(--admin-text-light);
  }

  .informe-print-row {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  @media print {
    .admin-sidebar,
    .sidebar-overlay,
    .admin-topbar,
    .informe-nav .btn,
    .informe-print-row {
      display: none !important;
    }

    .admin-main {
      margin-left: 0 !important;
    }

    .admin-content {
      padding: 0 !important;
    }

    .informe-nav {
      justify-content: center;
    }

    .informe-title {
      font-size: 1.5rem;
    }

    body {
      background: white;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .stat-card, .card {
      break-inside: avoid;
      border: 1px solid #ddd;
    }

    .stat-icon {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }

  @media (max-width: 640px) {
    .informe-nav {
      flex-direction: column;
    }
  }
</style>
