---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const db = (Astro.locals as any).runtime.env.DB;

interface Activity {
  tipo: string;
  fecha: string;
  descripcion: string;
  paciente_nombre: string;
  paciente_apellidos: string;
  paciente_id: number;
  extra: string | null;
}

let actividades: Activity[] = [];

try {
  // New patients
  const pacientesNuevos = (await db.prepare(`
    SELECT 'paciente_nuevo' as tipo, created_at as fecha, '' as descripcion,
      nombre as paciente_nombre, apellidos as paciente_apellidos, id as paciente_id, NULL as extra
    FROM pacientes
    ORDER BY created_at DESC LIMIT 50
  `).all()).results;

  // Appointments created
  const citasCreadas = (await db.prepare(`
    SELECT 'cita_creada' as tipo, c.created_at as fecha,
      c.fecha || ' ' || c.hora as descripcion,
      p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, p.id as paciente_id,
      c.estado as extra
    FROM citas c JOIN pacientes p ON c.paciente_id = p.id
    ORDER BY c.created_at DESC LIMIT 50
  `).all()).results;

  // Completed appointments
  const citasCompletadas = (await db.prepare(`
    SELECT 'cita_completada' as tipo, c.created_at as fecha,
      c.fecha || ' ' || c.hora as descripcion,
      p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, p.id as paciente_id,
      c.servicio as extra
    FROM citas c JOIN pacientes p ON c.paciente_id = p.id
    WHERE c.estado = 'completada'
    ORDER BY c.created_at DESC LIMIT 50
  `).all()).results;

  // Cancelled appointments
  const citasCanceladas = (await db.prepare(`
    SELECT 'cita_cancelada' as tipo, c.created_at as fecha,
      c.fecha || ' ' || c.hora as descripcion,
      p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, p.id as paciente_id,
      c.servicio as extra
    FROM citas c JOIN pacientes p ON c.paciente_id = p.id
    WHERE c.estado = 'cancelada'
    ORDER BY c.created_at DESC LIMIT 50
  `).all()).results;

  // Clinical notes added
  let notasCreadas: any[] = [];
  try {
    notasCreadas = (await db.prepare(`
      SELECT 'nota_clinica' as tipo, n.created_at as fecha,
        n.motivo as descripcion,
        p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, p.id as paciente_id,
        n.diagnostico as extra
      FROM notas_clinicas n JOIN pacientes p ON n.paciente_id = p.id
      ORDER BY n.created_at DESC LIMIT 50
    `).all()).results;
  } catch { /* table may not exist */ }

  // Treatments created
  const tratamientosCreados = (await db.prepare(`
    SELECT 'tratamiento' as tipo, t.created_at as fecha,
      t.tipo as descripcion,
      p.nombre as paciente_nombre, p.apellidos as paciente_apellidos, p.id as paciente_id,
      t.zona as extra
    FROM tratamientos t JOIN pacientes p ON t.paciente_id = p.id
    ORDER BY t.created_at DESC LIMIT 50
  `).all()).results;

  // Combine and sort by date descending, take first 50
  const all = [
    ...pacientesNuevos,
    ...citasCreadas,
    ...citasCompletadas,
    ...citasCanceladas,
    ...notasCreadas,
    ...tratamientosCreados,
  ] as Activity[];

  all.sort((a, b) => {
    const da = new Date(a.fecha).getTime();
    const db = new Date(b.fecha).getTime();
    return db - da;
  });

  actividades = all.slice(0, 50);
} catch (e) {
  console.error('Error loading activity:', e);
}

function getIcon(tipo: string): string {
  switch (tipo) {
    case 'paciente_nuevo':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>';
    case 'cita_creada':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>';
    case 'cita_completada':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>';
    case 'cita_cancelada':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>';
    case 'nota_clinica':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>';
    case 'tratamiento':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>';
    default:
      return '';
  }
}

function getColor(tipo: string): string {
  switch (tipo) {
    case 'paciente_nuevo': return '#5a7c59';
    case 'cita_creada': return '#2196f3';
    case 'cita_completada': return '#4caf50';
    case 'cita_cancelada': return '#f44336';
    case 'nota_clinica': return '#9c27b0';
    case 'tratamiento': return '#ff9800';
    default: return '#666';
  }
}

function getLabel(tipo: string): string {
  switch (tipo) {
    case 'paciente_nuevo': return 'Nuevo paciente';
    case 'cita_creada': return 'Cita creada';
    case 'cita_completada': return 'Cita completada';
    case 'cita_cancelada': return 'Cita cancelada';
    case 'nota_clinica': return 'Nota clinica';
    case 'tratamiento': return 'Tratamiento';
    default: return tipo;
  }
}

function getMessage(a: Activity): string {
  const nombre = `${a.paciente_nombre} ${a.paciente_apellidos}`;
  switch (a.tipo) {
    case 'paciente_nuevo':
      return `Nuevo paciente: <strong>${nombre}</strong>`;
    case 'cita_creada':
      return `Nueva cita con <strong>${nombre}</strong> para el ${a.descripcion}`;
    case 'cita_completada':
      return `Cita completada con <strong>${nombre}</strong> (${a.descripcion})${a.extra ? ` - ${a.extra}` : ''}`;
    case 'cita_cancelada':
      return `Cita cancelada con <strong>${nombre}</strong> (${a.descripcion})`;
    case 'nota_clinica':
      return `Nota clinica añadida para <strong>${nombre}</strong>${a.descripcion ? `: ${a.descripcion}` : ''}`;
    case 'tratamiento':
      return `Tratamiento registrado para <strong>${nombre}</strong>: ${a.descripcion}${a.extra ? ` (${a.extra})` : ''}`;
    default:
      return nombre;
  }
}

function formatDate(fecha: string): string {
  try {
    const d = new Date(fecha);
    const now = new Date();
    const diff = now.getTime() - d.getTime();
    const mins = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (mins < 1) return 'Ahora';
    if (mins < 60) return `Hace ${mins} min`;
    if (hours < 24) return `Hace ${hours}h`;
    if (days < 7) return `Hace ${days}d`;

    return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch {
    return fecha;
  }
}
---

<AdminLayout title="Actividad reciente" activeSection="actividad">
  <div class="page-header">
    <h2>Actividad reciente de la clinica</h2>
  </div>

  {actividades.length === 0 ? (
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      <p>No hay actividad registrada todavia</p>
    </div>
  ) : (
    <div class="card">
      <div class="timeline">
        {actividades.map((a) => (
          <div class="timeline-item">
            <div class="timeline-icon" style={`background:${getColor(a.tipo)}15;color:${getColor(a.tipo)};`}>
              <Fragment set:html={getIcon(a.tipo)} />
            </div>
            <div class="timeline-content">
              <div class="timeline-message">
                <a href={`/admin/pacientes/${a.paciente_id}`} style="text-decoration:none;color:inherit;">
                  <Fragment set:html={getMessage(a)} />
                </a>
              </div>
              <div class="timeline-meta">
                <span class="timeline-badge" style={`background:${getColor(a.tipo)}15;color:${getColor(a.tipo)};`}>
                  {getLabel(a.tipo)}
                </span>
                <span class="timeline-date">{formatDate(a.fecha)}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <style is:inline>
    .timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .timeline-item {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .timeline-item:last-child {
      border-bottom: none;
    }
    .timeline-icon {
      width: 40px;
      height: 40px;
      min-width: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .timeline-icon svg {
      width: 20px !important;
      height: 20px !important;
    }
    .timeline-content {
      flex: 1;
      min-width: 0;
    }
    .timeline-message {
      font-size: 0.9rem;
      line-height: 1.5;
      color: #333;
      margin-bottom: 6px;
    }
    .timeline-message a:hover {
      color: #5a7c59;
    }
    .timeline-meta {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .timeline-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .timeline-date {
      font-size: 0.75rem;
      color: #999;
    }
  </style>
</AdminLayout>
