---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { crearPaciente } from '../../../lib/db';

let error = '';
const db = (Astro.locals as any).runtime.env.DB;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const nombre = form.get('nombre') as string;
  const apellidos = form.get('apellidos') as string;
  const origen = form.get('origen') as string;

  if (!nombre || !apellidos) {
    error = 'Nombre y apellidos son obligatorios';
  } else {
    const id = await crearPaciente(Astro, {
      nombre,
      apellidos,
      telefono: form.get('telefono') as string,
      email: form.get('email') as string,
      fecha_nacimiento: form.get('fecha_nacimiento') as string,
      direccion: form.get('direccion') as string,
      notas: form.get('notas') as string,
      motivo_consulta: form.get('motivo_consulta') as string,
      antecedentes: form.get('antecedentes') as string,
      alergias: form.get('alergias') as string,
      profesion: form.get('profesion') as string,
    });

    // Update origen field (column may not exist yet)
    if (origen) {
      try {
        await db.prepare('UPDATE pacientes SET origen = ? WHERE id = ?').bind(origen, id).run();
      } catch {
        // Column doesn't exist yet, try to create it
        try {
          await db.prepare('ALTER TABLE pacientes ADD COLUMN origen TEXT').run();
          await db.prepare('UPDATE pacientes SET origen = ? WHERE id = ?').bind(origen, id).run();
        } catch { /* ignore if ALTER fails too */ }
      }
    }

    return Astro.redirect(`/admin/pacientes/${id}`);
  }
}
---

<AdminLayout title="Nuevo paciente" activeSection="pacientes">
  <a href="/admin/pacientes" class="back-link">← Volver a pacientes</a>

  {error && <div class="alert alert-error">{error}</div>}

  <div class="card">
    <form method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="nombre">Nombre *</label>
          <input type="text" id="nombre" name="nombre" required>
        </div>
        <div class="form-group">
          <label for="apellidos">Apellidos *</label>
          <input type="text" id="apellidos" name="apellidos" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="telefono">Teléfono</label>
          <input type="tel" id="telefono" name="telefono" placeholder="612345678">
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="fecha_nacimiento">Fecha de nacimiento</label>
          <input type="date" id="fecha_nacimiento" name="fecha_nacimiento">
        </div>
        <div class="form-group">
          <label for="direccion">Dirección</label>
          <input type="text" id="direccion" name="direccion">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="origen">¿Cómo nos encontró?</label>
          <select id="origen" name="origen">
            <option value="">Seleccionar...</option>
            <option value="Google">Google</option>
            <option value="Recomendación">Recomendación</option>
            <option value="Instagram">Instagram</option>
            <option value="Redes sociales">Redes sociales</option>
            <option value="Cartel/Flyer">Cartel/Flyer</option>
            <option value="Repetidor">Repetidor</option>
            <option value="Otro">Otro</option>
          </select>
        </div>
        <div></div>
      </div>

      <details style="margin-bottom:20px;">
        <summary style="cursor:pointer;font-weight:600;font-size:0.9rem;color:var(--admin-primary, #5a7c59);margin-bottom:12px;">Información clínica (opcional)</summary>
        <div class="form-row">
          <div class="form-group">
            <label for="profesion">Profesión</label>
            <input type="text" id="profesion" name="profesion" placeholder="Oficinista, deportista...">
          </div>
          <div class="form-group">
            <label for="motivo_consulta">Motivo de consulta</label>
            <input type="text" id="motivo_consulta" name="motivo_consulta" placeholder="Dolor lumbar, cervical...">
          </div>
        </div>
        <div class="form-group">
          <label for="antecedentes">Antecedentes medicos</label>
          <textarea id="antecedentes" name="antecedentes" placeholder="Cirugias, enfermedades previas..."></textarea>
        </div>
        <div class="form-group">
          <label for="alergias">Alergias / Contraindicaciones</label>
          <textarea id="alergias" name="alergias" placeholder="Alergias a aceites, medicamentos..."></textarea>
        </div>
      </details>

      <div class="form-group">
        <label for="notas">Notas generales</label>
        <textarea id="notas" name="notas" placeholder="Observaciones adicionales..."></textarea>
      </div>

      <div id="duplicado-aviso" style="display:none;" class="alert alert-error">
        <strong>Posible duplicado:</strong> <span id="duplicado-texto"></span>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-primary">Guardar paciente</button>
        <a href="/admin/pacientes" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

<script>
  let checkTimer: any;
  function checkDuplicado() {
    clearTimeout(checkTimer);
    checkTimer = setTimeout(async () => {
      const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
      const apellidos = (document.getElementById('apellidos') as HTMLInputElement).value.trim();
      const telefono = (document.getElementById('telefono') as HTMLInputElement).value.trim();
      const aviso = document.getElementById('duplicado-aviso')!;
      const texto = document.getElementById('duplicado-texto')!;

      if ((!nombre && !apellidos) && !telefono) { aviso.style.display = 'none'; return; }

      const query = telefono || `${nombre} ${apellidos}`.trim();
      if (query.length < 3) { aviso.style.display = 'none'; return; }

      try {
        const res = await fetch(`/api/buscar-paciente?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        if (data.length > 0) {
          texto.innerHTML = data.map((p: any) =>
            `<a href="/admin/pacientes/${p.id}" style="color:inherit;text-decoration:underline;">${p.apellidos}, ${p.nombre}</a> (tel: ${p.telefono || 'sin tel'})`
          ).join(', ');
          aviso.style.display = 'block';
        } else {
          aviso.style.display = 'none';
        }
      } catch { aviso.style.display = 'none'; }
    }, 500);
  }

  document.getElementById('nombre')?.addEventListener('input', checkDuplicado);
  document.getElementById('apellidos')?.addEventListener('input', checkDuplicado);
  document.getElementById('telefono')?.addEventListener('input', checkDuplicado);
</script>
</AdminLayout>
