---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getPaciente, actualizarPaciente, eliminarPaciente, getCitas, getTratamientos } from '../../../lib/db';

const id = Number(Astro.params.id);
let mensaje = '';
let error = '';
const db = (Astro.locals as any).runtime.env.DB;

// Handle DELETE
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'eliminar') {
    await eliminarPaciente(Astro, id);
    return Astro.redirect('/admin/pacientes');
  }

  // Handle UPDATE
  const nombre = form.get('nombre') as string;
  const apellidos = form.get('apellidos') as string;

  if (!nombre || !apellidos) {
    error = 'Nombre y apellidos son obligatorios';
  } else {
    await actualizarPaciente(Astro, id, {
      nombre,
      apellidos,
      telefono: form.get('telefono') as string,
      email: form.get('email') as string,
      fecha_nacimiento: form.get('fecha_nacimiento') as string,
      direccion: form.get('direccion') as string,
      notas: form.get('notas') as string,
    });

    // Update clinical fields
    try {
      await db.prepare('UPDATE pacientes SET motivo_consulta = ?, antecedentes = ?, alergias = ?, profesion = ?, origen = ? WHERE id = ?')
        .bind(
          form.get('motivo_consulta') as string || null,
          form.get('antecedentes') as string || null,
          form.get('alergias') as string || null,
          form.get('profesion') as string || null,
          form.get('origen') as string || null,
          id
        ).run();
    } catch {
      // origen column may not exist, try without it
      try {
        await db.prepare('UPDATE pacientes SET motivo_consulta = ?, antecedentes = ?, alergias = ?, profesion = ? WHERE id = ?')
          .bind(
            form.get('motivo_consulta') as string || null,
            form.get('antecedentes') as string || null,
            form.get('alergias') as string || null,
            form.get('profesion') as string || null,
            id
          ).run();
      } catch { /* columns may not exist yet */ }
    }

    mensaje = 'Paciente actualizado correctamente';
  }
}

const paciente = await getPaciente(Astro, id);
if (!paciente) {
  return Astro.redirect('/admin/pacientes');
}

// Get clinical fields
let clinico = { motivo_consulta: '', antecedentes: '', alergias: '', profesion: '', origen: '' };
try {
  const row = await db.prepare('SELECT motivo_consulta, antecedentes, alergias, profesion, origen FROM pacientes WHERE id = ?').bind(id).first();
  if (row) clinico = row as any;
} catch {
  // origen column may not exist, try without it
  try {
    const row = await db.prepare('SELECT motivo_consulta, antecedentes, alergias, profesion FROM pacientes WHERE id = ?').bind(id).first();
    if (row) clinico = { ...(row as any), origen: '' };
  } catch { /* columns may not exist yet */ }
}

const citas = await getCitas(Astro, undefined, id);
const tratamientos = await getTratamientos(Astro, id);

// Calculate last visit and inactivity
let ultimaVisita: string | null = null;
let diasInactivo = 0;
try {
  const lastRow = await db.prepare("SELECT MAX(fecha) as ultima FROM citas WHERE paciente_id = ? AND estado = 'completada'").bind(id).first();
  if (lastRow?.ultima) {
    ultimaVisita = lastRow.ultima as string;
    diasInactivo = Math.floor((Date.now() - new Date(ultimaVisita).getTime()) / (1000 * 60 * 60 * 24));
  }
} catch { /* ok */ }

// Get notas clínicas and bonos
let notasClinicas: any[] = [];
let bonos: any[] = [];
try {
  notasClinicas = (await db.prepare('SELECT * FROM notas_clinicas WHERE paciente_id = ? ORDER BY fecha DESC').bind(id).all()).results;
} catch { /* table may not exist yet */ }
try {
  bonos = (await db.prepare("SELECT * FROM bonos WHERE paciente_id = ? ORDER BY created_at DESC").bind(id).all()).results;
} catch { /* table may not exist yet */ }
// Patient stats
const citasCompletadas = citas.filter((c: any) => c.estado === 'completada');
const totalVisitas = citasCompletadas.length;
const ingresosPaciente = citasCompletadas.reduce((s: number, c: any) => s + (c.precio || 0), 0);
const ingresosBonos = bonos.reduce((s: number, b: any) => s + (b.precio || 0), 0);
const totalIngresos = ingresosPaciente + ingresosBonos;

// Average frequency (days between visits)
let frecuenciaMedia = 0;
if (citasCompletadas.length >= 2) {
  const fechas = citasCompletadas.map((c: any) => new Date(c.fecha).getTime()).sort();
  const diffs = [];
  for (let i = 1; i < fechas.length; i++) diffs.push((fechas[i] - fechas[i-1]) / (1000*60*60*24));
  frecuenciaMedia = Math.round(diffs.reduce((a, b) => a + b, 0) / diffs.length);
}

// Last treatment for quick repeat
const ultimoTratamiento = tratamientos.length > 0 ? tratamientos[0] : null;
---

<AdminLayout title={`${paciente.nombre} ${paciente.apellidos}`} activeSection="pacientes">
  <a href="/admin/pacientes" class="back-link">&larr; Volver a pacientes</a>

  {mensaje && <div class="alert alert-success">{mensaje}</div>}
  {error && <div class="alert alert-error">{error}</div>}

  <!-- Patient stats -->
  {totalVisitas > 0 && (
    <div class="patient-stats">
      <div class="pstat">
        <span class="pstat-num">{totalVisitas}</span>
        <span class="pstat-label">Visitas</span>
      </div>
      <div class="pstat">
        <span class="pstat-num">{tratamientos.length}</span>
        <span class="pstat-label">Tratamientos</span>
      </div>
      {totalIngresos > 0 && (
        <div class="pstat">
          <span class="pstat-num">{totalIngresos.toFixed(0)}&euro;</span>
          <span class="pstat-label">Ingresos</span>
        </div>
      )}
      {frecuenciaMedia > 0 && (
        <div class="pstat">
          <span class="pstat-num">~{frecuenciaMedia}d</span>
          <span class="pstat-label">Frecuencia</span>
        </div>
      )}
      {bonos.filter((b: any) => b.estado === 'activo').length > 0 && (
        <div class="pstat pstat-bono">
          <span class="pstat-num">{bonos.filter((b: any) => b.estado === 'activo').length}</span>
          <span class="pstat-label">Bonos activos</span>
        </div>
      )}
    </div>
  )}

  <!-- Last visit indicator -->
  {ultimaVisita && (
    <div style={`display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:8px;font-size:0.85rem;margin-bottom:12px;${diasInactivo > 90 ? 'background:#fff3e0;color:#e65100;' : diasInactivo > 30 ? 'background:#e3f2fd;color:#1565c0;' : 'background:#e8f5e9;color:#2e7d32;'}`}>
      <strong>Última visita:</strong> {ultimaVisita}
      {diasInactivo > 90 && <span> — Inactivo {diasInactivo} días</span>}
      {diasInactivo > 30 && diasInactivo <= 90 && <span> — Hace {diasInactivo} días</span>}
      {diasInactivo > 30 && paciente.telefono && (
        <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy de la consulta de osteopatía. ¿Qué tal estás? Hace tiempo que no nos vemos y quería saber cómo te encuentras. Si necesitas una sesión, estoy a tu disposición 😊`)}`} target="_blank" style="margin-left:8px;color:inherit;text-decoration:underline;font-size:0.8rem;">Enviar recordatorio</a>
      )}
    </div>
  )}

  <!-- Contact actions -->
  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
    {paciente.telefono && (
      <div class="wa-dropdown" style="position:relative;">
        <button class="btn btn-whatsapp btn-sm" onclick="document.getElementById('wa-menu').classList.toggle('show')" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          WhatsApp ▾
        </button>
        <div id="wa-menu" class="wa-menu">
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}`} target="_blank" class="wa-item">
            Chat libre
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy de la consulta de osteopatía. Te escribo para recordarte tu próxima cita. ¡Nos vemos pronto!`)}`} target="_blank" class="wa-item">
            Recordatorio de cita
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy. ¿Qué tal te encuentras después de la última sesión? Si tienes alguna duda o necesitas otra cita, aquí estoy 😊`)}`} target="_blank" class="wa-item">
            Seguimiento post-sesión
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy de la consulta de osteopatía. Hace tiempo que no nos vemos y quería saber cómo te encuentras. Si necesitas una sesión, estoy a tu disposición 😊`)}`} target="_blank" class="wa-item">
            Reactivar paciente
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy. Quería comentarte que te quedan pocas sesiones del bono. Si quieres renovarlo o tienes cualquier duda, avísame 😊`)}`} target="_blank" class="wa-item">
            Renovar bono
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`Hola ${paciente.nombre}, soy Katy. Tu opinión es muy importante para mí. Si te ha ido bien el tratamiento, te agradecería mucho una reseña en Google: https://g.page/r/CUVuAD3Rp90PEBE/review ¡Muchas gracias! 😊`)}`} target="_blank" class="wa-item">
            Pedir reseña Google
          </a>
          <a href={`https://wa.me/34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}?text=${encodeURIComponent(`¡Feliz cumpleaños, ${paciente.nombre}! 🎂 Espero que pases un gran día. Un abrazo, Katy.`)}`} target="_blank" class="wa-item">
            Felicitación cumpleaños
          </a>
        </div>
      </div>
    )}
    {paciente.email && (
      <a href={`mailto:${paciente.email}`} class="btn btn-email btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
        Email
      </a>
    )}
    {paciente.telefono && (
      <a href={`tel:+34${paciente.telefono.replace(/\s/g, '').replace(/^\+34/, '')}`} class="btn btn-secondary btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
        Llamar
      </a>
    )}
    <a href={`/admin/citas/nueva?paciente=${id}`} class="btn btn-primary btn-sm">+ Cita</a>
    <a href={`/admin/tratamientos/nuevo?paciente=${id}`} class="btn btn-primary btn-sm">+ Tratamiento</a>
    {ultimoTratamiento && (
      <a href={`/admin/tratamientos/nuevo?paciente=${id}&tipo=${encodeURIComponent(ultimoTratamiento.tipo || '')}&zona=${encodeURIComponent(ultimoTratamiento.zona || '')}`} class="btn btn-secondary btn-sm" title={`Repetir: ${ultimoTratamiento.tipo} (${ultimoTratamiento.zona})`}>
        Repetir ultimo
      </a>
    )}
    <a href={`/admin/historial/nuevo?paciente=${id}`} class="btn btn-primary btn-sm">+ Nota clínica</a>
    <a href={`/admin/bonos/nuevo?paciente=${id}`} class="btn btn-secondary btn-sm">+ Bono</a>
    <a href={`/admin/pacientes/ficha/${id}`} target="_blank" class="btn btn-secondary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 7.234l-.007.003" /></svg>
      Imprimir ficha
    </a>
    <a href={`/admin/consentimiento/${id}`} target="_blank" class="btn btn-secondary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
      Consentimiento
    </a>
  </div>

  <style is:inline>
    .patient-stats {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .pstat {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 10px 16px;
      background: #f8f9fa;
      border-radius: 10px;
      border: 1px solid #e9ecef;
      min-width: 70px;
    }
    .pstat-num {
      font-size: 1.2rem;
      font-weight: 700;
      color: #333;
      line-height: 1;
    }
    .pstat-label {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      color: #888;
      font-weight: 600;
      margin-top: 3px;
    }
    .pstat-bono {
      background: #f0f7f0;
      border-color: #c8e6c9;
    }
    .pstat-bono .pstat-num { color: #2e7d32; }
    .wa-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      z-index: 50;
      min-width: 240px;
      background: white;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      margin-top: 4px;
      overflow: hidden;
    }
    .wa-menu.show { display: block; }
    .wa-item {
      display: block;
      padding: 10px 16px;
      font-size: 0.85rem;
      color: #333;
      text-decoration: none;
      border-bottom: 1px solid #f0f0f0;
      transition: background 0.15s;
    }
    .wa-item:last-child { border-bottom: none; }
    .wa-item:hover { background: #f0f7f0; color: #25D366; }
  </style>
  <script is:inline>
    document.addEventListener('click', function(e) {
      const menu = document.getElementById('wa-menu');
      if (menu && !e.target.closest('.wa-dropdown')) {
        menu.classList.remove('show');
      }
    });
  </script>

  <!-- Ficha del paciente -->
  <div class="card" style="margin-bottom:24px;">
    <h2 style="font-size:1rem;font-weight:600;margin-bottom:16px;">Datos del paciente</h2>
    <form method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="nombre">Nombre *</label>
          <input type="text" id="nombre" name="nombre" value={paciente.nombre} required>
        </div>
        <div class="form-group">
          <label for="apellidos">Apellidos *</label>
          <input type="text" id="apellidos" name="apellidos" value={paciente.apellidos} required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="telefono">Teléfono</label>
          <input type="tel" id="telefono" name="telefono" value={paciente.telefono || ''}>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" value={paciente.email || ''}>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="fecha_nacimiento">Fecha de nacimiento</label>
          <input type="date" id="fecha_nacimiento" name="fecha_nacimiento" value={paciente.fecha_nacimiento || ''}>
        </div>
        <div class="form-group">
          <label for="direccion">Dirección</label>
          <input type="text" id="direccion" name="direccion" value={paciente.direccion || ''}>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="profesion">Profesión</label>
          <input type="text" id="profesion" name="profesion" value={clinico.profesion || ''}>
        </div>
        <div class="form-group">
          <label for="origen">¿Cómo nos encontró?</label>
          <select id="origen" name="origen">
            <option value="">Seleccionar...</option>
            <option value="Google" selected={clinico.origen === 'Google'}>Google</option>
            <option value="Recomendación" selected={clinico.origen === 'Recomendación'}>Recomendación</option>
            <option value="Instagram" selected={clinico.origen === 'Instagram'}>Instagram</option>
            <option value="Redes sociales" selected={clinico.origen === 'Redes sociales'}>Redes sociales</option>
            <option value="Cartel/Flyer" selected={clinico.origen === 'Cartel/Flyer'}>Cartel/Flyer</option>
            <option value="Repetidor" selected={clinico.origen === 'Repetidor'}>Repetidor</option>
            <option value="Otro" selected={clinico.origen === 'Otro'}>Otro</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="notas">Notas generales</label>
        <textarea id="notas" name="notas">{paciente.notas || ''}</textarea>
      </div>

      <h3 style="font-size:0.95rem;font-weight:600;margin:20px 0 12px;color:var(--admin-primary);">Información clínica</h3>

      <div class="form-group">
        <label for="motivo_consulta">Motivo de consulta principal</label>
        <textarea id="motivo_consulta" name="motivo_consulta" placeholder="Dolor lumbar, cervicalgias, etc.">{clinico.motivo_consulta || ''}</textarea>
      </div>

      <div class="form-group">
        <label for="antecedentes">Antecedentes médicos</label>
        <textarea id="antecedentes" name="antecedentes" placeholder="Cirugías, enfermedades previas, medicación...">{clinico.antecedentes || ''}</textarea>
      </div>

      <div class="form-group">
        <label for="alergias">Alergias / Contraindicaciones</label>
        <textarea id="alergias" name="alergias" placeholder="Alergias, medicamentos, contraindicaciones...">{clinico.alergias || ''}</textarea>
      </div>

      <div style="display:flex;gap:12px;align-items:center;">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
      </div>
    </form>

    <!-- Delete form -->
    <form method="POST" style="margin-top:24px;padding-top:16px;border-top:1px solid #eee;" onsubmit="return confirm('¿Estás segura de que quieres eliminar este paciente? Se eliminarán también sus citas y tratamientos.')">
      <input type="hidden" name="_action" value="eliminar">
      <button type="submit" class="btn btn-danger btn-sm">Eliminar paciente</button>
    </form>
  </div>

  <!-- Historial de citas -->
  <div class="card" style="margin-bottom:24px;">
    <div class="page-header">
      <h2 style="font-size:1rem;font-weight:600;">Citas ({citas.length})</h2>
      <a href={`/admin/citas/nueva?paciente=${id}`} class="btn btn-primary btn-sm">+ Nueva cita</a>
    </div>

    {citas.length === 0 ? (
      <p style="color:#666;font-size:0.9rem;">Sin citas registradas</p>
    ) : (
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Servicio</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {citas.map((c) => (
              <tr>
                <td>{c.fecha}</td>
                <td>{c.hora}</td>
                <td>{c.servicio || '-'}</td>
                <td><span class={`badge badge-${c.estado}`}>{c.estado}</span></td>
                <td><a href={`/admin/citas/${c.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Historial de tratamientos -->
  <div class="card" style="margin-bottom:24px;">
    <div class="page-header">
      <h2 style="font-size:1rem;font-weight:600;">Tratamientos ({tratamientos.length})</h2>
      <a href={`/admin/tratamientos/nuevo?paciente=${id}`} class="btn btn-primary btn-sm">+ Nuevo tratamiento</a>
    </div>

    {tratamientos.length === 0 ? (
      <p style="color:#666;font-size:0.9rem;">Sin tratamientos registrados</p>
    ) : (
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Tipo</th>
              <th>Zona</th>
              <th>Observaciones</th>
            </tr>
          </thead>
          <tbody>
            {tratamientos.map((t) => (
              <tr>
                <td>{t.fecha}</td>
                <td>{t.tipo}</td>
                <td>{t.zona || '-'}</td>
                <td style="max-width:350px;">
                  {t.observaciones ? (
                    t.observaciones.length > 60 ? (
                      <details style="cursor:pointer;">
                        <summary style="font-size:0.85rem;color:#555;list-style:none;">{t.observaciones.substring(0, 60)}...</summary>
                        <p style="margin-top:6px;font-size:0.85rem;color:#333;line-height:1.5;white-space:pre-wrap;background:#f9f9f9;padding:8px;border-radius:6px;">{t.observaciones}</p>
                      </details>
                    ) : <span style="font-size:0.85rem;color:#555;">{t.observaciones}</span>
                  ) : '-'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Notas clínicas -->
  {notasClinicas.length > 0 && (
    <div class="card" style="margin-bottom:24px;">
      <div class="page-header">
        <h2 style="font-size:1rem;font-weight:600;">Notas clínicas ({notasClinicas.length})</h2>
        <a href={`/admin/historial/nuevo?paciente=${id}`} class="btn btn-primary btn-sm">+ Nueva nota</a>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Motivo</th>
              <th>Diagnóstico</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {notasClinicas.map((n: any) => (
              <tr>
                <td>{n.fecha}</td>
                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{n.motivo || '-'}</td>
                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{n.diagnostico || '-'}</td>
                <td><a href={`/admin/historial/${n.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- Bonos -->
  {bonos.length > 0 && (
    <div class="card">
      <div class="page-header">
        <h2 style="font-size:1rem;font-weight:600;">Bonos ({bonos.length})</h2>
        <a href={`/admin/bonos/nuevo?paciente=${id}`} class="btn btn-primary btn-sm">+ Nuevo bono</a>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Bono</th>
              <th>Sesiones</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {bonos.map((b: any) => (
              <tr>
                <td>{b.nombre}</td>
                <td>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div style={`width:80px;height:8px;background:#e0e0e0;border-radius:4px;overflow:hidden;`}>
                      <div style={`width:${Math.min(100, (b.sesiones_usadas / b.sesiones_total) * 100)}%;height:100%;background:${b.sesiones_usadas >= b.sesiones_total ? '#e65100' : b.sesiones_usadas / b.sesiones_total >= 0.8 ? '#f9a825' : '#2e7d32'};border-radius:4px;`}></div>
                    </div>
                    <span>{b.sesiones_usadas} / {b.sesiones_total}</span>
                  </div>
                </td>
                <td><span class={`badge badge-${b.estado === 'activo' ? 'confirmada' : b.estado === 'completado' ? 'completada' : 'cancelada'}`}>{b.estado}</span></td>
                <td><a href={`/admin/bonos/${b.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
