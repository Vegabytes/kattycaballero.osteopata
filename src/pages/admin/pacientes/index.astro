---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getPacientes } from '../../../lib/db';

const buscar = Astro.url.searchParams.get('buscar') || '';
const pacientes = await getPacientes(Astro, buscar || undefined);
---

<AdminLayout title="Pacientes" activeSection="pacientes">
  <div class="page-header">
    <h2>Pacientes ({pacientes.length})</h2>
    <a href="/admin/pacientes/nuevo" class="btn btn-primary">+ Nuevo paciente</a>
  </div>

  <form class="search-bar" method="GET">
    <input type="text" name="buscar" placeholder="Buscar por nombre, apellidos o teléfono..." value={buscar}>
    <button type="submit" class="btn btn-secondary">Buscar</button>
    {buscar && <a href="/admin/pacientes" class="btn btn-secondary">Limpiar</a>}
  </form>

  {pacientes.length === 0 ? (
    <div class="card empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
      <p>{buscar ? 'No se encontraron pacientes' : 'Aún no hay pacientes registrados'}</p>
      <a href="/admin/pacientes/nuevo" class="btn btn-primary">Añadir primer paciente</a>
    </div>
  ) : (
    <div class="card">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Teléfono</th>
              <th>Email</th>
              <th>Contactar</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {pacientes.map((p) => (
              <tr>
                <td>
                  <a href={`/admin/pacientes/${p.id}`}>
                    <strong>{p.apellidos}, {p.nombre}</strong>
                  </a>
                </td>
                <td>{p.telefono || '-'}</td>
                <td>{p.email || '-'}</td>
                <td>
                  <div class="contact-actions">
                    {p.telefono && (
                      <a href={`https://wa.me/34${p.telefono.replace(/\s/g, '').replace(/^\+34/, '')}`} target="_blank" class="btn btn-whatsapp btn-sm" title="WhatsApp">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                      </a>
                    )}
                    {p.email && (
                      <a href={`mailto:${p.email}`} class="btn btn-email btn-sm" title="Email">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                      </a>
                    )}
                  </div>
                </td>
                <td>
                  <a href={`/admin/pacientes/${p.id}`} class="btn btn-secondary btn-sm">Ver ficha</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
