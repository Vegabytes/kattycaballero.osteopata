---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getNotasClinicas } from '../../../lib/db';

const pacienteId = Astro.url.searchParams.get('paciente');
let notas: any[] = [];
let dbError = '';

try {
  notas = await getNotasClinicas(Astro, pacienteId ? Number(pacienteId) : undefined);
} catch (e: any) {
  dbError = e.message;
  console.error('DB error in historial:', e);
}
---

<AdminLayout title="Historial clínico" activeSection="historial">
  {dbError && (
    <div class="alert alert-error">
      <strong>Error de base de datos:</strong> {dbError}
      <br><small>Verifica que D1 esté vinculado en Cloudflare Pages → Settings → Functions → D1 database bindings.</small>
    </div>
  )}
  <div class="page-header">
    <h2>Notas clínicas ({notas.length})</h2>
    <a href="/admin/historial/nuevo" class="btn btn-primary">+ Nueva nota clínica</a>
  </div>

  {pacienteId && (
    <div class="alert alert-info">
      Filtrando por paciente. <a href="/admin/historial">Ver todos</a>
    </div>
  )}

  {notas.length === 0 ? (
    <div class="card empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
      <p>Sin notas clínicas registradas</p>
      <a href="/admin/historial/nuevo" class="btn btn-primary">Registrar primera nota clínica</a>
    </div>
  ) : (
    <div class="card">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Paciente</th>
              <th>Motivo</th>
              <th>Diagnóstico</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {notas.map((n) => (
              <tr>
                <td>{n.fecha}</td>
                <td>
                  <a href={`/admin/pacientes/${n.paciente_id}`}>
                    {n.paciente_nombre} {n.paciente_apellidos}
                  </a>
                </td>
                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  {n.motivo || '-'}
                </td>
                <td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  {n.diagnostico || '-'}
                </td>
                <td><a href={`/admin/historial/${n.id}`} class="btn btn-secondary btn-sm">Ver</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
