---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { crearNotaClinica, getPacientes } from '../../../lib/db';

const pacientes = await getPacientes(Astro);
const pacienteId = Astro.url.searchParams.get('paciente') || '';
const citaId = Astro.url.searchParams.get('cita') || '';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const paciente_id = Number(form.get('paciente_id'));
  const fecha = form.get('fecha') as string;

  if (!paciente_id || !fecha) {
    error = 'Paciente y fecha son obligatorios';
  } else {
    await crearNotaClinica(Astro, {
      paciente_id,
      cita_id: form.get('cita_id') ? Number(form.get('cita_id')) : null,
      fecha,
      motivo: form.get('motivo') as string,
      exploracion: form.get('exploracion') as string,
      diagnostico: form.get('diagnostico') as string,
      tratamiento_realizado: form.get('tratamiento_realizado') as string,
      recomendaciones: form.get('recomendaciones') as string,
    });
    return Astro.redirect(`/admin/pacientes/${paciente_id}`);
  }
}
---

<AdminLayout title="Nueva nota clínica" activeSection="historial">
  <a href="/admin/historial" class="back-link">← Volver a historial clínico</a>

  {error && <div class="alert alert-error">{error}</div>}

  <div class="card">
    <form method="POST">
      {citaId && <input type="hidden" name="cita_id" value={citaId}>}

      <div class="form-row">
        <div class="form-group">
          <label for="paciente_id">Paciente *</label>
          <select id="paciente_id" name="paciente_id" required>
            <option value="">Seleccionar paciente...</option>
            {pacientes.map((p) => (
              <option value={p.id} selected={String(p.id) === pacienteId}>
                {p.apellidos}, {p.nombre}
              </option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="fecha">Fecha *</label>
          <input type="date" id="fecha" name="fecha" value={new Date().toISOString().split('T')[0]} required>
        </div>
      </div>

      <div class="form-group">
        <label for="motivo">Motivo de consulta</label>
        <input type="text" id="motivo" name="motivo" placeholder="Motivo principal de la consulta...">
      </div>

      <div class="form-group">
        <label for="exploracion">Exploración / Hallazgos</label>
        <textarea id="exploracion" name="exploracion" placeholder="Hallazgos de la exploración física..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="diagnostico">Diagnóstico / Impresión clínica</label>
        <textarea id="diagnostico" name="diagnostico" placeholder="Diagnóstico o impresión clínica..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="tratamiento_realizado">Tratamiento realizado</label>
        <textarea id="tratamiento_realizado" name="tratamiento_realizado" placeholder="Técnicas y procedimientos aplicados..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="recomendaciones">Recomendaciones / Ejercicios para casa</label>
        <textarea id="recomendaciones" name="recomendaciones" placeholder="Recomendaciones, ejercicios, pautas para el paciente..." style="min-height:120px;"></textarea>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-primary">Guardar nota clínica</button>
        <a href="/admin/historial" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</AdminLayout>
