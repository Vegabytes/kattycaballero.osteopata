---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { crearNotaClinica, getPacientes } from '../../../lib/db';

const pacientes = await getPacientes(Astro);
const pacienteId = Astro.url.searchParams.get('paciente') || '';
const citaId = Astro.url.searchParams.get('cita') || '';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const paciente_id = Number(form.get('paciente_id'));
  const fecha = form.get('fecha') as string;

  if (!paciente_id || !fecha) {
    error = 'Paciente y fecha son obligatorios';
  } else {
    await crearNotaClinica(Astro, {
      paciente_id,
      cita_id: form.get('cita_id') ? Number(form.get('cita_id')) : null,
      fecha,
      motivo: form.get('motivo') as string,
      exploracion: form.get('exploracion') as string,
      diagnostico: form.get('diagnostico') as string,
      tratamiento_realizado: form.get('tratamiento_realizado') as string,
      recomendaciones: form.get('recomendaciones') as string,
    });
    return Astro.redirect(`/admin/pacientes/${paciente_id}`);
  }
}
---

<AdminLayout title="Nueva nota clínica" activeSection="historial">
  <a href="/admin/historial" class="back-link">← Volver a historial clínico</a>

  {error && <div class="alert alert-error">{error}</div>}

  <div class="card">
    <form method="POST">
      {citaId && <input type="hidden" name="cita_id" value={citaId}>}

      <div style="margin-bottom:24px;padding:16px;background:#f0f7f0;border-radius:8px;border:1px solid #e0e8e0;">
        <label style="display:block;font-weight:600;margin-bottom:8px;font-size:0.85rem;color:#4a6548;">Plantilla rápida (opcional)</label>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          <button type="button" class="template-btn" data-template="cervicalgia" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Cervicalgia</button>
          <button type="button" class="template-btn" data-template="lumbalgia" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Lumbalgia</button>
          <button type="button" class="template-btn" data-template="hombro" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Hombro</button>
          <button type="button" class="template-btn" data-template="deportivo" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Masaje deportivo</button>
          <button type="button" class="template-btn" data-template="embarazo" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Embarazo</button>
          <button type="button" class="template-btn" data-template="valoracion" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Valoración inicial</button>
          <button type="button" class="template-btn" data-template="seguimiento" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;font-family:inherit;">Seguimiento</button>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="paciente_id">Paciente *</label>
          <select id="paciente_id" name="paciente_id" required>
            <option value="">Seleccionar paciente...</option>
            {pacientes.map((p) => (
              <option value={p.id} selected={String(p.id) === pacienteId}>
                {p.apellidos}, {p.nombre}
              </option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="fecha">Fecha *</label>
          <input type="date" id="fecha" name="fecha" value={new Date().toISOString().split('T')[0]} required>
        </div>
      </div>

      <div class="form-group">
        <label for="motivo">Motivo de consulta</label>
        <input type="text" id="motivo" name="motivo" placeholder="Motivo principal de la consulta...">
      </div>

      <div class="form-group">
        <label for="exploracion">Exploración / Hallazgos</label>
        <textarea id="exploracion" name="exploracion" placeholder="Hallazgos de la exploración física..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="diagnostico">Diagnóstico / Impresión clínica</label>
        <textarea id="diagnostico" name="diagnostico" placeholder="Diagnóstico o impresión clínica..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="tratamiento_realizado">Tratamiento realizado</label>
        <textarea id="tratamiento_realizado" name="tratamiento_realizado" placeholder="Técnicas y procedimientos aplicados..." style="min-height:120px;"></textarea>
      </div>

      <div class="form-group">
        <label for="recomendaciones">Recomendaciones / Ejercicios para casa</label>
        <textarea id="recomendaciones" name="recomendaciones" placeholder="Recomendaciones, ejercicios, pautas para el paciente..." style="min-height:120px;"></textarea>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-primary">Guardar nota clínica</button>
        <a href="/admin/historial" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

  <script is:inline>
    const templates = {
      cervicalgia: {
        motivo: 'Dolor cervical',
        exploracion: 'Restricción movilidad cervical. Contractura trapecio bilateral. Puntos gatillo en ECOM y escalenos.',
        diagnostico: 'Cervicalgia mecánica con componente muscular',
        tratamiento_realizado: 'Técnicas de tejido blando en trapecio y ECOM. Manipulación cervical C3-C4. Stretching musculatura cervical posterior. Técnica de inhibición suboccipital.',
        recomendaciones: 'Ejercicios de movilización cervical suave (10 rep x 3/día). Evitar posiciones mantenidas >30 min. Aplicar calor local 15 min antes de dormir. Revisar ergonomía del puesto de trabajo.'
      },
      lumbalgia: {
        motivo: 'Dolor lumbar',
        exploracion: 'Restricción flexión lumbar. Hipertonía cuadrado lumbar y paravertebrales. Test de Lasègue negativo bilateral.',
        diagnostico: 'Lumbalgia mecánica inespecífica',
        tratamiento_realizado: 'Técnicas de tejido blando en cuadrado lumbar y paravertebrales. Manipulación L4-L5. Técnica de energía muscular en psoas. Stretching isquiotibiales.',
        recomendaciones: 'Ejercicios de estabilización lumbar (puente, plancha). Caminar 30 min/día. Evitar sedestación prolongada. Aplicar frío si dolor agudo, calor si contractura.'
      },
      hombro: {
        motivo: 'Dolor de hombro',
        exploracion: 'Limitación ABD y RE del hombro. Dolor en arco doloroso 60-120°. Test de Neer positivo. Contractura infraespinoso y deltoides.',
        diagnostico: 'Síndrome subacromial / Tendinopatía del manguito rotador',
        tratamiento_realizado: 'Técnicas miofasciales en manguito rotador. Movilización glenohumeral. Técnica de Jones en infraespinoso. Ejercicios de Codman.',
        recomendaciones: 'Ejercicios pendulares de Codman (3x/día). Ejercicios de rotación externa con goma elástica. No cargar peso con el brazo afecto. Evitar movimientos por encima de la cabeza.'
      },
      deportivo: {
        motivo: 'Recuperación deportiva / Contractura muscular',
        exploracion: 'Hipertonía muscular generalizada. Puntos gatillo en zona afectada. Restricción de movilidad articular asociada.',
        diagnostico: 'Contractura muscular post-esfuerzo',
        tratamiento_realizado: 'Masaje deportivo profundo. Técnicas de compresión isquémica en puntos gatillo. Stretching analítico. Crioterapia local.',
        recomendaciones: 'Hidratación abundante post-sesión. Stretching suave 24-48h post-tratamiento. Aplicar hielo 15 min si molestia. Vuelta gradual a la actividad deportiva.'
      },
      embarazo: {
        motivo: 'Molestias propias del embarazo',
        exploracion: 'Valoración postural adaptada al trimestre. Tensión en musculatura lumbar y piramidal. Edema leve en MMII.',
        diagnostico: 'Adaptaciones musculoesqueléticas del embarazo',
        tratamiento_realizado: 'Masaje prenatal en decúbito lateral. Técnicas suaves de tejido blando en lumbar y ciática. Drenaje linfático en MMII. Técnicas de relajación diafragmática.',
        recomendaciones: 'Ejercicios de Kegel. Caminar a ritmo suave. Posición lateral para dormir con cojín entre piernas. Evitar permanecer mucho tiempo de pie. Próxima sesión recomendada en 2-3 semanas.'
      },
      valoracion: {
        motivo: 'Primera visita - Valoración inicial',
        exploracion: 'Anamnesis completa. Valoración postural estática y dinámica. Palpación tisular. Tests ortopédicos específicos según zona de queja.',
        diagnostico: '',
        tratamiento_realizado: 'Tratamiento inicial según hallazgos de la exploración.',
        recomendaciones: 'Se recomienda seguimiento en 1-2 semanas para valorar evolución. Se pautan ejercicios específicos según diagnóstico.'
      },
      seguimiento: {
        motivo: 'Seguimiento',
        exploracion: 'Reevaluación de la zona tratada. Comparación con sesión anterior.',
        diagnostico: 'En evolución - mejoría / sin cambios / empeoramiento',
        tratamiento_realizado: '',
        recomendaciones: 'Continuar con ejercicios pautados. Próxima revisión según evolución.'
      }
    };

    document.querySelectorAll('.template-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = btn.getAttribute('data-template');
        var t = templates[key];
        if (!t) return;

        var motivo = document.getElementById('motivo');
        var exploracion = document.getElementById('exploracion');
        var diagnostico = document.getElementById('diagnostico');
        var tratamiento = document.getElementById('tratamiento_realizado');
        var recomendaciones = document.getElementById('recomendaciones');

        if (motivo) motivo.value = t.motivo;
        if (exploracion) exploracion.value = t.exploracion;
        if (diagnostico) diagnostico.value = t.diagnostico;
        if (tratamiento) tratamiento.value = t.tratamiento_realizado;
        if (recomendaciones) recomendaciones.value = t.recomendaciones;

        document.querySelectorAll('.template-btn').forEach(function(b) { b.style.borderColor = '#ddd'; b.style.background = 'white'; });
        btn.style.borderColor = '#5a7c59';
        btn.style.background = '#f0f7f0';
      });
    });
  </script>
</AdminLayout>
