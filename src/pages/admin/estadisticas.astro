export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const db = (Astro.locals as any).runtime.env.DB;

// --- Summary cards ---
let totalPacientes = 0;
let totalCitas = 0;
let totalIngresos = 0;
let mediaIngreso = 0;

try {
  const r1 = await db.prepare("SELECT COUNT(*) as total FROM pacientes").first();
  totalPacientes = (r1 as any)?.total || 0;
} catch (e: any) {
  console.error('Stats: error totalPacientes', e);
}

try {
  const r2 = await db.prepare("SELECT COUNT(*) as total FROM citas").first();
  totalCitas = (r2 as any)?.total || 0;
} catch (e: any) {
  console.error('Stats: error totalCitas', e);
}

try {
  const r3 = await db.prepare("SELECT COALESCE(SUM(precio), 0) as total, COALESCE(AVG(precio), 0) as media FROM citas WHERE estado = 'completada' AND precio > 0").first();
  totalIngresos = (r3 as any)?.total || 0;
  mediaIngreso = (r3 as any)?.media || 0;
} catch (e: any) {
  console.error('Stats: error ingresos', e);
}

// --- Monthly income (last 6 months) ---
interface MonthData { mes: string; total: number; }
let ingresosMensuales: MonthData[] = [];

try {
  const rows = await db.prepare(`
    SELECT strftime('%Y-%m', fecha) as mes, COALESCE(SUM(precio), 0) as total
    FROM citas
    WHERE estado = 'completada' AND precio > 0
      AND fecha >= date('now', '-6 months')
    GROUP BY strftime('%Y-%m', fecha)
    ORDER BY mes ASC
  `).all();
  ingresosMensuales = (rows.results || []) as MonthData[];
} catch (e: any) {
  console.error('Stats: error ingresosMensuales', e);
}

// --- New patients per month (last 6 months) ---
let pacientesMensuales: MonthData[] = [];

try {
  const rows = await db.prepare(`
    SELECT strftime('%Y-%m', created_at) as mes, COUNT(*) as total
    FROM pacientes
    WHERE created_at >= date('now', '-6 months')
    GROUP BY strftime('%Y-%m', created_at)
    ORDER BY mes ASC
  `).all();
  pacientesMensuales = (rows.results || []) as MonthData[];
} catch (e: any) {
  console.error('Stats: error pacientesMensuales', e);
}

// --- Top 5 services ---
interface ServiceData { servicio: string; total: number; }
let topServicios: ServiceData[] = [];

try {
  const rows = await db.prepare(`
    SELECT servicio, COUNT(*) as total
    FROM citas
    WHERE servicio IS NOT NULL AND servicio != ''
    GROUP BY servicio
    ORDER BY total DESC
    LIMIT 5
  `).all();
  topServicios = (rows.results || []) as ServiceData[];
} catch (e: any) {
  console.error('Stats: error topServicios', e);
}

// --- Income by service ---
interface ServiceIncomeData { servicio: string; total: number; count: number; }
let ingresosPorServicio: ServiceIncomeData[] = [];

try {
  const rows = await db.prepare(`
    SELECT servicio, COALESCE(SUM(precio), 0) as total, COUNT(*) as count
    FROM citas
    WHERE estado = 'completada' AND precio > 0 AND servicio IS NOT NULL AND servicio != ''
    GROUP BY servicio
    ORDER BY total DESC
  `).all();
  ingresosPorServicio = (rows.results || []) as ServiceIncomeData[];
} catch (e: any) {
  console.error('Stats: error ingresosPorServicio', e);
}

// --- Citas by status ---
interface StatusData { estado: string; total: number; }
let citasPorEstado: StatusData[] = [];

try {
  const rows = await db.prepare(`
    SELECT estado, COUNT(*) as total
    FROM citas
    GROUP BY estado
    ORDER BY total DESC
  `).all();
  citasPorEstado = (rows.results || []) as StatusData[];
} catch (e: any) {
  console.error('Stats: error citasPorEstado', e);
}

const estadoLabels: Record<string, string> = {
  pendiente: 'Pendiente',
  confirmada: 'Confirmada',
  completada: 'Completada',
  cancelada: 'Cancelada',
};
const estadoColors: Record<string, string> = {
  pendiente: '#ff9800',
  confirmada: '#2196f3',
  completada: '#4caf50',
  cancelada: '#f44336',
};

// --- Helpers ---
const meses: Record<string, string> = {
  '01': 'Ene', '02': 'Feb', '03': 'Mar', '04': 'Abr',
  '05': 'May', '06': 'Jun', '07': 'Jul', '08': 'Ago',
  '09': 'Sep', '10': 'Oct', '11': 'Nov', '12': 'Dic'
};

function mesLabel(ym: string): string {
  const parts = ym.split('-');
  return (meses[parts[1]] || parts[1]) + ' ' + parts[0].slice(2);
}

const maxIngreso = ingresosMensuales.length > 0 ? Math.max(...ingresosMensuales.map(m => m.total)) : 1;
const maxPacientes = pacientesMensuales.length > 0 ? Math.max(...pacientesMensuales.map(m => m.total)) : 1;
const maxServicio = topServicios.length > 0 ? Math.max(...topServicios.map(s => s.total)) : 1;

const barColors = ['#5a7c59', '#7a9c79', '#c4a35a', '#2196f3', '#ff9800', '#f44336'];

// --- Patient origin (donut chart) ---
interface OrigenData { origen: string; total: number; }
let origenes: OrigenData[] = [];

try {
  const rows = await db.prepare(`
    SELECT origen, COUNT(*) as total
    FROM pacientes
    WHERE origen IS NOT NULL AND origen != ''
    GROUP BY origen
    ORDER BY total DESC
  `).all();
  origenes = (rows.results || []) as OrigenData[];
} catch (e: any) {
  console.error('Stats: error origenes', e);
}

const origenColors = ['#5a7c59', '#c4a35a', '#2196f3', '#ff9800', '#7a9c79', '#f44336', '#9c27b0', '#00bcd4', '#795548', '#607d8b'];
const totalOrigenes = origenes.reduce((sum, o) => sum + o.total, 0);

// --- Heatmap: horas punta por día y hora ---
interface HeatmapData { dia: number; hora: number; total: number; }
let heatmapData: HeatmapData[] = [];

try {
  const rows = await db.prepare(`
    SELECT CAST(strftime('%w', fecha) AS INTEGER) as dia,
           CAST(substr(hora, 1, 2) AS INTEGER) as hora,
           COUNT(*) as total
    FROM citas
    WHERE estado IN ('completada', 'confirmada', 'pendiente') AND hora IS NOT NULL
    GROUP BY dia, hora
    ORDER BY dia, hora
  `).all();
  heatmapData = (rows.results || []) as HeatmapData[];
} catch (e: any) {
  console.error('Stats: error heatmap', e);
}

// Build heatmap grid: rows = hours (8-21), cols = days (1-6, Mon-Sat)
const heatmapHoras = Array.from({ length: 14 }, (_, i) => i + 8); // 8:00 - 21:00
const heatmapDias = [1, 2, 3, 4, 5, 6]; // Mon-Sat (strftime %w: 0=Sun, 1=Mon...)
const heatmapDiasLabels = ['L', 'M', 'X', 'J', 'V', 'S'];
const heatmapMap: Record<string, number> = {};
let heatmapMax = 1;
for (const row of heatmapData) {
  const key = `${row.dia}-${row.hora}`;
  heatmapMap[key] = row.total;
  if (row.total > heatmapMax) heatmapMax = row.total;
}

// --- Retención de pacientes ---
let pacientesUnaVisita = 0;
let pacientesRepiten = 0;

try {
  const r = await db.prepare(`
    SELECT
      SUM(CASE WHEN cnt = 1 THEN 1 ELSE 0 END) as una_visita,
      SUM(CASE WHEN cnt > 1 THEN 1 ELSE 0 END) as repiten
    FROM (
      SELECT paciente_id, COUNT(*) as cnt
      FROM citas WHERE estado = 'completada'
      GROUP BY paciente_id
    )
  `).first();
  pacientesUnaVisita = (r as any)?.una_visita || 0;
  pacientesRepiten = (r as any)?.repiten || 0;
} catch (e: any) {
  console.error('Stats: error retención', e);
}

const totalConVisita = pacientesUnaVisita + pacientesRepiten;
const tasaRetencion = totalConVisita > 0 ? Math.round((pacientesRepiten / totalConVisita) * 100) : 0;

// Distribución por número de visitas
interface VisitasDist { visitas: string; total: number; }
let distribucionVisitas: VisitasDist[] = [];

try {
  const rows = await db.prepare(`
    SELECT
      CASE
        WHEN cnt = 1 THEN '1 visita'
        WHEN cnt BETWEEN 2 AND 3 THEN '2-3 visitas'
        WHEN cnt BETWEEN 4 AND 6 THEN '4-6 visitas'
        WHEN cnt BETWEEN 7 AND 12 THEN '7-12 visitas'
        ELSE '13+ visitas'
      END as visitas,
      COUNT(*) as total
    FROM (
      SELECT paciente_id, COUNT(*) as cnt
      FROM citas WHERE estado = 'completada'
      GROUP BY paciente_id
    )
    GROUP BY visitas
    ORDER BY MIN(cnt)
  `).all();
  distribucionVisitas = (rows.results || []) as VisitasDist[];
} catch (e: any) {
  console.error('Stats: error distribución visitas', e);
}

const maxDistVisitas = distribucionVisitas.length > 0 ? Math.max(...distribucionVisitas.map(d => d.total)) : 1;

// --- Top pacientes por valor (ingresos citas + bonos) ---
interface TopPaciente { nombre: string; apellidos: string; id: number; ingresos_citas: number; ingresos_bonos: number; total: number; visitas: number; }
let topPacientes: TopPaciente[] = [];

try {
  const rows = await db.prepare(`
    SELECT
      p.nombre, p.apellidos, p.id,
      COALESCE(c.ingresos, 0) as ingresos_citas,
      COALESCE(b.ingresos, 0) as ingresos_bonos,
      COALESCE(c.ingresos, 0) + COALESCE(b.ingresos, 0) as total,
      COALESCE(c.visitas, 0) as visitas
    FROM pacientes p
    LEFT JOIN (
      SELECT paciente_id, SUM(precio) as ingresos, COUNT(*) as visitas
      FROM citas WHERE estado = 'completada' AND precio > 0
      GROUP BY paciente_id
    ) c ON c.paciente_id = p.id
    LEFT JOIN (
      SELECT paciente_id, SUM(precio) as ingresos
      FROM bonos WHERE precio > 0
      GROUP BY paciente_id
    ) b ON b.paciente_id = p.id
    WHERE COALESCE(c.ingresos, 0) + COALESCE(b.ingresos, 0) > 0
    ORDER BY total DESC
    LIMIT 10
  `).all();
  topPacientes = (rows.results || []) as TopPaciente[];
} catch (e: any) {
  console.error('Stats: error topPacientes', e);
}

// --- Motivos de cancelación ---
interface MotivoCancelacion { motivo_cancelacion: string; total: number; }
let motivosCancelacion: MotivoCancelacion[] = [];

try {
  const rows = await db.prepare(`
    SELECT COALESCE(motivo_cancelacion, 'Sin motivo') as motivo_cancelacion, COUNT(*) as total
    FROM citas
    WHERE estado IN ('cancelada', 'no_show') AND motivo_cancelacion IS NOT NULL AND motivo_cancelacion != ''
    GROUP BY motivo_cancelacion
    ORDER BY total DESC
  `).all();
  motivosCancelacion = (rows.results || []) as MotivoCancelacion[];
} catch { /* column may not exist yet */ }

let totalCancelaciones = 0;
let totalNoShow = 0;
try {
  const r = await db.prepare(`
    SELECT
      SUM(CASE WHEN estado = 'cancelada' THEN 1 ELSE 0 END) as canceladas,
      SUM(CASE WHEN estado = 'no_show' THEN 1 ELSE 0 END) as no_show
    FROM citas
  `).first();
  totalCancelaciones = (r as any)?.canceladas || 0;
  totalNoShow = (r as any)?.no_show || 0;
} catch {}

// Compute donut arcs
function describeArc(cx: number, cy: number, r: number, startAngle: number, endAngle: number): string {
  const startRad = (startAngle - 90) * Math.PI / 180;
  const endRad = (endAngle - 90) * Math.PI / 180;
  const x1 = cx + r * Math.cos(startRad);
  const y1 = cy + r * Math.sin(startRad);
  const x2 = cx + r * Math.cos(endRad);
  const y2 = cy + r * Math.sin(endRad);
  const largeArc = (endAngle - startAngle) > 180 ? 1 : 0;
  return `M ${x1} ${y1} A ${r} ${r} 0 ${largeArc} 1 ${x2} ${y2}`;
}

interface ArcData { path: string; color: string; label: string; total: number; pct: number; }
let arcs: ArcData[] = [];
if (totalOrigenes > 0) {
  let currentAngle = 0;
  arcs = origenes.map((o, i) => {
    const pct = o.total / totalOrigenes;
    const angle = pct * 360;
    // Avoid exactly 360 degrees (full circle) — cap at 359.99
    const endAngle = currentAngle + Math.min(angle, 359.99);
    const path = describeArc(100, 100, 70, currentAngle, endAngle);
    currentAngle = endAngle;
    return {
      path,
      color: origenColors[i % origenColors.length],
      label: o.origen,
      total: o.total,
      pct: Math.round(pct * 100),
    };
  });
}
