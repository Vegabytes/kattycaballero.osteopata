---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const db = (Astro.locals as any).runtime.env.DB;

// --- Summary cards ---
let totalPacientes = 0;
let totalCitas = 0;
let totalIngresos = 0;
let mediaIngreso = 0;

try {
  const r1 = await db.prepare("SELECT COUNT(*) as total FROM pacientes").first();
  totalPacientes = (r1 as any)?.total || 0;
} catch (e: any) {
  console.error('Stats: error totalPacientes', e);
}

try {
  const r2 = await db.prepare("SELECT COUNT(*) as total FROM citas").first();
  totalCitas = (r2 as any)?.total || 0;
} catch (e: any) {
  console.error('Stats: error totalCitas', e);
}

try {
  const r3 = await db.prepare("SELECT COALESCE(SUM(precio), 0) as total, COALESCE(AVG(precio), 0) as media FROM citas WHERE estado = 'completada' AND precio > 0").first();
  totalIngresos = (r3 as any)?.total || 0;
  mediaIngreso = (r3 as any)?.media || 0;
} catch (e: any) {
  console.error('Stats: error ingresos', e);
}

// --- Monthly income (last 6 months) ---
interface MonthData { mes: string; total: number; }
let ingresosMensuales: MonthData[] = [];

try {
  const rows = await db.prepare(`
    SELECT strftime('%Y-%m', fecha) as mes, COALESCE(SUM(precio), 0) as total
    FROM citas
    WHERE estado = 'completada' AND precio > 0
      AND fecha >= date('now', '-6 months')
    GROUP BY strftime('%Y-%m', fecha)
    ORDER BY mes ASC
  `).all();
  ingresosMensuales = (rows.results || []) as MonthData[];
} catch (e: any) {
  console.error('Stats: error ingresosMensuales', e);
}

// --- New patients per month (last 6 months) ---
let pacientesMensuales: MonthData[] = [];

try {
  const rows = await db.prepare(`
    SELECT strftime('%Y-%m', created_at) as mes, COUNT(*) as total
    FROM pacientes
    WHERE created_at >= date('now', '-6 months')
    GROUP BY strftime('%Y-%m', created_at)
    ORDER BY mes ASC
  `).all();
  pacientesMensuales = (rows.results || []) as MonthData[];
} catch (e: any) {
  console.error('Stats: error pacientesMensuales', e);
}

// --- Top 5 services ---
interface ServiceData { servicio: string; total: number; }
let topServicios: ServiceData[] = [];

try {
  const rows = await db.prepare(`
    SELECT servicio, COUNT(*) as total
    FROM citas
    WHERE servicio IS NOT NULL AND servicio != ''
    GROUP BY servicio
    ORDER BY total DESC
    LIMIT 5
  `).all();
  topServicios = (rows.results || []) as ServiceData[];
} catch (e: any) {
  console.error('Stats: error topServicios', e);
}

// --- Helpers ---
const meses: Record<string, string> = {
  '01': 'Ene', '02': 'Feb', '03': 'Mar', '04': 'Abr',
  '05': 'May', '06': 'Jun', '07': 'Jul', '08': 'Ago',
  '09': 'Sep', '10': 'Oct', '11': 'Nov', '12': 'Dic'
};

function mesLabel(ym: string): string {
  const parts = ym.split('-');
  return (meses[parts[1]] || parts[1]) + ' ' + parts[0].slice(2);
}

const maxIngreso = ingresosMensuales.length > 0 ? Math.max(...ingresosMensuales.map(m => m.total)) : 1;
const maxPacientes = pacientesMensuales.length > 0 ? Math.max(...pacientesMensuales.map(m => m.total)) : 1;
const maxServicio = topServicios.length > 0 ? Math.max(...topServicios.map(s => s.total)) : 1;

const barColors = ['#5a7c59', '#7a9c79', '#c4a35a', '#2196f3', '#ff9800', '#f44336'];
---

<AdminLayout title="Estadísticas" activeSection="estadisticas">

  <!-- Summary Cards -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalPacientes}</h3>
        <p>Pacientes totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalCitas}</h3>
        <p>Citas totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalIngresos.toFixed(0)}&euro;</h3>
        <p>Ingresos totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{mediaIngreso.toFixed(0)}&euro;</h3>
        <p>Media por cita</p>
      </div>
    </div>
  </div>

  <!-- Charts grid -->
  <div class="charts-grid">

    <!-- Monthly Income -->
    <div class="card chart-card">
      <h3 class="chart-title">Ingresos mensuales</h3>
      {ingresosMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {ingresosMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total.toFixed(0)}&euro;</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxIngreso) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- New patients per month -->
    <div class="card chart-card">
      <h3 class="chart-title">Nuevos pacientes por mes</h3>
      {pacientesMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de pacientes</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {pacientesMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total}</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxPacientes) * 100, 4)}%; background: ${barColors[(i + 2) % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Top services (horizontal) -->
    <div class="card chart-card chart-card-wide">
      <h3 class="chart-title">Servicios más solicitados</h3>
      {topServicios.length === 0 ? (
        <p class="chart-empty">Sin datos de servicios</p>
      ) : (
        <div class="h-bar-chart">
          {topServicios.map((s, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label">{s.servicio}</span>
              <div class="h-bar-track">
                <div class="h-bar-fill" style={`width: ${Math.max((s.total / maxServicio) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="h-bar-value">{s.total}</span>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>

</AdminLayout>

<style is:global>
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .chart-card {
    padding: 24px;
  }

  .chart-card-wide {
    grid-column: 1 / -1;
  }

  .chart-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--admin-text);
  }

  .chart-empty {
    text-align: center;
    color: var(--admin-text-light);
    padding: 40px 0;
    font-size: 0.9rem;
  }

  /* Vertical bar chart */
  .vertical-chart {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 220px;
    padding-top: 20px;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .bar-value {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--admin-text);
    margin-bottom: 6px;
    white-space: nowrap;
  }

  .bar-track {
    flex: 1;
    width: 100%;
    max-width: 48px;
    display: flex;
    align-items: flex-end;
    background: #f0f0f0;
    border-radius: 6px 6px 0 0;
    overflow: hidden;
  }

  .bar-fill {
    width: 100%;
    border-radius: 6px 6px 0 0;
    transition: height 0.4s ease;
    min-height: 4px;
  }

  .bar-label {
    font-size: 0.72rem;
    color: var(--admin-text-light);
    margin-top: 8px;
    white-space: nowrap;
  }

  /* Horizontal bar chart */
  .h-bar-chart {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .h-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .h-bar-label {
    width: 160px;
    flex-shrink: 0;
    font-size: 0.85rem;
    color: var(--admin-text);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .h-bar-track {
    flex: 1;
    height: 28px;
    background: #f0f0f0;
    border-radius: 6px;
    overflow: hidden;
  }

  .h-bar-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 0.4s ease;
    min-width: 4px;
  }

  .h-bar-value {
    width: 40px;
    flex-shrink: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--admin-text);
  }

  @media (max-width: 768px) {
    .charts-grid {
      grid-template-columns: 1fr;
    }

    .h-bar-label {
      width: 100px;
      font-size: 0.78rem;
    }

    .vertical-chart {
      height: 180px;
    }
  }
</style>
