    overflow: hidden;
  }

  .bar-fill {
    width: 100%;
    border-radius: 6px 6px 0 0;
    transition: height 0.4s ease;
    min-height: 4px;
  }

  .bar-label {
    font-size: 0.72rem;
    color: var(--admin-text-light);
