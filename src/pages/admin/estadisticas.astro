      </div>
      <div class="stat-info">
        <h3>{totalCitas}</h3>
        <p>Citas totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalIngresos.toFixed(0)}&euro;</h3>
        <p>Ingresos totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{mediaIngreso.toFixed(0)}&euro;</h3>
        <p>Media por cita</p>
      </div>
    </div>
  </div>

  <!-- Charts grid -->
  <div class="charts-grid">

    <!-- Monthly Income -->
    <div class="card chart-card">
      <h3 class="chart-title">Ingresos mensuales</h3>
      {ingresosMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {ingresosMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total.toFixed(0)}&euro;</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxIngreso) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- New patients per month -->
    <div class="card chart-card">
      <h3 class="chart-title">Nuevos pacientes por mes</h3>
      {pacientesMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de pacientes</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {pacientesMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total}</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxPacientes) * 100, 4)}%; background: ${barColors[(i + 2) % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Top services (horizontal) -->
    <div class="card chart-card chart-card-wide">
      <h3 class="chart-title">Servicios más solicitados</h3>
      {topServicios.length === 0 ? (
        <p class="chart-empty">Sin datos de servicios</p>
      ) : (
        <div class="h-bar-chart">
          {topServicios.map((s, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label">{s.servicio}</span>
              <div class="h-bar-track">
                <div class="h-bar-fill" style={`width: ${Math.max((s.total / maxServicio) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="h-bar-value">{s.total}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Income by service -->
    <div class="card chart-card">
      <h3 class="chart-title">Ingresos por servicio</h3>
      {ingresosPorServicio.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="h-bar-chart">
          {ingresosPorServicio.map((s, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label" title={s.servicio}>{s.servicio}</span>
              <div class="h-bar-track">
                <div class="h-bar-fill" style={`width: ${Math.max((s.total / (ingresosPorServicio[0]?.total || 1)) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="h-bar-value">{s.total.toFixed(0)}&euro;</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Citas by status -->
    <div class="card chart-card">
      <h3 class="chart-title">Citas por estado</h3>
      {citasPorEstado.length === 0 ? (
        <p class="chart-empty">Sin datos de citas</p>
      ) : (
        <div class="status-chart">
          {citasPorEstado.map((s) => (
            <div class="status-row">
              <span class="status-dot" style={`background: ${estadoColors[s.estado] || '#999'};`}></span>
              <span class="status-label">{estadoLabels[s.estado] || s.estado}</span>
              <span class="status-count">{s.total}</span>
              <div class="status-bar-track">
                <div class="status-bar-fill" style={`width: ${Math.max((s.total / (citasPorEstado[0]?.total || 1)) * 100, 4)}%; background: ${estadoColors[s.estado] || '#999'};`}></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Heatmap: horas punta -->
    <div class="card chart-card chart-card-wide">
      <h3 class="chart-title">Horas punta por día</h3>
      {heatmapData.length === 0 ? (
        <p class="chart-empty">Sin datos suficientes</p>
      ) : (
        <div class="heatmap-container">
          <div class="heatmap-grid">
            <div class="heatmap-corner"></div>
            {heatmapDiasLabels.map((d) => (
              <div class="heatmap-day-label">{d}</div>
            ))}
            {heatmapHoras.map((hora) => (
              <>
                <div class="heatmap-hour-label">{hora}:00</div>
                {heatmapDias.map((dia) => {
                  const val = heatmapMap[`${dia}-${hora}`] || 0;
                  const intensity = val > 0 ? Math.max(0.15, val / heatmapMax) : 0;
                  return (
                    <div
                      class={`heatmap-cell ${val === 0 ? 'heatmap-empty' : ''}`}
                      style={val > 0 ? `background: rgba(90, 124, 89, ${intensity});` : ''}
                      title={`${heatmapDiasLabels[heatmapDias.indexOf(dia)]} ${hora}:00 — ${val} cita${val !== 1 ? 's' : ''}`}
                    >
                      {val > 0 ? val : ''}
                    </div>
                  );
                })}
              </>
            ))}
          </div>
          <div class="heatmap-legend">
            <span>Menos</span>
            <div class="heatmap-legend-bar"></div>
            <span>Más</span>
          </div>
        </div>
      )}
    </div>

    <!-- Retención de pacientes -->
    <div class="card chart-card">
      <h3 class="chart-title">Retención de pacientes</h3>
      {totalConVisita === 0 ? (
        <p class="chart-empty">Sin datos de visitas completadas</p>
      ) : (
        <div class="retencion-container">
          <div class="retencion-donut">
            <svg viewBox="0 0 200 200" width="180" height="180" xmlns="http://www.w3.org/2000/svg">
              {tasaRetencion > 0 && (
                <path
                  d={describeArc(100, 100, 70, 0, Math.min(tasaRetencion * 3.6, 359.99))}
                  fill="none"
                  stroke="#4caf50"
                  stroke-width="28"
                  stroke-linecap="butt"
                >
                  <title>Repiten: {pacientesRepiten} ({tasaRetencion}%)</title>
                </path>
              )}
              {tasaRetencion < 100 && (
                <path
                  d={describeArc(100, 100, 70, Math.min(tasaRetencion * 3.6, 359.99), 359.99)}
                  fill="none"
                  stroke="#ff9800"
                  stroke-width="28"
                  stroke-linecap="butt"
                >
                  <title>Una sola visita: {pacientesUnaVisita} ({100 - tasaRetencion}%)</title>
                </path>
              )}
              <text x="100" y="92" text-anchor="middle" fill="#333" font-size="28" font-weight="700">{tasaRetencion}%</text>
              <text x="100" y="114" text-anchor="middle" fill="#888" font-size="11">retención</text>
            </svg>
          </div>
          <div class="retencion-stats">
            <div class="retencion-row">
              <span class="origen-legend-dot" style="background:#4caf50;"></span>
              <span>Repiten</span>
              <strong>{pacientesRepiten}</strong>
            </div>
            <div class="retencion-row">
              <span class="origen-legend-dot" style="background:#ff9800;"></span>
              <span>Una visita</span>
              <strong>{pacientesUnaVisita}</strong>
            </div>
          </div>
          {distribucionVisitas.length > 0 && (
            <div class="dist-visitas" style="width:100%;margin-top:16px;">
              <h4 style="font-size:0.8rem;color:var(--admin-text-light);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">Distribución por frecuencia</h4>
              {distribucionVisitas.map((d, i) => (
                <div class="h-bar-row" style="gap:8px;">
                  <span class="h-bar-label" style="width:90px;font-size:0.8rem;">{d.visitas}</span>
                  <div class="h-bar-track" style="height:22px;">
                    <div class="h-bar-fill" style={`width: ${Math.max((d.total / maxDistVisitas) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
                  </div>
                  <span class="h-bar-value" style="width:30px;font-size:0.8rem;">{d.total}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </div>

    <!-- Top pacientes por valor -->
    <div class="card chart-card">
      <h3 class="chart-title">Top pacientes por ingresos</h3>
      {topPacientes.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="top-pacientes">
          {topPacientes.map((p, i) => (
            <a href={`/admin/pacientes/${p.id}`} class="top-paciente-row" title={`Citas: ${p.ingresos_citas.toFixed(0)}€ | Bonos: ${p.ingresos_bonos.toFixed(0)}€`}>
              <span class="top-paciente-rank">#{i + 1}</span>
              <span class="top-paciente-name">{p.nombre} {p.apellidos}</span>
              <span class="top-paciente-visits">{p.visitas} vis.</span>
              <div class="top-paciente-bar-track">
                <div class="top-paciente-bar-fill" style={`width: ${Math.max((p.total / (topPacientes[0]?.total || 1)) * 100, 4)}%;`}></div>
              </div>
              <span class="top-paciente-value">{p.total.toFixed(0)}&euro;</span>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Motivos de cancelación -->
    <div class="card chart-card">
      <h3 class="chart-title">Cancelaciones y no-shows</h3>
      <div class="cancel-summary">
        <div class="cancel-stat">
          <span class="cancel-num" style="color:#f44336;">{totalCancelaciones}</span>
          <span class="cancel-label">Canceladas</span>
        </div>
        <div class="cancel-stat">
          <span class="cancel-num" style="color:#ff9800;">{totalNoShow}</span>
          <span class="cancel-label">No acudió</span>
        </div>
        <div class="cancel-stat">
          <span class="cancel-num" style="color:var(--admin-text);">{totalCitas > 0 ? Math.round(((totalCancelaciones + totalNoShow) / totalCitas) * 100) : 0}%</span>
          <span class="cancel-label">Tasa total</span>
        </div>
      </div>
      {motivosCancelacion.length > 0 ? (
        <div class="h-bar-chart" style="margin-top:16px;">
          {motivosCancelacion.map((m, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label" style="width:140px;font-size:0.8rem;">{m.motivo_cancelacion}</span>
              <div class="h-bar-track" style="height:22px;">
                <div class="h-bar-fill" style={`width: ${Math.max((m.total / (motivosCancelacion[0]?.total || 1)) * 100, 4)}%; background: ${i === 0 ? '#f44336' : '#ff9800'};`}></div>
              </div>
              <span class="h-bar-value" style="font-size:0.8rem;">{m.total}</span>
            </div>
          ))}
        </div>
      ) : (
        <p class="chart-empty" style="padding:16px 0;">Aún no hay motivos registrados. Aparecerán aquí cuando se registren cancelaciones con motivo.</p>
      )}
    </div>

    <!-- Patient origin donut chart -->
    <div class="card chart-card">
      <h3 class="chart-title">Como nos encuentran</h3>
      {origenes.length === 0 ? (
        <p class="chart-empty">Sin datos de origen registrados</p>
      ) : (
        <div class="origen-chart-container">
          <div class="origen-donut">
            <svg viewBox="0 0 200 200" width="200" height="200" xmlns="http://www.w3.org/2000/svg">
              {arcs.map((arc) => (
                <path
                  d={arc.path}
                  fill="none"
                  stroke={arc.color}
                  stroke-width="28"
                  stroke-linecap="butt"
                >
                  <title>{arc.label}: {arc.total} ({arc.pct}%)</title>
                </path>
              ))}
              <text x="100" y="96" text-anchor="middle" fill="#333" font-size="22" font-weight="700">{totalOrigenes}</text>
              <text x="100" y="116" text-anchor="middle" fill="#888" font-size="11">pacientes</text>
            </svg>
          </div>
          <div class="origen-legend">
            {arcs.map((arc) => (
              <div class="origen-legend-item">
                <span class="origen-legend-dot" style={`background: ${arc.color};`}></span>
                <span class="origen-legend-label">{arc.label}</span>
                <span class="origen-legend-count">{arc.total}</span>
                <span class="origen-legend-pct">({arc.pct}%)</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

  </div>

</AdminLayout>

