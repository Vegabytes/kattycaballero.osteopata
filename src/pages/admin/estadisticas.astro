    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .chart-card {
    padding: 24px;
  }

  .chart-card-wide {
    grid-column: 1 / -1;
  }

  .chart-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--admin-text);
  }

  .chart-empty {
    text-align: center;
    color: var(--admin-text-light);
    padding: 40px 0;
    font-size: 0.9rem;
  }

  /* Vertical bar chart */
  .vertical-chart {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 220px;
