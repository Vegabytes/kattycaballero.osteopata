      </div>
      <div class="stat-info">
        <h3>{totalPacientes}</h3>
        <p>Pacientes totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalCitas}</h3>
        <p>Citas totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{totalIngresos.toFixed(0)}&euro;</h3>
        <p>Ingresos totales</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon red">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
      </div>
      <div class="stat-info">
        <h3>{mediaIngreso.toFixed(0)}&euro;</h3>
        <p>Media por cita</p>
      </div>
    </div>
  </div>

  <!-- Charts grid -->
  <div class="charts-grid">

    <!-- Monthly Income -->
    <div class="card chart-card">
      <h3 class="chart-title">Ingresos mensuales</h3>
      {ingresosMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {ingresosMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total.toFixed(0)}&euro;</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxIngreso) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- New patients per month -->
    <div class="card chart-card">
      <h3 class="chart-title">Nuevos pacientes por mes</h3>
      {pacientesMensuales.length === 0 ? (
        <p class="chart-empty">Sin datos de pacientes</p>
      ) : (
        <div class="bar-chart vertical-chart">
          {pacientesMensuales.map((m, i) => (
            <div class="bar-col">
              <span class="bar-value">{m.total}</span>
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${Math.max((m.total / maxPacientes) * 100, 4)}%; background: ${barColors[(i + 2) % barColors.length]};`}></div>
              </div>
              <span class="bar-label">{mesLabel(m.mes)}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Top services (horizontal) -->
    <div class="card chart-card chart-card-wide">
      <h3 class="chart-title">Servicios más solicitados</h3>
      {topServicios.length === 0 ? (
        <p class="chart-empty">Sin datos de servicios</p>
      ) : (
        <div class="h-bar-chart">
          {topServicios.map((s, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label">{s.servicio}</span>
              <div class="h-bar-track">
                <div class="h-bar-fill" style={`width: ${Math.max((s.total / maxServicio) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="h-bar-value">{s.total}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Income by service -->
    <div class="card chart-card">
      <h3 class="chart-title">Ingresos por servicio</h3>
      {ingresosPorServicio.length === 0 ? (
        <p class="chart-empty">Sin datos de ingresos</p>
      ) : (
        <div class="h-bar-chart">
          {ingresosPorServicio.map((s, i) => (
            <div class="h-bar-row">
              <span class="h-bar-label" title={s.servicio}>{s.servicio}</span>
              <div class="h-bar-track">
                <div class="h-bar-fill" style={`width: ${Math.max((s.total / (ingresosPorServicio[0]?.total || 1)) * 100, 4)}%; background: ${barColors[i % barColors.length]};`}></div>
              </div>
              <span class="h-bar-value">{s.total.toFixed(0)}&euro;</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Citas by status -->
    <div class="card chart-card">
      <h3 class="chart-title">Citas por estado</h3>
      {citasPorEstado.length === 0 ? (
        <p class="chart-empty">Sin datos de citas</p>
      ) : (
        <div class="status-chart">
          {citasPorEstado.map((s) => (
            <div class="status-row">
              <span class="status-dot" style={`background: ${estadoColors[s.estado] || '#999'};`}></span>
              <span class="status-label">{estadoLabels[s.estado] || s.estado}</span>
              <span class="status-count">{s.total}</span>
              <div class="status-bar-track">
                <div class="status-bar-fill" style={`width: ${Math.max((s.total / (citasPorEstado[0]?.total || 1)) * 100, 4)}%; background: ${estadoColors[s.estado] || '#999'};`}></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Patient origin donut chart -->
    <div class="card chart-card">
      <h3 class="chart-title">Como nos encuentran</h3>
      {origenes.length === 0 ? (
        <p class="chart-empty">Sin datos de origen registrados</p>
      ) : (
        <div class="origen-chart-container">
          <div class="origen-donut">
            <svg viewBox="0 0 200 200" width="200" height="200" xmlns="http://www.w3.org/2000/svg">
              {arcs.map((arc) => (
                <path
                  d={arc.path}
                  fill="none"
                  stroke={arc.color}
                  stroke-width="28"
                  stroke-linecap="butt"
                >
                  <title>{arc.label}: {arc.total} ({arc.pct}%)</title>
                </path>
              ))}
              <text x="100" y="96" text-anchor="middle" fill="#333" font-size="22" font-weight="700">{totalOrigenes}</text>
              <text x="100" y="116" text-anchor="middle" fill="#888" font-size="11">pacientes</text>
            </svg>
          </div>
          <div class="origen-legend">
            {arcs.map((arc) => (
              <div class="origen-legend-item">
                <span class="origen-legend-dot" style={`background: ${arc.color};`}></span>
                <span class="origen-legend-label">{arc.label}</span>
                <span class="origen-legend-count">{arc.total}</span>
                <span class="origen-legend-pct">({arc.pct}%)</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

  </div>

</AdminLayout>

<style is:global>
