---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const db = (Astro.locals as any).runtime.env.DB;
let mensaje = '';
let mensajeTipo = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const action = form.get('_action') as string;

    if (action === 'crear') {
      const texto = (form.get('texto') as string)?.trim();
      const tipo = form.get('tipo') as string || 'tarea';
      const prioridad = form.get('prioridad') as string || 'normal';
      if (texto) {
        await db.prepare("INSERT INTO notas (texto, tipo, prioridad) VALUES (?, ?, ?)").bind(texto, tipo, prioridad).run();
        mensaje = 'Nota creada';
        mensajeTipo = 'success';
      }
    } else if (action === 'completar') {
      const id = form.get('id');
      await db.prepare("UPDATE notas SET completada = 1, updated_at = datetime('now') WHERE id = ?").bind(id).run();
    } else if (action === 'reabrir') {
      const id = form.get('id');
      await db.prepare("UPDATE notas SET completada = 0, updated_at = datetime('now') WHERE id = ?").bind(id).run();
    } else if (action === 'eliminar') {
      const id = form.get('id');
      await db.prepare("DELETE FROM notas WHERE id = ?").bind(id).run();
      mensaje = 'Nota eliminada';
      mensajeTipo = 'success';
    } else if (action === 'editar') {
      const id = form.get('id');
      const texto = (form.get('texto') as string)?.trim();
      const prioridad = form.get('prioridad') as string || 'normal';
      if (texto) {
        await db.prepare("UPDATE notas SET texto = ?, prioridad = ?, updated_at = datetime('now') WHERE id = ?").bind(texto, prioridad, id).run();
      }
    }
  } catch (e: any) {
    mensaje = 'Error: ' + e.message;
    mensajeTipo = 'error';
  }
}

// Fetch all notes
let tareasPendientes: any[] = [];
let tareasCompletadas: any[] = [];
let notasLibres: any[] = [];
let dbError = '';

try {
  const all = await db.prepare("SELECT * FROM notas ORDER BY CASE prioridad WHEN 'alta' THEN 0 WHEN 'normal' THEN 1 WHEN 'baja' THEN 2 END, created_at DESC").all();
  const rows = (all.results || []) as any[];
  tareasPendientes = rows.filter(r => r.tipo === 'tarea' && !r.completada);
  tareasCompletadas = rows.filter(r => r.tipo === 'tarea' && r.completada);
  notasLibres = rows.filter(r => r.tipo === 'nota');
} catch (e: any) {
  dbError = e.message;
}

function formatDate(d: string) {
  if (!d) return '';
  const date = new Date(d + 'Z');
  return date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
}
---

<AdminLayout title="Notas y Tareas" activeSection="notas">
  {mensaje && <div class={`alert alert-${mensajeTipo}`}>{mensaje}</div>}
  {dbError && <div class="alert alert-error">Error BD: {dbError}</div>}

  <!-- Nueva nota/tarea -->
  <div class="card" style="margin-bottom:1.5rem;">
    <form method="POST" class="nota-form">
      <input type="hidden" name="_action" value="crear" />
      <div class="nota-form-top">
        <textarea name="texto" placeholder="Escribe una tarea o nota..." required class="nota-input" rows="2"></textarea>
      </div>
      <div class="nota-form-bottom">
        <select name="tipo" class="nota-select">
          <option value="tarea">Tarea</option>
          <option value="nota">Nota</option>
        </select>
        <select name="prioridad" class="nota-select">
          <option value="normal">Normal</option>
          <option value="alta">Alta</option>
          <option value="baja">Baja</option>
        </select>
        <button type="submit" class="btn btn-primary">Añadir</button>
      </div>
    </form>
  </div>

  <!-- Tareas pendientes -->
  <div class="card" style="margin-bottom:1.5rem;">
    <h3 style="margin:0 0 1rem;display:flex;align-items:center;gap:8px;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      Tareas pendientes
      {tareasPendientes.length > 0 && <span class="badge badge-primary">{tareasPendientes.length}</span>}
    </h3>
    {tareasPendientes.length === 0 ? (
      <p style="color:var(--color-text-muted);margin:0;">No hay tareas pendientes</p>
    ) : (
      <div class="notas-list">
        {tareasPendientes.map(t => (
          <div class={`nota-item prioridad-${t.prioridad}`}>
            <form method="POST" style="display:contents;">
              <input type="hidden" name="_action" value="completar" />
              <input type="hidden" name="id" value={t.id} />
              <button type="submit" class="nota-check" title="Marcar como completada">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:18px;height:18px;"><circle cx="12" cy="12" r="9" /></svg>
              </button>
            </form>
            <div class="nota-content">
              <span class="nota-texto">{t.texto}</span>
              <div class="nota-meta">
                {t.prioridad === 'alta' && <span class="badge badge-danger">Alta</span>}
                {t.prioridad === 'baja' && <span class="badge badge-muted">Baja</span>}
                <span class="nota-fecha">{formatDate(t.created_at)}</span>
              </div>
            </div>
            <div class="nota-actions">
              <button class="btn-icon" title="Editar" onclick={`editarNota(${t.id}, ${JSON.stringify(t.texto)}, '${t.prioridad}')`}>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
              </button>
              <form method="POST" style="display:contents;">
                <input type="hidden" name="_action" value="eliminar" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" class="btn-icon btn-icon-danger" title="Eliminar" onclick="return confirm('¿Eliminar esta nota?')">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Notas libres -->
  <div class="card" style="margin-bottom:1.5rem;">
    <h3 style="margin:0 0 1rem;display:flex;align-items:center;gap:8px;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
      Notas
      {notasLibres.length > 0 && <span class="badge">{notasLibres.length}</span>}
    </h3>
    {notasLibres.length === 0 ? (
      <p style="color:var(--color-text-muted);margin:0;">No hay notas</p>
    ) : (
      <div class="notas-list">
        {notasLibres.map(t => (
          <div class={`nota-item nota-libre prioridad-${t.prioridad}`}>
            <div class="nota-content">
              <span class="nota-texto">{t.texto}</span>
              <div class="nota-meta">
                {t.prioridad === 'alta' && <span class="badge badge-danger">Alta</span>}
                {t.prioridad === 'baja' && <span class="badge badge-muted">Baja</span>}
                <span class="nota-fecha">{formatDate(t.created_at)}</span>
              </div>
            </div>
            <div class="nota-actions">
              <button class="btn-icon" title="Editar" onclick={`editarNota(${t.id}, ${JSON.stringify(t.texto)}, '${t.prioridad}')`}>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
              </button>
              <form method="POST" style="display:contents;">
                <input type="hidden" name="_action" value="eliminar" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" class="btn-icon btn-icon-danger" title="Eliminar" onclick="return confirm('¿Eliminar esta nota?')">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Tareas completadas -->
  {tareasCompletadas.length > 0 && (
    <div class="card">
      <details>
        <summary style="cursor:pointer;font-weight:600;color:var(--color-text-muted);display:flex;align-items:center;gap:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          Completadas ({tareasCompletadas.length})
        </summary>
        <div class="notas-list" style="margin-top:1rem;">
          {tareasCompletadas.map(t => (
            <div class="nota-item nota-completada">
              <form method="POST" style="display:contents;">
                <input type="hidden" name="_action" value="reabrir" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" class="nota-check checked" title="Reabrir tarea">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" style="width:18px;height:18px;"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
                </button>
              </form>
              <div class="nota-content">
                <span class="nota-texto">{t.texto}</span>
                <span class="nota-fecha">{formatDate(t.updated_at)}</span>
              </div>
              <form method="POST" style="display:contents;">
                <input type="hidden" name="_action" value="eliminar" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" class="btn-icon btn-icon-danger" title="Eliminar" onclick="return confirm('¿Eliminar?')">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                </button>
              </form>
            </div>
          ))}
        </div>
      </details>
    </div>
  )}

  <!-- Modal editar -->
  <div id="modal-editar" class="modal-overlay" style="display:none;">
    <div class="modal-content card">
      <h3 style="margin:0 0 1rem;">Editar nota</h3>
      <form method="POST">
        <input type="hidden" name="_action" value="editar" />
        <input type="hidden" name="id" id="edit-id" />
        <div class="form-group">
          <textarea name="texto" id="edit-texto" rows="5" required style="width:100%;min-height:120px;"></textarea>
        </div>
        <div class="form-group">
          <select name="prioridad" id="edit-prioridad" class="nota-select" style="width:100%;">
            <option value="normal">Normal</option>
            <option value="alta">Alta</option>
            <option value="baja">Baja</option>
          </select>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
  .nota-form-top {
    margin-bottom: 10px;
  }
  .nota-form-bottom {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .nota-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--admin-border, #e0e0e0);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--admin-bg, #fff);
    color: var(--admin-text, #3d3d3d);
    resize: vertical;
    min-height: 60px;
  }
  .nota-input:focus {
    outline: none;
    border-color: var(--admin-primary, #5a7c59);
    box-shadow: 0 0 0 2px rgba(90,124,89,0.15);
  }
  .nota-select {
    padding: 10px 12px;
    border: 1px solid var(--admin-border, #e0e0e0);
    border-radius: 8px;
    font-size: 0.9rem;
    background: var(--admin-bg, #fff);
    color: var(--admin-text, #3d3d3d);
  }
  .notas-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nota-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .nota-item:hover {
    background: rgba(90,124,89,0.05);
  }
  .prioridad-alta {
    border-left: 3px solid #e74c3c;
  }
  .prioridad-baja {
    border-left: 3px solid #95a5a6;
  }
  .nota-check {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--admin-text-muted, #999);
    padding: 2px;
    display: flex;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .nota-check:hover {
    color: var(--admin-primary, #5a7c59);
  }
  .nota-check.checked {
    color: var(--admin-primary, #5a7c59);
  }
  .nota-content {
    flex: 1;
    min-width: 0;
  }
  .nota-texto {
    display: block;
    font-size: 0.95rem;
    word-break: break-word;
  }
  .nota-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
  }
  .nota-fecha {
    font-size: 0.78rem;
    color: var(--admin-text-muted, #999);
  }
  .nota-completada .nota-texto {
    text-decoration: line-through;
    color: var(--admin-text-muted, #999);
  }
  .nota-actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .nota-item:hover .nota-actions {
    opacity: 1;
  }
  .btn-icon {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    color: var(--admin-text-muted, #999);
    display: flex;
    transition: all 0.15s;
  }
  .btn-icon:hover {
    background: rgba(90,124,89,0.1);
    color: var(--admin-primary, #5a7c59);
  }
  .btn-icon-danger:hover {
    background: rgba(231,76,60,0.1);
    color: #e74c3c;
  }
  .badge-muted {
    background: #95a5a6;
    color: #fff;
    font-size: 0.7rem;
    padding: 1px 6px;
    border-radius: 4px;
  }
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-content {
    max-width: 480px;
    width: 100%;
  }

  @media (max-width: 600px) {
    .nota-form-bottom {
      flex-wrap: wrap;
    }
    .nota-form-bottom .nota-select {
      flex: 1;
      min-width: 100px;
    }
    .nota-form-bottom .btn {
      width: 100%;
    }
    .nota-actions {
      opacity: 1;
    }
  }
</style>

<script is:inline>
  function editarNota(id, texto, prioridad) {
    document.getElementById('edit-id').value = id;
    document.getElementById('edit-texto').value = texto;
    document.getElementById('edit-prioridad').value = prioridad;
    document.getElementById('modal-editar').style.display = 'flex';
    document.getElementById('edit-texto').focus();
  }
  function cerrarModal() {
    document.getElementById('modal-editar').style.display = 'none';
  }
  document.getElementById('modal-editar')?.addEventListener('click', function(e) {
    if (e.target === this) cerrarModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') cerrarModal();
  });
</script>
