---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { verifyCitaToken } from '../../lib/cita-token';

const token = String(Astro.params.token || '');
const env = (Astro.locals as any).runtime.env;
const secret = env?.BOOKING_TOKEN_SECRET;

let cita: any = null;
let errorMsg = '';

if (!secret) {
  errorMsg = 'El sistema de reagendado no está configurado.';
} else {
  const citaId = await verifyCitaToken(token, secret);
  if (!citaId) {
    errorMsg = 'Enlace no válido o caducado.';
  } else {
    try {
      cita = await env.DB.prepare(
        `SELECT c.id, c.fecha, c.hora, c.duracion, c.servicio, c.estado, c.notas,
                p.nombre, p.apellidos
         FROM citas c JOIN pacientes p ON c.paciente_id = p.id
         WHERE c.id = ?`,
      ).bind(citaId).first();
      if (!cita) errorMsg = 'No encontramos esa cita.';
    } catch (e: any) {
      errorMsg = 'Error consultando la cita.';
    }
  }
}

const cancelable = cita && !['cancelada', 'completada', 'no_show'].includes(cita.estado);
const todayISO = new Date().toISOString().split('T')[0];
const isPast = cita && cita.fecha < todayISO;

const fechaDisplay = cita
  ? new Date(cita.fecha + 'T00:00:00').toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })
  : '';
---

<Layout title="Tu cita | Katy Caballero" description="Gestiona tu cita: reagendar o cancelar." noindex={true}>
  <section class="cita-hero">
    <div class="container">
      <h1>Tu cita</h1>
      {errorMsg ? (
        <p class="error">{errorMsg}</p>
      ) : cita ? (
        <div class="cita-card">
          <div class="cita-row"><span>Paciente</span><strong>{cita.nombre} {cita.apellidos}</strong></div>
          <div class="cita-row"><span>Fecha</span><strong>{fechaDisplay}</strong></div>
          <div class="cita-row"><span>Hora</span><strong>{cita.hora}</strong></div>
          {cita.servicio && <div class="cita-row"><span>Servicio</span><strong>{cita.servicio}</strong></div>}
          <div class="cita-row"><span>Estado</span><strong class={`badge badge-${cita.estado}`}>{cita.estado}</strong></div>
        </div>
      ) : null}

      {cita && cancelable && !isPast && (
        <div class="actions">
          <button id="btn-toggle-reschedule" class="btn-primary">Cambiar fecha u hora</button>
          <button id="btn-cancel" class="btn-secondary">Cancelar cita</button>
        </div>
      )}

      {cita && (cita.estado === 'cancelada' || isPast) && (
        <p class="muted">Esta cita ya no se puede modificar. Si necesitas otra, escríbeme por <a href="https://wa.me/34643961065">WhatsApp</a>.</p>
      )}
    </div>
  </section>

  {cita && cancelable && !isPast && (
    <section class="reschedule-section hidden" id="reschedule-section">
      <div class="container">
        <h2>Elige nueva fecha y hora</h2>
        <div class="datetime-grid">
          <div class="calendar-wrapper">
            <div class="calendar-header">
              <button class="cal-nav" id="cal-prev" aria-label="Mes anterior">‹</button>
              <span id="cal-month"></span>
              <button class="cal-nav" id="cal-next" aria-label="Mes siguiente">›</button>
            </div>
            <div class="cal-weekdays"><span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span></div>
            <div class="calendar-days" id="cal-days"></div>
          </div>
          <div class="time-wrapper">
            <h3 id="time-title">Selecciona un día</h3>
            <div class="time-slots" id="time-slots"></div>
          </div>
        </div>
        <div class="confirm-row">
          <button id="btn-confirm-reschedule" class="btn-primary" disabled>Confirmar nueva cita</button>
          <span id="reschedule-feedback" role="status" aria-live="polite"></span>
        </div>
      </div>
    </section>
  )}
</Layout>

{cita && (
  <script define:vars={{ token, citaDuracion: cita.duracion || 60 }}>
    const DAY_NAMES = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
    const MONTHS = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
    let availability = { horario: {}, diasBloqueados: [], horasBloqueadas: [] };
    const occupiedCache = {};
    const state = {
      date: null,
      time: null,
      currentMonth: new Date().getMonth(),
      currentYear: new Date().getFullYear(),
    };

    async function loadAvailability() {
      try {
        const res = await fetch('/api/disponibilidad?_=' + Date.now(), { cache: 'no-store' });
        if (res.ok) {
          const data = await res.json();
          availability = { horario: data.horario, diasBloqueados: data.diasBloqueados || [], horasBloqueadas: data.horasBloqueadas || [] };
        }
      } catch {}
    }

    function isDayActive(date) {
      const day = DAY_NAMES[date.getDay()].replace('miércoles', 'miercoles').replace('sábado', 'sabado');
      const cfg = availability.horario[day];
      if (!cfg || !cfg.activo) return false;
      const dateStr = date.toISOString().split('T')[0];
      if (availability.diasBloqueados.includes(dateStr)) return false;
      return true;
    }

    function getTimeSlots(date) {
      const day = DAY_NAMES[date.getDay()].replace('miércoles', 'miercoles').replace('sábado', 'sabado');
      const cfg = availability.horario[day];
      if (!cfg || !cfg.activo) return [];
      const dateStr = date.toISOString().split('T')[0];
      const blocked = (availability.horasBloqueadas || []).filter(b => b.fecha === dateStr);
      const [sh, sm] = cfg.inicio.split(':').map(Number);
      const [eh, em] = cfg.fin.split(':').map(Number);
      const slots = [];
      let h = sh, m = sm || 0;
      while (h < eh || (h === eh && m < em)) {
        const slot = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
        if (!blocked.some(b => slot >= b.inicio && slot < b.fin)) slots.push(slot);
        m += 30;
        if (m >= 60) { h++; m = 0; }
      }
      return slots;
    }

    async function fetchOccupied(dateStr) {
      if (occupiedCache[dateStr]) return occupiedCache[dateStr];
      try {
        const res = await fetch('/api/citas-disponibles?fecha=' + dateStr);
        if (res.ok) {
          const data = await res.json();
          occupiedCache[dateStr] = data.occupied || [];
          return occupiedCache[dateStr];
        }
      } catch {}
      return [];
    }

    function renderCalendar() {
      const calDays = document.getElementById('cal-days');
      const calMonth = document.getElementById('cal-month');
      if (!calDays || !calMonth) return;
      const today = new Date(); today.setHours(0,0,0,0);
      calMonth.textContent = MONTHS[state.currentMonth] + ' ' + state.currentYear;

      const max = new Date(today.getFullYear(), today.getMonth() + 3, 0);
      document.getElementById('cal-prev').disabled = (state.currentYear === today.getFullYear() && state.currentMonth === today.getMonth());
      document.getElementById('cal-next').disabled = state.currentYear > max.getFullYear() || (state.currentYear === max.getFullYear() && state.currentMonth >= max.getMonth());

      const first = new Date(state.currentYear, state.currentMonth, 1);
      const last = new Date(state.currentYear, state.currentMonth + 1, 0);
      let offset = first.getDay() - 1; if (offset < 0) offset = 6;
      calDays.innerHTML = '';
      for (let i = 0; i < offset; i++) {
        const e = document.createElement('span'); e.className = 'cal-day empty'; calDays.appendChild(e);
      }
      for (let d = 1; d <= last.getDate(); d++) {
        const date = new Date(state.currentYear, state.currentMonth, d);
        const btn = document.createElement('button');
        btn.className = 'cal-day';
        btn.textContent = String(d);
        const inactive = !isDayActive(date) || date < today;
        if (inactive) btn.disabled = true;
        if (state.date && date.getTime() === state.date.getTime()) btn.classList.add('selected');
        btn.addEventListener('click', () => { state.date = date; state.time = null; renderCalendar(); renderTimeSlots(); });
        calDays.appendChild(btn);
      }
    }

    async function renderTimeSlots() {
      const container = document.getElementById('time-slots');
      const title = document.getElementById('time-title');
      if (!container || !title) return;
      if (!state.date) { title.textContent = 'Selecciona un día'; container.innerHTML = ''; return; }
      const dateStr = state.date.toISOString().split('T')[0];
      title.textContent = state.date.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
      container.innerHTML = '<p class="muted">Cargando...</p>';
      const [slots, occupied] = await Promise.all([Promise.resolve(getTimeSlots(state.date)), fetchOccupied(dateStr)]);
      const now = new Date();
      const filtered = slots.filter(s => {
        if (state.date.toDateString() !== now.toDateString()) return true;
        const [hh, mm] = s.split(':').map(Number);
        return hh > now.getHours() || (hh === now.getHours() && mm > now.getMinutes());
      });
      container.innerHTML = '';
      if (filtered.length === 0) { container.innerHTML = '<p class="muted">No hay horas este día</p>'; return; }
      filtered.forEach(slot => {
        const btn = document.createElement('button');
        btn.className = 'time-slot';
        btn.textContent = slot;
        if (occupied.includes(slot)) { btn.disabled = true; btn.classList.add('occupied'); }
        if (state.time === slot) btn.classList.add('selected');
        btn.addEventListener('click', () => {
          if (occupied.includes(slot)) return;
          state.time = slot;
          renderTimeSlots();
          document.getElementById('btn-confirm-reschedule').disabled = false;
        });
        container.appendChild(btn);
      });
    }

    document.getElementById('cal-prev')?.addEventListener('click', () => {
      state.currentMonth--; if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
      renderCalendar();
    });
    document.getElementById('cal-next')?.addEventListener('click', () => {
      state.currentMonth++; if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
      renderCalendar();
    });

    document.getElementById('btn-toggle-reschedule')?.addEventListener('click', async () => {
      document.getElementById('reschedule-section').classList.remove('hidden');
      await loadAvailability();
      renderCalendar();
      document.getElementById('reschedule-section').scrollIntoView({ behavior: 'smooth' });
    });

    document.getElementById('btn-cancel')?.addEventListener('click', async () => {
      if (!confirm('¿Seguro que quieres cancelar tu cita?')) return;
      const res = await fetch('/api/cita-reagendar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, action: 'cancel' }),
      });
      if (res.ok) {
        alert('Cita cancelada. Te he avisado a Katy. Si quieres pedir otra, hazlo desde /reservar.');
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.error || 'No se ha podido cancelar.');
      }
    });

    document.getElementById('btn-confirm-reschedule')?.addEventListener('click', async () => {
      if (!state.date || !state.time) return;
      const btn = document.getElementById('btn-confirm-reschedule');
      const fb = document.getElementById('reschedule-feedback');
      btn.disabled = true; btn.textContent = 'Guardando...';
      const dateStr = state.date.toISOString().split('T')[0];
      const res = await fetch('/api/cita-reagendar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, action: 'reschedule', fecha: dateStr, hora: state.time }),
      });
      if (res.ok) {
        fb.textContent = '¡Hecho! Tu nueva cita queda pendiente de confirmación.';
        setTimeout(() => window.location.reload(), 1500);
      } else {
        const d = await res.json().catch(() => ({}));
        fb.textContent = d.error || 'No se ha podido guardar.';
        btn.disabled = false; btn.textContent = 'Confirmar nueva cita';
      }
    });
  </script>
)}

<style>
  .cita-hero { padding-top: 130px; padding-bottom: 40px; text-align: center; }
  .cita-hero h1 { margin-bottom: 24px; }
  .cita-card { max-width: 480px; margin: 0 auto; background: var(--color-cream); border-radius: 14px; padding: 22px; text-align: left; border-left: 4px solid var(--color-primary); }
  .cita-row { display: flex; justify-content: space-between; padding: 6px 0; gap: 16px; border-bottom: 1px solid rgba(0,0,0,0.06); }
  .cita-row:last-child { border-bottom: none; }
  .cita-row span { color: var(--color-text-light); font-size: 0.9rem; }
  .badge { padding: 2px 10px; border-radius: 10px; font-size: 0.78rem; background: rgba(196, 163, 90, 0.2); }
  .badge-cancelada { background: #fde2e2; color: #8a1d1d; }
  .badge-completada { background: #e2f5e6; color: #1d5a2c; }
  .badge-pendiente { background: #fff4d8; color: #6b5121; }
  .badge-confirmada { background: #dde9f5; color: #1d3f6b; }
  .actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 26px; }
  .btn-primary, .btn-secondary { padding: 12px 22px; border-radius: 50px; border: none; font-family: var(--font-body); font-weight: 600; font-size: 0.95rem; cursor: pointer; }
  .btn-primary { background: var(--color-primary-dark); color: #fff; }
  .btn-secondary { background: transparent; border: 2px solid #c5363a; color: #c5363a; }
  .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
  .error { color: #8a1d1d; max-width: 480px; margin: 0 auto; }
  .muted { color: var(--color-text-muted); font-size: 0.95rem; max-width: 480px; margin: 16px auto 0; }
  .reschedule-section { background: var(--color-warm-white); padding: 40px 0 80px; }
  .reschedule-section.hidden { display: none; }
  .reschedule-section h2 { text-align: center; margin-bottom: 24px; }
  .datetime-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 24px; max-width: 800px; margin: 0 auto; }
  .calendar-wrapper { background: var(--color-cream); border-radius: 18px; padding: 22px; }
  .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  #cal-month { font-family: var(--font-display); font-size: 1.2rem; text-transform: capitalize; }
  .cal-nav { width: 36px; height: 36px; border-radius: 50%; border: none; background: #fff; cursor: pointer; font-size: 1.1rem; }
  .cal-nav:disabled { opacity: 0.3; cursor: default; }
  .cal-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 6px; }
  .calendar-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .cal-day { aspect-ratio: 1; border: none; border-radius: 50%; background: none; cursor: pointer; }
  .cal-day:disabled { color: #ccc; cursor: not-allowed; }
  .cal-day:not(:disabled):hover { background: var(--color-secondary-light); }
  .cal-day.selected { background: var(--color-primary); color: #fff; }
  .cal-day.empty { visibility: hidden; }
  .time-wrapper h3 { margin-bottom: 12px; font-size: 1rem; }
  .time-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .time-slot { padding: 10px; border: 1px solid var(--color-secondary-light); background: #fff; border-radius: 10px; cursor: pointer; font-family: var(--font-body); }
  .time-slot:hover:not(:disabled) { border-color: var(--color-primary); }
  .time-slot.selected { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .time-slot.occupied { background: #f0f0f0; color: #aaa; cursor: not-allowed; text-decoration: line-through; }
  .confirm-row { text-align: center; margin-top: 22px; }
  #reschedule-feedback { display: block; margin-top: 12px; color: var(--color-text-light); }
  @media (max-width: 768px) { .datetime-grid { grid-template-columns: 1fr; } }
</style>
