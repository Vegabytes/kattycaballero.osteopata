<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Masaje y Osteopatía cerca de Torrelodones" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="town-hero">
    <div class="container">
      <span class="section-tag">Torrelodones</span>
      <h1>Masaje y Osteopatía cerca de Torrelodones</h1>
      <p class="town-hero-subtitle">Consulta de masajes y osteopatía en Alpedrete, a solo <strong>15 minutos en coche</strong> de Torrelodones</p>
      <div class="town-hero-actions">
        <a href="https://wa.me/34643961065?text=Hola%20Katy,%20soy%20de%20Torrelodones%20y%20me%20gustaría%20reservar%20una%20cita" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Reservar por WhatsApp</a>
        <a href="/reservar" class="btn btn-outline">Reservar online</a>
      </div>
    </div>
  </section>

