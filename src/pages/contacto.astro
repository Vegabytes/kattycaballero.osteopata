    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .contact-form .form-group {
    margin-bottom: 16px;
  }

  .contact-form label {
    display: block;
    margin-bottom: 5px;
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    width: 100%;
    padding: 13px 16px;
    border: 2px solid rgba(90, 124, 89, 0.12);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: white;
    transition: all 0.3s ease;
