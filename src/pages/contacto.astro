---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const pageTitle = "Contacto | Osteópata en Alpedrete - Katy Caballero";
const pageDescription = "Contacta con Katy Caballero para reservar tu cita de osteopatía o masaje en Alpedrete, Sierra Noroeste de Madrid. Atendemos Collado Villalba, Moralzarzal, Galapagar y toda la Sierra de Guadarrama. WhatsApp, teléfono y email.";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "name": "Katy Caballero - Osteópata y Masajista",
  "description": "Centro de osteopatía y masajes en Alpedrete, Sierra Noroeste de Madrid.",
  "image": "https://katycaballeroosteopata.com/images/logo.png",
  "telephone": "+34643961065",
  "email": "katycaballero.osteopata@gmail.com",
  "url": "https://katycaballeroosteopata.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Río Guadarrama 2",
    "addressLocality": "Alpedrete",
    "addressRegion": "Madrid",
    "postalCode": "28430",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6631",
    "longitude": "-4.0270"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "14:00"
    }
  ],
  "priceRange": "€€"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo puedo reservar una cita?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Puedes reservar llamando al 643 961 065, por WhatsApp, o enviando un email. Te confirmaré la cita lo antes posible."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto dura una sesión de osteopatía o masaje?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Las sesiones de osteopatía duran 55 minutos, mientras que los masajes varían entre 30 y 90 minutos dependiendo del tratamiento elegido."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué métodos de pago se aceptan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se acepta efectivo, Bizum y transferencia bancaria. El pago se realiza al finalizar la sesión."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la política de cancelación?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se solicita avisar con al menos 24 horas de antelación para cancelar o cambiar la cita."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hay parking cerca de la consulta?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, hay estacionamiento gratuito en la zona. Al reservar se proporcionan indicaciones exactas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Se emite factura?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, se puede emitir factura si se necesita. Solo hay que solicitarla."
      }
    },
    {
      "@type": "Question",
      "name": "¿Necesito llevar algo a la sesión?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No necesitas traer nada especial. Ven con ropa cómoda. Yo proporciono todo lo necesario para el tratamiento (camilla, aceites, toallas)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuántas sesiones necesitaré?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende de cada caso. En la primera sesión evaluaré tu situación y te daré una estimación. Muchos pacientes notan mejoría desde la primera sesión."
      }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} keywords="contacto osteopata alpedrete, reservar cita masaje sierra madrid, reservar cita masaje sierra noroeste, osteopatia collado villalba contacto, telefono osteopata moralzarzal, cita masajista galapagar, osteopata sierra de guadarrama, osteopata sierra noroeste madrid, direccion osteopatia alpedrete" breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Contacto" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="contact-page">
    <div class="container">
      <Breadcrumbs items={[{label: "Inicio", href: "/"}, {label: "Contacto"}]} />
      <div class="contact-header">
        <span class="section-tag">Contacto</span>
        <h1>Reserva tu cita o consúltame sin compromiso</h1>
        <p>Te atiendo personalmente. Escríbeme por WhatsApp, llámame o envíame un email.</p>
        <div class="response-promise">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
          <span>Respondo en menos de 2 horas · L-V 9:00-20:00</span>
        </div>
      </div>

      <!-- Contact methods grid -->
      <div class="contact-cards">
        <a href="https://wa.me/34643961065?text=Hola%20Katy,%20me%20gustaría%20reservar%20una%20cita" class="contact-card contact-card--wa" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <h3>WhatsApp</h3>
          <span>643 961 065</span>
        </a>
        <a href="tel:+34643961065" class="contact-card">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          <h3>Llamar</h3>
          <span>643 961 065</span>
        </a>
        <a href="mailto:katycaballero.osteopata@gmail.com" class="contact-card">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          <h3>Email</h3>
          <span>Escribir correo</span>
        </a>
        <a href="/reservar" class="contact-card">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
          <h3>Reservar online</h3>
          <span>Elige día y hora</span>
        </a>
      </div>

      <!-- Contact form -->
      <div class="contact-form-section">
        <h2>Escríbeme directamente</h2>
        <p class="contact-form-subtitle">Si prefieres, déjame tu mensaje y te respondo lo antes posible.</p>
        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="cf-nombre">Nombre *</label>
              <input type="text" id="cf-nombre" placeholder="Tu nombre" required>
            </div>
            <div class="form-group">
              <label for="cf-telefono">Teléfono</label>
              <input type="tel" id="cf-telefono" placeholder="Tu teléfono">
            </div>
          </div>
          <div class="form-group">
            <label for="cf-email">Email</label>
            <input type="email" id="cf-email" placeholder="tu@email.com">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="cf-servicio">Servicio de interés</label>
              <select id="cf-servicio">
                <option value="">Seleccionar...</option>
                <option value="Osteopatía">Osteopatía</option>
                <option value="Masaje deportivo">Masaje deportivo</option>
                <option value="Masaje tailandés">Masaje tailandés</option>
                <option value="Masaje corporal">Masaje corporal</option>
                <option value="Pindas herbales">Pindas herbales</option>
                <option value="Masaje embarazadas">Masaje embarazadas</option>
                <option value="No estoy seguro/a">No estoy seguro/a</option>
              </select>
            </div>
            <div class="form-group">
              <label for="cf-origen">¿Cómo nos encontraste?</label>
              <select id="cf-origen">
                <option value="">Seleccionar...</option>
                <option value="Google">Google</option>
                <option value="Recomendación">Recomendación</option>
                <option value="Instagram">Instagram</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="cf-mensaje">Mensaje *</label>
            <textarea id="cf-mensaje" rows="4" placeholder="¿En qué puedo ayudarte?" required></textarea>
          </div>
          <button type="submit" class="contact-form-btn" id="cf-submit">Enviar mensaje</button>
          <p class="contact-form-status" id="cf-status"></p>
        </form>
      </div>

      <!-- Info + map + exterior -->
      <div class="contact-bottom-grid">
        <div class="contact-info-col">
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            <div>
              <strong>Dirección</strong>
              <p>Calle Río Guadarrama 2<br>28430 Alpedrete, Madrid</p>
            </div>
          </div>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            <div>
              <strong>Horario</strong>
              <p>L-V: 9:00 - 20:00<br>Sábados: 10:00 - 14:00</p>
            </div>
          </div>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
            <div>
              <strong>Pago</strong>
              <p>Efectivo, Bizum, transferencia</p>
            </div>
          </div>

          <div class="contact-exterior">
            <img src="/images/entrada-exterior.webp" alt="Entrada exterior de la consulta de osteopatía en Alpedrete" width="828" height="1211" loading="lazy" />
            <p class="exterior-caption">Así encontrarás la entrada - Número 2</p>
          </div>
        </div>

        <div class="contact-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3033.5!2d-4.027!3d40.663!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4189d3f2e8e9e1%3A0x1!2sCalle%20R%C3%ADo%20Guadarrama%2C%202%2C%2028430%20Alpedrete%2C%20Madrid!5e0!3m2!1ses!2ses!4v1"
            width="100%"
            height="100%"
            style="border:0; border-radius: 16px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de la consulta de osteopatía en Alpedrete">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="text-center mb-4">Preguntas frecuentes</h2>

      <div class="faq-grid">
        <details class="faq-item">
          <summary>¿Cómo puedo reservar una cita?</summary>
          <p>Puedes reservar llamándome al <a href="tel:+34643961065">643 961 065</a>, por WhatsApp, o enviándome un email. Te confirmaré la cita lo antes posible.</p>
        </details>

        <details class="faq-item">
          <summary>¿Cuánto dura una sesión?</summary>
          <p>La duración depende del tratamiento. Las sesiones de osteopatía duran 55 minutos, mientras que los masajes varían entre 30 y 90 minutos.</p>
        </details>

        <details class="faq-item">
          <summary>¿Qué métodos de pago aceptas?</summary>
          <p>Acepto efectivo, Bizum y transferencia bancaria. El pago se realiza al finalizar la sesión.</p>
        </details>

        <details class="faq-item">
          <summary>¿Puedo cancelar o cambiar mi cita?</summary>
          <p>Sí, te pido que me avises con al menos 24 horas de antelación para poder reorganizar mi agenda.</p>
        </details>

        <details class="faq-item">
          <summary>¿Hay parking cerca?</summary>
          <p>Sí, hay estacionamiento gratuito en la zona. Al reservar te daré indicaciones exactas.</p>
        </details>

        <details class="faq-item">
          <summary>¿Emites factura?</summary>
          <p>Sí, puedo emitir factura si la necesitas. Solo tienes que pedírmelo.</p>
        </details>

        <details class="faq-item">
          <summary>¿Necesito llevar algo a la sesión?</summary>
          <p>No necesitas traer nada especial. Ven con ropa cómoda. Yo proporciono todo lo necesario para el tratamiento (camilla, aceites, toallas).</p>
        </details>

        <details class="faq-item">
          <summary>¿Cuántas sesiones necesitaré?</summary>
          <p>Depende de cada caso. En la primera sesión evaluaré tu situación y te daré una estimación. Muchos pacientes notan mejoría desde la primera sesión.</p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-page {
    padding-top: 140px;
    padding-bottom: 80px;
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
  }

  .contact-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .contact-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    max-width: 600px;
    margin: 0 auto 20px;
  }

  .contact-header p {
    margin: 0 auto;
    max-width: 500px;
    color: var(--color-text-light);
  }

  .response-promise {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 10px 20px;
    background: rgba(90, 124, 89, 0.08);
    border-radius: 25px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary-dark);
  }

  .response-promise svg {
    width: 18px;
    height: 18px;
    fill: var(--color-primary);
    flex-shrink: 0;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 50px;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 28px 16px;
    background: white;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid rgba(90, 124, 89, 0.08);
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(90, 124, 89, 0.12);
    border-color: rgba(90, 124, 89, 0.15);
  }

  .contact-card svg {
    width: 28px;
    height: 28px;
    fill: var(--color-primary);
    margin-bottom: 12px;
    transition: transform 0.3s ease;
  }

  .contact-card:hover svg {
    transform: scale(1.1);
  }

  .contact-card h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .contact-card span {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .contact-card--wa {
    background: rgba(37, 211, 102, 0.06);
    border-color: rgba(37, 211, 102, 0.12);
  }

  .contact-card--wa svg {
    fill: #25D366;
  }

  .contact-card--wa:hover {
    background: rgba(37, 211, 102, 0.1);
    border-color: rgba(37, 211, 102, 0.25);
  }

  .contact-bottom-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 40px;
    align-items: start;
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .info-item svg {
    width: 22px;
    height: 22px;
    fill: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-item strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .info-item p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .contact-exterior {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .contact-exterior img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .exterior-caption {
    background: var(--color-cream);
    padding: 10px;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text);
    font-weight: 500;
    margin: 0;
  }

  .contact-map {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    height: 350px;
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 350px;
  }

  .faq {
    background: var(--color-cream);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--color-warm-white);
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgba(90, 124, 89, 0.1);
    transition: all 0.3s ease;
  }

  .faq-item[open] {
    box-shadow: 0 4px 15px rgba(90, 124, 89, 0.1);
  }

  .faq-item summary {
    padding: 20px 25px;
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    font-size: 1.05rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--color-primary);
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item summary:hover {
    color: var(--color-primary);
  }

  .faq-item p {
    padding: 0 25px 20px;
    color: var(--color-text-light);
    line-height: 1.8;
    font-size: 0.95rem;
    max-width: none;
  }

  .faq-item a {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* Contact form */
  .contact-form-section {
    margin-bottom: 50px;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  .contact-form-section h2 {
    text-align: center;
    margin-bottom: 8px;
  }

