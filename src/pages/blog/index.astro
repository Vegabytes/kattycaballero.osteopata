---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../lib/reading-time';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pageTitle = "Blog de Osteopatía y Bienestar | Katy Caballero";
const pageDescription = "Artículos sobre osteopatía, masajes, ejercicios para dolor de espalda y consejos de salud. Blog de Katy Caballero, osteópata en Alpedrete, Sierra Noroeste de Madrid. Aprende a cuidar tu cuerpo.";

// Unique categories
const categories = [...new Set(sortedPosts.map(p => p.data.category))].sort();

// Blog schema
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Osteopatía y Bienestar - Katy Caballero",
  "description": pageDescription,
  "url": "https://katycaballeroosteopata.com/blog",
  "author": { "@type": "Person", "name": "Katy Caballero" },
  "blogPost": sortedPosts.slice(0, 10).map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.excerpt,
    "datePublished": post.data.date.toISOString(),
    "url": `https://katycaballeroosteopata.com/blog/${post.slug}`,
    "image": `https://katycaballeroosteopata.com${post.data.image}`,
    "author": { "@type": "Person", "name": "Katy Caballero" },
  }))
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('es-ES', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
}
---

<Layout title={pageTitle} description={pageDescription} keywords="blog osteopatia, consejos dolor de espalda, ejercicios contracturas, masaje terapeutico beneficios, osteopatia sierra de madrid, osteopatia sierra noroeste madrid, osteopatia sierra de guadarrama, salud bienestar alpedrete, fisioterapia consejos" breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Blog" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <section class="page-header">
    <div class="container">
      <Breadcrumbs items={[{label: "Inicio", href: "/"}, {label: "Blog"}]} />
      <span class="section-tag">Blog</span>
      <h1>Consejos de salud y bienestar</h1>
      <p>Artículos útiles para cuidar tu cuerpo en el día a día</p>
    </div>
  </section>
  
  <section class="blog-list">
    <div class="container">
      <div class="blog-filters">
        <div class="blog-search">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="blog-search-input" placeholder="Buscar artículos..." autocomplete="off" />
        </div>
        <div class="blog-categories" id="blog-categories">
          <button class="category-tag active" data-category="all">Todos</button>
          {categories.map(cat => (
            <button class="category-tag" data-category={cat}>{cat}</button>
          ))}
        </div>
      </div>
      <div class="blog-grid">
        {sortedPosts.map((post, index) => (
          <article class="blog-card" class:list={[{ featured: index === 0 }]} data-category={post.data.category} data-title={post.data.title.toLowerCase()} data-excerpt={post.data.excerpt.toLowerCase()}>
            <a href={`/blog/${post.slug}`} class="blog-card-image-link">
              <img src={post.data.image} alt={post.data.title} class="blog-card-image" width="600" height="280" loading={index === 0 ? "eager" : "lazy"} />
            </a>
            <div class="blog-card-content">
              <span class="blog-card-tag">{post.data.category}</span>
              <h2>
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p>{post.data.excerpt}</p>
              <div class="blog-card-meta">
                <span>{formatDate(post.data.date)}</span>
                <span>•</span>
                <span>{post.data.readTime ?? getReadingTime(post.body)} min de lectura</span>
              </div>
              <a href={`/blog/${post.slug}`} class="blog-card-link">
                Leer artículo
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
      
      <div class="pagination-info" id="pagination-info" style="display: none;">
        <span id="pagination-info-text"></span>
      </div>

      <nav class="pagination" id="pagination" aria-label="Paginación del blog" style="display: none;">
        <button class="pagination-btn" id="pagination-prev" aria-label="Página anterior">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          Anterior
        </button>
        <div class="pagination-pages" id="pagination-pages"></div>
        <button class="pagination-btn" id="pagination-next" aria-label="Página siguiente">
          Siguiente
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
      </nav>

      <div class="no-results" id="no-results" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        <p class="no-results-title">No se encontraron artículos</p>
        <p class="no-results-text">Prueba con otros términos de búsqueda o selecciona otra categoría.</p>
      </div>

      {sortedPosts.length === 0 && (
        <div class="no-posts">
          <p>Próximamente publicaré artículos sobre osteopatía, masajes y bienestar.</p>
          <p>¡Vuelve pronto!</p>
        </div>
      )}
    </div>
  </section>
  
  <section class="blog-cta">
    <div class="container text-center">
      <h2>¿Tienes alguna duda sobre tu salud?</h2>
      <p>Contacta conmigo y te ayudaré a encontrar el mejor tratamiento para ti.</p>
      <a href="/contacto" class="btn btn-primary">Contactar</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }
  
  .page-header h1 {
    margin-bottom: 20px;
  }
  
  .page-header p {
    margin: 0 auto;
    max-width: 600px;
  }
  
  .blog-list {
    background: var(--color-warm-white);
  }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  
  .blog-card {
    background: var(--color-cream);
    border-radius: 20px;
    overflow: hidden;
    transition: var(--transition);
  }
  
  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-medium);
  }
  
  .blog-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
  }
  
  .blog-card-image-link {
    display: block;
    overflow: hidden;
  }
  
  .blog-card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    transition: var(--transition);
  }
  
  .blog-card.featured .blog-card-image {
    height: 100%;
    min-height: 400px;
  }
  
  .blog-card:hover .blog-card-image {
    transform: scale(1.05);
  }
  
  .blog-card-content {
    padding: 35px;
  }
  
  .blog-card.featured .blog-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .blog-card-tag {
    display: inline-block;
    background: var(--color-secondary-light);
    color: var(--color-text);
    padding: 6px 14px;
    border-radius: 15px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 18px;
  }
  
  .blog-card h2 {
    font-size: 1.4rem;
    margin-bottom: 15px;
    line-height: 1.4;
  }
  
  .blog-card.featured h2 {
    font-size: 1.8rem;
  }
  
  .blog-card h2 a {
    text-decoration: none;
    color: var(--color-text);
    transition: var(--transition);
  }
  
  .blog-card h2 a:hover {
    color: var(--color-primary);
  }
  
  .blog-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: none;
    margin-bottom: 20px;
  }
  
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }
  
  .blog-card-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
    transition: var(--transition);
  }
  
  .blog-card-link svg {
    width: 18px;
    height: 18px;
    transition: var(--transition);
  }
  
  .blog-card-link:hover {
    color: var(--color-primary-dark);
  }
  
  .blog-card-link:hover svg {
    transform: translateX(4px);
  }
  
  .no-posts {
    text-align: center;
    padding: 60px 0;
  }
  
  .blog-cta {
    background: var(--color-cream);
    padding: 80px 0;
  }
  
  .blog-cta h2 {
    margin-bottom: 15px;
  }
  
  .blog-cta p {
    margin: 0 auto 30px;
    max-width: 500px;
  }
  
  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    
    .blog-card.featured {
      grid-template-columns: 1fr;
    }
    
    .blog-card.featured .blog-card-image {
      min-height: auto;
      height: 280px;
    }
  }

  .blog-filters {
    margin-bottom: 40px;
  }

  .blog-search {
    position: relative;
    max-width: 480px;
    margin: 0 auto 24px;
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: var(--color-text-muted, #767676);
    pointer-events: none;
  }

  #blog-search-input {
    width: 100%;
    padding: 14px 16px 14px 48px;
    border: 1px solid rgba(90, 124, 89, 0.2);
    border-radius: 30px;
    background: var(--color-warm-white, #fff);
    color: var(--color-text, #3d3d3d);
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  #blog-search-input::placeholder {
    color: var(--color-text-muted, #767676);
  }

  #blog-search-input:focus {
    border-color: var(--color-primary, #5a7c59);
    box-shadow: 0 0 0 3px rgba(90, 124, 89, 0.15);
  }

  .blog-categories {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .category-tag {
    padding: 8px 20px;
    border-radius: 25px;
    border: 1px solid rgba(90, 124, 89, 0.2);
    background: var(--color-warm-white);
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .category-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .category-tag.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .blog-card.hidden-by-filter {
    display: none;
  }

  .no-results {
    text-align: center;
    padding: 60px 20px;
  }

  .no-results svg {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted, #767676);
    margin-bottom: 16px;
  }

  .no-results-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text, #3d3d3d);
    margin-bottom: 8px;
  }

  .no-results-text {
    font-size: 0.95rem;
    color: var(--color-text-muted, #767676);
  }

  /* Dark mode */
  :global([data-theme="dark"]) #blog-search-input {
    background: #2a2a2a;
    border-color: rgba(122, 156, 121, 0.3);
    color: #e0e0e0;
  }

  :global([data-theme="dark"]) #blog-search-input::placeholder {
    color: #888;
  }

  :global([data-theme="dark"]) #blog-search-input:focus {
    border-color: var(--color-primary-light, #7a9c79);
    box-shadow: 0 0 0 3px rgba(122, 156, 121, 0.2);
  }

  :global([data-theme="dark"]) .search-icon {
    color: #888;
  }

  :global([data-theme="dark"]) .category-tag {
    background: #2a2a2a;
    border-color: rgba(122, 156, 121, 0.3);
    color: #ccc;
  }

  :global([data-theme="dark"]) .category-tag:hover {
    border-color: var(--color-primary-light, #7a9c79);
    color: var(--color-primary-light, #7a9c79);
  }

  :global([data-theme="dark"]) .category-tag.active {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  :global([data-theme="dark"]) .no-results svg {
    color: #888;
  }

  :global([data-theme="dark"]) .no-results-title {
    color: #e0e0e0;
  }

  :global([data-theme="dark"]) .no-results-text {
    color: #888;
  }

  /* Pagination */
  .pagination-info {
    text-align: center;
    margin-top: 32px;
    margin-bottom: 8px;
    font-size: 0.9rem;
    color: var(--color-text-muted, #767676);
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border-radius: 50px;
    border: 1px solid rgba(90, 124, 89, 0.2);
    background: var(--color-warm-white, #fff);
    color: var(--color-primary, #5a7c59);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .pagination-btn:hover:not(:disabled) {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  .pagination-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .pagination-btn svg {
    width: 16px;
    height: 16px;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .pagination-page {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(90, 124, 89, 0.2);
    background: var(--color-warm-white, #fff);
    color: var(--color-text, #3d3d3d);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pagination-page:hover {
    border-color: var(--color-primary, #5a7c59);
    color: var(--color-primary, #5a7c59);
  }

  .pagination-page.active {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  .pagination-ellipsis {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted, #767676);
    font-size: 0.9rem;
  }

  /* Dark mode pagination */
  :global([data-theme="dark"]) .pagination-info {
    color: #888;
  }

  :global([data-theme="dark"]) .pagination-btn {
    background: #2a2a2a;
    border-color: rgba(122, 156, 121, 0.3);
    color: var(--color-primary-light, #7a9c79);
  }

  :global([data-theme="dark"]) .pagination-btn:hover:not(:disabled) {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  :global([data-theme="dark"]) .pagination-page {
    background: #2a2a2a;
    border-color: rgba(122, 156, 121, 0.3);
    color: #ccc;
  }

  :global([data-theme="dark"]) .pagination-page:hover {
    border-color: var(--color-primary-light, #7a9c79);
    color: var(--color-primary-light, #7a9c79);
  }

  :global([data-theme="dark"]) .pagination-page.active {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  :global([data-theme="dark"]) .pagination-ellipsis {
    color: #888;
  }

  .blog-card.hidden-by-page {
    display: none;
  }
</style>

<script>
  const POSTS_PER_PAGE = 6;
  let currentPage = 1;

  function getFilteredCards(): HTMLElement[] {
    const searchInput = document.getElementById('blog-search-input') as HTMLInputElement;
    const activeBtn = document.querySelector('.category-tag.active') as HTMLElement;
    const query = (searchInput?.value || '').toLowerCase().trim();
    const cat = activeBtn?.dataset.category || 'all';
    const cards = Array.from(document.querySelectorAll('.blog-card')) as HTMLElement[];

    return cards.filter(el => {
      const matchesCategory = cat === 'all' || el.dataset.category === cat;
      const title = el.dataset.title || '';
      const excerpt = el.dataset.excerpt || '';
      const matchesSearch = !query || title.includes(query) || excerpt.includes(query);
      return matchesCategory && matchesSearch;
    });
  }

  function renderPagination(filteredCards: HTMLElement[]) {
    const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);
    const paginationEl = document.getElementById('pagination') as HTMLElement;
    const paginationInfo = document.getElementById('pagination-info') as HTMLElement;
    const paginationInfoText = document.getElementById('pagination-info-text') as HTMLElement;
    const paginationPages = document.getElementById('pagination-pages') as HTMLElement;
    const prevBtn = document.getElementById('pagination-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('pagination-next') as HTMLButtonElement;

    // Only show pagination if more than 6 filtered posts
    if (filteredCards.length <= POSTS_PER_PAGE) {
      paginationEl.style.display = 'none';
      paginationInfo.style.display = 'none';
      return;
    }

    paginationEl.style.display = 'flex';
    paginationInfo.style.display = 'block';

    // Info text
    const start = (currentPage - 1) * POSTS_PER_PAGE + 1;
    const end = Math.min(currentPage * POSTS_PER_PAGE, filteredCards.length);
    paginationInfoText.textContent = `Mostrando ${start}-${end} de ${filteredCards.length} artículos`;

    // Prev / Next
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Page numbers
    paginationPages.innerHTML = '';
    const pages = getPageNumbers(currentPage, totalPages);
    pages.forEach(p => {
      if (p === '...') {
        const ellipsis = document.createElement('span');
        ellipsis.className = 'pagination-ellipsis';
        ellipsis.textContent = '...';
        paginationPages.appendChild(ellipsis);
      } else {
        const btn = document.createElement('button');
        btn.className = 'pagination-page' + (p === currentPage ? ' active' : '');
        btn.textContent = String(p);
        btn.setAttribute('aria-label', `Página ${p}`);
        if (p === currentPage) btn.setAttribute('aria-current', 'page');
        btn.addEventListener('click', () => {
          currentPage = p as number;
          applyPagination();
        });
        paginationPages.appendChild(btn);
      }
    });
  }

  function getPageNumbers(current: number, total: number): (number | string)[] {
    if (total <= 7) {
      return Array.from({ length: total }, (_, i) => i + 1);
    }
    const pages: (number | string)[] = [1];
    if (current > 3) pages.push('...');
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
      pages.push(i);
    }
    if (current < total - 2) pages.push('...');
    pages.push(total);
    return pages;
  }

  function applyPagination() {
    const allCards = Array.from(document.querySelectorAll('.blog-card')) as HTMLElement[];
    const filteredCards = getFilteredCards();
    const noResults = document.getElementById('no-results') as HTMLElement;
    const totalPages = Math.max(1, Math.ceil(filteredCards.length / POSTS_PER_PAGE));

    // Clamp current page
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    // First: hide all by filter, then show only filtered ones on current page
    allCards.forEach(el => {
      el.classList.add('hidden-by-filter');
      el.classList.remove('hidden-by-page');
    });

    filteredCards.forEach((el, index) => {
      el.classList.remove('hidden-by-filter');
      const pageOfCard = Math.floor(index / POSTS_PER_PAGE) + 1;
      if (pageOfCard !== currentPage) {
        el.classList.add('hidden-by-page');
      }
    });

    // No results message
    if (noResults) {
      noResults.style.display = filteredCards.length === 0 ? 'block' : 'none';
    }

    renderPagination(filteredCards);

    // Scroll to top of blog grid when changing page (not on initial load)
    const blogGrid = document.querySelector('.blog-filters');
    if (blogGrid && document.hasFocus()) {
      blogGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function filterBlog() {
    currentPage = 1;
    applyPagination();
  }

  // Category filter
  document.querySelectorAll('.category-tag').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.category-tag.active')?.classList.remove('active');
      btn.classList.add('active');
      filterBlog();
    });
  });

  // Search input
  const searchInput = document.getElementById('blog-search-input');
  if (searchInput) {
    searchInput.addEventListener('input', filterBlog);
  }

  // Prev / Next buttons
  document.getElementById('pagination-prev')?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      applyPagination();
    }
  });

  document.getElementById('pagination-next')?.addEventListener('click', () => {
    const filteredCards = getFilteredCards();
    const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      applyPagination();
    }
  });

  // Initial render
  applyPagination();
</script>
