---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pageTitle = "Blog de Osteopatía y Bienestar | Sierra Noroeste de Madrid";
const pageDescription = "Artículos sobre osteopatía, masajes terapéuticos, ejercicios para el dolor de espalda, contracturas y consejos de salud. Blog de Katy Caballero, osteópata en Alpedrete, Sierra Noroeste de Madrid.";

// Unique categories
const categories = [...new Set(sortedPosts.map(p => p.data.category))].sort();

// Blog schema
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Osteopatía y Bienestar - Katy Caballero",
  "description": pageDescription,
  "url": "https://katycaballeroosteopata.com/blog",
  "author": { "@type": "Person", "name": "Katy Caballero" },
  "blogPost": sortedPosts.slice(0, 10).map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.excerpt,
    "datePublished": post.data.date.toISOString(),
    "url": `https://katycaballeroosteopata.com/blog/${post.slug}`,
    "image": `https://katycaballeroosteopata.com${post.data.image}`,
    "author": { "@type": "Person", "name": "Katy Caballero" },
  }))
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('es-ES', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
}
---

<Layout title={pageTitle} description={pageDescription} keywords="blog osteopatia, consejos dolor de espalda, ejercicios contracturas, masaje terapeutico beneficios, osteopatia sierra de madrid, osteopatia sierra noroeste madrid, osteopatia sierra de guadarrama, salud bienestar alpedrete, fisioterapia consejos" breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Blog" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <section class="page-header">
    <div class="container">
      <span class="section-tag">Blog</span>
      <h1>Consejos de salud y bienestar</h1>
      <p>Artículos útiles para cuidar tu cuerpo en el día a día</p>
    </div>
  </section>
  
  <section class="blog-list">
    <div class="container">
      <div class="blog-categories" id="blog-categories">
        <button class="category-tag active" data-category="all">Todos</button>
        {categories.map(cat => (
          <button class="category-tag" data-category={cat}>{cat}</button>
        ))}
      </div>
      <div class="blog-grid">
        {sortedPosts.map((post, index) => (
          <article class="blog-card" class:list={[{ featured: index === 0 }]} data-category={post.data.category}>
            <a href={`/blog/${post.slug}`} class="blog-card-image-link">
              <img src={post.data.image} alt={post.data.title} class="blog-card-image" width="600" height="280" loading={index === 0 ? "eager" : "lazy"} />
            </a>
            <div class="blog-card-content">
              <span class="blog-card-tag">{post.data.category}</span>
              <h2>
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p>{post.data.excerpt}</p>
              <div class="blog-card-meta">
                <span>{formatDate(post.data.date)}</span>
                <span>•</span>
                <span>{post.data.readTime} min lectura</span>
              </div>
              <a href={`/blog/${post.slug}`} class="blog-card-link">
                Leer artículo
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
      
      {sortedPosts.length === 0 && (
        <div class="no-posts">
          <p>Próximamente publicaré artículos sobre osteopatía, masajes y bienestar.</p>
          <p>¡Vuelve pronto!</p>
        </div>
      )}
    </div>
  </section>
  
  <section class="blog-cta">
    <div class="container text-center">
      <h2>¿Tienes alguna duda sobre tu salud?</h2>
      <p>Contacta conmigo y te ayudaré a encontrar el mejor tratamiento para ti.</p>
      <a href="/contacto" class="btn btn-primary">Contactar</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }
  
  .page-header h1 {
    margin-bottom: 20px;
  }
  
  .page-header p {
    margin: 0 auto;
    max-width: 600px;
  }
  
  .blog-list {
    background: var(--color-warm-white);
  }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  
  .blog-card {
    background: var(--color-cream);
    border-radius: 20px;
    overflow: hidden;
    transition: var(--transition);
  }
  
  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-medium);
  }
  
  .blog-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
  }
  
  .blog-card-image-link {
    display: block;
    overflow: hidden;
  }
  
  .blog-card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    transition: var(--transition);
  }
  
  .blog-card.featured .blog-card-image {
    height: 100%;
    min-height: 400px;
  }
  
  .blog-card:hover .blog-card-image {
    transform: scale(1.05);
  }
  
  .blog-card-content {
    padding: 35px;
  }
  
  .blog-card.featured .blog-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .blog-card-tag {
    display: inline-block;
    background: var(--color-secondary-light);
    color: var(--color-text);
    padding: 6px 14px;
    border-radius: 15px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 18px;
  }
  
  .blog-card h2 {
    font-size: 1.4rem;
    margin-bottom: 15px;
    line-height: 1.4;
  }
  
  .blog-card.featured h2 {
    font-size: 1.8rem;
  }
  
  .blog-card h2 a {
    text-decoration: none;
    color: var(--color-text);
    transition: var(--transition);
  }
  
  .blog-card h2 a:hover {
    color: var(--color-primary);
  }
  
  .blog-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: none;
    margin-bottom: 20px;
  }
  
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }
  
  .blog-card-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
    transition: var(--transition);
  }
  
  .blog-card-link svg {
    width: 18px;
    height: 18px;
    transition: var(--transition);
  }
  
  .blog-card-link:hover {
    color: var(--color-primary-dark);
  }
  
  .blog-card-link:hover svg {
    transform: translateX(4px);
  }
  
  .no-posts {
    text-align: center;
    padding: 60px 0;
  }
  
  .blog-cta {
    background: var(--color-cream);
    padding: 80px 0;
  }
  
  .blog-cta h2 {
    margin-bottom: 15px;
  }
  
  .blog-cta p {
    margin: 0 auto 30px;
    max-width: 500px;
  }
  
  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    
    .blog-card.featured {
      grid-template-columns: 1fr;
    }
    
    .blog-card.featured .blog-card-image {
      min-height: auto;
      height: 280px;
    }
  }

  .blog-categories {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    justify-content: center;
  }

  .category-tag {
    padding: 8px 20px;
    border-radius: 25px;
    border: 1px solid rgba(90, 124, 89, 0.2);
    background: var(--color-warm-white);
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .category-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .category-tag.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .blog-card.hidden-by-filter {
    display: none;
  }
</style>

<script>
  document.querySelectorAll('.category-tag').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.category-tag.active')?.classList.remove('active');
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.category;
      document.querySelectorAll('.blog-card').forEach(card => {
        if (cat === 'all' || (card as HTMLElement).dataset.category === cat) {
          card.classList.remove('hidden-by-filter');
        } else {
          card.classList.add('hidden-by-filter');
        }
      });
    });
  });
</script>
