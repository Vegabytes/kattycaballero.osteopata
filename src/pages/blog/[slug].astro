---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getReadingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const readingTime = post.data.readTime ?? getReadingTime(post.body);
const postUrl = `https://katycaballeroosteopata.com/blog/${post.slug}`;
const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(postUrl);

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": `https://katycaballeroosteopata.com${post.data.image}`,
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "url": "https://katycaballeroosteopata.com/sobre-mi"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Katy Caballero - Osteópata y Masajista",
    "logo": {
      "@type": "ImageObject",
      "url": "https://katycaballeroosteopata.com/images/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://katycaballeroosteopata.com/blog/${post.slug}`
  },
  "articleSection": post.data.category || "Salud y Bienestar",
  "wordCount": post.body?.split(/\s+/).length || 0,
  "inLanguage": "es"
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('es-ES', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
}

// Get related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 2);

// Map blog categories to related service pages
const categoryServiceMap: Record<string, { url: string; name: string }[]> = {
  "Osteopatía": [
    { url: "/servicios/osteopatia-alpedrete", name: "Osteopatía estructural, visceral y craneal" },
  ],
  "Masajes": [
    { url: "/servicios/masaje-corporal-alpedrete", name: "Masaje corporal con aceite" },
    { url: "/servicios/masaje-tailandes-alpedrete", name: "Masaje tradicional tailandés" },
  ],
  "Deporte": [
    { url: "/servicios/masaje-deportivo-alpedrete", name: "Masaje deportivo" },
    { url: "/servicios/osteopatia-alpedrete", name: "Osteopatía para deportistas" },
  ],
  "Dolor de espalda": [
    { url: "/servicios/osteopatia-alpedrete", name: "Osteopatía estructural, visceral y craneal" },
  ],
  "Bienestar": [
    { url: "/servicios/masaje-corporal-alpedrete", name: "Masaje corporal con aceite" },
    { url: "/servicios/masaje-tailandes-alpedrete", name: "Masaje tradicional tailandés" },
  ],
  "Consejos": [
    { url: "/servicios", name: "Ver todos nuestros servicios" },
  ],
  "Ejercicios": [
    { url: "/servicios/osteopatia-alpedrete", name: "Osteopatía estructural, visceral y craneal" },
    { url: "/guia-estiramientos", name: "Guía de estiramientos" },
  ],
  "Lesiones": [
    { url: "/servicios/osteopatia-alpedrete", name: "Osteopatía estructural, visceral y craneal" },
    { url: "/servicios/masaje-deportivo-alpedrete", name: "Masaje deportivo" },
  ],
};
const relatedServices = categoryServiceMap[post.data.category] || [{ url: "/servicios", name: "Ver todos nuestros servicios" }];

// Map categories to booking pre-selection
const categoryBookingMap: Record<string, string> = {
  "Osteopatía": "/reservar?servicio=Osteopat%C3%ADa",
  "Dolor de espalda": "/reservar?servicio=Osteopat%C3%ADa",
  "Lesiones": "/reservar?servicio=Osteopat%C3%ADa",
  "Ejercicios": "/reservar?servicio=Osteopat%C3%ADa",
  "Deporte": "/reservar?servicio=Masaje%20deportivo",
  "Masajes": "/reservar?servicio=Masaje%20corporal",
  "Bienestar": "/reservar?servicio=Masaje%20corporal",
};
const bookingUrl = categoryBookingMap[post.data.category] || "/reservar";
---

<Layout
  title={`${post.data.title} | Katy Caballero`}
  description={post.data.excerpt}
  image={post.data.image}
  type="article"
  publishedDate={post.data.date.toISOString()}
  breadcrumbs={[
    { name: "Inicio", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: post.data.title }
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <div class="reading-progress" id="reading-progress"></div>
  <article class="blog-post">
    <header class="post-header">
      <div class="container">
        <a href="/blog" class="back-link">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
          Volver al blog
        </a>
        <span class="post-category">{post.data.category}</span>
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <img src="/images/logo.webp" alt="Katy Caballero" class="author-avatar" width="50" height="50" loading="lazy" />
          <div>
            <span class="author-name">{post.data.author}</span>
            <span class="post-date">{formatDate(post.data.date)} · {readingTime} min de lectura</span>
          </div>
        </div>
      </div>
    </header>
    
    <div class="post-image">
      <img src={post.data.image} alt={post.data.title} width="900" height="450" loading="eager" />
    </div>
    
    <div class="container post-layout">
      <aside class="toc-sidebar" id="toc-sidebar" aria-label="Tabla de contenidos">
        <nav class="toc-nav">
          <h2 class="toc-title">Contenido</h2>
          <ul class="toc-list" id="toc-list"></ul>
        </nav>
      </aside>
      <div class="post-main">
      <div class="toc-mobile" id="toc-mobile">
        <button class="toc-mobile-toggle" id="toc-mobile-toggle" aria-expanded="false" aria-controls="toc-mobile-list">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="9" y2="18"/></svg>
          Tabla de contenidos
          <svg class="toc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <ul class="toc-mobile-list" id="toc-mobile-list"></ul>
      </div>
      <div class="post-content">
        <Content />
      </div>
      
      <div class="post-cta">
        <h3>¿Necesitas ayuda profesional?</h3>
        <p>Si tienes dolor o molestias, puedo ayudarte a encontrar el origen y tratarlo de forma personalizada.</p>
        <div class="post-cta-buttons">
          <a href={bookingUrl} class="btn btn-primary">Reservar Cita</a>
          <a href="https://wa.me/34643961065" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
      
      <nav class="post-services" aria-label="Servicios relacionados">
        <h3>Servicios relacionados</h3>
        <div class="post-services-links">
          {relatedServices.map(service => (
            <a href={service.url} class="post-service-link">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              {service.name}
            </a>
          ))}
        </div>
      </nav>

      <div class="post-share">
        <h3 class="share-heading">Comparte este art&iacute;culo</h3>
        <div class="share-buttons">
          <a href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en WhatsApp" class="share-btn share-whatsapp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp</span>
          </a>
          <a href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en X (Twitter)" class="share-btn share-twitter">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>X</span>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en Facebook" class="share-btn share-facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span>Facebook</span>
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en LinkedIn" class="share-btn share-linkedin">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
          <button class="share-btn share-copy" aria-label="Copiar enlace" data-url={postUrl}>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
            <span class="copy-label">Copiar enlace</span>
          </button>
        </div>
      </div>
      <script>
        document.querySelector('.share-copy')?.addEventListener('click', async (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const url = btn.dataset.url || window.location.href;
          const label = btn.querySelector('.copy-label');
          try {
            await navigator.clipboard.writeText(url);
            btn.classList.add('copied');
            if (label) label.textContent = 'Copiado!';
            setTimeout(() => {
              btn.classList.remove('copied');
              if (label) label.textContent = 'Copiar enlace';
            }, 2000);
          } catch {}
        });

        // Reading progress bar
        const progressBar = document.getElementById('reading-progress');
        if (progressBar) {
          window.addEventListener('scroll', () => {
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const scrolled = (window.scrollY / docHeight) * 100;
            progressBar.style.width = Math.min(scrolled, 100) + '%';
          });
        }

        // Table of Contents generation
        (function() {
          const postContent = document.querySelector('.post-content');
          if (!postContent) return;

          const headings = postContent.querySelectorAll('h2, h3');
          if (headings.length < 2) {
            // Hide TOC elements if fewer than 2 headings
            const sidebar = document.getElementById('toc-sidebar');
            const mobile = document.getElementById('toc-mobile');
            if (sidebar) sidebar.style.display = 'none';
            if (mobile) mobile.style.display = 'none';
            return;
          }

          // Show TOC sidebar
          const sidebar = document.getElementById('toc-sidebar');
          const mobile = document.getElementById('toc-mobile');
          if (sidebar) sidebar.classList.add('has-toc');
          if (mobile) mobile.classList.add('has-toc');

          const tocList = document.getElementById('toc-list');
          const tocMobileList = document.getElementById('toc-mobile-list');

          // Generate IDs and TOC items
          headings.forEach((heading, index) => {
            if (!heading.id) {
              heading.id = 'heading-' + index;
            }

            const createItem = (container: Element | null) => {
              if (!container) return;
              const li = document.createElement('li');
              li.className = heading.tagName === 'H3' ? 'toc-item toc-h3' : 'toc-item';
              const a = document.createElement('a');
              a.href = '#' + heading.id;
              a.textContent = heading.textContent || '';
              a.addEventListener('click', (e) => {
                e.preventDefault();
                heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // Close mobile TOC after click
                const mobileList = document.getElementById('toc-mobile-list');
                const toggle = document.getElementById('toc-mobile-toggle');
                if (mobileList) mobileList.classList.remove('open');
                if (toggle) toggle.setAttribute('aria-expanded', 'false');
              });
              li.appendChild(a);
              container.appendChild(li);
            };

            createItem(tocList);
            createItem(tocMobileList);
          });

          // Highlight active section on scroll
          const tocLinks = tocList ? tocList.querySelectorAll('a') : [];
          const mobileTocLinks = tocMobileList ? tocMobileList.querySelectorAll('a') : [];

          function updateActiveHeading() {
            let current = '';
            headings.forEach((heading) => {
              const rect = heading.getBoundingClientRect();
              if (rect.top <= 120) {
                current = heading.id;
              }
            });

            const setActive = (links: NodeListOf<Element>) => {
              links.forEach((link) => {
                link.classList.toggle('active', link.getAttribute('href') === '#' + current);
              });
            };

            setActive(tocLinks);
            setActive(mobileTocLinks);
          }

          window.addEventListener('scroll', updateActiveHeading, { passive: true });
          updateActiveHeading();

          // Mobile TOC toggle
          const mobileToggle = document.getElementById('toc-mobile-toggle');
          const mobileList = document.getElementById('toc-mobile-list');
          if (mobileToggle && mobileList) {
            mobileToggle.addEventListener('click', () => {
              const isOpen = mobileList.classList.toggle('open');
              mobileToggle.setAttribute('aria-expanded', String(isOpen));
            });
          }
        })();
      </script>
      </div>
    </div>
  </article>
  
  {relatedPosts.length > 0 && (
    <section class="related-posts">
      <div class="container">
        <h2>Artículos relacionados</h2>
        <div class="related-grid">
          {relatedPosts.map(relatedPost => (
            <article class="related-card">
              <a href={`/blog/${relatedPost.slug}`}>
                <img src={relatedPost.data.image} alt={relatedPost.data.title} width="400" height="180" loading="lazy" />
              </a>
              <div class="related-content">
                <span class="related-tag">{relatedPost.data.category}</span>
                <h3><a href={`/blog/${relatedPost.slug}`}>{relatedPost.data.title}</a></h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
    z-index: 9999;
    transition: width 0.1s linear;
  }

  .post-header {
    padding-top: 130px;
    padding-bottom: 50px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 25px;
    transition: var(--transition);
  }
  
  .back-link svg {
    width: 18px;
    height: 18px;
  }
  
  .back-link:hover {
    color: var(--color-primary);
  }
  
  .post-category {
    display: inline-block;
    background: var(--color-secondary);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 20px;
  }
  
  .post-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    max-width: 800px;
    margin: 0 auto 30px;
    line-height: 1.3;
  }
  
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
  }
  
  .author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: contain;
    background: white;
    padding: 5px;
  }
  
  .author-name {
    display: block;
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
  }
  
  .post-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  
  .post-image {
    margin: -30px auto 50px;
    max-width: 900px;
    padding: 0 24px;
  }
  
  .post-image img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: var(--shadow-strong);
  }
  
  .post-content {
    max-width: 750px;
    font-size: 1.1rem;
    line-height: 1.9;
  }
  
  .post-content :global(h2) {
    margin-top: 50px;
    margin-bottom: 20px;
    font-size: 1.8rem;
  }
  
  .post-content :global(h3) {
    margin-top: 40px;
    margin-bottom: 15px;
    font-size: 1.4rem;
  }
  
  .post-content :global(p) {
    margin-bottom: 25px;
    color: var(--color-text-light);
  }
  
  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 25px;
    padding-left: 25px;
  }
  
  .post-content :global(li) {
    margin-bottom: 10px;
    color: var(--color-text-light);
  }
  
  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
  
  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
  
  .post-content :global(a:hover) {
    color: var(--color-primary-dark);
  }
  
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 30px 0;
    font-size: 0.95rem;
  }
  
  .post-content :global(th),
  .post-content :global(td) {
