---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Katy Caballero - Osteópata | Links";
const pageDescription = "Enlaces rápidos de Katy Caballero, osteópata y masajista en Alpedrete.";
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
  <div class="linktree-page">
    <div class="linktree-container">
      <div class="linktree-header">
        <img src="/images/logo.webp" alt="Katy Caballero - Osteópata" class="linktree-logo" width="120" height="120" />
        <h1 class="linktree-name">Katy Caballero</h1>
        <p class="linktree-subtitle">Osteópata y Masajista en Alpedrete</p>
        <p class="linktree-rating">&#9733;&#9733;&#9733;&#9733;&#9733; 5.0 en Google</p>
      </div>

      <nav class="linktree-links" aria-label="Enlaces rápidos">
        <a href="/reservar" class="linktree-btn linktree-btn-primary">
          <svg class="linktree-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Reservar Cita
