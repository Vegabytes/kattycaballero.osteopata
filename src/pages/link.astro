        <a href="/bonos" class="linktree-btn">
          <svg class="linktree-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="22" height="18" rx="3"/><line x1="1" y1="9" x2="23" y2="9"/></svg>
          Bonos y Regalos
        </a>
        <a href="/contacto" class="linktree-btn">
          <svg class="linktree-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Contacto y Ubicación
        </a>
      </nav>

      <div class="linktree-social">
        <a href="https://www.instagram.com/katycaballero.osteopata" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="tel:+34643961065" aria-label="Llamar por teléfono">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </a>
      </div>

      <p class="linktree-footer">Calle Río Guadarrama 2, Alpedrete · 643 961 065</p>
    </div>
  </div>
</Layout>

<style is:global>
  /* Hide header, footer, WhatsApp button, cookie banner, scroll-top on link page */
  .linktree-page ~ footer,
  .linktree-page ~ .whatsapp-float,
  .linktree-page ~ .cookie-banner,
  .linktree-page ~ #scroll-top,
  body:has(.linktree-page) header,
  body:has(.linktree-page) .skip-link,
  body:has(.linktree-page) .scroll-top-btn,
  body:has(.linktree-page) > .whatsapp-float {
    display: none !important;
  }
</style>

<style>
  .linktree-page {
    min-height: 100vh;
    background: linear-gradient(160deg, #f7f5f0 0%, #eef2ee 40%, #f5f0e8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .linktree-container {
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .linktree-header {
    margin-bottom: 32px;
  }

  .linktree-logo {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 16px;
    border-radius: 50%;
    box-shadow: 0 4px 20px rgba(90, 124, 89, 0.15);
  }

  .linktree-name {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1.8rem;
    color: var(--color-primary-dark, #4a6548);
    margin: 0 0 4px;
    font-weight: 600;
  }

  .linktree-subtitle {
    font-family: var(--font-body, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    color: var(--color-text-light, #6b6b6b);
    margin: 0 0 8px;
  }

  .linktree-rating {
    font-size: 0.9rem;
    color: var(--color-secondary, #c4a35a);
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.5px;
  }

  .linktree-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .linktree-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 24px;
    background: white;
    border: 2px solid rgba(90, 124, 89, 0.2);
    border-radius: 50px;
    text-decoration: none;
    color: var(--color-primary-dark, #4a6548);
    font-family: var(--font-body, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .linktree-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(90, 124, 89, 0.15);
    border-color: var(--color-primary, #5a7c59);
    background: rgba(90, 124, 89, 0.03);
  }

  .linktree-btn-primary {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
  }

  .linktree-btn-primary:hover {
    background: var(--color-primary-dark, #4a6548);
    border-color: var(--color-primary-dark, #4a6548);
    color: white;
  }

  .linktree-btn-whatsapp {
    background: #25D366;
    color: white;
    border-color: #25D366;
  }

  .linktree-btn-whatsapp:hover {
    background: #1da851;
    border-color: #1da851;
    color: white;
  }

  .linktree-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .linktree-social {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .linktree-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: white;
    color: var(--color-primary, #5a7c59);
    border: 2px solid rgba(90, 124, 89, 0.15);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .linktree-social a:hover {
    background: var(--color-primary, #5a7c59);
    color: white;
    border-color: var(--color-primary, #5a7c59);
    transform: translateY(-2px);
  }

  .linktree-social svg {
    width: 22px;
    height: 22px;
  }

  .linktree-footer {
    font-size: 0.8rem;
    color: var(--color-text-light, #6b6b6b);
    margin: 0;
    line-height: 1.5;
  }
</style>
