---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Reservar Cita | Osteópata en Alpedrete - Katy Caballero";
const pageDescription = "Reserva tu cita de osteopatía o masaje en Alpedrete, Sierra Noroeste de Madrid. Elige servicio, día y hora, y confirma por WhatsApp. Horario flexible.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo reservo una cita de osteopatía en Alpedrete?",
      "acceptedAnswer": { "@type": "Answer", "text": "Puedes reservar directamente desde esta página eligiendo servicio, día y hora. También puedes contactarme por WhatsApp al 643 961 065 o llamar por teléfono." }
    },
    {
      "@type": "Question",
      "name": "¿Puedo cancelar o cambiar mi cita?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, puedes cancelar o modificar tu cita con al menos 24 horas de antelación contactándome por WhatsApp o teléfono." }
    },
    {
      "@type": "Question",
      "name": "¿Qué formas de pago aceptáis?",
      "acceptedAnswer": { "@type": "Answer", "text": "Aceptamos pago en efectivo, Bizum, PayPal y Revolut." }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto dura una sesión?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depende del servicio: osteopatía 55 min, masaje deportivo 30 min, masaje corporal 60 o 90 min, masaje tailandés 60 o 90 min, pindas herbales 90 min, y masaje para embarazadas 60 min." }
    }
  ]
};

const services = [
  { name: 'Osteopatía estructural, visceral y sacrocraneal', duration: '55 min', price: '40€' },
  { name: 'Masaje deportivo', duration: '30 min', price: '20€' },
  { name: 'Masaje corporal con aceite (60 min)', duration: '60 min', price: '40€' },
  { name: 'Masaje corporal con aceite (90 min)', duration: '90 min', price: '55€' },
  { name: 'Masaje tradicional tailandés (60 min)', duration: '60 min', price: '45€' },
  { name: 'Masaje tradicional tailandés (90 min)', duration: '90 min', price: '60€' },
  { name: 'Masaje con pindas herbales calientes', duration: '90 min', price: '70€' },
  { name: 'Masaje para embarazadas (desde 4º mes)', duration: '60 min', price: '40€' },
];
---

<Layout title={pageTitle} description={pageDescription} keywords="reservar cita osteopatia alpedrete, cita masaje sierra de madrid, cita masaje sierra noroeste madrid, pedir cita osteopata collado villalba, reservar masajista moralzarzal, tarifas masajes sierra guadarrama, precios osteopatia galapagar, cita masaje deportivo" breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Reservar" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="booking-hero">
    <div class="container">
      <span class="section-tag">Reservar Cita</span>
      <h1>Reserva tu sesión</h1>
      <p>Elige servicio, día y hora, o escríbeme directamente por WhatsApp.</p>
    </div>
  </section>

  <section class="booking-main">
    <div class="container">
      <div class="booking-layout">
        <!-- LEFT: Booking form -->
        <div class="booking-form-col">
          <div class="booking-stepper">
            <div class="step active" data-step="1">
              <span class="step-number">1</span>
              <span class="step-label">Servicio</span>
            </div>
            <div class="step-line"></div>
            <div class="step" data-step="2">
              <span class="step-number">2</span>
              <span class="step-label">Fecha y hora</span>
            </div>
            <div class="step-line"></div>
            <div class="step" data-step="3">
              <span class="step-number">3</span>
              <span class="step-label">Tus datos</span>
            </div>
          </div>

          <!-- Step 1: Service selection -->
          <div class="booking-step" id="step-1">
            <h2>¿Qué servicio necesitas?</h2>
            <div class="services-grid">
              {services.map((service, i) => (
                <button class="service-option" data-index={i} data-name={service.name} data-duration={service.duration} data-price={service.price}>
                  <span class="service-option-name">{service.name}</span>
                  <div class="service-option-meta">
                    <span class="service-option-duration">{service.duration}</span>
                    <span class="service-option-price">{service.price}</span>
                  </div>
                </button>
              ))}
            </div>
          </div>

          <!-- Step 2: Date and time -->
          <div class="booking-step hidden" id="step-2">
            <h2>Elige día y hora</h2>
            <div class="datetime-grid">
              <div class="calendar-wrapper">
                <div class="calendar-header">
                  <button class="cal-nav" id="cal-prev" aria-label="Mes anterior">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
                  </button>
                  <span class="cal-month" id="cal-month"></span>
                  <button class="cal-nav" id="cal-next" aria-label="Mes siguiente">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                  </button>
                </div>
                <div class="calendar-weekdays">
                  <span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span>
                </div>
                <div class="calendar-days" id="cal-days"></div>
              </div>
              <div class="time-wrapper">
                <h3 id="time-title">Selecciona un día</h3>
                <div class="time-slots" id="time-slots"></div>
              </div>
            </div>
            <div class="step-nav">
              <button class="btn-back" id="back-to-1">Cambiar servicio</button>
            </div>
          </div>

          <!-- Step 3: User data -->
          <div class="booking-step hidden" id="step-3">
            <h2>Tus datos de contacto</h2>
            <div class="user-form">
              <div class="form-group">
                <label for="user-name">Nombre <span aria-hidden="true">*</span></label>
                <input type="text" id="user-name" placeholder="Tu nombre" autocomplete="given-name" required aria-required="true">
              </div>
              <div class="form-group">
                <label for="user-phone">Teléfono <span aria-hidden="true">*</span></label>
                <input type="tel" id="user-phone" placeholder="Ej: 612 345 678" autocomplete="tel" required aria-required="true" pattern="(\+34\s?)?[6789]\d{2}\s?\d{3}\s?\d{3}" title="Introduce un teléfono español válido (ej: 612 345 678)">
              </div>
              <div class="form-group">
                <label for="user-email">Email (opcional, para confirmaci&oacute;n)</label>
                <input type="email" id="user-email" placeholder="tu@email.com" autocomplete="email">
              </div>
              <div class="form-group">
                <label for="user-notes">Notas (opcional)</label>
                <textarea id="user-notes" placeholder="¿Algo que deba saber? Ej: primera visita, zona de dolor..." rows="3"></textarea>
              </div>

              <div class="form-group" style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
                <label for="booking-website">Website</label>
                <input type="text" id="booking-website" name="website" tabindex="-1" autocomplete="off">
              </div>

              <div class="booking-summary" id="booking-summary" role="status" aria-live="polite"></div>

              <label class="gdpr-consent">
                <input type="checkbox" id="gdpr-check">
                <span>Acepto la <a href="/politica-privacidad" target="_blank">política de privacidad</a>. Mis datos se usarán solo para gestionar esta cita.</span>
              </label>

              <button class="btn-whatsapp-send" id="btn-send" disabled>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Confirmar por WhatsApp
              </button>
              <button class="btn-reservar-web" id="btn-reservar" disabled>
                Reservar sin WhatsApp
              </button>
            </div>
            <div class="step-nav">
              <button class="btn-back" id="back-to-2">Cambiar fecha</button>
            </div>
          </div>

          <!-- Step 4: Confirmation -->
          <div class="booking-step hidden" id="step-4">
            <div class="confirmation-screen">
              <div class="confirmation-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              </div>
              <h2>Cita reservada</h2>
              <p class="confirmation-subtitle">Tu solicitud se ha registrado correctamente</p>
              <div class="confirmation-details" id="confirmation-details"></div>
              <p class="confirmation-note">Te confirmaré la cita por teléfono o WhatsApp en las próximas horas.</p>
              <div class="confirmation-actions">
                <a href="/" class="btn-back-home">Volver al inicio</a>
                <a href="/reservar" class="btn-otra-cita">Reservar otra cita</a>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="booking-sidebar">
          <!-- WhatsApp directo (destacado) -->
          <a href="https://wa.me/34643961065?text=Hola%20Katy,%20me%20gustaría%20reservar%20una%20cita" class="sidebar-whatsapp" target="_blank" rel="noopener noreferrer nofollow">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div>
              <strong>WhatsApp directo</strong>
              <span>643 961 065</span>
            </div>
          </a>

          <!-- Otros métodos -->
          <div class="sidebar-methods">
            <a href="tel:+34643961065" class="sidebar-method">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <div>
                <strong>Llamar</strong>
                <span>643 961 065</span>
              </div>
            </a>
            <a href="mailto:katycaballero.osteopata@gmail.com?subject=Reserva%20de%20cita&body=Hola%20Katy,%0A%0AMe%20gustaría%20reservar%20una%20cita.%0A%0AServicio:%0AFecha%20preferida:%0AHora%20preferida:%0A%0AGracias!" class="sidebar-method">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <div>
                <strong>Email</strong>
                <span>Escribir correo</span>
              </div>
            </a>
          </div>

          <!-- Info rápida -->
          <div class="sidebar-info">
            <div class="sidebar-info-item">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
              <div>
                <strong>Horario</strong>
                <span>L-V: 9:00-20:00</span>
                <span>Sáb: 10:00-14:00</span>
              </div>
            </div>
            <div class="sidebar-info-item">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <div>
                <strong>Ubicación</strong>
                <span>C/ Río Guadarrama 2</span>
                <span>28430 Alpedrete</span>
              </div>
            </div>
            <div class="sidebar-info-item">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
              <div>
                <strong>Pago</strong>
                <span>Efectivo, Bizum, transferencia</span>
              </div>
            </div>
          </div>

          <!-- Bonos -->
          <div class="sidebar-bonos">
            <h3>Bonos de osteopatía</h3>
            <div class="sidebar-bono">
              <span class="bono-name">3 sesiones</span>
              <span class="bono-price">114€</span>
              <span class="bono-detail">38€/sesión</span>
            </div>
            <div class="sidebar-bono">
              <span class="bono-name">5 sesiones</span>
              <span class="bono-price">180€</span>
              <span class="bono-detail">36€/sesión</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="booking-first-visit">
    <div class="container text-center">
      <h2>¿Es tu primera visita?</h2>
      <p>En la primera sesión dedicaré tiempo a conocer tu historia, tus hábitos y cómo se manifiestan tus molestias. A través de la observación, el movimiento y el tacto, identificaré las tensiones y desequilibrios que pueden estar afectando a tu bienestar.</p>
      <p><strong>No necesitas traer nada especial</strong>, solo ropa cómoda si optas por el masaje tailandés. Para los demás tratamientos, te proporcionaré todo lo necesario.</p>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .booking-hero {
    padding-top: 150px;
    padding-bottom: 50px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }
  .booking-hero h1 { margin-bottom: 16px; }
  .booking-hero p { margin: 0 auto; max-width: 550px; }

  /* Main layout: two columns */
  .booking-main {
    background: var(--color-warm-white);
    padding: 50px 0 80px;
  }
  .booking-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    align-items: start;
  }

  /* Left: Form column */
  .booking-form-col {
    min-width: 0;
  }

  /* Stepper */
  .booking-stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 35px;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.4;
    transition: var(--transition);
  }
  .step.active { opacity: 1; }
  .step.done { opacity: 0.7; }
  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-secondary-light);
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.85rem;
  }
  .step.active .step-number {
    background: var(--color-primary);
    color: white;
  }
  .step.done .step-number {
    background: var(--color-primary-light);
    color: white;
  }
  .step-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .step-line {
    width: 40px;
    height: 2px;
    background: var(--color-secondary-light);
    margin: 0 12px;
  }

  /* Steps */
  .booking-step.hidden { display: none; }
  .booking-step h2 {
    text-align: center;
    margin-bottom: 25px;
    font-size: 1.3rem;
  }

  /* Step 1: Services */
  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service-option {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: var(--color-cream);
    border: 2px solid transparent;
    border-radius: 14px;
    cursor: pointer;
    transition: var(--transition);
    text-align: left;
    font-family: var(--font-body);
  }
  .service-option:hover {
    border-color: var(--color-primary-light);
    background: white;
    transform: translateX(4px);
  }
  .service-option.selected {
    border-color: var(--color-primary);
    background: rgba(90, 124, 89, 0.06);
  }
  .service-option-name {
    font-weight: 500;
    font-size: 0.92rem;
    color: var(--color-text);
  }
  .service-option-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    margin-left: 12px;
  }
  .service-option-duration {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .service-option-price {
    background: var(--color-secondary-light);
    padding: 5px 14px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  /* Step 2: Calendar */
  .datetime-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 24px;
  }
  .calendar-wrapper {
    background: var(--color-cream);
    border-radius: 20px;
    padding: 28px;
  }
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .cal-month {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: capitalize;
  }
  .cal-nav {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--color-warm-white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }
  .cal-nav:hover { background: var(--color-secondary-light); }
  .cal-nav:disabled { opacity: 0.3; cursor: default; }
  .cal-nav svg { width: 22px; height: 22px; fill: var(--color-text); }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    margin-bottom: 10px;
  }
  .calendar-weekdays span {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    padding: 8px 0;
  }
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }
  .cal-day {
    aspect-ratio: 1;
    border: none;
    border-radius: 50%;
    background: none;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 42px;
    min-height: 42px;
  }
  .cal-day:hover:not(:disabled):not(.empty) {
    background: var(--color-secondary-light);
  }
  .cal-day.today {
    font-weight: 700;
    box-shadow: inset 0 0 0 2px var(--color-secondary);
  }
