</style>

<script>
  // === Booking App ===
  const DAY_NAMES = ['domingo', 'lunes', 'martes', 'miercoles', 'jueves', 'viernes', 'sabado'];

  // Default schedule (used until API responds)
  const DEFAULT_HORARIO: Record<string, { activo: boolean; inicio: string; fin: string }> = {
    lunes:    { activo: true, inicio: '09:00', fin: '19:30' },
    martes:   { activo: true, inicio: '09:00', fin: '19:30' },
    miercoles:{ activo: true, inicio: '09:00', fin: '19:30' },
    jueves:   { activo: true, inicio: '09:00', fin: '19:30' },
    viernes:  { activo: true, inicio: '09:00', fin: '19:30' },
    sabado:   { activo: true, inicio: '10:00', fin: '13:30' },
    domingo:  { activo: false, inicio: '00:00', fin: '00:00' },
  };

  let availabilityData: {
    horario: Record<string, { activo: boolean; inicio: string; fin: string }>;
    diasBloqueados: string[];
    horasBloqueadas: { fecha: string; inicio: string; fin: string }[];
  } = { horario: DEFAULT_HORARIO, diasBloqueados: [], horasBloqueadas: [] };

  // Fetch availability from API
  async function loadAvailability() {
    try {
      const res = await fetch('/api/disponibilidad?_=' + Date.now(), { cache: 'no-store' });
      if (res.ok) {
        const data = await res.json();
        availabilityData = { horario: data.horario, diasBloqueados: data.diasBloqueados || [], horasBloqueadas: data.horasBloqueadas || [] };
      }
    } catch {}
  }

  const state = {
    service: null as { name: string; duration: string; price: string } | null,
    date: null as Date | null,
    time: null as string | null,
    currentMonth: new Date().getMonth(),
    currentYear: new Date().getFullYear(),
  };

  const MONTHS = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  const WEEKDAYS_SHORT = ['lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado', 'domingo'];

  function isDayActive(date: Date): boolean {
    const dayName = DAY_NAMES[date.getDay()];
    const config = availabilityData.horario[dayName];
    if (!config || !config.activo) return false;
    // Check blocked dates
    const dateStr = `${date.getFullYear()}-${(date.getMonth()+1).toString().padStart(2,'0')}-${date.getDate().toString().padStart(2,'0')}`;
    if (availabilityData.diasBloqueados.includes(dateStr)) return false;
    return true;
  }

  function getTimeSlots(date: Date): string[] {
    const dayName = DAY_NAMES[date.getDay()];
    const config = availabilityData.horario[dayName];
    if (!config || !config.activo) return [];

    const dateStr = `${date.getFullYear()}-${(date.getMonth()+1).toString().padStart(2,'0')}-${date.getDate().toString().padStart(2,'0')}`;
    const blockedRanges = (availabilityData.horasBloqueadas || []).filter(b => b.fecha === dateStr);

    const [startH, startM] = config.inicio.split(':').map(Number);
    const [endH, endM] = config.fin.split(':').map(Number);
    const slots: string[] = [];
    let h = startH;
    let m = startM || 0;
    while (h < endH || (h === endH && m < endM)) {
      const slot = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
      // Check if slot falls within any blocked range
      const isBlocked = blockedRanges.some(b => slot >= b.inicio && slot < b.fin);
      if (!isBlocked) {
        slots.push(slot);
      }
      m += 30;
      if (m >= 60) { h++; m = 0; }
    }
    return slots;
  }

  function showStep(n: number) {
    document.querySelectorAll('.booking-step').forEach(el => el.classList.add('hidden'));
    document.getElementById(`step-${n}`)?.classList.remove('hidden');
    document.querySelectorAll('.step').forEach(el => {
      const s = Number(el.getAttribute('data-step'));
      el.classList.toggle('active', s === n);
      el.classList.toggle('done', s < n);
    });
    document.querySelector('.booking-main')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Load availability on page load
  loadAvailability();

  // Auto-select service from URL param (?servicio=Osteopatía...)
  (async () => {
    const params = new URLSearchParams(window.location.search);
    const preselect = params.get('servicio');
    if (preselect) {
      await loadAvailability();
      const match = document.querySelector(`.service-option[data-name="${preselect}"]`) as HTMLElement |
        null || Array.from(document.querySelectorAll('.service-option')).find(
          el => el.getAttribute('data-name')?.toLowerCase().includes(preselect.toLowerCase())
        ) as HTMLElement | null;
      if (match) {
        match.click();
      }
    }
  })();

  // Step 1
  document.querySelectorAll('.service-option').forEach(btn => {
    btn.addEventListener('click', async () => {
      document.querySelectorAll('.service-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      state.service = {
        name: btn.getAttribute('data-name') || '',
        duration: btn.getAttribute('data-duration') || '',
        price: btn.getAttribute('data-price') || '',
      };
      await loadAvailability();
      setTimeout(() => { showStep(2); renderCalendar(); }, 200);
    });
  });

  // Step 2
  function renderCalendar() {
    const calDays = document.getElementById('cal-days')!;
    const calMonth = document.getElementById('cal-month')!;
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    calMonth.textContent = `${MONTHS[state.currentMonth]} ${state.currentYear}`;

    const prevBtn = document.getElementById('cal-prev') as HTMLButtonElement;
    prevBtn.disabled = state.currentYear === today.getFullYear() && state.currentMonth === today.getMonth();

    const maxDate = new Date(today.getFullYear(), today.getMonth() + 3, 0);
    const nextBtn = document.getElementById('cal-next') as HTMLButtonElement;
    nextBtn.disabled = state.currentYear > maxDate.getFullYear() ||
      (state.currentYear === maxDate.getFullYear() && state.currentMonth >= maxDate.getMonth());

    const firstDay = new Date(state.currentYear, state.currentMonth, 1);
    const lastDay = new Date(state.currentYear, state.currentMonth + 1, 0);

    let startOffset = firstDay.getDay() - 1;
    if (startOffset < 0) startOffset = 6;

    calDays.innerHTML = '';

    for (let i = 0; i < startOffset; i++) {
      const empty = document.createElement('span');
      empty.className = 'cal-day empty';
      calDays.appendChild(empty);
    }

    for (let d = 1; d <= lastDay.getDate(); d++) {
      const date = new Date(state.currentYear, state.currentMonth, d);
      const btn = document.createElement('button');
      btn.className = 'cal-day';
      btn.textContent = String(d);

      const isInactive = !isDayActive(date);
      const isPast = date < today;
      const isToday = date.getTime() === today.getTime();

      if (isToday) btn.classList.add('today');
      if (isInactive || isPast) btn.disabled = true;
      if (state.date && date.getTime() === state.date.getTime()) btn.classList.add('selected');

      btn.addEventListener('click', () => {
        state.date = date;
        state.time = null;
        renderCalendar();
        renderTimeSlots();
      });

      calDays.appendChild(btn);
    }
  }

  // Cache for occupied slots per date
  const occupiedCache: Record<string, string[]> = {};

  async function fetchOccupiedSlots(date: Date): Promise<string[]> {
    const dateStr = `${date.getFullYear()}-${(date.getMonth()+1).toString().padStart(2,'0')}-${date.getDate().toString().padStart(2,'0')}`;
    if (occupiedCache[dateStr]) return occupiedCache[dateStr];
    try {
      const res = await fetch(`/api/citas-disponibles?fecha=${dateStr}`);
      if (res.ok) {
        const data = await res.json();
        occupiedCache[dateStr] = data.occupied || [];
        return occupiedCache[dateStr];
      }
    } catch {}
    return [];
  }

  async function renderTimeSlots() {
    const container = document.getElementById('time-slots')!;
    const title = document.getElementById('time-title')!;

    if (!state.date) {
      title.textContent = 'Selecciona un día';
      container.innerHTML = '';
      return;
    }

    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateStr = `${state.date.getDate()} de ${MONTHS[state.date.getMonth()]}`;
    title.textContent = `${dayName} ${dateStr}`;

    container.innerHTML = '<p style="grid-column:1/-1;text-align:center;color:var(--color-text-muted);font-size:0.9rem;">Cargando horarios...</p>';

    const [slots, occupied] = await Promise.all([
      Promise.resolve(getTimeSlots(state.date)),
      fetchOccupiedSlots(state.date),
    ]);

    const now = new Date();
    const filteredSlots = slots.filter(s => {
      if (state.date!.toDateString() !== now.toDateString()) return true;
      const [hh, mm] = s.split(':').map(Number);
      return hh > now.getHours() || (hh === now.getHours() && mm > now.getMinutes());
    });

    container.innerHTML = '';
    const availableSlots = filteredSlots.filter(s => !occupied.includes(s));

    if (availableSlots.length === 0) {
      container.innerHTML = '<p style="grid-column:1/-1;text-align:center;color:var(--color-text-muted);font-size:0.9rem;">No hay horas disponibles este día</p>';
      return;
    }

    filteredSlots.forEach(slot => {
      const btn = document.createElement('button');
      btn.className = 'time-slot';
      btn.textContent = slot;
      if (occupied.includes(slot)) {
        btn.disabled = true;
        btn.classList.add('occupied');
        btn.title = 'Hora no disponible';
      }
      if (state.time === slot) btn.classList.add('selected');
      btn.addEventListener('click', () => {
        if (occupied.includes(slot)) return;
        state.time = slot;
        renderTimeSlots();
        setTimeout(() => { showStep(3); updateSummary(); }, 200);
      });
      container.appendChild(btn);
    });
  }

  document.getElementById('cal-prev')?.addEventListener('click', () => {
    state.currentMonth--;
    if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
    renderCalendar();
  });
  document.getElementById('cal-next')?.addEventListener('click', () => {
    state.currentMonth++;
    if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
    renderCalendar();
  });

  document.getElementById('back-to-1')?.addEventListener('click', () => showStep(1));
  document.getElementById('back-to-2')?.addEventListener('click', () => { showStep(2); renderCalendar(); renderTimeSlots(); });

  // Step 3
  function updateSummary() {
    const summary = document.getElementById('booking-summary')!;
    if (!state.service || !state.date || !state.time) return;
    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateStr = `${dayName} ${state.date.getDate()} de ${MONTHS[state.date.getMonth()]} de ${state.date.getFullYear()}`;
    summary.innerHTML = `
      <strong>Resumen de tu cita:</strong><br>
      Servicio: ${state.service.name}<br>
      Duración: ${state.service.duration} · Precio: ${state.service.price}<br>
      Fecha: ${dateStr}<br>
      Hora: ${state.time}
    `;
    validateForm();
  }

  function validateForm() {
    const name = (document.getElementById('user-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('user-phone') as HTMLInputElement).value.trim();
    const gdpr = (document.getElementById('gdpr-check') as HTMLInputElement).checked;
    const phoneRegex = /^(\+34\s?)?[6789]\d{2}\s?\d{3}\s?\d{3}$/;
    const phoneValid = phoneRegex.test(phone);
    const phoneInput = document.getElementById('user-phone') as HTMLInputElement;
    if (phone && !phoneValid) {
      phoneInput.setCustomValidity('Introduce un teléfono español válido (ej: 612 345 678)');
    } else {
      phoneInput.setCustomValidity('');
    }
    const valid = !!(name && phone && phoneValid && gdpr);
    (document.getElementById('btn-reservar') as HTMLButtonElement).disabled = !valid;
    (document.getElementById('btn-send') as HTMLButtonElement).disabled = !valid;
  }

  document.getElementById('user-name')?.addEventListener('input', validateForm);
  document.getElementById('user-phone')?.addEventListener('input', validateForm);
  document.getElementById('gdpr-check')?.addEventListener('change', validateForm);

  function getBookingData() {
    if (!state.service || !state.date || !state.time) return null;
    const name = (document.getElementById('user-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('user-phone') as HTMLInputElement).value.trim();
    const email = (document.getElementById('user-email') as HTMLInputElement).value.trim();
    const notes = (document.getElementById('user-notes') as HTMLTextAreaElement).value.trim();
    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateDisplay = `${dayName} ${state.date.getDate()} de ${MONTHS[state.date.getMonth()]} de ${state.date.getFullYear()}`;
    const dateISO = `${state.date.getFullYear()}-${String(state.date.getMonth() + 1).padStart(2, '0')}-${String(state.date.getDate()).padStart(2, '0')}`;
    return { name, phone, email, notes, dateDisplay, dateISO, time: state.time, service: state.service };
  }

  async function saveBooking(data: ReturnType<typeof getBookingData>): Promise<{ ok: boolean; conflict?: boolean }> {
    if (!data) return { ok: false };
    try {
      const honeypot = (document.getElementById('booking-website') as HTMLInputElement)?.value;
      if (honeypot) return { ok: false };

      const res = await fetch('/api/reservar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nombre: data.name,
          telefono: data.phone,
          email: data.email || null,
          servicio: data.service!.name,
          fecha: data.dateISO,
          hora: data.time,
          duracion: parseInt(data.service!.duration) || 60,
          notas: data.notes || null,
        }),
      });
      if (res.status === 409) return { ok: false, conflict: true };
      return { ok: res.ok };
    } catch (e) {
      console.error('Error saving booking:', e);
      return { ok: false };
    }
  }

  function showConfirmation(data: ReturnType<typeof getBookingData>) {
    if (!data) return;
    const details = document.getElementById('confirmation-details')!;
    details.innerHTML = `
      <strong>Servicio:</strong> ${data.service!.name}<br>
      <strong>Fecha:</strong> ${data.dateDisplay}<br>
      <strong>Hora:</strong> ${data.time}<br>
      <strong>Duración:</strong> ${data.service!.duration} · <strong>Precio:</strong> ${data.service!.price}<br>
      <strong>Nombre:</strong> ${data.name}<br>
      <strong>Teléfono:</strong> ${data.phone}
      ${data.notes ? `<br><strong>Notas:</strong> ${data.notes}` : ''}
    `;
    // Show step 4
    document.querySelectorAll('.booking-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-4')?.classList.remove('hidden');
    document.querySelectorAll('.step').forEach(el => el.classList.remove('active'));
    document.querySelector('.booking-stepper')?.setAttribute('style', 'display:none;');
    document.querySelector('.booking-main')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Primary button: Reservar cita (web only)
  document.getElementById('btn-reservar')?.addEventListener('click', async () => {
    const data = getBookingData();
    if (!data) return;
    const btn = document.getElementById('btn-reservar') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Reservando...';
    const result = await saveBooking(data);
    if (result.ok) {
      const params = new URLSearchParams({
        servicio: data.service!.name,
        fecha: data.dateDisplay,
        hora: data.time!,
        precio: data.service!.price,
      });
      window.location.href = `/gracias?${params.toString()}`;
    } else if (result.conflict) {
      btn.textContent = 'Hora ya reservada';
      btn.disabled = false;
      // Invalidate cache and re-render slots
      const dateStr = `${state.date!.getFullYear()}-${(state.date!.getMonth()+1).toString().padStart(2,'0')}-${state.date!.getDate().toString().padStart(2,'0')}`;
      delete occupiedCache[dateStr];
      renderTimeSlots();
      setTimeout(() => { btn.textContent = 'Reservar cita'; showStep(2); }, 2000);
    } else {
      btn.textContent = 'Error, inténtalo de nuevo';
      btn.disabled = false;
      setTimeout(() => { btn.textContent = 'Reservar cita'; validateForm(); }, 3000);
    }
  });

  // Secondary button: Confirmar por WhatsApp
  document.getElementById('btn-send')?.addEventListener('click', async () => {
    const data = getBookingData();
    if (!data) return;

    const btn = document.getElementById('btn-send') as HTMLButtonElement;
    btn.disabled = true;

    // Save to DB and check for conflict
    const result = await saveBooking(data);
    if (result.conflict) {
      btn.textContent = 'Hora ya reservada';
      btn.disabled = false;
      const dateStr = `${state.date!.getFullYear()}-${(state.date!.getMonth()+1).toString().padStart(2,'0')}-${state.date!.getDate().toString().padStart(2,'0')}`;
      delete occupiedCache[dateStr];
      renderTimeSlots();
      setTimeout(() => { btn.textContent = 'Confirmar por WhatsApp'; showStep(2); }, 2000);
      return;
    }

    let message = `Hola Katy, me gustaría reservar una cita:\n\n`;
    message += `*Servicio:* ${data.service!.name}\n`;
    message += `*Fecha:* ${data.dateDisplay}\n`;
    message += `*Hora:* ${data.time}\n`;
    message += `*Nombre:* ${data.name}\n`;
    message += `*Teléfono:* ${data.phone}`;
    if (data.notes) message += `\n*Notas:* ${data.notes}`;

    window.open(`https://wa.me/34643961065?text=${encodeURIComponent(message)}`, '_blank');
    btn.disabled = false;
  });

  // === Booking Draft Persistence (localStorage) ===
  const DRAFT_KEY = 'katy_booking_draft';

  function saveDraft() {
    const draft: Record<string, any> = {};
    if (state.service) draft.service = state.service;
    if (state.date) draft.dateISO = `${state.date.getFullYear()}-${(state.date.getMonth()+1).toString().padStart(2,'0')}-${state.date.getDate().toString().padStart(2,'0')}`;
    if (state.time) draft.time = state.time;
    const name = (document.getElementById('user-name') as HTMLInputElement)?.value;
    const phone = (document.getElementById('user-phone') as HTMLInputElement)?.value;
    const email = (document.getElementById('user-email') as HTMLInputElement)?.value;
    if (name) draft.name = name;
    if (phone) draft.phone = phone;
    if (email) draft.email = email;
    if (Object.keys(draft).length > 0) {
      draft.savedAt = Date.now();
      localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
    }
  }

  function clearDraft() {
    localStorage.removeItem(DRAFT_KEY);
  }

  // Save draft on each step change
  const origShowStep = showStep;
  (window as any).__showStep = showStep;
  function showStepWithDraft(n: number) {
    origShowStep(n);
    saveDraft();
  }

  // Auto-save on form input
  ['user-name', 'user-phone', 'user-email'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', saveDraft);
  });

  // Restore draft on load (only if no URL pre-selection and draft is < 24h old)
  (function restoreDraft() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('servicio')) return; // URL pre-selection takes priority

    try {
      const raw = localStorage.getItem(DRAFT_KEY);
      if (!raw) return;
      const draft = JSON.parse(raw);

      // Expire after 24h
      if (Date.now() - (draft.savedAt || 0) > 24 * 60 * 60 * 1000) {
        clearDraft();
        return;
      }

      // Show restore banner
      if (draft.service) {
        const banner = document.createElement('div');
        banner.className = 'draft-banner';
        banner.innerHTML = `
          <span>Tienes una reserva sin terminar: <strong>${draft.service.name}</strong></span>
          <button class="draft-continue">Continuar</button>
          <button class="draft-dismiss">Descartar</button>
        `;
        document.querySelector('.booking-main .container')?.prepend(banner);

        banner.querySelector('.draft-continue')?.addEventListener('click', async () => {
          banner.remove();
          await loadAvailability();

          // Restore service
          const match = Array.from(document.querySelectorAll('.service-option')).find(
            el => el.getAttribute('data-name') === draft.service.name
          ) as HTMLElement | null;
          if (match) {
            match.classList.add('selected');
            state.service = draft.service;
          }

          // Restore date
          if (draft.dateISO) {
            const [y, m, d] = draft.dateISO.split('-').map(Number);
            const date = new Date(y, m - 1, d);
            if (date >= new Date(new Date().setHours(0,0,0,0)) && isDayActive(date)) {
              state.date = date;
              state.currentMonth = date.getMonth();
              state.currentYear = date.getFullYear();
            }
          }

          // Restore time
          if (draft.time) state.time = draft.time;

          // Restore contact
          if (draft.name) (document.getElementById('user-name') as HTMLInputElement).value = draft.name;
          if (draft.phone) (document.getElementById('user-phone') as HTMLInputElement).value = draft.phone;
          if (draft.email) (document.getElementById('user-email') as HTMLInputElement).value = draft.email;

          // Navigate to the furthest step
          if (state.service && state.date && state.time) {
            showStep(3);
            updateSummary();
            validateForm();
          } else if (state.service) {
            showStep(2);
            renderCalendar();
            renderTimeSlots();
          }
        });

        banner.querySelector('.draft-dismiss')?.addEventListener('click', () => {
          banner.remove();
          clearDraft();
        });
      }
    } catch {}
  })();

  // Clear draft after successful booking
  const origSaveBooking = saveBooking;
  saveBooking = async function(data: any) {
    const result = await origSaveBooking(data);
    if (result.ok) clearDraft();
    return result;
  };
</script>
