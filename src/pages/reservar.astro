---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Reservar Cita | Osteópata y Masajista en Alpedrete - Sierra Noroeste de Madrid";
const pageDescription = "Reserva tu cita de osteopatía o masaje en Alpedrete, Sierra Noroeste de Madrid. Elige servicio, día y hora, y confirma por WhatsApp. Horario flexible.";

const services = [
  { name: 'Osteopatía estructural, visceral y sacrocraneal', duration: '55 min', price: '40€' },
  { name: 'Masaje deportivo', duration: '30 min', price: '20€' },
  { name: 'Masaje corporal con aceite (60 min)', duration: '60 min', price: '40€' },
  { name: 'Masaje corporal con aceite (90 min)', duration: '90 min', price: '55€' },
  { name: 'Masaje tradicional tailandés (60 min)', duration: '60 min', price: '45€' },
  { name: 'Masaje tradicional tailandés (90 min)', duration: '90 min', price: '60€' },
  { name: 'Masaje con pindas herbales calientes', duration: '90 min', price: '70€' },
  { name: 'Masaje para embarazadas (desde 4º mes)', duration: '60 min', price: '40€' },
];
---

<Layout title={pageTitle} description={pageDescription} keywords="reservar cita osteopatia alpedrete, cita masaje sierra de madrid, cita masaje sierra noroeste madrid, pedir cita osteopata collado villalba, reservar masajista moralzarzal, tarifas masajes sierra guadarrama, precios osteopatia galapagar, cita masaje deportivo" breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Reservar" }]}>
  <section class="booking-hero">
    <div class="container">
      <span class="section-tag">Reservar Cita</span>
      <h1>Reserva tu sesión</h1>
      <p>Elige servicio, día y hora. Te confirmo la cita por WhatsApp.</p>
    </div>
  </section>

  <section class="booking-form-section">
    <div class="container">
      <div class="booking-stepper">
        <div class="step active" data-step="1">
          <span class="step-number">1</span>
          <span class="step-label">Servicio</span>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="2">
          <span class="step-number">2</span>
          <span class="step-label">Fecha y hora</span>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="3">
          <span class="step-number">3</span>
          <span class="step-label">Tus datos</span>
        </div>
      </div>

      <!-- Step 1: Service selection -->
      <div class="booking-step" id="step-1">
        <h2>¿Qué servicio necesitas?</h2>
        <div class="services-grid">
          {services.map((service, i) => (
            <button class="service-option" data-index={i} data-name={service.name} data-duration={service.duration} data-price={service.price}>
              <span class="service-option-name">{service.name}</span>
              <div class="service-option-meta">
                <span class="service-option-duration">{service.duration}</span>
                <span class="service-option-price">{service.price}</span>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 2: Date and time -->
      <div class="booking-step hidden" id="step-2">
        <h2>Elige día y hora</h2>
        <div class="datetime-grid">
          <div class="calendar-wrapper">
            <div class="calendar-header">
              <button class="cal-nav" id="cal-prev" aria-label="Mes anterior">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
              </button>
              <span class="cal-month" id="cal-month"></span>
              <button class="cal-nav" id="cal-next" aria-label="Mes siguiente">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </button>
            </div>
            <div class="calendar-weekdays">
              <span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span>
            </div>
            <div class="calendar-days" id="cal-days"></div>
          </div>
          <div class="time-wrapper">
            <h3 id="time-title">Selecciona un día</h3>
            <div class="time-slots" id="time-slots"></div>
          </div>
        </div>
        <div class="step-nav">
          <button class="btn-back" id="back-to-1">Cambiar servicio</button>
        </div>
      </div>

      <!-- Step 3: User data -->
      <div class="booking-step hidden" id="step-3">
        <h2>Tus datos de contacto</h2>
        <div class="user-form">
          <div class="form-group">
            <label for="user-name">Nombre</label>
            <input type="text" id="user-name" placeholder="Tu nombre" autocomplete="given-name" required>
          </div>
          <div class="form-group">
            <label for="user-phone">Teléfono</label>
            <input type="tel" id="user-phone" placeholder="Tu teléfono" autocomplete="tel" required>
          </div>
          <div class="form-group">
            <label for="user-notes">Notas (opcional)</label>
            <textarea id="user-notes" placeholder="¿Algo que deba saber? Ej: primera visita, zona de dolor..." rows="3"></textarea>
          </div>

          <div class="booking-summary" id="booking-summary"></div>

          <button class="btn-whatsapp-send" id="btn-send" disabled>
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Confirmar por WhatsApp
          </button>
        </div>
        <div class="step-nav">
          <button class="btn-back" id="back-to-2">Cambiar fecha</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Other contact methods -->
  <section class="booking-methods">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: 30px;">¿Prefieres otro método?</h2>
      <div class="booking-grid">
        <a href="https://wa.me/34643961065?text=Hola%20Katy,%20me%20gustaría%20reservar%20una%20cita" class="booking-card whatsapp" target="_blank" rel="noopener noreferrer">
          <div class="booking-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h3>WhatsApp directo</h3>
          <p>Escríbeme sin formulario</p>
          <span class="booking-cta">643 961 065</span>
        </a>
        <a href="tel:+34643961065" class="booking-card phone">
          <div class="booking-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
          </div>
          <h3>Llamar</h3>
          <p>Llámame para resolver dudas</p>
          <span class="booking-cta">643 961 065</span>
        </a>
        <a href="mailto:katycaballero.osteopata@gmail.com?subject=Reserva%20de%20cita&body=Hola%20Katy,%0A%0AMe%20gustaría%20reservar%20una%20cita.%0A%0AServicio:%0AFecha%20preferida:%0AHora%20preferida:%0A%0AGracias!" class="booking-card email">
          <div class="booking-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <h3>Email</h3>
          <p>Envíame un correo</p>
          <span class="booking-cta">Escribir email</span>
        </a>
      </div>
    </div>
  </section>

  <section class="booking-info">
    <div class="container">
      <div class="booking-info-grid">
        <div class="booking-details">
          <h2>Información de reserva</h2>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            <div>
              <h4>Horario de atención</h4>
              <p>Lunes a Viernes: 9:00 - 20:00<br>Sábados: 10:00 - 14:00</p>
            </div>
          </div>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            <div>
              <h4>Ubicación</h4>
              <p>Calle Río Guadarrama 2<br>28430 Alpedrete, Madrid</p>
            </div>
          </div>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"/></svg>
            <div>
              <h4>Política de cancelación</h4>
              <p>Por favor, avisa con 24h de antelación si necesitas cancelar o cambiar tu cita.</p>
            </div>
          </div>
          <div class="info-item">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
            <div>
              <h4>Formas de pago</h4>
              <p>Efectivo, Bizum y transferencia bancaria</p>
            </div>
          </div>
        </div>
        <div class="booking-services">
          <h2>Tarifas</h2>
          <div class="services-list">
            {services.map(service => (
              <div class="service-item">
                <div class="service-info">
                  <span class="service-name">{service.name}</span>
                  <span class="service-duration">{service.duration}</span>
                </div>
                <span class="service-price">{service.price}</span>
              </div>
            ))}
          </div>
          <div class="bonos-box">
            <h3>Bonos de osteopatía</h3>
            <div class="bono-row">
              <div class="bono-mini">
                <span class="bono-mini-name">Bono 3 sesiones</span>
                <span class="bono-mini-price">114€</span>
                <span class="bono-mini-detail">38€/sesión</span>
              </div>
              <div class="bono-mini">
                <span class="bono-mini-name">Bono 5 sesiones</span>
                <span class="bono-mini-price">180€</span>
                <span class="bono-mini-detail">36€/sesión</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="booking-first-visit">
    <div class="container text-center">
      <h2>¿Es tu primera visita?</h2>
      <p>En la primera sesión dedicaré tiempo a conocer tu historia, tus hábitos y cómo se manifiestan tus molestias. A través de la observación, el movimiento y el tacto, identificaré las tensiones y desequilibrios que pueden estar afectando a tu bienestar.</p>
      <p><strong>No necesitas traer nada especial</strong>, solo ropa cómoda si optas por el masaje tailandés. Para los demás tratamientos, te proporcionaré todo lo necesario.</p>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .booking-hero {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }
  .booking-hero h1 { margin-bottom: 20px; }
  .booking-hero p { margin: 0 auto; max-width: 550px; }

  /* Stepper */
  .booking-stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 40px;
    padding: 0 20px;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.4;
    transition: var(--transition);
  }
  .step.active { opacity: 1; }
  .step.done { opacity: 0.7; }
  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-secondary-light);
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.85rem;
  }
  .step.active .step-number {
    background: var(--color-primary);
    color: white;
  }
  .step.done .step-number {
    background: var(--color-primary-light);
    color: white;
  }
  .step-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .step-line {
    width: 40px;
    height: 2px;
    background: var(--color-secondary-light);
    margin: 0 12px;
  }

  /* Form section */
  .booking-form-section {
    background: var(--color-warm-white);
    padding: 60px 0 80px;
  }
  .booking-step { max-width: 800px; margin: 0 auto; }
  .booking-step.hidden { display: none; }
  .booking-step h2 {
    text-align: center;
    margin-bottom: 30px;
    font-size: 1.4rem;
  }

  /* Step 1: Services */
  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .service-option {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px;
    background: var(--color-cream);
    border: 2px solid transparent;
    border-radius: 14px;
    cursor: pointer;
    transition: var(--transition);
    text-align: left;
    font-family: var(--font-body);
  }
  .service-option:hover {
    border-color: var(--color-primary-light);
    background: white;
    transform: translateX(4px);
  }
  .service-option.selected {
    border-color: var(--color-primary);
    background: rgba(90, 124, 89, 0.06);
  }
  .service-option-name {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .service-option-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    margin-left: 16px;
  }
  .service-option-duration {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .service-option-price {
    background: var(--color-secondary-light);
    padding: 5px 14px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  /* Step 2: Calendar */
  .datetime-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  .calendar-wrapper {
    background: var(--color-cream);
    border-radius: 18px;
    padding: 24px;
  }
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .cal-month {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: capitalize;
  }
  .cal-nav {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--color-warm-white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }
  .cal-nav:hover { background: var(--color-secondary-light); }
  .cal-nav:disabled { opacity: 0.3; cursor: default; }
  .cal-nav svg { width: 20px; height: 20px; fill: var(--color-text); }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    margin-bottom: 8px;
  }
  .calendar-weekdays span {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    padding: 6px 0;
  }
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-day {
    aspect-ratio: 1;
    border: none;
    border-radius: 50%;
    background: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cal-day:hover:not(:disabled):not(.empty) {
    background: var(--color-secondary-light);
  }
  .cal-day.today {
    font-weight: 700;
    box-shadow: inset 0 0 0 2px var(--color-secondary);
  }
  .cal-day.selected {
    background: var(--color-primary) !important;
    color: white;
    font-weight: 600;
  }
  .cal-day:disabled {
    color: #ccc;
    cursor: default;
  }
  .cal-day.empty {
    cursor: default;
  }

  /* Time slots */
  .time-wrapper {
    background: var(--color-cream);
    border-radius: 18px;
    padding: 24px;
  }
  .time-wrapper h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--color-text);
  }
  .time-slots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .time-slot {
    padding: 10px;
    border: 2px solid var(--color-secondary-light);
    border-radius: 10px;
    background: var(--color-warm-white);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: var(--transition);
    text-align: center;
  }
  .time-slot:hover {
    border-color: var(--color-primary-light);
    background: white;
  }
  .time-slot.selected {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
  }

  /* Step 3: User form */
  .user-form {
    max-width: 500px;
    margin: 0 auto;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid var(--color-secondary-light);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: var(--color-cream);
    transition: var(--transition);
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: white;
  }
  .form-group textarea { resize: vertical; }

  /* Booking summary */
  .booking-summary {
    background: var(--color-cream);
    border-radius: 14px;
    padding: 20px;
    margin: 24px 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-text);
    border-left: 4px solid var(--color-primary);
  }
  .booking-summary strong { color: var(--color-primary-dark); }

  /* WhatsApp send button */
  .btn-whatsapp-send {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    background: #25D366;
    color: white;
    padding: 18px 32px;
    border-radius: 60px;
    border: none;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: 0 8px 30px rgba(37, 211, 102, 0.35);
  }
  .btn-whatsapp-send:hover:not(:disabled) {
    background: #20bd5a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(37, 211, 102, 0.45);
  }
  .btn-whatsapp-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-whatsapp-send svg {
    width: 24px;
    height: 24px;
  }

  /* Back button */
  .step-nav {
    text-align: center;
    margin-top: 24px;
  }
  .btn-back {
    background: none;
    border: none;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 0.9rem;
    cursor: pointer;
    text-decoration: underline;
    transition: var(--transition);
  }
  .btn-back:hover { color: var(--color-primary); }

  /* Contact methods */
  .booking-methods {
    background: var(--color-cream);
    padding: 60px 0;
  }
  .booking-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    max-width: 800px;
    margin: 0 auto;
  }
  .booking-card {
    background: var(--color-warm-white);
    padding: 30px 25px;
    border-radius: 20px;
    text-align: center;
    text-decoration: none;
    transition: var(--transition);
    border: 2px solid transparent;
  }
  .booking-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-medium);
  }
  .booking-card.whatsapp:hover { border-color: #25D366; background: rgba(37, 211, 102, 0.05); }
  .booking-card.phone:hover { border-color: var(--color-primary); background: rgba(90, 124, 89, 0.05); }
  .booking-card.email:hover { border-color: var(--color-secondary); background: rgba(196, 163, 90, 0.05); }
  .booking-icon {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
  }
  .booking-card.whatsapp .booking-icon { background: #25D366; }
  .booking-card.phone .booking-icon { background: var(--color-primary); }
  .booking-card.email .booking-icon { background: var(--color-secondary); }
  .booking-icon svg { width: 26px; height: 26px; fill: white; }
  .booking-card h3 { font-size: 1.1rem; margin-bottom: 8px; color: var(--color-text); }
  .booking-card p { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 12px; max-width: none; }
  .booking-cta { font-weight: 600; font-size: 0.85rem; }
  .booking-card.whatsapp .booking-cta { color: #25D366; }
  .booking-card.phone .booking-cta { color: var(--color-primary); }
  .booking-card.email .booking-cta { color: var(--color-secondary); }

  /* Info section */
  .booking-info { background: var(--color-warm-white); }
  .booking-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
  .booking-details h2, .booking-services h2 { margin-bottom: 30px; font-size: 1.5rem; }
  .info-item { display: flex; gap: 20px; margin-bottom: 25px; }
  .info-item svg { width: 24px; height: 24px; fill: var(--color-primary); flex-shrink: 0; margin-top: 3px; }
  .info-item h4 { font-family: var(--font-body); font-size: 1rem; font-weight: 600; margin-bottom: 5px; color: var(--color-text); }
  .info-item p { font-size: 0.9rem; color: var(--color-text-light); line-height: 1.6; }
  .services-list { background: var(--color-cream); border-radius: 15px; padding: 10px; }
  .service-item { display: flex; justify-content: space-between; align-items: center; padding: 15px; border-bottom: 1px solid rgba(90, 124, 89, 0.08); }
  .service-item:last-child { border-bottom: none; }
  .service-name { font-size: 0.9rem; color: var(--color-text); font-weight: 500; }
  .service-duration { font-size: 0.8rem; color: var(--color-text-muted); display: block; margin-top: 3px; }
  .service-price { background: var(--color-secondary-light); padding: 6px 14px; border-radius: 20px; font-weight: 600; font-size: 0.9rem; color: var(--color-text); white-space: nowrap; }

  /* Bonos in reservar */
  .bonos-box {
    margin-top: 20px;
    background: var(--color-primary);
    border-radius: 15px;
    padding: 20px;
    color: white;
  }
  .bonos-box h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 14px;
    color: white;
    text-align: center;
  }
  .bono-row {
    display: flex;
    gap: 10px;
  }
  .bono-mini {
    flex: 1;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .bono-mini-name {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 6px;
  }
  .bono-mini-price {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .bono-mini-detail {
    display: block;
    font-size: 0.78rem;
    opacity: 0.8;
    margin-top: 2px;
  }

  /* First visit */
  .booking-first-visit { background: var(--color-cream); padding: 80px 0; }
  .booking-first-visit h2 { margin-bottom: 25px; }
  .booking-first-visit p { max-width: 700px; margin: 0 auto 20px; font-size: 1.05rem; line-height: 1.8; }

  /* Responsive */
  @media (max-width: 768px) {
    .booking-stepper { gap: 0; }
    .step-label { display: none; }
    .step-line { width: 24px; margin: 0 8px; }
    .service-option {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .service-option-meta { margin-left: 0; }
    .datetime-grid { grid-template-columns: 1fr; }
    .time-slots { grid-template-columns: repeat(3, 1fr); }
    .booking-grid { grid-template-columns: 1fr; max-width: 350px; }
    .booking-info-grid { grid-template-columns: 1fr; gap: 50px; }
  }
</style>

<script>
  // === Booking App ===
  const state = {
    service: null as { name: string; duration: string; price: string } | null,
    date: null as Date | null,
    time: null as string | null,
    currentMonth: new Date().getMonth(),
    currentYear: new Date().getFullYear(),
  };

  const MONTHS = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  const WEEKDAYS_SHORT = ['lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado', 'domingo'];

  // Business hours
  function getTimeSlots(date: Date): string[] {
    const day = date.getDay(); // 0=Sun, 6=Sat
    const slots: string[] = [];
    if (day === 0) return slots; // Sunday - closed
    const start = day === 6 ? 10 : 9;
    const end = day === 6 ? 14 : 20;
    for (let h = start; h < end; h++) {
      slots.push(`${h.toString().padStart(2, '0')}:00`);
      if (end - h > 1 || (end - h === 1 && day !== 6)) {
        slots.push(`${h.toString().padStart(2, '0')}:30`);
      }
    }
    // Remove last slot if it would go past closing
    return slots.filter(s => {
      const [hh] = s.split(':').map(Number);
      return hh < end;
    });
  }

  // Steps
  function showStep(n: number) {
    document.querySelectorAll('.booking-step').forEach(el => el.classList.add('hidden'));
    document.getElementById(`step-${n}`)?.classList.remove('hidden');
    document.querySelectorAll('.step').forEach(el => {
      const s = Number(el.getAttribute('data-step'));
      el.classList.toggle('active', s === n);
      el.classList.toggle('done', s < n);
    });
    // Scroll to form
    document.querySelector('.booking-form-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Step 1: Service selection
  document.querySelectorAll('.service-option').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.service-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      state.service = {
        name: btn.getAttribute('data-name') || '',
        duration: btn.getAttribute('data-duration') || '',
        price: btn.getAttribute('data-price') || '',
      };
      // Auto-advance to step 2
      setTimeout(() => {
        showStep(2);
        renderCalendar();
      }, 200);
    });
  });

  // Step 2: Calendar
  function renderCalendar() {
    const calDays = document.getElementById('cal-days')!;
    const calMonth = document.getElementById('cal-month')!;
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    calMonth.textContent = `${MONTHS[state.currentMonth]} ${state.currentYear}`;

    // Disable prev if current month
    const prevBtn = document.getElementById('cal-prev') as HTMLButtonElement;
    prevBtn.disabled = state.currentYear === today.getFullYear() && state.currentMonth === today.getMonth();

    // Limit to 2 months ahead
    const maxDate = new Date(today.getFullYear(), today.getMonth() + 2, 0);
    const nextBtn = document.getElementById('cal-next') as HTMLButtonElement;
    nextBtn.disabled = state.currentYear > maxDate.getFullYear() ||
      (state.currentYear === maxDate.getFullYear() && state.currentMonth >= maxDate.getMonth());

    const firstDay = new Date(state.currentYear, state.currentMonth, 1);
    const lastDay = new Date(state.currentYear, state.currentMonth + 1, 0);

    // Monday-based: getDay() returns 0=Sun, we need Mon=0
    let startOffset = firstDay.getDay() - 1;
    if (startOffset < 0) startOffset = 6;

    calDays.innerHTML = '';

    // Empty cells
    for (let i = 0; i < startOffset; i++) {
      const empty = document.createElement('span');
      empty.className = 'cal-day empty';
      calDays.appendChild(empty);
    }

    // Days
    for (let d = 1; d <= lastDay.getDate(); d++) {
      const date = new Date(state.currentYear, state.currentMonth, d);
      const btn = document.createElement('button');
      btn.className = 'cal-day';
      btn.textContent = String(d);

      const isSunday = date.getDay() === 0;
      const isPast = date < today;
      const isToday = date.getTime() === today.getTime();

      if (isToday) btn.classList.add('today');
      if (isSunday || isPast) {
        btn.disabled = true;
      }
      if (state.date && date.getTime() === state.date.getTime()) {
        btn.classList.add('selected');
      }

      btn.addEventListener('click', () => {
        state.date = date;
        state.time = null;
        renderCalendar();
        renderTimeSlots();
      });

      calDays.appendChild(btn);
    }
  }

  function renderTimeSlots() {
    const container = document.getElementById('time-slots')!;
    const title = document.getElementById('time-title')!;

    if (!state.date) {
      title.textContent = 'Selecciona un día';
      container.innerHTML = '';
      return;
    }

    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateStr = `${state.date.getDate()} de ${MONTHS[state.date.getMonth()]}`;
    title.textContent = `${dayName} ${dateStr}`;

    const slots = getTimeSlots(state.date);

    // Filter out past time slots for today
    const now = new Date();
    const filteredSlots = slots.filter(s => {
      if (state.date!.toDateString() !== now.toDateString()) return true;
      const [hh, mm] = s.split(':').map(Number);
      return hh > now.getHours() || (hh === now.getHours() && mm > now.getMinutes());
    });

    container.innerHTML = '';
    if (filteredSlots.length === 0) {
      container.innerHTML = '<p style="grid-column:1/-1;text-align:center;color:var(--color-text-muted);font-size:0.9rem;">No hay horas disponibles para hoy</p>';
      return;
    }

    filteredSlots.forEach(slot => {
      const btn = document.createElement('button');
      btn.className = 'time-slot';
      btn.textContent = slot;
      if (state.time === slot) btn.classList.add('selected');
      btn.addEventListener('click', () => {
        state.time = slot;
        renderTimeSlots();
        // Auto-advance to step 3
        setTimeout(() => {
          showStep(3);
          updateSummary();
        }, 200);
      });
      container.appendChild(btn);
    });
  }

  // Calendar navigation
  document.getElementById('cal-prev')?.addEventListener('click', () => {
    state.currentMonth--;
    if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
    renderCalendar();
  });
  document.getElementById('cal-next')?.addEventListener('click', () => {
    state.currentMonth++;
    if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
    renderCalendar();
  });

  // Back buttons
  document.getElementById('back-to-1')?.addEventListener('click', () => showStep(1));
  document.getElementById('back-to-2')?.addEventListener('click', () => { showStep(2); renderCalendar(); renderTimeSlots(); });

  // Step 3: Summary & Send
  function updateSummary() {
    const summary = document.getElementById('booking-summary')!;
    if (!state.service || !state.date || !state.time) return;

    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateStr = `${dayName} ${state.date.getDate()} de ${MONTHS[state.date.getMonth()]} de ${state.date.getFullYear()}`;

    summary.innerHTML = `
      <strong>Resumen de tu cita:</strong><br>
      Servicio: ${state.service.name}<br>
      Duración: ${state.service.duration} · Precio: ${state.service.price}<br>
      Fecha: ${dateStr}<br>
      Hora: ${state.time}
    `;
    validateForm();
  }

  function validateForm() {
    const name = (document.getElementById('user-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('user-phone') as HTMLInputElement).value.trim();
    const btn = document.getElementById('btn-send') as HTMLButtonElement;
    btn.disabled = !name || !phone;
  }

  document.getElementById('user-name')?.addEventListener('input', validateForm);
  document.getElementById('user-phone')?.addEventListener('input', validateForm);

  // Send to WhatsApp
  document.getElementById('btn-send')?.addEventListener('click', () => {
    if (!state.service || !state.date || !state.time) return;

    const name = (document.getElementById('user-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('user-phone') as HTMLInputElement).value.trim();
    const notes = (document.getElementById('user-notes') as HTMLTextAreaElement).value.trim();

    const dayName = WEEKDAYS_SHORT[state.date.getDay() === 0 ? 6 : state.date.getDay() - 1];
    const dateStr = `${dayName} ${state.date.getDate()} de ${MONTHS[state.date.getMonth()]} de ${state.date.getFullYear()}`;

    let message = `Hola Katy, me gustaría reservar una cita:\n\n`;
    message += `*Servicio:* ${state.service.name}\n`;
    message += `*Fecha:* ${dateStr}\n`;
    message += `*Hora:* ${state.time}\n`;
    message += `*Nombre:* ${name}\n`;
    message += `*Teléfono:* ${phone}`;
    if (notes) message += `\n*Notas:* ${notes}`;

    const encoded = encodeURIComponent(message);
    window.open(`https://wa.me/34643961065?text=${encoded}`, '_blank');
  });
</script>
