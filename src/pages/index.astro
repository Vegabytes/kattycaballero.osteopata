---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';

import BlogPreview from '../components/BlogPreview.astro';
import ToolsSection from '../components/ToolsSection.astro';
import CTASection from '../components/CTASection.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Katy Caballero · Osteópata y Masajista en Alpedrete | Sierra Noroeste de Madrid"
  description="Centro de osteopatía y masajes en Alpedrete, Sierra Noroeste de Madrid. Tratamientos de osteopatía estructural, visceral y craneal, masaje deportivo y tailandés. Atendemos Collado Villalba, Moralzarzal, Galapagar y Sierra de Guadarrama."
  keywords="osteopata alpedrete, masajista sierra noroeste madrid, osteopatia collado villalba, masaje deportivo moralzarzal, osteopatia galapagar, fisioterapia sierra de guadarrama, osteopata sierra noroeste, dolor de espalda alpedrete, contracturas tratamiento, masaje tailandes sierra madrid, quiromasaje alpedrete, masajista zona noroeste madrid"
  breadcrumbs={[{ name: "Inicio" }]}
>
  <Hero />
  <Services />
  <About />
  <Gallery />
  <Testimonials />

  <BlogPreview />
  <ToolsSection />
  <CTASection />
  <Contact />

  <!-- Section navigation -->
  <nav class="section-nav" id="section-nav" aria-label="Navegación por secciones">
    <a href="#inicio" class="section-nav-dot active" data-section="inicio" title="Inicio"><span>Inicio</span></a>
    <a href="#servicios" class="section-nav-dot" data-section="servicios" title="Servicios"><span>Servicios</span></a>
    <a href="#sobre-mi" class="section-nav-dot" data-section="sobre-mi" title="Sobre mí"><span>Sobre mí</span></a>
    <a href="#espacio" class="section-nav-dot" data-section="espacio" title="Mi espacio"><span>Mi espacio</span></a>
    <a href="#testimonios" class="section-nav-dot" data-section="testimonios" title="Opiniones"><span>Opiniones</span></a>
    <a href="#contacto" class="section-nav-dot" data-section="contacto" title="Contacto"><span>Contacto</span></a>
  </nav>
</Layout>

<style>
  .section-nav {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 14px;
    z-index: 80;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .section-nav.visible {
    opacity: 1;
  }

  .section-nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(90, 124, 89, 0.25);
    border: 2px solid transparent;
    transition: all 0.3s ease;
    position: relative;
    text-decoration: none;
  }

  .section-nav-dot:hover {
    background: rgba(90, 124, 89, 0.5);
    transform: scale(1.3);
  }

  .section-nav-dot.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    transform: scale(1.2);
  }

  .section-nav-dot span {
    position: absolute;
    right: 22px;
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
    background: white;
    padding: 4px 10px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .section-nav-dot:hover span {
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .section-nav {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('section-nav');
  const dots = document.querySelectorAll('.section-nav-dot');
  const sections = ['inicio', 'servicios', 'sobre-mi', 'espacio', 'testimonios', 'contacto'];

  // Show/hide nav based on scroll
  window.addEventListener('scroll', () => {
    if (nav) {
      nav.classList.toggle('visible', window.scrollY > 300);
    }

    // Highlight active section
    let current = '';
    for (const id of sections) {
      const el = document.getElementById(id);
      if (el) {
        const rect = el.getBoundingClientRect();
        if (rect.top <= window.innerHeight / 2) {
          current = id;
        }
      }
    }
    dots.forEach(dot => {
      dot.classList.toggle('active', (dot as HTMLElement).dataset.section === current);
    });
  });
</script>
