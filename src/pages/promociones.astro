---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const pageTitle = "Promociones y Ofertas | Katy Caballero Osteópata en Alpedrete";
const pageDescription = "Ofertas osteopatia Alpedrete: bonos de sesiones, descuento masaje sierra Madrid, primera visita con valoración incluida y tarjetas regalo. Ahorra en tus tratamientos.";
const pageKeywords = "ofertas osteopatia alpedrete, descuento masaje sierra madrid, promociones osteopata, bonos osteopatia, regalar masaje, ofertas masaje alpedrete";

const promoSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Promociones - Katy Caballero Osteópata",
  "description": "Promociones y ofertas en osteopatía y masajes en Alpedrete, Sierra de Madrid",
  "itemListElement": [
    {
      "@type": "Offer",
      "name": "Bono 3 sesiones de osteopatía",
      "description": "3 sesiones de osteopatía por 114€. 38€ por sesión, ahorro de 6€.",
      "price": "114",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "name": "Bono 5 sesiones de osteopatía",
      "description": "5 sesiones de osteopatía por 180€. 36€ por sesión, ahorro de 20€.",
      "price": "180",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "name": "Descuento 10% AMPA El Peralejo y AFA Santa Quiteria",
      "description": "10% de descuento para miembros de AMPA El Peralejo y AFA Santa Quiteria.",
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "name": "Primera visita con valoración incluida",
      "description": "En tu primera visita, la valoración inicial está incluida sin coste extra.",
      "availability": "https://schema.org/InStock"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Promociones" }]}>
  <script type="application/ld+json" set:html={JSON.stringify(promoSchema)} />

  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{label: "Inicio", href: "/"}, {label: "Promociones"}]} />
      <span class="section-tag">Ofertas</span>
      <h1>Promociones y Ofertas</h1>
      <p>Aprovecha nuestras promociones para cuidarte al mejor precio</p>
    </div>
  </section>

  <section class="promos-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Promociones activas</span>
        <h2>Ofertas permanentes</h2>
        <p>Descuentos y ventajas disponibles durante todo el año.</p>
      </div>
      <div class="promos-grid">

        <!-- Bono 3 sesiones -->
        <div class="promo-card">
          <div class="promo-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </div>
          <span class="promo-badge">Ahorra 6€</span>
          <h3>Bono 3 sesiones</h3>
          <div class="promo-price">114<span class="promo-currency">€</span></div>
          <p class="promo-detail">38€ por sesión (precio individual: 40€)</p>
          <p class="promo-desc">Ideal para tratamientos que requieren seguimiento. Válido 6 meses desde la compra.</p>
          <a href="/bonos" class="promo-cta">Ver bonos</a>
        </div>

        <!-- Bono 5 sesiones -->
        <div class="promo-card featured">
          <div class="promo-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <span class="promo-badge best-badge">Mejor precio</span>
          <h3>Bono 5 sesiones</h3>
          <div class="promo-price">180<span class="promo-currency">€</span></div>
          <p class="promo-detail">36€ por sesión (precio individual: 40€)</p>
          <p class="promo-desc">El mayor ahorro por sesión. Perfecto para programas de recuperación completos.</p>
          <a href="/bonos" class="promo-cta">Ver bonos</a>
        </div>

        <!-- Descuento AMPA / AFA -->
        <div class="promo-card">
          <div class="promo-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <span class="promo-badge discount-badge">-10%</span>
          <h3>Descuento asociados</h3>
          <div class="promo-price">-10<span class="promo-currency">%</span></div>
          <p class="promo-detail">AMPA El Peralejo y AFA Santa Quiteria</p>
          <p class="promo-desc">Si perteneces a la AMPA El Peralejo o a la AFA Santa Quiteria, disfruta de un 10% de descuento en todas tus sesiones.</p>
          <a href="https://wa.me/34643961065?text=Hola%20Katy,%20soy%20miembro%20de%20AMPA/AFA%20y%20me%20gustar%C3%ADa%20reservar%20con%20descuento" class="promo-cta" target="_blank" rel="noopener noreferrer">Reservar con descuento</a>
        </div>

        <!-- Primera visita -->
        <div class="promo-card">
          <div class="promo-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span class="promo-badge included-badge">Incluido</span>
          <h3>Primera visita</h3>
          <div class="promo-highlight">Valoración incluida</div>
          <p class="promo-detail">Sin coste adicional</p>
          <p class="promo-desc">En tu primera sesión, realizamos una valoración completa de tu estado: postura, movilidad y zonas de tensión. Todo incluido en el precio de la sesión.</p>
          <a href="/primera-visita" class="promo-cta">Más información</a>
        </div>

        <!-- Regala bienestar -->
        <div class="promo-card">
          <div class="promo-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          </div>
          <span class="promo-badge gift-badge">Idea regalo</span>
          <h3>Regala bienestar</h3>
          <div class="promo-highlight">Tarjeta regalo</div>
          <p class="promo-detail">Para cualquier ocasión</p>
          <p class="promo-desc">Sorprende a alguien especial con una tarjeta regalo de sesiones de osteopatía. Cumpleaños, Día de la Madre, Navidad... Un regalo que de verdad se agradece.</p>
          <a href="/regalar" class="promo-cta">Regalar una sesión</a>
        </div>

      </div>
    </div>
  </section>

  <section class="seasonal-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Ofertas estacionales</span>
        <h2>Ofertas de temporada</h2>
        <p>Promociones especiales según la época del año.</p>
      </div>
      <div class="seasonal-content">
        <div class="seasonal-empty">
          <div class="seasonal-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Próximamente</h3>
          <p>Estamos preparando nuevas ofertas de temporada. Síguenos en Instagram o contacta por WhatsApp para enterarte de las novedades.</p>
          <div class="seasonal-links">
            <a href="https://www.instagram.com/katycaballero.osteopata" target="_blank" rel="noopener noreferrer" class="seasonal-btn instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Seguir en Instagram
            </a>
            <a href="https://wa.me/34643961065?text=Hola%20Katy,%20quiero%20enterarme%20de%20las%20próximas%20ofertas" target="_blank" rel="noopener noreferrer" class="seasonal-btn whatsapp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Preguntar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="¿Quieres aprovechar una oferta?"
    description="Reserva tu cita y disfruta de nuestras promociones. Consulta inicial incluida en tu primera visita."
    buttonText="Reservar Cita"
    buttonLink="/reservar"
  />
</Layout>

<style>
  .page-hero {
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-warm-white) 100%);
    text-align: center;
  }

  .page-hero h1 {
    margin-bottom: 20px;
  }

  .page-hero p {
    margin: 0 auto;
    max-width: 600px;
    font-size: 1.15rem;
  }

  /* Promos Section */
  .promos-section {
    background: var(--color-warm-white);
  }

  .promos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .promo-card {
    background: white;
    border-radius: 20px;
    padding: 35px 28px;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    border: 1px solid rgba(90, 124, 89, 0.1);
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .promo-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
  }

  .promo-card.featured {
    border: 2px solid var(--color-primary);
    box-shadow: 0 10px 30px rgba(90, 124, 89, 0.15);
  }

  .promo-card.featured:hover {
    box-shadow: 0 20px 50px rgba(90, 124, 89, 0.2);
  }

  .promo-icon {
    width: 70px;
    height: 70px;
    background: var(--color-secondary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--color-primary);
  }

  .promo-badge {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .promo-badge.best-badge {
    background: var(--color-secondary);
  }

  .promo-badge.discount-badge {
    background: #d35400;
  }

  .promo-badge.included-badge {
    background: var(--color-primary);
  }

  .promo-badge.gift-badge {
    background: #8e44ad;
  }

  .promo-card h3 {
    font-size: 1.2rem;
    margin-bottom: 10px;
    color: var(--color-text);
  }

  .promo-price {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
    color: var(--color-primary);
  }

  .promo-currency {
    font-size: 1.3rem;
    vertical-align: super;
  }

  .promo-highlight {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 6px;
  }

  .promo-detail {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 10px;
    font-weight: 500;
  }

  .promo-desc {
    font-size: 0.92rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 20px;
    flex-grow: 1;
    max-width: none;
  }

  .promo-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: white;
    padding: 12px 24px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .promo-cta:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(90, 124, 89, 0.3);
    color: white;
  }

  /* Seasonal Section */
  .seasonal-section {
    background: var(--color-cream);
  }

  .seasonal-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .seasonal-empty {
    background: white;
    border-radius: 20px;
    padding: 50px 40px;
    text-align: center;
    border: 2px dashed rgba(90, 124, 89, 0.2);
  }

  .seasonal-icon {
    width: 80px;
    height: 80px;
    background: var(--color-secondary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
    color: var(--color-primary);
  }

  .seasonal-empty h3 {
    font-size: 1.4rem;
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .seasonal-empty p {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 500px;
    margin: 0 auto 25px;
  }

  .seasonal-links {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .seasonal-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .seasonal-btn.instagram {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
  }

  .seasonal-btn.instagram:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(220, 39, 67, 0.3);
    color: white;
  }

  .seasonal-btn.whatsapp {
    background: #25d366;
    color: white;
  }

  .seasonal-btn.whatsapp:hover {
    background: #20bd5a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.3);
    color: white;
  }

  /* Dark Mode */
  :global([data-theme="dark"]) .page-hero {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global([data-theme="dark"]) .page-hero h1,
  :global([data-theme="dark"]) .page-hero p {
    color: rgba(255, 255, 255, 0.9);
  }

  :global([data-theme="dark"]) .promos-section {
    background: #0f0f23;
  }

  :global([data-theme="dark"]) .promos-section .section-header h2,
  :global([data-theme="dark"]) .promos-section .section-header p {
    color: rgba(255, 255, 255, 0.85);
  }

  :global([data-theme="dark"]) .promo-card {
    background: #1a1a2e;
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .promo-card.featured {
    border-color: var(--color-primary-light);
  }

  :global([data-theme="dark"]) .promo-card h3 {
    color: rgba(255, 255, 255, 0.95);
  }

  :global([data-theme="dark"]) .promo-detail,
  :global([data-theme="dark"]) .promo-desc {
    color: rgba(255, 255, 255, 0.65);
  }

  :global([data-theme="dark"]) .promo-icon {
    background: rgba(196, 163, 90, 0.15);
  }

  :global([data-theme="dark"]) .seasonal-section {
    background: #111122;
  }

  :global([data-theme="dark"]) .seasonal-section .section-header h2,
  :global([data-theme="dark"]) .seasonal-section .section-header p {
    color: rgba(255, 255, 255, 0.85);
  }

  :global([data-theme="dark"]) .seasonal-empty {
    background: #1a1a2e;
    border-color: rgba(255, 255, 255, 0.15);
  }

  :global([data-theme="dark"]) .seasonal-empty h3 {
    color: rgba(255, 255, 255, 0.95);
  }

  :global([data-theme="dark"]) .seasonal-empty p {
    color: rgba(255, 255, 255, 0.65);
  }

  :global([data-theme="dark"]) .seasonal-icon {
    background: rgba(196, 163, 90, 0.15);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .promos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .promos-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .promo-card.featured {
      order: -1;
    }

    .seasonal-empty {
      padding: 35px 25px;
    }

    .seasonal-links {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
