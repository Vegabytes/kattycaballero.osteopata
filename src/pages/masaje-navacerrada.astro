            </div>
            <div class="direction-detail">
              <strong>Dirección</strong>
              <p>Calle Río Guadarrama 2, 28430 Alpedrete, Madrid</p>
            </div>
            <div class="direction-detail">
              <strong>Horario</strong>
              <p>Lunes a Viernes: 9:00 - 20:00<br>Sábados: 10:00 - 14:00</p>
            </div>
          </div>
        </div>
        <div class="directions-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3033.5!2d-4.027!3d40.663!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4189d3f2e8e9e1%3A0x1!2sCalle%20R%C3%ADo%20Guadarrama%2C%202%2C%2028430%20Alpedrete%2C%20Madrid!5e0!3m2!1ses!2ses!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Cómo llegar desde Navacerrada a la consulta en Alpedrete">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="town-cta">
