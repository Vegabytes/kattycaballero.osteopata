---
interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Migas de pan">
  <ol class="breadcrumbs-list">
    {items.map((item, index) => (
      <li class="breadcrumbs-item">
        {item.url ? (
          <a href={item.url} class="breadcrumbs-link">{item.name}</a>
        ) : (
          <span class="breadcrumbs-current" aria-current="page">{item.name}</span>
        )}
        {index < items.length - 1 && (
          <span class="breadcrumbs-separator" aria-hidden="true">/</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    padding: 0.75rem 0 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .breadcrumbs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .breadcrumbs-item {
    display: flex;
    align-items: center;
  }

  .breadcrumbs-link {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumbs-link:hover {
    color: var(--color-primary-dark, #4a6548);
    text-decoration: underline;
  }

  .breadcrumbs-current {
    color: var(--color-text-light);
  }

  .breadcrumbs-separator {
    margin: 0 0.4rem;
    color: var(--color-text-light);
    opacity: 0.6;
    font-size: 0.75rem;
  }

  :global([data-theme="dark"]) .breadcrumbs-link {
    color: var(--color-primary-light, #8bb98a);
  }

  :global([data-theme="dark"]) .breadcrumbs-link:hover {
    color: var(--color-primary, #6f9b6e);
  }

  :global([data-theme="dark"]) .breadcrumbs-current {
    color: var(--color-text-light);
  }

  :global([data-theme="dark"]) .breadcrumbs-separator {
    color: var(--color-text-light);
  }
</style>
