---

<!-- Search Modal (Ctrl+K / Cmd+K) -->
<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Buscar en el sitio" style="display:none;">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-dialog">
    <div class="search-input-wrapper">
      <svg class="search-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="search-input" class="search-input" placeholder="Buscar..." autocomplete="off" aria-label="Buscar en el sitio" />
      <kbd class="search-kbd">Esc</kbd>
    </div>
    <div class="search-results" id="search-results" role="listbox" aria-label="Resultados de búsqueda" aria-live="polite">
      <!-- Results populated by JS -->
    </div>
    <div class="search-footer">
      <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> navegar</span>
      <span><kbd>Enter</kbd> ir</span>
      <span><kbd>Esc</kbd> cerrar</span>
    </div>
  </div>
</div>

<script define:vars={{ initialSearchData: searchData }}>
  const searchData = initialSearchData;
  const categoryOrder = ['Servicios', 'Zonas', 'Dolencias', 'Audiencias', 'Blog', 'Herramientas', 'Información'];

  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input');
  const resultsContainer = document.getElementById('search-results');
  let activeIndex = -1;
  let filteredResults = [];

  function openSearch() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    input.value = '';
    activeIndex = -1;
    renderResults('');
    requestAnimationFrame(() => input.focus());
  }

  function closeSearch() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  function normalize(str) {
    return str.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();
  }

  function renderResults(query) {
    const q = normalize(query.trim());

    if (q) {
      filteredResults = searchData.filter(item =>
        normalize(item.title).includes(q) ||
        normalize(item.desc).includes(q) ||
        normalize(item.category).includes(q)
      );
    } else {
      // Sin query: mostrar selección curada (no inundar con 100 items)
      filteredResults = [
        ...searchData.filter(r => r.category === 'Servicios').slice(0, 6),
        ...searchData.filter(r => r.category === 'Zonas').slice(0, 4),
        ...searchData.filter(r => r.category === 'Herramientas'),
        ...searchData.filter(r => r.category === 'Información').slice(0, 4),
      ];
    }

    const grouped = {};
    for (const cat of categoryOrder) {
      const items = filteredResults.filter(r => r.category === cat);
      if (items.length > 0) grouped[cat] = items;
    }

    if (filteredResults.length === 0) {
      resultsContainer.innerHTML = '<div class="search-empty">No se encontraron resultados</div>';
      return;
    }

    let html = '';
    let globalIndex = 0;
    for (const [cat, items] of Object.entries(grouped)) {
      html += `<div class="search-category">${cat} <span class="search-category-count">(${items.length})</span></div>`;
      for (const item of items) {
        html += `<a href="${item.url}" class="search-result-item" role="option" data-index="${globalIndex}" aria-selected="false">
          <span class="search-result-title">${highlightMatch(item.title, q)}</span>
          <span class="search-result-desc">${highlightMatch(item.desc, q)}</span>
        </a>`;
        globalIndex++;
      }
    }

    resultsContainer.innerHTML = html;
    activeIndex = -1;
  }

  function highlightMatch(text, query) {
    if (!query) return text;
    const normalizedText = normalize(text);
    const idx = normalizedText.indexOf(query);
    if (idx === -1) return text;
    const before = text.slice(0, idx);
    const match = text.slice(idx, idx + query.length);
    const after = text.slice(idx + query.length);
    return `${before}<mark>${match}</mark>${after}`;
  }

  function updateActive() {
    const items = resultsContainer.querySelectorAll('.search-result-item');
    items.forEach((item, i) => {
      if (i === activeIndex) {
        item.classList.add('active');
        item.setAttribute('aria-selected', 'true');
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('active');
        item.setAttribute('aria-selected', 'false');
      }
    });
  }

  input?.addEventListener('input', () => {
    renderResults(input.value);
  });

  input?.addEventListener('keydown', (e) => {
    const items = resultsContainer.querySelectorAll('.search-result-item');
    const count = items.length;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % count;
      updateActive();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = activeIndex <= 0 ? count - 1 : activeIndex - 1;
      updateActive();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIndex >= 0 && items[activeIndex]) {
        window.location.href = items[activeIndex].getAttribute('href') || '/';
      }
    }
  });

  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeSearch();
      return;
    }
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.style.display === 'flex') {
        closeSearch();
      } else {
        openSearch();
      }
    }
  });

  resultsContainer?.addEventListener('click', (e) => {
    const item = e.target.closest('.search-result-item');
    if (item) {
      closeSearch();
    }
  });

  window.__openSearch = openSearch;
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .search-dialog {
    position: relative;
    width: 90%;
    max-width: 600px;
    background: var(--color-warm-white);
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(90, 124, 89, 0.1);
  }

  .search-input-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1.1rem;
    font-family: inherit;
    background: transparent;
    color: var(--color-text);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-kbd {
    font-size: 0.75rem;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(90, 124, 89, 0.08);
    color: var(--color-text-muted);
    border: 1px solid rgba(90, 124, 89, 0.15);
    font-family: inherit;
    line-height: 1;
  }

  .search-results {
    overflow-y: auto;
    flex: 1;
    padding: 8px;
  }

  .search-category {
    padding: 10px 12px 6px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-category-count {
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 10px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.1s ease;
  }

  .search-result-item:hover,
  .search-result-item.active {
    background: rgba(90, 124, 89, 0.08);
  }

  .search-result-item::after {
    display: none !important;
  }

  .search-result-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .search-result-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .search-result-item :global(mark) {
    background: rgba(196, 163, 90, 0.3);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  .search-empty {
    padding: 40px 20px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .search-footer {
    display: flex;
    gap: 20px;
    padding: 10px 20px;
    border-top: 1px solid rgba(90, 124, 89, 0.1);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .search-footer kbd {
    font-size: 0.72rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(90, 124, 89, 0.08);
    border: 1px solid rgba(90, 124, 89, 0.15);
    font-family: inherit;
    margin-right: 3px;
  }

  :global([data-theme="dark"]) .search-dialog {
    background: #1e1e2a;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  :global([data-theme="dark"]) .search-input-wrapper {
    border-bottom-color: rgba(111, 155, 110, 0.15);
  }

  :global([data-theme="dark"]) .search-input {
    color: #e0e0e0;
  }

  :global([data-theme="dark"]) .search-kbd,
  :global([data-theme="dark"]) .search-footer kbd {
    background: rgba(111, 155, 110, 0.1);
    border-color: rgba(111, 155, 110, 0.2);
    color: #aaa;
  }

  :global([data-theme="dark"]) .search-result-item:hover,
  :global([data-theme="dark"]) .search-result-item.active {
    background: rgba(111, 155, 110, 0.1);
  }

  :global([data-theme="dark"]) .search-result-title {
    color: #e0e0e0;
  }

  :global([data-theme="dark"]) .search-result-desc {
    color: #aaa;
  }

  :global([data-theme="dark"]) .search-result-item :global(mark) {
    background: rgba(196, 163, 90, 0.35);
  }

  :global([data-theme="dark"]) .search-footer {
    border-top-color: rgba(111, 155, 110, 0.15);
  }

  @media (max-width: 640px) {
    .search-modal {
      padding-top: 5vh;
    }

    .search-dialog {
      max-height: 80vh;
    }

    .search-footer {
      display: none;
    }
  }
</style>
