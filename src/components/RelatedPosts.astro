---
interface RelatedPost {
  slug: string;
  title: string;
}

interface Props {
  title?: string;
  posts: RelatedPost[];
}

const { title = "Artículos relacionados", posts } = Astro.props;
---

<section class="related-posts">
  <div class="container">
    <h2>{title}</h2>
    <div class="related-posts-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="related-post-card">
          <span class="related-post-title">{post.title}</span>
          <span class="related-post-link">Leer artículo →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .related-posts {
    background: var(--color-cream);
  }

  .related-posts h2 {
    text-align: center;
    margin-bottom: 40px;
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .related-post-card {
    background: var(--color-warm-white);
    padding: 24px;
    border-radius: 14px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(90, 124, 89, 0.1);
    transition: all 0.3s ease;
  }

  .related-post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 15px rgba(90, 124, 89, 0.12);
    border-color: var(--color-primary);
  }

  .related-post-title {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .related-post-link {
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 500;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
