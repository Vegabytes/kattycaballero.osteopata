---
/**
 * Feed de Instagram en "tiempo real" (caché de 15 min en Cloudflare edge).
 * El feed se sirve desde /api/instagram-feed, que llama a Instagram Graph API.
 *
 * Configuración en Cloudflare Pages:
 *   - INSTAGRAM_ACCESS_TOKEN (obligatorio): long-lived token (60 días).
 *   - INSTAGRAM_BUSINESS_ACCOUNT_ID (opcional): solo si la cuenta es Business/Creator.
 *
 * Ver docs/INSTAGRAM-API-SETUP.md para los pasos.
 */
const instagramUsername = "katycaballero.osteopata";
const instagramUrl = `https://www.instagram.com/${instagramUsername}/`;
---

<section class="instagram" id="instagram">
  <div class="container">
    <div class="instagram-header">
      <span class="section-tag">Instagram</span>
      <h2>Sígueme en Instagram</h2>
      <p>Consejos de bienestar, ejercicios y el día a día en consulta</p>
    </div>

    <div class="instagram-feed" id="instagram-feed">
      <!-- 12 skeletons iniciales (sustituidos por JS cuando llegan los posts) -->
      <div class="ig-skeleton" aria-hidden="true"></div>
      <div class="ig-skeleton" aria-hidden="true"></div>
      <div class="ig-skeleton" aria-hidden="true"></div>
      <div class="ig-skeleton" aria-hidden="true"></div>
      <div class="ig-skeleton" aria-hidden="true"></div>
      <div class="ig-skeleton" aria-hidden="true"></div>
    </div>

    <div class="instagram-fallback" id="instagram-fallback" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
        <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
      </svg>
      <p>Visita mi perfil para ver consejos, ejercicios y novedades.</p>
      <a href={instagramUrl} target="_blank" rel="noopener noreferrer nofollow" class="btn btn-primary">
        Ver @{instagramUsername}
      </a>
    </div>

    <div class="instagram-footer">
      <a href={instagramUrl} target="_blank" rel="noopener noreferrer nofollow" class="instagram-link">
        Ver todas las publicaciones en Instagram →
      </a>
    </div>
  </div>
</section>

<script>
  (() => {
    interface IGPost {
      id: string;
      caption?: string;
      media_type: 'IMAGE' | 'VIDEO' | 'CAROUSEL_ALBUM';
      media_url: string;
      thumbnail_url?: string;
      permalink: string;
      timestamp: string;
    }
    interface FeedResponse {
      posts: IGPost[];
      cachedAt: string;
      source: 'cache' | 'live' | 'empty';
      error?: string;
    }

    const feedEl = document.getElementById('instagram-feed');
    const fallbackEl = document.getElementById('instagram-fallback');
    if (!feedEl) return;

    const showFallback = () => {
      feedEl.innerHTML = '';
      feedEl.style.display = 'none';
      if (fallbackEl) fallbackEl.hidden = false;
    };

    const renderPosts = (posts: IGPost[]) => {
      if (!posts.length) {
        showFallback();
        return;
      }
      const html = posts.map((p) => {
        const isVideo = p.media_type === 'VIDEO';
        const isCarousel = p.media_type === 'CAROUSEL_ALBUM';
        const imgSrc = (isVideo && p.thumbnail_url) ? p.thumbnail_url : p.media_url;
        const captionShort = (p.caption || '').slice(0, 120);
        const altText = captionShort.replace(/[\n\r]/g, ' ').replace(/"/g, '&quot;') || 'Publicación de Instagram de Katy Caballero';

        const overlayIcon = isVideo
          ? '<svg viewBox="0 0 24 24" width="22" height="22" fill="white" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>'
          : isCarousel
          ? '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="14" height="14" rx="2"/><path d="M7 7h14v14"/></svg>'
          : '';

        return `
          <a href="${p.permalink}" target="_blank" rel="noopener noreferrer nofollow" class="ig-post" aria-label="Ver en Instagram: ${altText}">
            <img src="${imgSrc}" alt="${altText}" loading="lazy" width="320" height="320" />
            ${overlayIcon ? `<span class="ig-badge">${overlayIcon}</span>` : ''}
          </a>
        `;
      }).join('');
      feedEl.innerHTML = html;
    };

    const load = async () => {
      try {
        const ctrl = new AbortController();
        const timer = setTimeout(() => ctrl.abort(), 7000);
        const resp = await fetch('/api/instagram-feed', { signal: ctrl.signal });
        clearTimeout(timer);

        if (!resp.ok) { showFallback(); return; }
        const data = await resp.json() as FeedResponse;
        if (data.error) console.warn('[Instagram]', data.error);
        renderPosts(data.posts);
      } catch (err) {
        console.warn('[Instagram] fetch failed', err);
        showFallback();
      }
    };

    // Lazy: solo carga cuando la sección está cerca del viewport
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          observer.disconnect();
          load();
        }
      });
    }, { rootMargin: '300px' });

    observer.observe(feedEl);
  })();
</script>

<style>
  .instagram {
    background: var(--color-cream);
  }
  .instagram-header {
    text-align: center;
    margin-bottom: 36px;
  }
  .instagram-header h2 {
    color: var(--color-primary-dark);
    margin-bottom: 12px;
  }
  .instagram-header p {
    color: var(--color-text-light);
    margin: 0 auto;
    max-width: 400px;
  }

  .instagram-feed {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .ig-skeleton {
    aspect-ratio: 1 / 1;
    background: linear-gradient(90deg, rgba(0,0,0,0.05), rgba(0,0,0,0.1), rgba(0,0,0,0.05));
    background-size: 200% 100%;
    animation: ig-shimmer 1.4s linear infinite;
    border-radius: 8px;
  }

  @keyframes ig-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  :global(.ig-post) {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.05);
    transition: transform 0.25s ease;
  }
  :global(.ig-post:hover) {
    transform: scale(1.02);
  }
  :global(.ig-post img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  :global(.ig-badge) {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    padding: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .instagram-fallback {
    text-align: center;
    max-width: 420px;
    margin: 30px auto 0;
  }
  .instagram-fallback svg {
    color: var(--color-primary-light);
    margin-bottom: 12px;
  }
  .instagram-fallback p {
    color: var(--color-text-light);
    margin: 0 auto 16px;
  }

  .instagram-footer {
    text-align: center;
    margin-top: 28px;
  }
  .instagram-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .instagram-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .instagram-feed { grid-template-columns: repeat(4, 1fr); }
    .ig-skeleton:nth-child(n+9) { display: none; }
  }
  @media (max-width: 600px) {
    .instagram-feed { grid-template-columns: repeat(3, 1fr); }
    .ig-skeleton:nth-child(n+7) { display: none; }
  }

  :global([data-theme="dark"]) .instagram-header h2 {
    color: var(--color-primary-light);
  }
  :global([data-theme="dark"]) .ig-skeleton {
    background: linear-gradient(90deg, rgba(255,255,255,0.05), rgba(255,255,255,0.1), rgba(255,255,255,0.05));
    background-size: 200% 100%;
  }
</style>
