---
const instagramUsername = "katycaballero.osteopata";
const instagramUrl = `https://www.instagram.com/${instagramUsername}/`;
---

<section class="instagram" id="instagram">
  <div class="container">
    <div class="instagram-header">
      <span class="section-tag">Instagram</span>
      <h2>Sígueme en Instagram</h2>
      <p>Consejos de bienestar, ejercicios y el día a día en consulta</p>
    </div>
  </div>

  <div class="instagram-feed" id="instagram-feed">
    <behold-widget feed-id="DrkcCAEJCQOWOB0TdjnT"></behold-widget>
    <div class="instagram-fallback" id="instagram-fallback">
      <div class="instagram-fallback-content">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
        </svg>
        <p>Visita mi perfil de Instagram para ver consejos, ejercicios y novedades</p>
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          Ver @katycaballero.osteopata
        </a>
      </div>
    </div>
  </div>

</section>

<script>
  (() => {
    const d = document, s = d.createElement("script");
    s.type = "module";
    s.src = "https://w.behold.so/widget.js";
    s.onerror = () => {
      const fallback = d.getElementById('instagram-fallback');
      if (fallback) fallback.style.display = 'flex';
    };
    d.head.append(s);

    // If widget doesn't render after 5s, show fallback
    setTimeout(() => {
      const widget = d.querySelector('behold-widget');
      if (widget && widget.shadowRoot === null) {
        const fallback = d.getElementById('instagram-fallback');
        if (fallback) fallback.style.display = 'flex';
      }
    }, 5000);
  })();
</script>

<style>
  .instagram {
    background: var(--color-cream);
  }

  .instagram-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .instagram-header h2 {
    color: var(--color-primary-dark);
    margin-bottom: 12px;
  }

  .instagram-header p {
    color: var(--color-text-light);
    margin: 0 auto;
    max-width: 400px;
  }

  .instagram-feed {
    padding: 0 24px;
    max-width: 1600px;
    margin-left: auto;
    margin-right: auto;
  }

  .instagram-fallback {
    display: none;
    justify-content: center;
    align-items: center;
    padding: 40px 24px;
  }

  .instagram-fallback-content {
    text-align: center;
    max-width: 400px;
  }

  .instagram-fallback-content svg {
    color: var(--color-primary-light);
    margin-bottom: 16px;
  }

  .instagram-fallback-content p {
    color: var(--color-text-light);
    margin: 0 auto 20px;
    font-size: 1rem;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .instagram-header h2 {
    color: var(--color-primary-light);
  }
</style>
