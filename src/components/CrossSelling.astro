---
import { services } from '../data/services';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

// Define related services for each service page
const relatedMap: Record<string, string[]> = {
  'osteopatia-alpedrete': ['masaje-deportivo-alpedrete', 'masaje-corporal-alpedrete', 'masaje-embarazadas-alpedrete'],
  'masaje-deportivo-alpedrete': ['osteopatia-alpedrete', 'masaje-tailandes-alpedrete', 'masaje-corporal-alpedrete'],
  'masaje-tailandes-alpedrete': ['masaje-corporal-alpedrete', 'osteopatia-alpedrete', 'masaje-pindas-herbales-alpedrete'],
  'masaje-corporal-alpedrete': ['masaje-pindas-herbales-alpedrete', 'masaje-tailandes-alpedrete', 'osteopatia-alpedrete'],
  'masaje-pindas-herbales-alpedrete': ['masaje-corporal-alpedrete', 'masaje-tailandes-alpedrete', 'osteopatia-alpedrete'],
  'masaje-embarazadas-alpedrete': ['osteopatia-alpedrete', 'masaje-corporal-alpedrete', 'masaje-tailandes-alpedrete'],
};

const relatedSlugs = relatedMap[currentSlug] || services.filter(s => s.slug !== currentSlug).slice(0, 3).map(s => s.slug);
const relatedServices = relatedSlugs.map(slug => services.find(s => s.slug === slug)!).filter(Boolean);
---

<section class="cross-selling">
  <div class="container">
    <h2>También te puede interesar</h2>
    <div class="cross-selling-grid">
      {relatedServices.map(s => (
        <a href={`/servicios/${s.slug}`} class="cross-selling-card">
          <h3>{s.title}</h3>
          <div class="cross-selling-meta">
            <span class="cross-selling-duration">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
              {s.duration}
            </span>
            <span class="cross-selling-price">{s.price}</span>
          </div>
          <p class="cross-selling-intro">{s.intro.substring(0, 100)}...</p>
          <span class="cross-selling-link">Ver servicio &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cross-selling {
    background: var(--color-cream);
    padding: 80px 0;
  }

  .cross-selling h2 {
    text-align: center;
    margin-bottom: 45px;
  }

  .cross-selling-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .cross-selling-card {
    background: var(--color-warm-white);
    border-radius: 16px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
    border: 1px solid rgba(90, 124, 89, 0.08);
    display: flex;
    flex-direction: column;
  }

  .cross-selling-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: rgba(90, 124, 89, 0.2);
  }

  .cross-selling-card h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 12px;
    font-family: var(--font-display);
  }

  .cross-selling-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .cross-selling-duration {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.88rem;
    color: var(--color-text-light);
  }

  .cross-selling-duration svg {
    width: 16px;
    height: 16px;
  }

  .cross-selling-price {
    background: var(--color-secondary-light);
    padding: 3px 12px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--color-text);
  }

  .cross-selling-intro {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .cross-selling-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: var(--transition);
  }

  .cross-selling-card:hover .cross-selling-link {
    color: var(--color-primary-dark);
  }

  @media (max-width: 1024px) {
    .cross-selling-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .cross-selling {
      padding: 60px 0;
    }

    .cross-selling-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .cross-selling-card {
      padding: 22px;
    }
  }

  /* Dark mode */
  :global([data-theme="dark"]) .cross-selling {
    background: var(--color-bg-alt, #16162a);
  }

  :global([data-theme="dark"]) .cross-selling-card {
    background: var(--color-bg, #1a1a2e);
    border-color: rgba(111, 155, 110, 0.12);
  }

  :global([data-theme="dark"]) .cross-selling-card:hover {
    border-color: rgba(111, 155, 110, 0.3);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }

  :global([data-theme="dark"]) .cross-selling-price {
    background: rgba(196, 163, 90, 0.2);
    color: var(--color-secondary, #c4a35a);
  }

  :global([data-theme="dark"]) .cross-selling-intro {
    color: var(--color-text-light, #a0a0a0);
  }
</style>
