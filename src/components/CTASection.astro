---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  title = "¿Listo para sentirte mejor?",
  description = "Reserva tu primera sesión y comienza tu camino hacia el bienestar. Consulta inicial incluida.",
  buttonText = "Reservar Cita",
  buttonLink = "/reservar",
} = Astro.props;
---

<section class="cta-section">
  <div class="container">
    <h2>{title}</h2>
    <p>{description}</p>
    <div class="cta-buttons">
      <a href={buttonLink} class="btn btn-cta" aria-label={buttonText}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
        {buttonText}
      </a>
      <a href="https://wa.me/34643961065?text=Hola%20Katy,%20me%20gustaría%20reservar%20una%20cita" class="btn btn-cta-whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp para reservar cita">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp directo
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    text-align: center;
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }
  
  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  
  .cta-section h2 {
    color: white;
    margin-bottom: 20px;
    position: relative;
  }
  
  .cta-section p {
    color: rgba(255, 255, 255, 0.9);
    max-width: 500px;
    margin: 0 auto 30px;
    font-size: 1.1rem;
    position: relative;
  }
  
  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: white;
    color: var(--color-primary-dark);
    padding: 18px 35px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: var(--transition);
    position: relative;
  }

  .btn-cta:hover {
    background: var(--color-secondary-light);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    color: var(--color-primary-dark);
  }

  .btn-cta-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: white;
    padding: 18px 35px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: var(--transition);
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn-cta-whatsapp:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-3px);
    border-color: white;
    color: white;
  }
  
  @media (max-width: 768px) {
    .cta-section {
      padding: 60px 0;
    }
  }

  /* Dark mode */
  :global([data-theme="dark"]) .cta-section {
    background: linear-gradient(135deg, #1a1a2e 0%, #2a2a3e 100%);
    border-top: 1px solid rgba(111, 155, 110, 0.15);
    border-bottom: 1px solid rgba(111, 155, 110, 0.15);
  }

  :global([data-theme="dark"]) .btn-cta {
    background: var(--color-primary);
    color: white;
  }

  :global([data-theme="dark"]) .btn-cta:hover {
    background: var(--color-primary-light);
    color: white;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }

  :global([data-theme="dark"]) .btn-cta-whatsapp {
    border-color: rgba(111, 155, 110, 0.4);
  }

  :global([data-theme="dark"]) .btn-cta-whatsapp:hover {
    background: rgba(111, 155, 110, 0.15);
    border-color: var(--color-primary-light);
  }
</style>
