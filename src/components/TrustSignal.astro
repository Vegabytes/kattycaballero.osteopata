---
/**
 * Trust signal compacto para insertar en páginas comerciales (promociones, bonos, tarifas).
 * Muestra: 5 estrellas + reseñas Google + años de experiencia.
 *
 * Datos centralizados en `src/data/reviews.ts` para que se mantengan sincronizados.
 */
import { reviews, averageRating } from '../data/reviews';

interface Props {
  /** Texto adicional a la derecha. Default: "Más de 12 años de experiencia". */
  experience?: string;
  /** Compact mode: solo línea de stars + años. Sin URL externa. */
  compact?: boolean;
}

const { experience = "Más de 12 años de experiencia", compact = false } = Astro.props;
const count = reviews.length;
---

<div class={`trust-signal ${compact ? 'trust-signal--compact' : ''}`}>
  <a href="/opiniones" class="trust-stars" aria-label={`${averageRating} de 5 estrellas — ${count} reseñas`}>
    <span class="trust-stars-row" aria-hidden="true">
      {Array.from({ length: 5 }).map(() => (
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#FBBC05"/>
        </svg>
      ))}
    </span>
    <span class="trust-text">{averageRating} · {count} reseñas en Google</span>
  </a>
  <span class="trust-separator" aria-hidden="true">·</span>
  <span class="trust-experience">{experience}</span>
</div>

<style>
  .trust-signal {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 18px;
    background: var(--color-warm-white);
    border: 1px solid rgba(90, 124, 89, 0.15);
    border-radius: 50px;
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 16px auto 0;
    flex-wrap: wrap;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .trust-stars {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .trust-stars:hover .trust-text {
    text-decoration: underline;
    text-decoration-color: var(--color-primary);
  }

  .trust-stars-row {
    display: inline-flex;
    gap: 2px;
  }

  .trust-text {
    font-weight: 600;
  }

  .trust-separator {
    color: var(--color-text-light);
    opacity: 0.5;
  }

  .trust-experience {
    color: var(--color-text-light);
  }

  @media (max-width: 540px) {
    .trust-signal {
      flex-direction: column;
      gap: 6px;
      padding: 14px 22px;
    }
    .trust-separator { display: none; }
  }

  :global([data-theme="dark"]) .trust-signal {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(111, 155, 110, 0.2);
  }
</style>
